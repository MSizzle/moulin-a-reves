  <!-- Location -->
  <section class="section section--stone">
    <div class="container--narrow fade-in text-center">
      <h2 data-i18n="jardin.neighbours.heading">Your Neighbours</h2>
      <p data-i18n="jardin.neighbours.text" style="margin-top: 24px;">
        Le Jardin sits at the quietest edge of the compound, where the garden gives way to the first trees of Fontainebleau Forest. You can walk into the forest from the back gate in two minutes. Barbizon, the painters' village with its galleries and boulangeries, is a ten-minute drive. The grand Chateau de Fontainebleau is twenty minutes. Paris is reachable in an hour by car or by train from Fontainebleau-Avon station.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container fade-in">
      <h2 data-i18n="jardin.cta.heading">Interested in Le Jardin?</h2>
      <p data-i18n="jardin.cta.text" style="margin-top: 16px; margin-bottom: 32px;">
        Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.
      </p>
      <a href="/contact/" class="btn btn--primary" data-i18n="jardin.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 48px;">
        <h2 data-i18n="jardin.otherhomes.heading">The Other Maisons</h2>
      </div>
      <div class="grid grid--2">
        <a href="/homes/le-moulin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin stone mill house with blue shutters at Moulin à Rêves, Barbizon" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Moulin</h3>
            <p class="card__description" data-i18n="jardin.cross.moulin.desc">The heart of the compound. A stone mill house where thick walls keep summer cool and the millstream runs just outside.</p>
            <span class="link-arrow" data-i18n="jardin.cross.moulin.link" style="margin-top: 12px;">Discover Le Moulin</span>
          </div>
        </a>
        <a href="/homes/la-grange/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="La Grange converted stone barn with tall windows at Moulin à Rêves, Barbizon" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Grange</h3>
            <p class="card__description" data-i18n="jardin.cross.grange.desc">A converted stone barn with soaring ceilings, an open kitchen, and doors that open straight onto the garden.</p>
            <span class="link-arrow" data-i18n="jardin.cross.grange.link" style="margin-top: 12px;">Discover La Grange</span>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="jardin.rentall">Rent All Three Maisons</a>
      </div>
    </div>
  </section>

