      { src: '/images/homes/hh-american-in-paris.webp', alt: 'An American in Paris — bedroom with floral wallpaper' },
      { src: '/images/homes/hh-american-in-paris-window.webp', alt: 'An American in Paris — window view onto the gardens' },
      { src: '/images/homes/hh-american-in-paris-bath.webp', alt: 'An American in Paris bathroom' },
      { src: '/images/homes/hh-american-in-paris-bath-2.webp', alt: 'An American in Paris bathroom, alternate view' },
