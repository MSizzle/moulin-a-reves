  {
    id: 'kitchen',
    title: 'Kitchen',
    summary: 'Bright kitchen with induction stove, oven, full fridge.',
    photos: [
      { src: '/images/homes/hh-kitchen.webp', alt: 'Cherry-red themed kitchen at the Hollywood Hideaway' },
    ],
  },
  {
    id: 'gazebo',
    title: 'Gazebo & Patio',
    summary: 'Covered gazebo dining table for eight, plus the patio facing the home.',
    photos: [
      { src: '/images/homes/hh-gazebo.webp', alt: 'Garden gazebo with cafe seating' },
      { src: '/images/homes/hh-patio.webp', alt: 'Patio at the Hollywood Hideaway' },
      { src: '/images/homes/hh-patio-facing-home.webp', alt: 'Patio facing the Hollywood Hideaway facade' },
      { src: '/images/homes/hh-steps.webp', alt: 'Stone steps leading up to the Hollywood Hideaway entrance' },
      { src: '/images/homes/hh-gate.webp', alt: 'Entry gate at the Hollywood Hideaway' },
