];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: 'Induction stove + oven', icon: 'oven' },
  { label: 'Nespresso', icon: 'coffee' },
  { label: 'Full-size fridge', icon: 'fridge' },
  { label: 'Washing machine', icon: 'washer' },
  { label: 'Covered gazebo dining', icon: 'patio' },
  { label: 'Sleeps 7 across 4 beds', icon: 'guests' },
];
---

<BaseLayout title="The Hollywood Hideaway — French Countryside Rental Near Paris" description="Three-bedroom French countryside rental with a suite, sleeps 7. A 60-year sanctuary of Hollywood's top power lawyer. Méréville, France — one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/hollywood-hideaway/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "The Hollywood Hideaway", "item": "https://www.moulinareves.com/homes/hollywood-hideaway/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — a treasured sanctuary in the French countryside`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="hideaway.hero.title">{cms.title}</h1>
      <p class="hero__tagline" data-i18n="hideaway.hero.tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
    /* TYPOG-02: client-flagged italic tagline noise on this page; override the global italic rule */
    .hero__tagline {
      font-style: normal;
    }
    /* PHOTO-03: client-flagged hero text "feels too low — please center it".
       Top-of-page hero only; CTA hero opts out via .hero--cta. */
    .hero:not(.hero--cta) {
      align-items: center;
      justify-content: center;
      padding-bottom: 0;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 32px; padding-bottom: 24px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.bathrooms">Baths</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.beds">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Narrative Description -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="hideaway.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 24px;">
        <p class="prose-lead" data-i18n="hideaway.narrative.summary">
          {cms.summary}
        </p>
        <p style="margin-top: 16px;" data-i18n="hideaway.narrative.p1">
          For 60 years, the 60-year sanctuary of Hollywood's #1 power lawyer — clients included Tom Cruise, Dustin Hoffman, Michael Jackson, and Mario Puzo. Furnished with French antiques.
        </p>
      </div>
    </div>
  </section>

  <!-- Rooms (bedrooms) -->
  <RoomShowcase
    eyebrow=""
    heading="Where you'll sleep"
    intro="3 bedrooms."
    rooms={bedrooms}
    background="stone"
    i18nKey="hideaway.bedrooms"
    hideTileSummary={true}
  />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow=""
    heading="Where you'll gather &amp; dine"
    intro=""
    rooms={livingSpaces}
    i18nKey="hideaway.living"
    hideTileSummary={true}
    gatherMode={true}
  />

  <!-- Explore the Estate (4-square lightbox tiles) + Also Included amenity list -->
  <AmenitiesSection
    eyebrow=""
    heading="Explore the Estate"
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="hideaway.amenities"
    exploreMode={true}
  />

  <!-- Availability -->
  <AvailabilityCalendar
    monthsToShow={12}
    eyebrow=""
    heading="Join us!"
    intro=""
    i18nKey="hideaway.availability"
  />

  <!-- CTA -->
  <section class="hero hero--cta" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="hideaway.cta.heading">Interested in {cms.title}?</h2>
      <a href="/contact/" class="btn btn--white" data-i18n="hideaway.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 24px;">
        <h2 data-i18n="hideaway.cross.heading">Les Autres Maisons</h2>
      </div>
    </div>
    <div class="maisons-stack">
        <a href="/homes/le-moulin/" class="split split--maison fade-in">
          <div class="split__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin" loading="lazy" />
          </div>
          <div class="split__body">
            <h2 data-i18n="hideaway.cross.moulin.title">Le Moulin</h2>
            <div class="split__meta">
              <span data-i18n="hideaway.cross.moulin.beds">5 Bedrooms</span>
              <span data-i18n="hideaway.cross.moulin.sleeps">Sleeps 10</span>
            </div>
            <p>An historic mill on the Juine River. The river runs through the house. Five bedrooms across three floors.</p>
            <span class="link-arrow">Discover Le Moulin →</span>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="split split--maison split--reverse fade-in">
          <div class="split__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière" loading="lazy" />
          </div>
          <div class="split__body">
            <h2 data-i18n="hideaway.cross.riviere.title">La Maison de la Rivière</h2>
            <div class="split__meta">
              <span data-i18n="hideaway.cross.riviere.beds">2 Bedrooms</span>
              <span data-i18n="hideaway.cross.riviere.sleeps">Sleeps 5</span>
            </div>
            <p>Sun-drenched cottage with French doors onto the stream and apple trees. Two bedrooms, dining for 18, an authentic Louis Vuitton trunk as a coffee table.</p>
            <span class="link-arrow">Discover La Maison →</span>
          </div>
        </a>
      </div>
    <div class="container">
      <div class="text-center" style="margin-top: 32px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="hideaway.cross.cta">Rent the Compound</a>
      </div>
    </div>
  </section>

</BaseLayout>
