---
import BaseLayout from '../../layouts/BaseLayout.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/hollywood-hideaway.md', 'utf-8');
const { data: cms } = matter(raw);
---

<BaseLayout title="The Hollywood Hideaway — French Countryside Rental Near Paris" description="Three-bedroom French countryside rental with a suite, sleeps 8. A 60-year sanctuary of Hollywood's top power lawyer. Mereville, France — one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/hollywood-hideaway/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mereville",
        "addressRegion": "Essonne",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "The Hollywood Hideaway", "item": "https://www.moulinareves.com/homes/hollywood-hideaway/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — a treasured sanctuary in the French countryside`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow">{cms.eyebrow}</span>
      <h1 class="hero__title">{cms.title}</h1>
      <p class="hero__tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 48px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}+1</div>
          <div class="stats-bar__label">Bedrooms + Suite</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Narrative Description -->
  <section class="section">
    <div class="container--narrow fade-in">
      <span class="eyebrow">The Maison</span>
      <h2>{cms.title}</h2>
      <div style="margin-top: 32px;">
        <p class="prose-lead">
          {cms.summary}
        </p>
        <p style="margin-top: 20px;">
          For 60 years, The Hollywood Hideaway was a treasured sanctuary getaway for Hollywood's #1 power lawyer whose clients included Tom Cruise, Dustin Hoffman, Michael Jackson, Mario Puzzo and the luminaries of LA.
        </p>
        <p style="margin-top: 20px;">
          This was his happy home where he entertained his Hollywood pals and cooked and relaxed in the French countryside. Now you can follow in the footsteps of the stars and make this your own home in France. It is beautifully furnished with French antiques.
        </p>
      </div>
    </div>
  </section>

  <!-- Room by Room -->
  <section class="section section--soft">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <span class="eyebrow">Room by Room</span>
        <h2>Three Bedrooms Plus a Suite</h2>
      </div>
      <div class="grid grid--3" style="gap: 24px;">
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/hh-looking-glass.webp" alt="Through the Looking Glass bedroom" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Through the Looking Glass</h3>
            <p class="card__description">Ground floor. King bedroom with en-suite bathroom featuring tub/shower.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/hh-secret-garden.webp" alt="The Secret Garden suite" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">The Secret Garden</h3>
            <p class="card__description">Adjacent sitting room suite with pull-out sofa for 1 person. Accesses bathroom through Bedroom 1.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/hh-american-in-paris.webp" alt="An American in Paris bedroom" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">An American in Paris</h3>
            <p class="card__description">Ground floor. Queen bedroom. Bathroom in the hall with tub/shower and separate toilet. Washing machine.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/hh-sleeping-beauty.webp" alt="Sleeping Beauty bedroom" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Sleeping Beauty</h3>
            <p class="card__description">Attic room. 2 twins + 1 twin in foyer. Bathroom in the hall down 2 flights. Note: steep stairs required.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/la-grange-living.webp" alt="Upstairs living and dining space" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Living & Dining</h3>
            <p class="card__description">Upstairs open space. Dining table seats 10. Induction stove, oven, Nespresso, full fridge. Works for yoga and meetings too.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/hh-gazebo.webp" alt="Covered gazebo dining" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Outdoor Gazebo</h3>
            <p class="card__description">Covered gazebo with a dining table for 8. Al fresco dining in the French countryside.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/la-grange-hero.webp" alt="The Hollywood Hideaway at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);">Interested in {cms.title}?</h2>
      <p class="hero__tagline">Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.</p>
      <a href="/contact/" class="btn btn--white">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section section--soft">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 48px;">
        <h2>The Other Maisons</h2>
      </div>
      <div class="grid grid--2" style="gap: 24px;">
        <a href="/homes/le-moulin/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Maison One</span>
            <h3 class="card__title">Le Moulin à Rêves</h3>
            <div class="card__meta">
              <span>5 Bedrooms</span>
              <span>Sleeps 12</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Maison Three</span>
            <h3 class="card__title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span>2 Bedrooms</span>
              <span>Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow">Rent All Three Maisons</a>
      </div>
    </div>
  </section>

</BaseLayout>
