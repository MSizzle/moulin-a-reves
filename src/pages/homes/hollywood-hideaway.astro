// Explore the Estate — 4-square section (house pages only; homepage keeps its 6 tiles)
const amenityFeatures = [
  {
    title: 'The Gardens',
    summary: 'The Giverny-style bridge, walled gardens, millstream, and quiet corners.',
    image: '/images/bridge-garden.webp',
    alt: 'The Giverny-style bridge across the millstream',
    gallery: [
      { src: '/images/bridge-garden.webp', alt: 'Giverny-style painted bridge over the stream beneath willow trees' },
      { src: '/images/garden-giverny-bridge.webp', alt: 'Painted Giverny-style bridge over the millstream in the gardens' },
      { src: '/images/garden-giverny-bridge-2.webp', alt: 'Giverny-style bridge in the gardens, alternate view' },
      { src: '/images/garden-chaises.webp', alt: 'Garden chaise lounges facing the painted bridge' },
      { src: '/images/garden-chaises-wide.webp', alt: 'Wide garden view with chaise lounges and the painted bridge' },
      { src: '/images/garden-chaise-jetson.webp', alt: 'Garden chaise lounges with Jetson the Cavalier in the sun' },
      { src: '/images/garden-private-spot.webp', alt: 'Private wicker bistro table in a wooded corner of the garden' },
      { src: '/images/garden-stone-well.webp', alt: 'Vine-covered antique stone well sheltered in the garden' },
      { src: '/images/garden-steps.webp', alt: 'Stone steps descending through the gardens' },
      { src: '/images/garden-breakfast.webp', alt: 'Breakfast set on the patio outside the stone cottage' },
      { src: '/images/garden-monet-painting.webp', alt: 'Monet-inspired painting set among the gardens at Moulin à Rêves' },
      { src: '/images/compound-river-courtyard.webp', alt: 'Stone footbridge with planter boxes over the small stream' },
      { src: '/images/evening-compound.webp', alt: 'Garden at dusk with feet propped up looking toward the stone cottage' },
      { src: '/images/yoga-lawn.webp', alt: 'Morning yoga on the lawn between the houses' },
    ],
  },
  {
    title: 'The Grange',
    summary: 'Open-air entertaining barn with stone fireplace, ping-pong table, and the long communal table for twenty.',
    image: '/images/homes/la-grange-hero.webp',
    alt: 'La Grange exterior — covered pavilion at the heart of the compound',
    gallery: [
      { src: '/images/homes/la-grange-hero.webp', alt: 'La Grange exterior — covered pavilion at the heart of the compound' },
      { src: '/images/homes/la-grange-pavilion-wide.webp', alt: 'Wide view of La Grange\'s open pavilion with ping-pong and dining table' },
      { src: '/images/homes/la-grange-pavilion.webp', alt: 'La Grange\'s open pavilion with stone fireplace' },
      { src: '/images/homes/la-grange-living.webp', alt: 'La Grange living area beside the stone hearth' },
      { src: '/images/homes/la-grange-fire.webp', alt: 'Fire crackling in the stone hearth of La Grange' },
      { src: '/images/homes/la-grange-fire-2.webp', alt: 'Roaring fire in the stone fireplace at La Grange' },
      { src: '/images/homes/la-grange-party-setup.webp', alt: 'La Grange pavilion set with banquet tables for a party' },
      { src: '/images/homes/la-grange-plates.webp', alt: 'Long banquet table at La Grange set with china plates and stemware' },
      { src: '/images/homes/la-grange-carriage.webp', alt: 'Antique horse carriage on display inside La Grange' },
      { src: '/images/homes/la-grange-jetson-chariot.webp', alt: 'Jetson the Cavalier in a small chariot inside La Grange' },
      { src: '/images/group-dinner.webp', alt: 'Dinner laid on the long table under La Grange\'s pavilion' },
    ],
  },
  {
    title: 'The Spa',
    summary: 'A glassed-in solarium with jacuzzi — warm-weather mornings, winter evenings, year-round.',
    image: '/images/wellness-jacuzzi-2.webp',
    alt: 'The jacuzzi in the solarium at Moulin à Rêves',
    gallery: [
      { src: '/images/wellness-pool.webp', alt: 'Solarium with jacuzzi at Moulin à Rêves' },
      { src: '/images/wellness-jacuzzi-2.webp', alt: 'The jacuzzi in the solarium at Moulin à Rêves' },
    ],
  },
  {
    title: 'The Chicken Coop & Wishing Well',
    summary: 'Charming corners of the estate — the resident chickens and the vine-covered wishing well.',
    image: '/images/garden-stone-well.webp',
