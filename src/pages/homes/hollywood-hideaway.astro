---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import { exploreEstateFeatures } from '../../data/explore-estate';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/hollywood-hideaway.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = cms.gallery ?? [];

const bedrooms = [
  {
    id: 'looking-glass',
    title: 'Through the Looking Glass',
    summary: 'King bedroom on the ground floor — en-suite bath with tub and shower.',
    longDescription: 'The largest bedroom.',
    qualities: 'King bed · En-suite tub & shower · Ground Floor',
    details: [
      { label: 'Bed', value: 'King' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'En-suite, tub + shower' },
    ],
    photos: [
      { src: '/images/homes/hh-looking-glass.webp', alt: 'Through the Looking Glass — bedroom with vanity mirror and ornate frame' },
      { src: '/images/homes/hh-looking-glass-2.webp', alt: 'Through the Looking Glass bedroom, alternate view' },
      { src: '/images/homes/hh-looking-glass-bath.webp', alt: 'Through the Looking Glass bathroom with hanging robe' },
      { src: '/images/homes/hh-looking-glass-bath-2.webp', alt: 'Through the Looking Glass bathroom, alternate view' },
      { src: '/images/homes/hh-secret-garden.webp', alt: 'Adjoining sitting nook off Through the Looking Glass' },
      { src: '/images/homes/hh-secret-garden-couch.webp', alt: 'Secret Garden sitting room with deep velvet couch' },
      { src: '/images/homes/hh-secret-garden-2.webp', alt: 'Secret Garden suite, alternate angle' },
    ],
  },
  {
    id: 'secret-garden',
    title: 'The Secret Garden',
    summary: 'A small adjacent sitting-room suite with a pull-out sofa for one. Accesses the bathroom through Through the Looking Glass.',
    longDescription: 'A bonus space attached to the master — perfect for a kid, an extra adult, or a quiet reading nook by day. The pull-out sofa sleeps one comfortably.',
    qualities: 'Sitting-room suite · Pull-out sofa for one · Ground Floor',
    details: [
      { label: 'Sleeps', value: '1 (pull-out sofa)' },
      { label: 'Bathroom', value: 'Shared via Through the Looking Glass' },
    ],
    photos: [
      { src: '/images/homes/hh-secret-garden-sitting.webp', alt: 'The Secret Garden suite sitting room with floral wallpaper and fireplace' },
      { src: '/images/homes/hh-secret-garden-couch.webp', alt: 'Secret Garden sitting room with deep velvet couch' },
      { src: '/images/homes/hh-secret-garden-2.webp', alt: 'Secret Garden suite, alternate angle' },
    ],
  },
  {
    id: 'american-in-paris',
    title: 'An American in Paris',
    summary: 'Queen bedroom on the ground floor.',
    qualities: 'Queen bed · Hall tub & shower · Ground Floor',
    details: [
      { label: 'Bed', value: 'Queen' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'Hall, tub + shower' },
    ],
    photos: [
      { src: '/images/homes/hh-american-in-paris.webp', alt: 'An American in Paris — bedroom with floral wallpaper' },
      { src: '/images/homes/hh-american-in-paris-window.webp', alt: 'An American in Paris — window view onto the gardens' },
      { src: '/images/homes/hh-american-in-paris-bath.webp', alt: 'An American in Paris bathroom' },
      { src: '/images/homes/hh-american-in-paris-bath-2.webp', alt: 'An American in Paris bathroom, alternate view' },
      { src: '/images/homes/hh-secret-garden.webp', alt: 'Adjoining sitting nook with floral wallpaper' },
      { src: '/images/homes/hh-secret-garden-couch.webp', alt: 'Secret Garden sitting room with deep velvet couch' },
      { src: '/images/homes/hh-secret-garden-2.webp', alt: 'Secret Garden suite, alternate angle' },
    ],
  },
  {
    id: 'sleeping-beauty',
    title: 'Sleeping Beauty',
    summary: 'Attic room with two twins. Up two steep flights.',
    longDescription: 'Tucked under the eaves, themed around the fairy tale — antique spinning wheels visible through the doorway. The two stairwells climbing up to the room are lined with framed scarf-print and embroidered art.',
    qualities: 'Twin beds · Hall bath · Up Steep Stairs',
    details: [
      { label: 'Bed', value: '2 Twins' },
      { label: 'Floor', value: 'Up Steep Stairs' },
      { label: 'Bathroom', value: 'Hall, two flights down' },
    ],
    photos: [
      { src: '/images/homes/hh-sleeping-beauty.webp', alt: 'Sleeping Beauty room with antique spinning wheels through the doorway' },
      { src: '/images/homes/hh-sleeping-beauty-spinning-wheels.webp', alt: 'Sleeping Beauty bedroom with two antique spinning wheels' },
      { src: '/images/homes/hh-sleeping-beauty-loft.webp', alt: 'Sleeping Beauty loft bedroom with twin beds under the eaves' },
      { src: '/images/homes/hh-scarf-stairwell.webp', alt: 'Stairwell up to Sleeping Beauty lined with framed scarf-print art' },
      { src: '/images/homes/hh-needlework-stairwell.webp', alt: 'Narrow stairwell with red carpet runner and walls lined with framed embroidered art' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'upstairs',
    title: 'The Living & Dining Room',
    summary: 'Open upstairs space — dining for ten, sitting area, room for yoga.',
    details: [
      { label: 'Seats', value: '10' },
    ],
    photos: [
      { src: '/images/homes/hh-dining-living.webp', alt: 'Open dining and living room at the Hollywood Hideaway' },
      { src: '/images/homes/hh-living-room.webp', alt: 'Living room at the Hollywood Hideaway with red velvet sofa' },
      { src: '/images/homes/hh-living-movement.webp', alt: 'Living room cleared for yoga and movement' },
      { src: '/images/homes/hh-dining-into-kitchen.webp', alt: 'View from the dining and living room through to the kitchen' },
    ],
  },
  {
    id: 'kitchen',
    title: 'Kitchen',
    summary: 'Bright kitchen with induction stove, oven, full fridge.',
    photos: [
      { src: '/images/homes/hh-kitchen.webp', alt: 'Cherry-red themed kitchen at the Hollywood Hideaway' },
    ],
  },
  {
    id: 'gazebo',
    title: 'Gazebo & Patio',
    summary: 'Covered gazebo dining table for eight, plus the patio facing the home.',
    photos: [
      { src: '/images/homes/hh-gazebo.webp', alt: 'Garden gazebo with cafe seating' },
      { src: '/images/homes/hh-patio.webp', alt: 'Patio at the Hollywood Hideaway' },
      { src: '/images/homes/hh-steps.webp', alt: 'Stone steps leading up to the Hollywood Hideaway entrance' },
      { src: '/images/homes/hh-gate.webp', alt: 'Entry gate at the Hollywood Hideaway' },
      { src: '/images/homes/hh-roses.webp', alt: 'Climbing roses against the Hollywood Hideaway exterior' },
    ],
  },
  // Gardens card removed (Item 15) — content now in Explore the Estate → The Gardens
];

// Explore the Estate — six estate-wide tiles, shared with the home page and the
// other house pages via src/data/explore-estate.ts (single source of truth).
const amenityFeatures = exploreEstateFeatures;

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: 'Induction stove + oven', icon: 'oven' },
  { label: 'Nespresso', icon: 'coffee' },
  { label: 'Full-size fridge', icon: 'fridge' },
  { label: 'Washing machine', icon: 'washer' },
  { label: 'Covered gazebo dining', icon: 'patio' },
  { label: 'Sleeps 6 across 4 beds', icon: 'guests' },
];
---

<BaseLayout title="The Hollywood Hideaway — French Countryside Retreat Near Paris" description="A longtime private retreat in Méréville, France — sleeps 6, one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/hollywood-hideaway/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "The Hollywood Hideaway", "item": "https://www.moulinareves.com/homes/hollywood-hideaway/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — a treasured sanctuary in the French countryside`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="hideaway.hero.title">{cms.title}</h1>
      <p class="hero__tagline" data-i18n="hideaway.hero.tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
    /* TYPOG-02: client-flagged italic tagline noise on this page; override the global italic rule */
    .hero__tagline {
      font-style: normal;
    }
    /* PHOTO-03: client-flagged hero text "feels too low — please center it".
       Top-of-page hero only; CTA hero opts out via .hero--cta. */
    .hero:not(.hero--cta) {
      align-items: center;
      justify-content: center;
      padding-bottom: 0;
    }
  </style>

  <!-- Narrative / Story (directly beneath hero) -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <div>
        <p class="prose-lead" data-i18n="hideaway.narrative.summary">
          For almost half a century, The Hollywood Hideaway was the cherished summer retreat of renowned Hollywood attorney Bert Fields. Here he spent Augusts writing, cooking, entertaining friends, and enjoying the pleasures of French country life far from the spotlight of Los Angeles.
        </p>
        <p style="margin-top: 16px;" data-i18n="hideaway.narrative.p1">
          Thoughtfully decorated by his wife, renowned art advisor Barbara Guggenheim, the Hollywood Hideaway's bedrooms are named for classic movies and inspired by the French antiques within them. The oversized living-and-dining room opens onto a wisteria-covered gazebo and patio. This home retains the warmth and character that made it such a beloved refuge for generations of family and friends.
        </p>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow=""
    heading="The Living Spaces"
    intro=""
    rooms={livingSpaces}
    i18nKey="hideaway.living"
    hideTileSummary={true}
    gatherMode={true}
  />

  <!-- The Bedrooms -->
  <RoomShowcase
    eyebrow=""
    heading="The Bedrooms"
    intro="4 Bedrooms • 2 Bathrooms • 4 Beds • Sleeps 6"
    introStrong={true}
    rooms={bedrooms}
    background="stone"
    i18nKey="hideaway.bedrooms"
    hideTileSummary={true}
  />

  <!-- Explore the Estate (4-square lightbox tiles) + Also Included amenity list -->
  <AmenitiesSection
    eyebrow=""
    heading="Explore the Estate"
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="hideaway.amenities"
    featureKeyPrefix="home.compound.feat"
    exploreMode={true}
  />

  <!-- Join us -->
  <section class="section--tighter text-center">
    <div class="container fade-in">
      <a href="/contact/" class="btn btn--green" data-i18n="hideaway.cta.button">Join us</a>
    </div>
  </section>

</BaseLayout>
