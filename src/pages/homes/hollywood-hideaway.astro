  {
    id: 'sleeping-beauty',
    title: 'Sleeping Beauty',
    summary: 'Attic room with two twins. Up two steep flights.',
    longDescription: 'Tucked under the eaves, themed around the fairy tale — antique spinning wheels visible through the doorway. The two stairwells climbing up to the room are lined with framed scarf-print and embroidered art.',
    qualities: '🛏 Twin beds · 🚿 Hall bath · Up two steep flights',
    details: [
      { label: 'Bed', value: '2 Twins' },
      { label: 'Floor', value: 'Attic' },
      { label: 'Bathroom', value: 'Hall, two flights down' },
    ],
    photos: [
      { src: '/images/homes/hh-sleeping-beauty.webp', alt: 'Sleeping Beauty room with antique spinning wheels through the doorway' },
      { src: '/images/homes/hh-sleeping-beauty-spinning-wheels.webp', alt: 'Sleeping Beauty bedroom with two antique spinning wheels' },
      { src: '/images/homes/hh-sleeping-beauty-loft.webp', alt: 'Sleeping Beauty loft bedroom with twin beds under the eaves' },
      { src: '/images/homes/hh-scarf-stairwell.webp', alt: 'Stairwell up to Sleeping Beauty lined with framed scarf-print art' },
      { src: '/images/homes/hh-needlework-stairwell.webp', alt: 'Narrow stairwell with red carpet runner and walls lined with framed embroidered art' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'upstairs',
    title: 'Upstairs Living & Dining',
    summary: 'Open upstairs space — dining for ten, sitting area, room for yoga.',
    details: [
      { label: 'Seats', value: '10' },
    ],
    photos: [
      { src: '/images/homes/hh-dining-living.webp', alt: 'Open dining and living room at the Hollywood Hideaway' },
      { src: '/images/homes/hh-living-room.webp', alt: 'Living room at the Hollywood Hideaway with red velvet sofa' },
      { src: '/images/homes/hh-living-movement.webp', alt: 'Living room cleared for yoga and movement' },
      { src: '/images/homes/hh-dining-into-kitchen.webp', alt: 'View from the dining and living room through to the kitchen' },
