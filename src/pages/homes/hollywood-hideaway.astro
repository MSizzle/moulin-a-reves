      { src: '/images/homes/hh-looking-glass.webp', alt: 'Through the Looking Glass — bedroom with vanity mirror and ornate frame' },
      { src: '/images/homes/hh-looking-glass-2.webp', alt: 'Through the Looking Glass bedroom, alternate view' },
      { src: '/images/homes/hh-looking-glass-bath.webp', alt: 'Through the Looking Glass bathroom with hanging robe' },
