---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/hollywood-hideaway.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = [
  { src: '/images/homes/la-grange-hero.webp', alt: 'The Hollywood Hideaway — exterior in the French countryside' },
  { src: '/images/homes/la-grange-living.webp', alt: 'Upstairs living and dining space' },
  { src: '/images/homes/hh-kitchen.webp', alt: 'Bright white kitchen with red accents' },
  { src: '/images/homes/hh-looking-glass.webp', alt: 'Through the Looking Glass — king bedroom' },
  { src: '/images/homes/hh-american-in-paris.webp', alt: 'An American in Paris — queen bedroom' },
  { src: '/images/homes/hh-secret-garden.webp', alt: 'The Secret Garden — sitting-room suite' },
  { src: '/images/homes/hh-gazebo.webp', alt: 'Covered gazebo with dining table for eight' },
];

const bedrooms = [
  {
    id: 'looking-glass',
    eyebrow: 'Bedroom · Ground Floor',
    title: 'Through the Looking Glass',
    summary: 'King bedroom on the ground floor with an en-suite bathroom featuring a tub and shower.',
    longDescription: 'The largest of the bedrooms — a king bed under a generous window, with a full en-suite tub-and-shower bathroom. The Secret Garden suite shares its bath through a connecting door.',
    details: [
      { label: 'Bed', value: 'King' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'En-suite · tub + shower' },
    ],
    photos: [
      { src: '/images/homes/hh-looking-glass.webp', alt: 'Through the Looking Glass bedroom' },
    ],
  },
  {
    id: 'secret-garden',
    eyebrow: 'Suite · Adjacent',
    title: 'The Secret Garden',
    summary: 'A small adjacent sitting-room suite with a pull-out sofa for one. Accesses the bathroom through Through the Looking Glass.',
    longDescription: 'A bonus space attached to the master — perfect for a kid, an extra adult, or a quiet reading nook by day. The pull-out sofa sleeps one comfortably.',
    details: [
      { label: 'Sleeps', value: '1 (pull-out sofa)' },
      { label: 'Bathroom', value: 'Shared via Through the Looking Glass' },
    ],
    photos: [
      { src: '/images/homes/hh-secret-garden.webp', alt: 'The Secret Garden suite' },
    ],
  },
  {
    id: 'american-in-paris',
    eyebrow: 'Bedroom · Ground Floor',
    title: 'An American in Paris',
    summary: 'Queen bedroom on the ground floor. Hall bathroom with tub/shower and a separate toilet. Washing machine on this level.',
    details: [
      { label: 'Bed', value: 'Queen' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'Hall · tub + shower' },
      { label: 'Also', value: 'Separate WC, washing machine' },
    ],
    photos: [
      { src: '/images/homes/hh-american-in-paris.webp', alt: 'An American in Paris bedroom' },
    ],
  },
  {
    id: 'sleeping-beauty',
    eyebrow: 'Bedroom · Attic',
    title: 'Sleeping Beauty',
    summary: 'Attic room with two twins, plus a third twin in the foyer. Bathroom is in the hall, two flights down.',
    longDescription: 'A storybook attic — sloping beams, twin beds, and one extra twin in the foyer for a third guest. Note: only suitable for guests comfortable climbing two steep flights.',
    details: [
      { label: 'Beds', value: '2 twin + 1 foyer twin' },
      { label: 'Floor', value: 'Attic' },
      { label: 'Bathroom', value: 'Hall, two flights down' },
      { label: 'Note', value: 'Steep stairs required' },
    ],
    photos: [
      { src: '/images/homes/hh-sleeping-beauty.webp', alt: 'Sleeping Beauty bedroom' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'upstairs',
    eyebrow: 'Living & Dining',
    title: 'The Upstairs Room',
    summary: 'Open upstairs space — dining table for ten, sitting area, and the room many guests use for yoga or morning meetings.',
    longDescription: 'The upstairs of the Hideaway is one long, light-filled room. The dining table seats ten, the sitting area runs alongside it, and there is enough open floor for a yoga class or a private workshop.',
    details: [
      { label: 'Seats at table', value: '10' },
      { label: 'Best for', value: 'Dinners, yoga, meetings' },
    ],
    photos: [
      { src: '/images/homes/la-grange-living.webp', alt: 'Upstairs living and dining space' },
    ],
  },
  {
    id: 'kitchen',
    eyebrow: 'Kitchen',
    title: 'The Kitchen',
    summary: 'Bright white kitchen with red accents. Induction stove, oven, Nespresso, full fridge.',
    details: [
      { label: 'Stove', value: 'Induction' },
      { label: 'Coffee', value: 'Nespresso' },
      { label: 'Fridge', value: 'Full size' },
    ],
    photos: [
      { src: '/images/homes/hh-kitchen.webp', alt: 'Bright white kitchen with red accents' },
    ],
  },
];

const amenityFeatures = [
  {
    title: 'The Gazebo',
    summary: 'Covered gazebo with a dining table for eight — al fresco meals, sheltered from the afternoon sun.',
    image: '/images/homes/hh-gazebo.webp',
    alt: 'Covered gazebo dining at the Hollywood Hideaway',
  },
  {
    title: 'The Compound Gardens',
    summary: 'Shared with the rest of the compound — flower beds, lawns, and a Giverny-style bridge over the millstream.',
    image: '/images/bridge-garden.webp',
    alt: 'Compound gardens and bridge',
  },
  {
    title: 'Yoga on the Lawn',
    summary: 'Wide stretch of lawn beside the gazebo — used for morning yoga, lawn games, or simply doing nothing.',
    image: '/images/yoga-lawn.webp',
    alt: 'Yoga on the lawn at the compound',
  },
];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: 'Induction stove + oven', icon: 'oven' },
  { label: 'Nespresso', icon: 'coffee' },
  { label: 'Full-size fridge', icon: 'fridge' },
  { label: 'Washing machine', icon: 'washer' },
  { label: 'Compound gardens', icon: 'garden' },
  { label: 'Covered gazebo dining', icon: 'patio' },
  { label: 'Sleeps 8 across 5 beds', icon: 'guests' },
];
---

<BaseLayout title="The Hollywood Hideaway — French Countryside Rental Near Paris" description="Three-bedroom French countryside rental with a suite, sleeps 8. A 60-year sanctuary of Hollywood's top power lawyer. Mereville, France — one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/hollywood-hideaway/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mereville",
        "addressRegion": "Essonne",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "The Hollywood Hideaway", "item": "https://www.moulinareves.com/homes/hollywood-hideaway/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — a treasured sanctuary in the French countryside`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow" data-i18n="hideaway.hero.eyebrow">{cms.eyebrow}</span>
      <h1 class="hero__title" data-i18n="hideaway.hero.title">{cms.title}</h1>
      <p class="hero__tagline" data-i18n="hideaway.hero.tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 32px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}+1</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.bedroomsSuite">Bedrooms + Suite</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.bathrooms">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.beds">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Narrative Description -->
  <section class="section section--tight">
    <div class="container--narrow fade-in">
      <span class="eyebrow" data-i18n="hideaway.narrative.eyebrow">The Maison</span>
      <h2 data-i18n="hideaway.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 32px;">
        <p class="prose-lead" data-i18n="hideaway.narrative.summary">
          {cms.summary}
        </p>
        <p style="margin-top: 20px;" data-i18n="hideaway.narrative.p1">
          For 60 years, The Hollywood Hideaway was a treasured sanctuary getaway for Hollywood's #1 power lawyer whose clients included Tom Cruise, Dustin Hoffman, Michael Jackson, Mario Puzzo and the luminaries of LA.
        </p>
        <p style="margin-top: 20px;" data-i18n="hideaway.narrative.p2">
          This was his happy home where he entertained his Hollywood pals and cooked and relaxed in the French countryside. Now you can follow in the footsteps of the stars and make this your own home in France. It is beautifully furnished with French antiques.
        </p>
      </div>
    </div>
  </section>

  <!-- Rooms (bedrooms) -->
  <RoomShowcase
    eyebrow="Rooms"
    heading={`Where you'll <span class="serif-italic">sleep</span>`}
    intro="Three bedrooms plus an adjacent suite. Tap any room for details and photos."
    rooms={bedrooms}
    background="stone"
    i18nKey="hideaway.bedrooms"
  />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow="Living Spaces"
    heading={`Where you'll <span class="serif-italic">gather</span>`}
    intro="One long upstairs room and the bright kitchen below — the working heart of the Hideaway."
    rooms={livingSpaces}
    i18nKey="hideaway.living"
  />

  <!-- Amenities -->
  <AmenitiesSection
    eyebrow="Amenities & Grounds"
    heading={`What's <span class="serif-italic">here</span>`}
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="hideaway.amenities"
  />

  <!-- Availability -->
  <AvailabilityCalendar
    eyebrow="Availability"
    heading={`When You Can <span class="serif-italic">Stay</span>`}
    intro="Live calendar synced from our Airbnb and VRBO listings — covers the whole compound. Greyed dates are already booked. Found a window? Tell us your dates and we'll confirm."
    i18nKey="hideaway.availability"
  />

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/la-grange-hero.webp" alt="The Hollywood Hideaway at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="hideaway.cta.heading">Interested in {cms.title}?</h2>
      <p class="hero__tagline" data-i18n="hideaway.cta.text">Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="hideaway.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="hideaway.cross.heading">Les <span class="serif-italic">Autres Maisons</span></h2>
      </div>
      <div class="grid grid--2" style="gap: 24px;">
        <a href="/homes/le-moulin/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow" data-i18n="hideaway.cross.moulin.eyebrow">Maison One</span>
            <h3 class="card__title" data-i18n="hideaway.cross.moulin.title">Le Moulin à Rêves</h3>
            <div class="card__meta">
              <span data-i18n="hideaway.cross.moulin.beds">5 Bedrooms</span>
              <span data-i18n="hideaway.cross.moulin.sleeps">Sleeps 12</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow" data-i18n="hideaway.cross.riviere.eyebrow">Maison Three</span>
            <h3 class="card__title" data-i18n="hideaway.cross.riviere.title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span data-i18n="hideaway.cross.riviere.beds">2 Bedrooms</span>
              <span data-i18n="hideaway.cross.riviere.sleeps">Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="hideaway.cross.cta">Rent All Three Maisons</a>
      </div>
    </div>
  </section>

</BaseLayout>
