---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/hollywood-hideaway.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = cms.gallery ?? [];

const bedrooms = [
  {
    id: 'looking-glass',
    title: 'Through the Looking Glass',
    summary: 'King bedroom on the ground floor — en-suite bath with tub and shower.',
    longDescription: 'The largest bedroom.',
    details: [
      { label: 'Bed', value: 'King' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'En-suite, tub + shower' },
    ],
    photos: [
      { src: '/images/homes/hh-looking-glass.webp', alt: 'Through the Looking Glass — bedroom with vanity mirror and ornate frame' },
      { src: '/images/homes/hh-looking-glass-2.webp', alt: 'Through the Looking Glass bedroom, alternate view' },
      { src: '/images/homes/hh-looking-glass-bath.webp', alt: 'Through the Looking Glass bathroom with hanging robe' },
      { src: '/images/homes/hh-looking-glass-bath-2.webp', alt: 'Through the Looking Glass bathroom, alternate view' },
      { src: '/images/homes/hh-secret-garden.webp', alt: 'Adjoining sitting nook off Through the Looking Glass' },
      { src: '/images/homes/hh-secret-garden-sitting.webp', alt: 'Adjoining sitting room with floral wallpaper and fireplace' },
    ],
  },
  {
    id: 'american-in-paris',
    title: 'An American in Paris',
    summary: 'Queen bedroom on the ground floor.',
    details: [
      { label: 'Bed', value: 'Queen' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'Hall, tub + shower' },
    ],
    photos: [
      { src: '/images/homes/hh-american-in-paris.webp', alt: 'An American in Paris — bedroom with floral wallpaper' },
      { src: '/images/homes/hh-american-in-paris-window.webp', alt: 'An American in Paris — window view onto the gardens' },
      { src: '/images/homes/hh-american-in-paris-bath.webp', alt: 'An American in Paris bathroom' },
      { src: '/images/homes/hh-american-in-paris-bath-2.webp', alt: 'An American in Paris bathroom, alternate view' },
      { src: '/images/homes/hh-secret-garden.webp', alt: 'Adjoining sitting nook with floral wallpaper' },
      { src: '/images/homes/hh-secret-garden-sitting.webp', alt: 'Adjoining sitting room with floral wallpaper and fireplace' },
    ],
  },
  {
    id: 'sleeping-beauty',
    title: 'Sleeping Beauty',
    summary: 'Attic room with two twins. Up two steep flights.',
    longDescription: 'Tucked under the eaves, themed around the fairy tale — antique spinning wheels visible through the doorway. The two stairwells climbing up to the room are lined with framed scarf-print and embroidered art.',
    details: [
      { label: 'Bed', value: '2 Twins' },
      { label: 'Floor', value: 'Attic' },
      { label: 'Bathroom', value: 'Hall, two flights down' },
    ],
    photos: [
      { src: '/images/homes/hh-sleeping-beauty.webp', alt: 'Sleeping Beauty room with antique spinning wheels through the doorway' },
      { src: '/images/homes/hh-sleeping-beauty-loft.webp', alt: 'Sleeping Beauty loft bedroom with twin beds under the eaves' },
      { src: '/images/homes/hh-scarf-stairwell.webp', alt: 'Stairwell up to Sleeping Beauty lined with framed scarf-print art' },
      { src: '/images/homes/hh-needlework-stairwell.webp', alt: 'Narrow stairwell with red carpet runner and walls lined with framed embroidered art' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'upstairs',
    title: 'Upstairs Living & Dining',
    summary: 'Open upstairs space — dining for ten, sitting area, room for yoga.',
    details: [
      { label: 'Seats', value: '10' },
    ],
    photos: [
      { src: '/images/homes/hh-dining-living.webp', alt: 'Open dining and living room at the Hollywood Hideaway' },
      { src: '/images/homes/hh-dining-into-kitchen.webp', alt: 'View from the dining and living room through to the kitchen' },
    ],
  },
  {
    id: 'kitchen',
    title: 'Kitchen',
    summary: 'Bright kitchen with induction stove, oven, full fridge.',
    photos: [
      { src: '/images/homes/hh-kitchen.webp', alt: 'Cherry-red themed kitchen at the Hollywood Hideaway' },
    ],
  },
  {
    id: 'gazebo',
    title: 'Gazebo & Patio',
    summary: 'Covered gazebo dining table for eight, plus the patio facing the home.',
    photos: [
      { src: '/images/homes/hh-gazebo.webp', alt: 'Garden gazebo with cafe seating' },
      { src: '/images/homes/hh-patio.webp', alt: 'Patio at the Hollywood Hideaway' },
      { src: '/images/homes/hh-patio-facing-home.webp', alt: 'Patio facing the Hollywood Hideaway facade' },
      { src: '/images/homes/hh-steps.webp', alt: 'Stone steps leading up to the Hollywood Hideaway entrance' },
    ],
  },
  {
    id: 'gardens',
    title: 'Gardens',
    summary: 'Shared compound gardens, the lawn, and the millstream.',
    photos: [
      { src: '/images/bridge-garden.webp', alt: 'Giverny-style painted bridge over the stream beneath willow trees' },
      { src: '/images/garden-chaises.webp', alt: 'Garden chaise lounges facing the Giverny-style bridge' },
      { src: '/images/garden-stone-well.webp', alt: 'Vine-covered antique stone well sheltered in the garden' },
    ],
  },
];

const amenityFeatures = [
  {
    title: 'The Gazebo',
    summary: 'Covered gazebo with a dining table for eight — al fresco meals, sheltered from the afternoon sun.',
    image: '/images/homes/hh-gazebo.webp',
    alt: 'Covered gazebo dining at the Hollywood Hideaway',
  },
  {
    title: 'The Compound Gardens',
    summary: 'Shared with the rest of the compound — flower beds, lawns, and a Giverny-style bridge over the millstream.',
    image: '/images/bridge-garden.webp',
    alt: 'Compound gardens and bridge',
  },
  {
    title: 'Yoga on the Lawn',
    summary: 'Wide stretch of lawn beside the gazebo — used for morning yoga, lawn games, or simply doing nothing.',
    image: '/images/yoga-lawn.webp',
    alt: 'Yoga on the lawn at the compound',
  },
];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: 'Induction stove + oven', icon: 'oven' },
  { label: 'Nespresso', icon: 'coffee' },
  { label: 'Full-size fridge', icon: 'fridge' },
  { label: 'Washing machine', icon: 'washer' },
  { label: 'Compound gardens', icon: 'garden' },
  { label: 'Covered gazebo dining', icon: 'patio' },
  { label: 'Sleeps 7 across 4 beds', icon: 'guests' },
];
---

<BaseLayout title="The Hollywood Hideaway — French Countryside Rental Near Paris" description="Three-bedroom French countryside rental with a suite, sleeps 7. A 60-year sanctuary of Hollywood's top power lawyer. Méréville, France — one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/hollywood-hideaway/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "The Hollywood Hideaway", "item": "https://www.moulinareves.com/homes/hollywood-hideaway/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — a treasured sanctuary in the French countryside`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="hideaway.hero.title">{cms.title}</h1>
      <p class="hero__tagline" data-i18n="hideaway.hero.tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 32px; padding-bottom: 24px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.bathrooms">Baths</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label" data-i18n="hideaway.stats.beds">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Narrative Description -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="hideaway.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 24px;">
        <p class="prose-lead" data-i18n="hideaway.narrative.summary">
          {cms.summary}
        </p>
        <p style="margin-top: 16px;" data-i18n="hideaway.narrative.p1">
          For 60 years, the 60-year sanctuary of Hollywood's #1 power lawyer — clients included Tom Cruise, Dustin Hoffman, Michael Jackson, and Mario Puzo. Furnished with French antiques.
        </p>
      </div>
    </div>
  </section>

  <!-- Rooms (bedrooms) -->
  <RoomShowcase
    eyebrow=""
    heading={`Where you'll <span class="serif-italic">sleep</span>`}
    intro="3 bedrooms."
    rooms={bedrooms}
    background="stone"
    i18nKey="hideaway.bedrooms"
  />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow=""
    heading={`Where you'll <span class="serif-italic">gather</span>`}
    intro=""
    rooms={livingSpaces}
    i18nKey="hideaway.living"
    hideTileSummary={true}
  />

  <!-- Amenities -->
  <AmenitiesSection
    eyebrow=""
    heading={`What's <span class="serif-italic">here</span>`}
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="hideaway.amenities"
  />

  <!-- Availability -->
  <AvailabilityCalendar
    monthsToShow={12}
    eyebrow=""
    heading={`Join <span class="serif-italic">us</span>`}
    intro="Live calendar synced from Airbnb and VRBO. Greyed dates are booked."
    i18nKey="hideaway.availability"
  />

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="hideaway.cta.heading">Interested in {cms.title}?</h2>
      <p class="hero__tagline" data-i18n="hideaway.cta.text">Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="hideaway.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 24px;">
        <h2 data-i18n-html="hideaway.cross.heading">Les <span class="serif-italic">Autres Maisons</span></h2>
      </div>
      <div class="maisons-stack">
        <a href="/homes/le-moulin/" class="split split--maison fade-in">
          <div class="split__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin" loading="lazy" />
          </div>
          <div class="split__body">
            <span class="split__eyebrow">The Mill House</span>
            <h2 data-i18n="hideaway.cross.moulin.title">Le Moulin</h2>
            <div class="split__meta">
              <span data-i18n="hideaway.cross.moulin.beds">5 Bedrooms</span>
              <span data-i18n="hideaway.cross.moulin.sleeps">Sleeps 10</span>
            </div>
            <p>An historic mill on the Juine River. The river runs through the house. Five bedrooms across three floors.</p>
            <span class="link-arrow">Discover Le Moulin →</span>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="split split--maison split--reverse fade-in">
          <div class="split__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière" loading="lazy" />
          </div>
          <div class="split__body">
            <span class="split__eyebrow">The Garden Cottage</span>
            <h2 data-i18n="hideaway.cross.riviere.title">La Maison de la Rivière</h2>
            <div class="split__meta">
              <span data-i18n="hideaway.cross.riviere.beds">2 Bedrooms</span>
              <span data-i18n="hideaway.cross.riviere.sleeps">Sleeps 5</span>
            </div>
            <p>Sun-drenched cottage with French doors onto the stream and apple trees. Two bedrooms, dining for 18, an authentic Louis Vuitton trunk as a coffee table.</p>
            <span class="link-arrow">Discover La Maison →</span>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 32px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="hideaway.cross.cta">Rent the Compound</a>
      </div>
    </div>
  </section>

</BaseLayout>
