---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import { exploreEstateFeatures } from '../../data/explore-estate';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/le-moulin.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = cms.gallery ?? [];

const bedrooms = [
  {
    id: 'romantique',
    title: 'La Suite Romantique',
    summary: 'Upstairs master with king bed, en-suite shower.',
    longDescription: 'The largest bedroom in the house. Tall windows, exposed beams, and a king bed.',
    qualities: 'King bedroom · En-suite shower · Upstairs',
    details: [
      { label: 'Bed', value: 'King' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'En-suite, shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-suite-romantique.webp', alt: 'La Suite Romantique — master bedroom with beamed ceiling and fireplace' },
      { src: '/images/homes/le-moulin-suite-romantique-2.webp', alt: 'La Suite Romantique — alternate view from the bed toward the windows' },
      { src: '/images/homes/le-moulin-suite-romantique-master-bath.webp', alt: 'La Suite Romantique master bathroom' },
      { src: '/images/homes/le-moulin-suite-romantique-bath.webp', alt: 'La Suite Romantique bathroom with painting' },
      { src: '/images/homes/le-moulin-suite-antique-dresser.webp', alt: 'La Suite Romantique with an antique commode, oil painting, and a brass triple shaving mirror' },
    ],
  },
  {
    id: 'riviere',
    title: 'La Chambre de la Rivière',
    summary: 'The River Room — two twin beds on the ground floor.',
    longDescription: 'A quiet ground-floor bedroom that opens onto the millhouse hall. The river runs just beyond the wall.',
    qualities: 'Twin beds · Hall shower · Ground Floor',
    details: [
      { label: 'Bed', value: '2 Twins' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'Hall, shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-river-room.webp', alt: 'La Chambre de la Rivière — twin beds with stone walls and lantern light' },
      { src: '/images/homes/le-moulin-river-room-entrance.webp', alt: 'Entrance to La Chambre de la Rivière' },
      { src: '/images/homes/le-moulin-river-room-bath.webp', alt: 'River Room bathroom' },
    ],
  },
  {
    id: 'cerises',
    title: 'Les Cerises',
    summary: 'The Cherry Room — queen bed, in-room sink and bidet.',
    qualities: 'Queen bed · In-room sink & bidet · Hall clawfoot tub · Upstairs',
    details: [
      { label: 'Bed', value: 'Queen' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall clawfoot tub (shared with Les Roses)' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-cerises-bed.webp', alt: 'Les Cerises — the Cherry Room with a queen bed, oval portrait, and patterned wallpaper' },
      { src: '/images/homes/le-moulin-cerises-bath.webp', alt: 'Les Cerises — the Cherry Room with painted portrait, in-room sink and bidet' },
      { src: '/images/homes/le-moulin-cerises-sink.webp', alt: 'Les Cerises in-room sink, mirror and bidet detail' },
      { src: '/images/homes/le-moulin-cerises-rose-bath.webp', alt: 'Shared clawfoot bathroom serving Les Cerises and Les Roses' },
    ],
  },
  {
    id: 'roses',
    title: 'Les Roses',
    summary: 'The Rose Room — two twin beds.',
    qualities: 'Twin beds · Hall clawfoot tub · Upstairs',
    details: [
      { label: 'Bed', value: '2 Twins' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall clawfoot tub (shared with Les Cerises)' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-roses.webp', alt: 'Les Roses — the Rose Room with twin beds and rose-print wallpaper' },
      { src: '/images/homes/le-moulin-cerises-rose-bath.webp', alt: 'Shared clawfoot bathroom serving Les Roses and Les Cerises' },
    ],
  },
  {
    id: 'loft',
    title: 'Le Loft Suite',
    summary: 'Attic suite with two twins (combinable as king) plus a separate TV area.',
    longDescription: 'A whole-floor retreat. Up a steep flight of stairs.',
    qualities: 'Twins or King · Hall shower · Up Steep Stairs',
    details: [
      { label: 'Bed', value: '2 Twins (or King) + 2 Floor Twins' },
      { label: 'Floor', value: 'Up Steep Stairs' },
      { label: 'Bathroom', value: 'Hall, shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-loft.webp', alt: 'Le Loft Suite — master bedroom under cathedral ceilings with floral wallpaper' },
      { src: '/images/homes/le-moulin-loft-2-twins.webp', alt: 'Le Loft second bedroom with twin beds, exposed beams, and figurine shelves' },
      { src: '/images/homes/le-moulin-loft-2-twins-2.webp', alt: 'Le Loft second bedroom with twin beds, alternate angle' },
      { src: '/images/homes/le-moulin-loft-bath.webp', alt: 'Le Loft bathroom with shower and sink' },
      { src: '/images/homes/le-moulin-loft-bath-2.webp', alt: 'Le Loft bathroom, alternate view' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'salon',
    title: 'Le Salon',
    summary: 'Living room with leather couch, club chairs, and views of the river and bridge.',
    photos: [
      { src: '/images/homes/le-moulin-living.webp', alt: 'Le Salon — leather club chairs, exposed beams, and the antique mill wheel' },
      { src: '/images/homes/le-moulin-living-couch.webp', alt: 'Le Salon facing the floral couch and stone walls' },
      { src: '/images/homes/le-moulin-living-detail.webp', alt: 'Detail of the antique mill wheel with backgammon on the table' },
    ],
  },
  {
    id: 'dining',
    title: 'Dining Room',
    summary: 'Formal dining for up to twelve.',
    photos: [
      { src: '/images/homes/le-moulin-dining-one-table.webp', alt: 'Formal dining room with a single long table set for ten beneath the beamed ceiling and stone fireplace' },
      { src: '/images/homes/le-moulin-dining-green-table.webp', alt: 'The dining room with a green-clothed serving table facing the long set dining table beneath the beamed ceiling' },
      { src: '/images/homes/le-moulin-dining-2.webp', alt: 'Dining room from an alternate angle showing the fireplace' },
    ],
  },
  {
    id: 'kitchen',
    title: 'Kitchen',
    summary: 'Eat-in kitchen for six. Two Viking-style ovens, six gas burners.',
    details: [
      { label: 'Seats', value: '6' },
      { label: 'Ovens', value: '2 Viking-style' },
      { label: 'Burners', value: '6 gas' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-kitchen.webp', alt: 'Kitchen with cast-iron stove, beamed ceiling, and country paintings' },
      { src: '/images/homes/le-moulin-kitchen-table.webp', alt: 'Kitchen table set with fruit bowls under a beamed ceiling' },
    ],
  },
];

// Explore the Estate — six estate-wide tiles, shared with the home page and the
// other house pages via src/data/explore-estate.ts (single source of truth).
const amenityFeatures = exploreEstateFeatures;

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: '2 Viking-style ovens', icon: 'oven' },
  { label: 'Nespresso & kettle', icon: 'coffee' },
  { label: 'Full fridge + freezer', icon: 'fridge' },
  { label: 'Garden & wishing well', icon: 'garden' },
  { label: 'River frontage', icon: 'river' },
  { label: 'Patio dining', icon: 'patio' },
  { label: 'Sleeps 10 across 8 beds', icon: 'guests' },
];
---

<BaseLayout title="Le Moulin — Historic Mill House in Méréville, France" description="Historic 1800s mill house in Méréville, France. Sleeps 10 across 5 bedrooms and 4 baths. The Juine River flows through the house. One hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/le-moulin/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true}
      ]
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "Le Moulin", "item": "https://www.moulinareves.com/homes/le-moulin/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — historic mill house on the Juine River`} />
    </div>
    <div class="hero__overlay"></div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Narrative / Story (directly beneath hero) -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="le-moulin.narrative.heading">Le Moulin</h2>
      <div style="margin-top: 24px;">
        <p class="prose-lead" data-i18n="le-moulin.narrative.summary">
          The original mill house was once home to the famed vaudevillian Borrah Minevitch. Here he entertained an extraordinary circle of friends — among them Charlie Chaplin, Jean Cocteau, Jacques Tati, legendary Paris restaurateur, Maxim, and even the Duchess of Windsor.
        </p>
        <p style="margin-top: 16px;" data-i18n="le-moulin.narrative.p1">
          Borrah's musical instruments and antiques - including a 1891 Folies Bergère poster — fill Le Moulin with his showman style.
        </p>
        <p style="margin-top: 16px;" data-i18n="le-moulin.narrative.p2">
          His tradition of joyful hospitality welcomes you and your guests!
        </p>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow=""
    heading="The Living Spaces"
    intro=""
    rooms={livingSpaces}
    i18nKey="le-moulin.living"
    hideTileSummary={true}
    gatherMode={true}
  />

  <!-- The Bedrooms -->
  <RoomShowcase
    eyebrow=""
    heading="The Bedrooms"
    intro="5 Bedrooms • 4 Bathrooms • 8 Beds • Sleeps 10"
    introStrong={true}
    rooms={bedrooms}
    background="stone"
    i18nKey="le-moulin.bedrooms"
    hideTileSummary={true}
  />

  <!-- Explore the Estate (4-square lightbox tiles) + Also Included amenity list -->
  <AmenitiesSection
    eyebrow=""
    heading="Explore the Estate"
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="le-moulin.amenities"
    featureKeyPrefix="home.compound.feat"
    exploreMode={true}
  />

  <!-- Join us -->
  <section class="section text-center">
    <div class="container fade-in">
      <a href="/contact/" class="btn btn--green" data-i18n="le-moulin.cta.button">Join us</a>
    </div>
  </section>

</BaseLayout>
