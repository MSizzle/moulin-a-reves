---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Le Moulin — Moulin à Rêves" description="Le Moulin: the original stone mill house at Moulin à Rêves. 3 bedrooms, sleeps 6, with thick walls, a working fireplace, and the millstream at your door.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": "Le Moulin — Moulin à Rêves",
      "description": "The original stone mill house at Moulin à Rêves. 3 bedrooms, 2 bathrooms, sleeps 6. Thick walls, a working fireplace, and the millstream at your door.",
      "url": "https://moulin-a-reves.com/homes/le-moulin/",
      "image": "/images/homes/le-moulin-hero.webp",
      "numberOfBedrooms": 3,
      "numberOfBathroomsTotal": 2,
      "occupancy": { "@type": "QuantitativeValue", "value": 6 },
      "floorSize": { "@type": "QuantitativeValue", "value": 150, "unitCode": "MTK" },
      "petsAllowed": true,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Barbizon",
        "addressRegion": "Seine-et-Marne",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.4433,
        "longitude": 2.6033
      },
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Fireplace", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Hot Tub", "value": true}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin — stone mill house with blue shutters beside the millstream" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow">House One of Three</span>
      <h1 class="hero__title hero__title--italic">Le Moulin</h1>
      <p class="hero__tagline" data-i18n="moulin.hero.tagline">The heart of the compound. Where the millstream meets your morning.</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.85);
      margin-bottom: 20px;
    }
    .hero__title--italic {
      font-style: italic;
      font-weight: 300;
      font-size: clamp(3.5rem, 10vw, 8rem);
      line-height: 0.95;
      letter-spacing: -0.01em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 48px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number stats-bar__number--serif">3</div>
          <div class="stats-bar__label" data-i18n="moulin.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number stats-bar__number--serif">2</div>
          <div class="stats-bar__label" data-i18n="moulin.stats.bathrooms">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number stats-bar__number--serif">6</div>
          <div class="stats-bar__label" data-i18n="moulin.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number stats-bar__number--serif">150</div>
          <div class="stats-bar__label">m&sup2;</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Narrative Description -->
  <section class="section">
    <div class="container--narrow fade-in">
      <span class="eyebrow">The House</span>
      <h2 data-i18n="moulin.narrative.heading">The Original Mill</h2>
      <div style="margin-top: 32px;">
        <p class="prose-lead" data-i18n="moulin.narrative.p1">
          You'll wake to the sound of water. Not the rush of a river, but the steady, quiet conversation of the millstream passing just beneath your window. The shutters are blue — the kind of faded, chalky blue that only decades of French sun can produce — and when you push them open in the morning, the garden smells of damp stone and lavender.
        </p>
        <p data-i18n="moulin.narrative.p2" style="margin-top: 20px;">
          Le Moulin is the oldest of the three houses, the one that gave the compound its name. Its walls are thick — nearly a metre in places — built from the same limestone that lines the forest paths of Fontainebleau. In summer, they keep the rooms cool even when the temperature outside climbs past thirty. In autumn, the fireplace in the living room draws beautifully, and you'll find yourself reading longer than you meant to, a glass of something local in hand.
        </p>
        <p data-i18n="moulin.narrative.p3" style="margin-top: 20px;">
          The kitchen is where most mornings begin: a farmhouse table that seats eight without crowding, copper pans on the wall, and light that pours in from two sides. If you've ordered breakfast delivery, it arrives in a basket at your door — croissants still warm, butter from the crémerie in Barbizon, jam made from the garden's own figs. If you'd rather cook, the Saturday marché in Milly-la-Forêt is ten minutes away, and you'll come back with more than you planned.
        </p>
        <p data-i18n="moulin.narrative.p4" style="margin-top: 20px;">
          Evenings belong to the terrace. It sits just above the stream, shaded by a pair of old linden trees, and when the light drops low it turns everything the colour of warm bread. This is where the long dinners happen — the ones where nobody checks the time, where the children fall asleep in their chairs, where someone opens a second bottle and nobody objects.
        </p>
      </div>
    </div>
  </section>

  <!-- Room by Room -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <h2 data-i18n="moulin.rooms.heading">Room by Room</h2>
      </div>
      <div class="grid grid--3">
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin master bedroom with exposed oak beams at Moulin à Rêves, Barbizon" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="moulin.room.master.title">Master Bedroom</h3>
            <p class="card__description" data-i18n="moulin.room.master.desc">King bed beneath original oak beams. Millstream views through the blue shutters. En-suite bathroom with walk-in rain shower and heated stone floor.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin garden bedroom with antique armoire and morning light at Moulin à Rêves" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="moulin.room.garden.title">Garden Bedroom</h3>
            <p class="card__description" data-i18n="moulin.room.garden.desc">Queen bed facing the walled garden. Antique armoire, reading chair by the window, and morning light that arrives gently.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin cosy nook bedroom with twin beds beneath the eaves at Moulin à Rêves" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="moulin.room.nook.title">The Nook</h3>
            <p class="card__description" data-i18n="moulin.room.nook.desc">Two single beds in the quietest room of the house. Tucked beneath the eaves, perfect for children or light sleepers who want absolute stillness.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin farmhouse kitchen with copper pans and farmhouse table at Moulin à Rêves" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="moulin.room.kitchen.title">Kitchen & Dining</h3>
            <p class="card__description" data-i18n="moulin.room.kitchen.desc">Farmhouse table for eight, full oven and gas hob, copper pans, dishwasher, Nespresso machine, and all the essentials for cooking with market ingredients.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin stone living room with working fireplace and deep sofas at Moulin à Rêves" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="moulin.room.living.title">Living Room</h3>
            <p class="card__description" data-i18n="moulin.room.living.desc">Working stone fireplace, deep sofas, bookshelves stocked for rainy afternoons. Doors open onto the millstream terrace.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/bridge-garden.webp" alt="Le Moulin stone terrace above the millstream shaded by linden trees at Moulin à Rêves" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="moulin.room.terrace.title">Millstream Terrace</h3>
            <p class="card__description" data-i18n="moulin.room.terrace.desc">Stone terrace shaded by linden trees, directly above the stream. Table for eight, lounge chairs, and the sound of water all evening.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Amenities -->
  <section class="section">
    <div class="container fade-in">
      <div class="text-center" style="margin-bottom: 48px;">
        <h2 data-i18n="moulin.amenities.heading">Amenities</h2>
      </div>
      <div class="amenities">
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
          <span data-i18n="amenity.livingspace150">150 m&sup2; living space</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
