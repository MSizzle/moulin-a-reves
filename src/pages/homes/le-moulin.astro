---
import BaseLayout from '../../layouts/BaseLayout.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/le-moulin.md', 'utf-8');
const { data: cms, content: body } = matter(raw);
---

<BaseLayout title="Le Moulin à Rêves — Historic Mill Vacation Rental, Mereville France" description="Historic 1800s mill house in Mereville, France. Sleeps 12 across 5 bedrooms and 4 baths. The Juine River flows through the house. One hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://moulin-a-reves.com/homes/le-moulin/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mereville",
        "addressRegion": "Essonne",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true}
      ]
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://moulin-a-reves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://moulin-a-reves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "Le Moulin à Rêves", "item": "https://moulin-a-reves.com/homes/le-moulin/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — historic mill house on the Juine River`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow">{cms.eyebrow}</span>
      <h1 class="hero__title">{cms.title}</h1>
      <p class="hero__tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 48px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}</div>
          <div class="stats-bar__label">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Narrative Description -->
  <section class="section">
    <div class="container--narrow fade-in">
      <span class="eyebrow">The Maison</span>
      <h2>{cms.title}</h2>
      <div style="margin-top: 32px;">
        <p class="prose-lead">
          {cms.summary}
        </p>
        <p style="margin-top: 20px;">
          Relax in the gardens and watch as the day goes by. Let your worries float away on the Juine River. Wake up to the roosters crowing in the chicken coop. Go back in time as you gaze at the flower gardens and Giverny-style bridge. Make a wish in the wishing well!
        </p>
        <p style="margin-top: 20px;">
          Dine al fresco with friends, colleagues, family or students. This is a wonderful compound for inspiration, fun, reflection and quiet time together.
        </p>
      </div>
    </div>
  </section>

  <!-- Room by Room -->
  <section class="section section--soft">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <span class="eyebrow">Room by Room</span>
        <h2>Five Bedrooms Across Three Floors</h2>
      </div>
      <div class="grid grid--3" style="gap: 24px;">
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="La Chambre de la Rivière at Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Chambre de la Rivière</h3>
            <p class="card__description">The River Room. 2 twin beds on the ground floor. Bathroom in the hall with a shower.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="La Suite Romantique at Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Suite Romantique</h3>
            <p class="card__description">King bed in a large master bedroom upstairs. En-suite bathroom with a shower.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Les Cerises at Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Les Cerises</h3>
            <p class="card__description">The Cherry Room. Queen bed with sink and bidet. Shares a bathroom with Les Roses — clawfoot bathtub and bidet in the hall.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Les Roses at Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Les Roses</h3>
            <p class="card__description">The Rose Room. 2 twin beds. Shares a bathroom with Les Cerises in the hall.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Loft Suite at Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Loft Suite</h3>
            <p class="card__description">Second-floor attic. 2 twins (or King) plus a separate TV room with 2 floor twins. Shared bathroom with shower. Note: steep stairs.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Kitchen and dining at Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Kitchen & Dining</h3>
            <p class="card__description">Eat-in kitchen for 6 with 2 Viking-style ovens, 6 gas burners, Nespresso. Formal dining room for 12 with art and antiques.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Entertaining Spaces -->
  <section class="section">
    <div class="container--narrow fade-in">
      <span class="eyebrow">Living Spaces</span>
      <h2>Made for Long Evenings</h2>
      <div style="margin-top: 32px;">
        <p><strong>Le Salon</strong> — Large living room with leather couch, club chairs, and antiques. Beautiful view of the river and bridge illuminated at night.</p>
        <p style="margin-top: 16px;"><strong>Office</strong> — Separate office with a desk and printer.</p>
        <p style="margin-top: 16px;"><strong>Outdoor</strong> — Wonderful patio for outdoor dining, lounge chairs, and gorgeous gardens overlooking the Juine River.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);">Interested in {cms.title}?</h2>
      <p class="hero__tagline">Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.</p>
      <a href="/contact/" class="btn btn--white">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 48px;">
        <h2>The Other Maisons</h2>
      </div>
      <div class="grid grid--2" style="gap: 24px;">
        <a href="/homes/hollywood-hideaway/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="The Hollywood Hideaway at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Maison Two</span>
            <h3 class="card__title">The Hollywood Hideaway</h3>
            <div class="card__meta">
              <span>3 Bedrooms + Suite</span>
              <span>Sleeps 8</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Maison Three</span>
            <h3 class="card__title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span>2 Bedrooms</span>
              <span>Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow">Rent All Three Maisons</a>
      </div>
    </div>
  </section>

</BaseLayout>
