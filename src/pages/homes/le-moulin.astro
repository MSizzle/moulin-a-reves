---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Le Moulin — Moulin à Rêves" description="Le Moulin: the original stone mill house at Moulin à Rêves. 3 bedrooms, sleeps 6, with thick walls, a working fireplace, and the millstream at your door.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src="/images/homes/le-moulin-hero.jpg" alt="Le Moulin — stone mill house with blue shutters beside the millstream" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title">Le Moulin</h1>
      <p class="hero__tagline">The heart of the compound. Where the millstream meets your morning.</p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 48px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">3</div>
          <div class="stats-bar__label">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">2</div>
          <div class="stats-bar__label">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">6</div>
          <div class="stats-bar__label">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">150</div>
          <div class="stats-bar__label">m&sup2;</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Narrative Description -->
  <section class="section">
    <div class="container--narrow fade-in">
      <h2>The Original Mill</h2>
      <div style="margin-top: 32px;">
        <p>
          You'll wake to the sound of water. Not the rush of a river, but the steady, quiet conversation of the millstream passing just beneath your window. The shutters are blue — the kind of faded, chalky blue that only decades of French sun can produce — and when you push them open in the morning, the garden smells of damp stone and lavender.
        </p>
        <p style="margin-top: 20px;">
          Le Moulin is the oldest of the three houses, the one that gave the compound its name. Its walls are thick — nearly a metre in places — built from the same limestone that lines the forest paths of Fontainebleau. In summer, they keep the rooms cool even when the temperature outside climbs past thirty. In autumn, the fireplace in the living room draws beautifully, and you'll find yourself reading longer than you meant to, a glass of something local in hand.
        </p>
        <p style="margin-top: 20px;">
          The kitchen is where most mornings begin: a farmhouse table that seats eight without crowding, copper pans on the wall, and light that pours in from two sides. If you've ordered breakfast delivery, it arrives in a basket at your door — croissants still warm, butter from the crémerie in Barbizon, jam made from the garden's own figs. If you'd rather cook, the Saturday marché in Milly-la-Forêt is ten minutes away, and you'll come back with more than you planned.
        </p>
        <p style="margin-top: 20px;">
          Evenings belong to the terrace. It sits just above the stream, shaded by a pair of old linden trees, and when the light drops low it turns everything the colour of warm bread. This is where the long dinners happen — the ones where nobody checks the time, where the children fall asleep in their chairs, where someone opens a second bottle and nobody objects.
        </p>
      </div>
    </div>
  </section>

  <!-- Room by Room -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <h2>Room by Room</h2>
      </div>
      <div class="grid grid--3">
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin master bedroom with exposed beams" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Master Bedroom</h3>
            <p class="card__description">King bed beneath original oak beams. Millstream views through the blue shutters. En-suite bathroom with walk-in rain shower and heated stone floor.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin second bedroom overlooking the garden" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Garden Bedroom</h3>
            <p class="card__description">Queen bed facing the walled garden. Antique armoire, reading chair by the window, and morning light that arrives gently.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin third bedroom with twin beds" />
          </div>
          <div class="card__body">
            <h3 class="card__title">The Nook</h3>
            <p class="card__description">Two single beds in the quietest room of the house. Tucked beneath the eaves, perfect for children or light sleepers who want absolute stillness.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin farmhouse kitchen" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Kitchen & Dining</h3>
            <p class="card__description">Farmhouse table for eight, full oven and gas hob, copper pans, dishwasher, Nespresso machine, and all the essentials for cooking with market ingredients.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin living room with fireplace" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Living Room</h3>
            <p class="card__description">Working stone fireplace, deep sofas, bookshelves stocked for rainy afternoons. Doors open onto the millstream terrace.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/bridge-garden.webp" alt="Le Moulin terrace above the millstream" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Millstream Terrace</h3>
            <p class="card__description">Stone terrace shaded by linden trees, directly above the stream. Table for eight, lounge chairs, and the sound of water all evening.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Amenities -->
  <section class="section">
    <div class="container fade-in">
      <div class="text-center" style="margin-bottom: 48px;">
        <h2>Amenities</h2>
      </div>
      <div class="amenities">
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
          <span>150 m&sup2; living space</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
          <span>Sleeps 6</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line></svg>
          <span>High-speed WiFi</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"></path></svg>
          <span>Working fireplace</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path></svg>
          <span>Nespresso machine</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"></rect></svg>
          <span>Dishwasher</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v18"></path><path d="M5 8l7-5 7 5"></path></svg>
          <span>Washer & dryer</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
          <span>Heated bathroom floors</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
          <span>Private terrace</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" y1="22" x2="4" y2="15"></line></svg>
          <span>French linens</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18v18H3z"></path></svg>
          <span>Private parking</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path></svg>
          <span>Garden access</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
          <span>Indoor pool & hot tub</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"></path><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path></svg>
          <span>Gym with stone walls</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line></svg>
          <span>Screening room</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
          <span>Covered barn with ping pong & fireplace</span>
        </div>
        <div class="amenity">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"></path><path d="M12 5l7 7-7 7"></path></svg>
          <span>Gazebo dining area</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Location -->
  <section class="section section--stone">
    <div class="container--narrow fade-in text-center">
      <h2>Your Neighbours</h2>
      <p style="margin-top: 24px;">
        Le Moulin sits at the edge of Fontainebleau Forest in the Seine-et-Marne department, just south of Paris. The painters' village of Barbizon is a ten-minute drive, with its galleries, boulangeries, and the kind of light that made Millet and Rousseau stay forever. Fontainebleau itself — the town and its grand chateau — is twenty minutes away. Paris is an hour by car or train from Fontainebleau-Avon station. You'll feel a world away, but you're not.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container fade-in">
      <h2>Interested in Le Moulin?</h2>
      <p style="margin-top: 16px; margin-bottom: 32px;">
        Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.
      </p>
      <a href="/contact/" class="btn btn--primary">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 48px;">
        <h2>The Other Homes</h2>
      </div>
      <div class="grid grid--2">
        <a href="/homes/la-grange/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="La Grange exterior" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Grange</h3>
            <p class="card__description">A converted stone barn with soaring ceilings, an open kitchen, and doors that open straight onto the garden.</p>
            <span class="link-arrow" style="margin-top: 12px;">Discover La Grange</span>
          </div>
        </a>
        <a href="/homes/le-jardin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="Le Jardin exterior" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Jardin</h3>
            <p class="card__description">The quietest of the three. A garden cottage wrapped in wisteria, with a terrace made for long afternoons.</p>
            <span class="link-arrow" style="margin-top: 12px;">Discover Le Jardin</span>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow">Rent All Three Houses</a>
      </div>
    </div>
  </section>

</BaseLayout>
