---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/le-moulin.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = cms.gallery ?? [];

const bedrooms = [
  {
    id: 'riviere',
    title: 'La Chambre de la Rivière',
    summary: 'The River Room — two twin beds on the ground floor.',
    longDescription: 'A quiet ground-floor bedroom that opens onto the millhouse hall. The river runs just beyond the wall.',
    details: [
      { label: 'Bed', value: '2 twin' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'Hall, shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-river-room.webp', alt: 'La Chambre de la Rivière — twin beds with stone walls and lantern light' },
      { src: '/images/homes/le-moulin-river-room-entrance.webp', alt: 'Entrance to La Chambre de la Rivière' },
      { src: '/images/homes/le-moulin-river-room-bath.webp', alt: 'River Room bathroom' },
    ],
  },
  {
    id: 'romantique',
    title: 'La Suite Romantique',
    summary: 'Upstairs master with king bed, en-suite shower.',
    longDescription: 'The largest bedroom in the house. Tall windows, exposed beams, and a king bed.',
    details: [
      { label: 'Bed', value: 'King' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'En-suite, shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-suite-romantique.webp', alt: 'La Suite Romantique — master bedroom with beamed ceiling and fireplace' },
      { src: '/images/homes/le-moulin-suite-romantique-2.webp', alt: 'La Suite Romantique — alternate view from the bed toward the windows' },
      { src: '/images/homes/le-moulin-suite-romantique-master-bath.webp', alt: 'La Suite Romantique master bathroom' },
      { src: '/images/homes/le-moulin-suite-romantique-bath.webp', alt: 'La Suite Romantique bathroom with painting' },
    ],
  },
  {
    id: 'cerises',
    title: 'Les Cerises',
    summary: 'The Cherry Room — queen bed, in-room sink and bidet.',
    details: [
      { label: 'Bed', value: 'Queen' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall clawfoot tub (shared with Les Roses)' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-cerises.webp', alt: 'Les Cerises — the Cherry Room with portraits and patterned bedspread' },
      { src: '/images/homes/le-moulin-cerises-bath.webp', alt: 'Les Cerises master bathroom with sink and bidet' },
      { src: '/images/homes/le-moulin-cerises-sink.webp', alt: 'Les Cerises bathroom sink and vanity' },
      { src: '/images/homes/le-moulin-cerises-rose-bath.webp', alt: 'Shared clawfoot bathroom serving Les Cerises and Les Roses' },
    ],
  },
  {
    id: 'roses',
    title: 'Les Roses',
    summary: 'The Rose Room — two twin beds.',
    details: [
      { label: 'Bed', value: '2 twin' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall clawfoot tub (shared with Les Cerises)' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-roses.webp', alt: 'Les Roses — the Rose Room with twin beds and rose-print wallpaper' },
      { src: '/images/homes/le-moulin-cerises-rose-bath.webp', alt: 'Shared clawfoot bathroom serving Les Roses and Les Cerises' },
    ],
  },
  {
    id: 'loft',
    title: 'Le Loft Suite',
    summary: 'Attic suite with two twins (combinable as king) plus a separate TV area.',
    longDescription: 'A whole-floor retreat. Up a steep flight of stairs.',
    details: [
      { label: 'Bed', value: '2 twin (or king) + 2 floor twins' },
      { label: 'Floor', value: 'Attic' },
      { label: 'Bathroom', value: 'Hall, shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-loft.webp', alt: 'Le Loft Suite — master bedroom under cathedral ceilings with floral wallpaper' },
      { src: '/images/homes/le-moulin-loft-2-twins.webp', alt: 'Le Loft second bedroom with twin beds, exposed beams, and figurine shelves' },
      { src: '/images/homes/le-moulin-loft-2-twins-2.webp', alt: 'Le Loft second bedroom with twin beds, alternate angle' },
      { src: '/images/homes/le-moulin-loft-bath.webp', alt: 'Le Loft bathroom with shower and sink' },
      { src: '/images/homes/le-moulin-loft-bath-2.webp', alt: 'Le Loft bathroom, alternate view' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'salon',
    title: 'Le Salon',
    summary: 'Living room with leather couch, club chairs, and views of the river and bridge.',
    photos: [
      { src: '/images/homes/le-moulin-living.webp', alt: 'Le Salon — leather club chairs, exposed beams, and the antique mill wheel' },
      { src: '/images/homes/le-moulin-living-couch.webp', alt: 'Le Salon facing the floral couch and stone walls' },
      { src: '/images/homes/le-moulin-living-detail.webp', alt: 'Detail of the antique mill wheel with backgammon on the table' },
    ],
  },
  {
    id: 'dining',
    title: 'Dining Room',
    summary: 'Formal dining for up to twelve.',
    photos: [
      { src: '/images/homes/le-moulin-dining.webp', alt: 'Formal dining room set for a meal with the fireplace and copper pots' },
      { src: '/images/homes/le-moulin-dining-2.webp', alt: 'Dining room from an alternate angle showing the fireplace' },
    ],
  },
  {
    id: 'kitchen',
    title: 'Kitchen',
    summary: 'Eat-in kitchen for six. Two Viking-style ovens, six gas burners.',
    details: [
      { label: 'Seats', value: '6' },
      { label: 'Ovens', value: '2 Viking-style' },
      { label: 'Burners', value: '6 gas' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-kitchen.webp', alt: 'Kitchen with cast-iron stove, beamed ceiling, and country paintings' },
      { src: '/images/homes/le-moulin-kitchen-table.webp', alt: 'Kitchen table set with fruit bowls under a beamed ceiling' },
    ],
  },
  {
    id: 'office',
    title: 'Office',
    summary: 'Separate office with desk and printer.',
    photos: [
      { src: '/images/homes/le-moulin-office.webp', alt: 'Floral-papered home office with vintage wooden desk and wicker chair' },
    ],
  },
  {
    id: 'courtyard',
    title: 'Courtyard & Patio',
    summary: 'Cobblestone courtyard, back patio, and the front gate of the millhouse.',
    photos: [
      { src: '/images/homes/le-moulin-courtyard.webp', alt: 'Cobblestone courtyard welcoming guests to the compound' },
      { src: '/images/homes/le-moulin-back-patio.webp', alt: 'Back patio with cafe seating outside the stone facade' },
      { src: '/images/homes/le-moulin-flower-cart.webp', alt: 'Stone facade with the antique flower cart in the courtyard' },
      { src: '/images/homes/le-moulin-gate.webp', alt: 'Front gate at Le Moulin with vintage bicycle and baguette' },
      { src: '/images/homes/le-moulin-marie-antoinette.webp', alt: 'Marie Antoinette themed breakfast in the garden with the Giverny bridge' },
      { src: '/images/homes/le-moulin-marie-antoinette-patio.webp', alt: 'Marie Antoinette themed breakfast with croissants on the patio' },
    ],
  },
];

const amenityFeatures = [
  {
    title: 'Gardens & the Bridge',
    summary: 'Flower gardens and a Giverny-style bridge across the millstream — the photo-spot of the property.',
    image: '/images/bridge-garden.webp',
    alt: 'The Giverny-style bridge across the millstream',
  },
  {
    title: 'Al Fresco Patio',
    summary: 'A wide patio for outdoor dining and lounge chairs, opening directly onto the gardens and the river.',
    image: '/images/gazebo-dining.webp',
    alt: 'Patio dining at the compound',
  },
  {
    title: 'The River at Dusk',
    summary: 'The Juine flows through the house itself. Stay up for the moment the bridge lights and the water turns gold.',
    image: '/images/evening-compound.webp',
    alt: 'Le Moulin at golden hour',
  },
];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: '2 Viking-style ovens', icon: 'oven' },
  { label: 'Nespresso & kettle', icon: 'coffee' },
  { label: 'Full fridge + freezer', icon: 'fridge' },
  { label: 'Office with desk + printer', icon: 'office' },
  { label: 'Garden & wishing well', icon: 'garden' },
  { label: 'River frontage', icon: 'river' },
  { label: 'Patio dining', icon: 'patio' },
  { label: 'Sleeps 10 across 8 beds', icon: 'guests' },
];
---

<BaseLayout title="Le Moulin à Rêves — Historic Mill Rental in Méréville, France" description="Historic 1800s mill house in Méréville, France. Sleeps 10 across 5 bedrooms and 4 baths. The Juine River flows through the house. One hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/le-moulin/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "16 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true}
      ]
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "Le Moulin à Rêves", "item": "https://www.moulinareves.com/homes/le-moulin/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — historic mill house on the Juine River`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow" data-i18n="le-moulin.hero.eyebrow">{cms.eyebrow}</span>
      <h1 class="hero__title" data-i18n="le-moulin.hero.title">{cms.title}</h1>
      <p class="hero__tagline" data-i18n="le-moulin.hero.tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 32px; padding-bottom: 24px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.bathrooms">Baths</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.beds">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Narrative Description -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="le-moulin.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 24px;">
        <p class="prose-lead" data-i18n="le-moulin.narrative.summary">
          {cms.summary}
        </p>
        <p style="margin-top: 16px;" data-i18n="le-moulin.narrative.p1">
          Built in 1800. The Juine River flows through the house. Wake up to the roosters; cross the Giverny-style bridge to the gardens.
        </p>
      </div>
    </div>
  </section>

  <!-- Rooms (bedrooms) -->
  <RoomShowcase
    eyebrow=""
    heading={`Where you'll <span class="serif-italic">sleep</span>`}
    intro="5 bedrooms on 3 floors."
    rooms={bedrooms}
    background="stone"
    i18nKey="le-moulin.bedrooms"
  />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow=""
    heading={`Where you'll <span class="serif-italic">gather</span>`}
    intro="Salon, dining, kitchen, and office."
    rooms={livingSpaces}
    i18nKey="le-moulin.living"
  />

  <!-- Amenities -->
  <AmenitiesSection
    eyebrow=""
    heading={`What's <span class="serif-italic">here</span>`}
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="le-moulin.amenities"
  />

  <!-- Availability -->
  <AvailabilityCalendar
    monthsToShow={12}
    eyebrow=""
    heading={`When You Can <span class="serif-italic">Stay</span>`}
    intro="Live calendar synced from Airbnb and VRBO. Greyed dates are booked."
    i18nKey="le-moulin.availability"
  />

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="le-moulin.cta.heading">Interested in {cms.title}?</h2>
      <p class="hero__tagline" data-i18n="le-moulin.cta.text">Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="le-moulin.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 24px;">
        <h2 data-i18n-html="le-moulin.cross.heading">Les <span class="serif-italic">Autres Maisons</span></h2>
      </div>
      <div class="grid grid--2" style="gap: 20px; max-width: 880px; margin: 0 auto;">
        <a href="/homes/hollywood-hideaway/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <h3 class="card__title" data-i18n="le-moulin.cross.hideaway.title">The Hollywood Hideaway</h3>
            <div class="card__meta">
              <span data-i18n="le-moulin.cross.hideaway.beds">3 Bedrooms + Suite</span>
              <span data-i18n="le-moulin.cross.hideaway.sleeps">Sleeps 7</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <h3 class="card__title" data-i18n="le-moulin.cross.riviere.title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span data-i18n="le-moulin.cross.riviere.beds">2 Bedrooms</span>
              <span data-i18n="le-moulin.cross.riviere.sleeps">Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 32px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="le-moulin.cross.cta">Rent the Compound</a>
      </div>
    </div>
  </section>

</BaseLayout>
