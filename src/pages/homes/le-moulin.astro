  <!-- Location -->
  <section class="section section--stone">
    <div class="container--narrow fade-in text-center">
      <h2 data-i18n="moulin.neighbours.heading">Your Neighbours</h2>
      <p data-i18n="moulin.neighbours.text" style="margin-top: 24px;">
        Le Moulin sits at the edge of Fontainebleau Forest in the Seine-et-Marne department, just south of Paris. The painters' village of Barbizon is a ten-minute drive, with its galleries, boulangeries, and the kind of light that made Millet and Rousseau stay forever. Fontainebleau itself — the town and its grand chateau — is twenty minutes away. Paris is an hour by car or train from Fontainebleau-Avon station. You'll feel a world away, but you're not.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container fade-in">
      <h2 data-i18n="moulin.cta.heading">Interested in Le Moulin?</h2>
      <p data-i18n="moulin.cta.text" style="margin-top: 16px; margin-bottom: 32px;">
        Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.
      </p>
      <a href="/contact/" class="btn btn--primary" data-i18n="moulin.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 48px;">
        <h2 data-i18n="moulin.otherhomes.heading">The Other Homes</h2>
      </div>
      <div class="grid grid--2">
        <a href="/homes/la-grange/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="La Grange converted stone barn with tall windows at Moulin à Rêves, Barbizon" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Grange</h3>
            <p class="card__description" data-i18n="moulin.cross.grange.desc">A converted stone barn with soaring ceilings, an open kitchen, and doors that open straight onto the garden.</p>
            <span class="link-arrow" data-i18n="moulin.cross.grange.link" style="margin-top: 12px;">Discover La Grange</span>
          </div>
        </a>
        <a href="/homes/le-jardin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="Le Jardin garden cottage wrapped in wisteria at Moulin à Rêves, Barbizon" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Jardin</h3>
            <p class="card__description" data-i18n="moulin.cross.jardin.desc">The quietest of the three. A garden cottage wrapped in wisteria, with a terrace made for long afternoons.</p>
            <span class="link-arrow" data-i18n="moulin.cross.jardin.link" style="margin-top: 12px;">Discover Le Jardin</span>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="moulin.rentall">Rent All Three Houses</a>
      </div>
    </div>
  </section>

</BaseLayout>
