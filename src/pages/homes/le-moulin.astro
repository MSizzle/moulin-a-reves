---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/le-moulin.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = [
  { src: '/images/homes/le-moulin-hero.webp', alt: 'Le Moulin à Rêves — exterior with the Juine River' },
  { src: '/images/homes/le-moulin-living.webp', alt: 'Le Salon — leather couch and club chairs with river view' },
  { src: '/images/homes/le-moulin-dining.webp', alt: 'Formal dining room set for twelve' },
  { src: '/images/homes/le-moulin-kitchen.webp', alt: 'Eat-in kitchen with French armoire and Viking ovens' },
  { src: '/images/homes/le-moulin-suite-romantique.webp', alt: 'La Suite Romantique — master bedroom with exposed beams' },
  { src: '/images/homes/le-moulin-river-room.webp', alt: 'La Chambre de la Rivière' },
  { src: '/images/homes/le-moulin-loft.webp', alt: 'Le Loft Suite — second-floor attic' },
];

const bedrooms = [
  {
    id: 'riviere',
    eyebrow: 'Bedroom · Ground Floor',
    title: 'La Chambre de la Rivière',
    summary: 'The River Room. Two twin beds on the ground floor, with a hall bathroom and shower just outside the door.',
    longDescription: 'A quiet ground-floor bedroom that opens onto the millhouse hall. The river runs just beyond the wall, so this is the room where the water is loudest at night — a steady, soothing rush that most guests come to miss when they leave.',
    details: [
      { label: 'Beds', value: '2 twin' },
      { label: 'Floor', value: 'Ground' },
      { label: 'Bathroom', value: 'Hall · shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-river-room.webp', alt: 'La Chambre de la Rivière — twin beds and antique wardrobe' },
    ],
  },
  {
    id: 'romantique',
    eyebrow: 'Bedroom · Upstairs',
    title: 'La Suite Romantique',
    summary: 'King bed in the upstairs master, beneath original exposed beams. En-suite bathroom with shower.',
    longDescription: 'The largest bedroom in the house. Tall windows, exposed beams, and a king bed dressed in white linen. Step into the en-suite bathroom for a hot shower after a long Paris day.',
    details: [
      { label: 'Bed', value: 'King' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'En-suite · shower' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-suite-romantique.webp', alt: 'La Suite Romantique — master bedroom' },
    ],
  },
  {
    id: 'cerises',
    eyebrow: 'Bedroom · Upstairs',
    title: 'Les Cerises',
    summary: 'The Cherry Room. Queen bed with a sink and bidet in the room. Shares the clawfoot-tub hall bath with Les Roses.',
    details: [
      { label: 'Bed', value: 'Queen' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'In-room', value: 'Sink, bidet' },
      { label: 'Bathroom', value: 'Hall · clawfoot tub (shared with Les Roses)' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-cerises.webp', alt: 'Les Cerises — the Cherry Room' },
    ],
  },
  {
    id: 'roses',
    eyebrow: 'Bedroom · Upstairs',
    title: 'Les Roses',
    summary: 'The Rose Room. Two twin beds. Shares the clawfoot-tub hall bath with Les Cerises.',
    details: [
      { label: 'Beds', value: '2 twin' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall · clawfoot tub (shared with Les Cerises)' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-roses.webp', alt: 'Les Roses — the Rose Room' },
    ],
  },
  {
    id: 'loft',
    eyebrow: 'Suite · Attic',
    title: 'Le Loft Suite',
    summary: 'Second-floor attic with two twins (combinable as a king) plus a separate TV room with two floor twins. Shared hall bath with shower.',
    longDescription: 'A whole-floor retreat for the kids, the cousins, or anyone who wants their own private wing. Note: the loft is up a steep flight of stairs — best for guests comfortable with a climb.',
    details: [
      { label: 'Beds', value: '2 twin (or king) + 2 floor twins' },
      { label: 'Floor', value: 'Second-floor attic' },
      { label: 'Bathroom', value: 'Hall · shower' },
      { label: 'Note', value: 'Steep stairs' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-loft.webp', alt: 'Le Loft Suite' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'salon',
    eyebrow: 'Living',
    title: 'Le Salon',
    summary: 'Large living room with leather couch, club chairs, and antiques. The river and bridge are illuminated at night.',
    longDescription: 'The heart of the house in the evenings. Light a fire (decorative), pour something French, and watch the bridge glow over the millstream through the tall windows.',
    photos: [
      { src: '/images/homes/le-moulin-living.webp', alt: 'Le Salon at Le Moulin à Rêves' },
    ],
  },
  {
    id: 'dining',
    eyebrow: 'Dining',
    title: 'The Dining Room',
    summary: 'Formal dining room for up to twelve, with art, antiques, a chandelier, and a long candlelit table.',
    photos: [
      { src: '/images/homes/le-moulin-dining.webp', alt: 'Formal dining room at Le Moulin à Rêves' },
    ],
  },
  {
    id: 'kitchen',
    eyebrow: 'Kitchen',
    title: 'The Kitchen',
    summary: 'Eat-in kitchen for six. Two Viking-style ovens, six gas burners, full fridge and freezer, Nespresso, kettle.',
    longDescription: 'A working cook\'s kitchen with light pouring in through the tall windows. Built around a French armoire and a long farmhouse table — equally good for a leisurely breakfast or a serious dinner prep.',
    details: [
      { label: 'Seats', value: '6 at the table' },
      { label: 'Ovens', value: '2 Viking-style' },
      { label: 'Burners', value: '6 gas' },
      { label: 'Coffee', value: 'Nespresso' },
    ],
    photos: [
      { src: '/images/homes/le-moulin-kitchen.webp', alt: 'Kitchen at Le Moulin à Rêves' },
    ],
  },
];

const amenityFeatures = [
  {
    title: 'Gardens & the Bridge',
    summary: 'Flower gardens and a Giverny-style bridge across the millstream — the photo-spot of the property.',
    image: '/images/bridge-garden.webp',
    alt: 'The Giverny-style bridge across the millstream',
  },
  {
    title: 'Al Fresco Patio',
    summary: 'A wide patio for outdoor dining and lounge chairs, opening directly onto the gardens and the river.',
    image: '/images/gazebo-dining.webp',
    alt: 'Patio dining at the compound',
  },
  {
    title: 'The River at Dusk',
    summary: 'The Juine flows through the house itself. Stay up for the moment the bridge lights and the water turns gold.',
    image: '/images/evening-compound.webp',
    alt: 'Le Moulin at golden hour',
  },
];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: '2 Viking-style ovens', icon: 'oven' },
  { label: 'Nespresso & kettle', icon: 'coffee' },
  { label: 'Full fridge + freezer', icon: 'fridge' },
  { label: 'Office with desk + printer', icon: 'office' },
  { label: 'Garden & wishing well', icon: 'garden' },
  { label: 'River frontage', icon: 'river' },
  { label: 'Patio dining', icon: 'patio' },
  { label: 'Sleeps 12 across 8 beds', icon: 'guests' },
];
---

<BaseLayout title="Le Moulin à Rêves — Historic Mill Vacation Rental, Mereville France" description="Historic 1800s mill house in Mereville, France. Sleeps 12 across 5 bedrooms and 4 baths. The Juine River flows through the house. One hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/le-moulin/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mereville",
        "addressRegion": "Essonne",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true}
      ]
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "Le Moulin à Rêves", "item": "https://www.moulinareves.com/homes/le-moulin/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — historic mill house on the Juine River`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow" data-i18n="le-moulin.hero.eyebrow">{cms.eyebrow}</span>
      <h1 class="hero__title" data-i18n="le-moulin.hero.title">{cms.title}</h1>
      <p class="hero__tagline" data-i18n="le-moulin.hero.tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 32px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.bathrooms">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label" data-i18n="le-moulin.stats.beds">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Narrative Description -->
  <section class="section section--tight">
    <div class="container--narrow fade-in">
      <span class="eyebrow" data-i18n="le-moulin.narrative.eyebrow">The Maison</span>
      <h2 data-i18n="le-moulin.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 32px;">
        <p class="prose-lead" data-i18n="le-moulin.narrative.summary">
          {cms.summary}
        </p>
        <p style="margin-top: 20px;" data-i18n="le-moulin.narrative.p1">
          Relax in the gardens and watch as the day goes by. Let your worries float away on the Juine River. Wake up to the roosters crowing in the chicken coop. Go back in time as you gaze at the flower gardens and Giverny-style bridge. Make a wish in the wishing well!
        </p>
        <p style="margin-top: 20px;" data-i18n="le-moulin.narrative.p2">
          Dine al fresco with friends, colleagues, family or students. This is a wonderful compound for inspiration, fun, reflection and quiet time together.
        </p>
      </div>
    </div>
  </section>

  <!-- Rooms (bedrooms) -->
  <RoomShowcase
    eyebrow="Rooms"
    heading={`Where you'll <span class="serif-italic">sleep</span>`}
    intro="Five bedrooms across three floors. Tap any room for details and photos."
    rooms={bedrooms}
    background="stone"
    i18nKey="le-moulin.bedrooms"
  />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow="Living Spaces"
    heading={`Where you'll <span class="serif-italic">gather</span>`}
    intro="Salon, dining, and kitchen — the rooms made for long evenings together."
    rooms={livingSpaces}
    i18nKey="le-moulin.living"
  />

  <!-- Amenities -->
  <AmenitiesSection
    eyebrow="Amenities & Grounds"
    heading={`What's <span class="serif-italic">here</span>`}
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="le-moulin.amenities"
  />

  <!-- Availability -->
  <AvailabilityCalendar
    eyebrow="Availability"
    heading={`When You Can <span class="serif-italic">Stay</span>`}
    intro="Live calendar synced from our Airbnb and VRBO listings — covers the whole compound. Greyed dates are already booked. Found a window? Tell us your dates and we'll confirm."
    i18nKey="le-moulin.availability"
  />

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="le-moulin.cta.heading">Interested in {cms.title}?</h2>
      <p class="hero__tagline" data-i18n="le-moulin.cta.text">Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="le-moulin.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="le-moulin.cross.heading">Les <span class="serif-italic">Autres Maisons</span></h2>
      </div>
      <div class="grid grid--2" style="gap: 24px;">
        <a href="/homes/hollywood-hideaway/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="The Hollywood Hideaway at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow" data-i18n="le-moulin.cross.hideaway.eyebrow">Maison Two</span>
            <h3 class="card__title" data-i18n="le-moulin.cross.hideaway.title">The Hollywood Hideaway</h3>
            <div class="card__meta">
              <span data-i18n="le-moulin.cross.hideaway.beds">3 Bedrooms + Suite</span>
              <span data-i18n="le-moulin.cross.hideaway.sleeps">Sleeps 8</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow" data-i18n="le-moulin.cross.riviere.eyebrow">Maison Three</span>
            <h3 class="card__title" data-i18n="le-moulin.cross.riviere.title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span data-i18n="le-moulin.cross.riviere.beds">2 Bedrooms</span>
              <span data-i18n="le-moulin.cross.riviere.sleeps">Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="le-moulin.cross.cta">Rent All Three Maisons</a>
      </div>
    </div>
  </section>

</BaseLayout>
