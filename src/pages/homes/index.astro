---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Les Maisons — Three Vacation Rentals in Méréville, France" description="Three maisons in a private historic compound in Méréville, France. Le Moulin à Rêves, The Hollywood Hideaway, and La Maison de la Rivière.">

  <section class="hero" style="height: 56vh;">
    <div class="hero__image">
      <img src="/images/homes/all-three.webp" alt="The compound at Moulin à Rêves in Méréville, France" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n-html="homes.hero.title">Les <span class="serif-italic">Maisons</span></h1>
      <p class="hero__tagline" data-i18n="homes.hero.tagline">Three maisons. Sleeps 20 across 10 bedrooms.</p>
    </div>
  </section>

  <section class="section--tighter">
    <div class="container">
      <div class="grid grid--3" style="gap: 20px;">
        <a href="/homes/le-moulin/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves — historic mill house on the Juine River" loading="lazy" />
          </div>
          <div class="card__overlay">
            <h3 class="card__title" data-i18n="homes.card.moulin.title">Le Moulin à Rêves</h3>
            <div class="card__meta">
              <span data-i18n="homes.card.moulin.beds">5 Bedrooms</span>
              <span data-i18n="homes.card.moulin.baths">4 Baths</span>
              <span data-i18n="homes.card.moulin.sleeps">Sleeps 10</span>
            </div>
          </div>
        </a>
        <a href="/homes/hollywood-hideaway/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <h3 class="card__title" data-i18n="homes.card.hideaway.title">The Hollywood Hideaway</h3>
            <div class="card__meta">
              <span data-i18n="homes.card.hideaway.beds">3 Bedrooms + Suite</span>
              <span data-i18n="homes.card.hideaway.baths">2 Baths</span>
              <span data-i18n="homes.card.hideaway.sleeps">Sleeps 7</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <h3 class="card__title" data-i18n="homes.card.riviere.title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span data-i18n="homes.card.riviere.beds">2 Bedrooms</span>
              <span data-i18n="homes.card.riviere.baths">1 Bath</span>
              <span data-i18n="homes.card.riviere.sleeps">Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="section--tighter section--soft text-center">
    <div class="container fade-in">
      <h2 data-i18n="homes.rentall.heading">Rent the Compound</h2>
      <p style="margin-top: 16px; margin-bottom: 28px;" data-i18n="homes.rentall.text">
        Book all three houses for up to 20 guests. Family reunions, retreats, celebrations.
      </p>
      <a href="/the-compound/" class="btn btn--primary" data-i18n="homes.rentall.cta">Explore the Compound</a>
    </div>
  </section>

  <style>
    .section--tighter { padding-top: 56px; padding-bottom: 56px; }
  </style>

</BaseLayout>
