---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Img from '../../components/Img.astro';
---

<BaseLayout title="Les Maisons — Three Vacation Rentals in Méréville, France" description="Three maisons in a private historic compound in Méréville, France. Le Moulin, The Hollywood Hideaway, and La Maison de la Rivière.">

  <!-- Hero — lead Garden photo with the two lounge chairs (June 16 client note) -->
  <section class="hero" style="height: 60vh;">
    <div class="hero__image">
      <Img src="/images/garden-chaises-dream-view.webp" alt="Wicker chaise lounges with blue cushions on the sunlit garden lawn beneath a weeping willow at Moulin à Rêves" sizes="100vw" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="homes.hero.title">Your Private French Country Estate</h1>
    </div>
  </section>

  <!-- Subheader (June 16 client note: header text styled like "Discover Méréville") -->
  <section class="section--tighter text-center">
    <div class="container--narrow fade-in">
      <h2 class="homes-subhead" data-i18n="homes.hero.tagline">Stay in one home or enjoy all three.</h2>
    </div>
  </section>

  <section class="section--tighter">
    <div class="maisons-stack">
      <a href="/homes/le-moulin/" class="split split--maison fade-in">
        <div class="split__image">
          <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin — historic mill house on the Juine River" loading="lazy" />
        </div>
        <div class="split__body">
          <h2 data-i18n="homes.card.moulin.title">Le Moulin</h2>
          <div class="split__meta">
            <span data-i18n="homes.card.moulin.beds">5 Bedrooms</span>
            <span data-i18n="homes.card.moulin.baths">4 Baths</span>
            <span data-i18n="homes.card.moulin.sleeps">Sleeps 10</span>
          </div>
          <p>The original mill and principal residence of the estate.</p>
          <span class="link-arrow">Discover Le Moulin</span>
        </div>
      </a>
      <a href="/homes/hollywood-hideaway/" class="split split--maison split--reverse fade-in">
        <div class="split__image">
          <img src="/images/homes/hh-patio.webp" alt="The Hollywood Hideaway — breakfast table on the patio facing the blue-shuttered facade" loading="lazy" />
        </div>
        <div class="split__body">
          <h2 data-i18n="homes.card.hideaway.title">The Hollywood Hideaway</h2>
          <div class="split__meta">
            <span data-i18n="homes.card.hideaway.beds">4 Bedrooms</span>
            <span data-i18n="homes.card.hideaway.baths">2 Baths</span>
            <span data-i18n="homes.card.hideaway.sleeps">Sleeps 6</span>
          </div>
          <p>The secluded retreat once enjoyed by French and American stars.</p>
          <span class="link-arrow">Discover the Hideaway</span>
        </div>
      </a>
      <a href="/homes/maison-de-la-riviere/" class="split split--maison fade-in">
        <div class="split__image">
          <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="split__body">
          <h2 data-i18n="homes.card.riviere.title">La Maison de la Rivière</h2>
          <div class="split__meta">
            <span data-i18n="homes.card.riviere.beds">2 Bedrooms</span>
            <span data-i18n="homes.card.riviere.baths">1 Bath</span>
            <span data-i18n="homes.card.riviere.sleeps">Sleeps 4</span>
          </div>
          <p>The sun-drenched cottage where your cares float away.</p>
          <span class="link-arrow">Discover La Maison</span>
        </div>
      </a>
    </div>
  </section>

  <section class="section--tighter section--soft text-center">
    <div class="container fade-in">
      <a href="/the-compound/" class="btn btn--green" data-i18n="homes.rentall.cta">Join us.</a>
    </div>
  </section>

  <style>
    .section--tighter { padding-top: 56px; padding-bottom: 56px; }

    /* June 16 client note: full-bleed Garden hero (the two lounge chairs).
       Crop raised toward the bottom (not all the way) so more lawn shows and
       the chairs sit at the bottom of the frame, above the foreground bed. */
    .hero .hero__image img { object-position: center 85%; }

    /* June 16 client note: keep the subheader on one line. Fluid size capped
       so it fills the narrow container on desktop without wrapping, and shrinks
       with the viewport on mobile so nowrap never overflows. */
    .homes-subhead {
      white-space: nowrap;
      font-size: min(2.25rem, calc((100vw - 56px) / 19));
    }
  </style>

</BaseLayout>
