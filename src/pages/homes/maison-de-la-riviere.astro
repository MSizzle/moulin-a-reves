---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/maison-de-la-riviere.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = cms.gallery ?? [];

const bedrooms = [
  {
    id: 'artistes',
    title: 'La Chambre des Artistes',
    summary: 'The Artists\' Room — upstairs. King bed plus a twin.',
    qualities: 'King + twin beds · Hall tub & shower · Upstairs',
    details: [
      { label: 'Bed', value: 'King + Twin' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall, tub + shower (shared)' },
    ],
    photos: [
      { src: '/images/homes/maison-artistes.webp', alt: 'La Chambre des Artistes — attic bedroom with cathedral ceiling and antique drawings' },
      { src: '/images/homes/maison-artistes-couch.webp', alt: 'La Chambre des Artistes facing the couch, alternate angle' },
      { src: '/images/homes/maison-bath.webp', alt: 'Shared upstairs bathroom at Maison de la Rivière' },
    ],
  },
  {
    id: 'ecrivains',
    title: 'La Chambre des Écrivains',
    summary: 'The Writers\' Room — upstairs. Double bed, in-room sink.',
    qualities: 'Double bed · In-room sink · Hall tub & shower · Upstairs',
    details: [
      { label: 'Bed', value: 'Double' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall, tub + shower (shared)' },
    ],
    photos: [
      { src: '/images/homes/maison-ecrivains.webp', alt: 'La Chambre des Écrivains with toile-print wallpaper and corner sink' },
      { src: '/images/homes/maison-ecrivains-2.webp', alt: 'La Chambre des Écrivains with the door to the balcony, alternate view' },
      { src: '/images/homes/maison-bath.webp', alt: 'Shared upstairs bathroom at Maison de la Rivière' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'living',
    title: 'Living Room',
    summary: 'Sun-drenched with two couches, French doors to the stream and apple trees.',
    photos: [
      { src: '/images/homes/maison-living-fire.webp', alt: 'Living room with stone fireplace, exposed beams, and floral couches' },
      { src: '/images/homes/maison-living.webp', alt: 'Sun-drenched living room with French doors' },
      { src: '/images/homes/maison-living-into-dining.webp', alt: 'View from the living room into the dining room' },
    ],
  },
  {
    id: 'dining',
    title: 'Dining Room',
    summary: 'Elegant dining room — table seats up to eighteen.',
    photos: [
      { src: '/images/homes/maison-dinner-light.webp', alt: 'Long dining table set with plates, glasses, and bread under warm chandelier light' },
      { src: '/images/homes/maison-dining.webp', alt: 'Dining room board table under the large landscape painting' },
      { src: '/images/homes/maison-dining-into-living.webp', alt: 'View from the dining room through to the living room with bookshelves and floral couch' },
      { src: '/images/homes/maison-board-room.webp', alt: 'Long wooden board-room dining table for retreat-style gatherings' },
    ],
  },
  {
    id: 'kitchen',
    title: 'Kitchen',
    summary: 'Eat-in kitchen with stone walls and exposed beams.',
    photos: [
      { src: '/images/homes/maison-kitchen.webp', alt: 'Kitchen with wood cabinetry and bread on the stovetop' },
      { src: '/images/homes/maison-eat-in-kitchen.webp', alt: 'Eat-in kitchen with wooden staircase and dining nook' },
    ],
  },
];

// Explore the Estate — 4-square section (house pages only; homepage keeps its 6 tiles)
const amenityFeatures = [
  {
    title: 'The Gardens',
    summary: 'The Giverny-style bridge, walled gardens, millstream, and quiet corners.',
    image: '/images/bridge-garden.webp',
    alt: 'The Giverny-style bridge across the millstream',
    gallery: [
      { src: '/images/bridge-garden.webp', alt: 'Giverny-style painted bridge over the stream beneath willow trees' },
      { src: '/images/garden-giverny-bridge.webp', alt: 'Painted Giverny-style bridge over the millstream in the gardens' },
      { src: '/images/garden-giverny-bridge-2.webp', alt: 'Giverny-style bridge in the gardens, alternate view' },
      { src: '/images/garden-chaises.webp', alt: 'Garden chaise lounges facing the painted bridge' },
      { src: '/images/garden-chaises-wide.webp', alt: 'Wide garden view with chaise lounges and the painted bridge' },
      { src: '/images/garden-chaise-jetson.webp', alt: 'Garden chaise lounges with Jetson the Cavalier in the sun' },
      { src: '/images/garden-private-spot.webp', alt: 'Private wicker bistro table in a wooded corner of the garden' },
      { src: '/images/garden-stone-well.webp', alt: 'Vine-covered antique stone well sheltered in the garden' },
      { src: '/images/garden-steps.webp', alt: 'Stone steps descending through the gardens' },
      { src: '/images/garden-breakfast.webp', alt: 'Breakfast set on the patio outside the stone cottage' },
      { src: '/images/garden-monet-painting.webp', alt: 'Monet-inspired painting set among the gardens at Moulin à Rêves' },
      { src: '/images/compound-river-courtyard.webp', alt: 'Stone footbridge with planter boxes over the small stream' },
      { src: '/images/evening-compound.webp', alt: 'Garden at dusk with feet propped up looking toward the stone cottage' },
      { src: '/images/yoga-lawn.webp', alt: 'Morning yoga on the lawn between the houses' },
    ],
  },
  {
    title: 'The Grange',
    summary: 'Open-air entertaining barn with stone fireplace, ping-pong table, and the long communal table for twenty.',
    image: '/images/homes/la-grange-hero.webp',
    alt: 'La Grange exterior — covered pavilion at the heart of the compound',
    gallery: [
      { src: '/images/homes/la-grange-hero.webp', alt: 'La Grange exterior — covered pavilion at the heart of the compound' },
      { src: '/images/homes/la-grange-pavilion-wide.webp', alt: 'Wide view of La Grange\'s open pavilion with ping-pong and dining table' },
      { src: '/images/homes/la-grange-pavilion.webp', alt: 'La Grange\'s open pavilion with stone fireplace' },
      { src: '/images/grange-fireplace-flame.webp', alt: 'Stone fireplace blazing at La Grange with champagne and celebration setup' },
      { src: '/images/homes/la-grange-fire-2.webp', alt: 'Roaring fire in the stone fireplace at La Grange' },
      { src: '/images/homes/la-grange-party-setup.webp', alt: 'La Grange pavilion set with banquet tables for a party' },
      { src: '/images/homes/la-grange-plates.webp', alt: 'Long banquet table at La Grange set with china plates and stemware' },
      { src: '/images/homes/la-grange-carriage.webp', alt: 'Antique horse carriage on display inside La Grange' },
      { src: '/images/grange-screening-netflix.webp', alt: 'Screening room at La Grange with Netflix on the large screen and leather sofas' },
      { src: '/images/group-dinner.webp', alt: 'Dinner laid on the long table under La Grange\'s pavilion' },
    ],
  },
  {
    title: 'The Spa',
    summary: 'A glassed-in solarium with jacuzzi — warm-weather mornings, winter evenings, year-round.',
    image: '/images/wellness-jacuzzi-2.webp',
    alt: 'The jacuzzi in the solarium at Moulin à Rêves',
    gallery: [
      { src: '/images/wellness-jacuzzi-2.webp', alt: 'The jacuzzi in the solarium at Moulin à Rêves' },
    ],
  },
  {
    title: 'The Chicken Coop & Wishing Well',
    summary: 'Charming corners of the estate — the resident chickens and the vine-covered wishing well.',
    image: '/images/garden-stone-well.webp',
    alt: 'Vine-covered antique stone well sheltered in the garden',
    gallery: [
      { src: '/images/garden-stone-well.webp', alt: 'Vine-covered antique stone well sheltered in the garden' },
      // TODO: add chicken-coop photos here when owner provides them
    ],
  },
];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: 'Oven + microwave', icon: 'oven' },
  { label: 'Nespresso & kettle', icon: 'coffee' },
  { label: 'Full fridge + freezer', icon: 'fridge' },
  { label: 'Dining for up to 18', icon: 'patio' },
  { label: 'Compound gardens', icon: 'garden' },
  { label: 'Stream & orchard view', icon: 'river' },
  { label: 'Sleeps 4 across 3 beds', icon: 'guests' },
];
---

<BaseLayout title="La Maison de la Rivière — Sunny Cottage Near Paris" description="Sunny two-bedroom cottage in Méréville, France — sleeps 4. Overlooks the Juine River and apple trees. Dining for 18, one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/maison-de-la-riviere/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "La Maison de la Rivière", "item": "https://www.moulinareves.com/homes/maison-de-la-riviere/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — sunny cottage overlooking the stream`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="riviere.hero.title">{cms.title}</h1>
    </div>
  </section>

  <!-- Narrative / Story (directly beneath hero) -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="riviere.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 24px;">
        <p class="prose-lead" data-i18n="riviere.narrative.summary">
          Bathed in natural light and overlooking the river, Maison de la Rivière combines the beauty of the French countryside with an atmosphere of creativity and inspiration. Floor-to-ceiling French doors open to the water, while thoughtfully collected artwork and inviting gathering spaces make it a favorite place for conversation. Whether writing, laughing, or simply watching the river flow by, guests are drawn to the elegance and beauty that make Maison de la Rivière so inspiring.
        </p>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow=""
    heading="The Living Spaces"
    intro=""
    rooms={livingSpaces}
    i18nKey="riviere.living"
    hideTileSummary={true}
    gatherMode={true}
  />

  <!-- The Bedrooms -->
  <RoomShowcase
    eyebrow=""
    heading="The Bedrooms"
    intro="2 Bedrooms • 1 Bathroom • 3 Beds • Sleeps 4"
    rooms={bedrooms}
    background="stone"
    i18nKey="riviere.bedrooms"
    hideTileSummary={true}
  />

  <!-- Explore the Estate (4-square lightbox tiles) + Also Included amenity list -->
  <AmenitiesSection
    eyebrow=""
    heading="Explore the Estate"
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="riviere.amenities"
    exploreMode={true}
  />

  <!-- Availability -->
  <AvailabilityCalendar
    monthsToShow={12}
    eyebrow=""
    heading="Join us!"
    intro=""
    i18nKey="riviere.availability"
  />

  <!-- CTA -->
  <section class="hero hero--cta" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="riviere.cta.heading">Interested in {cms.title}?</h2>
      <a href="/contact/" class="btn btn--white" data-i18n="riviere.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 24px;">
        <h2 data-i18n="riviere.cross.heading">Les Autres Maisons</h2>
      </div>
    </div>
    <div class="maisons-stack">
        <a href="/homes/le-moulin/" class="split split--maison fade-in">
          <div class="split__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin" loading="lazy" />
          </div>
          <div class="split__body">
            <h2 data-i18n="riviere.cross.moulin.title">Le Moulin</h2>
            <div class="split__meta">
              <span data-i18n="riviere.cross.moulin.beds">5 Bedrooms</span>
              <span data-i18n="riviere.cross.moulin.sleeps">Sleeps 10</span>
            </div>
            <p>The original mill and principal residence of the estate.</p>
            <span class="link-arrow">Discover Le Moulin</span>
          </div>
        </a>
        <a href="/homes/hollywood-hideaway/" class="split split--maison split--reverse fade-in">
          <div class="split__image">
            <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway" loading="lazy" />
          </div>
          <div class="split__body">
            <h2 data-i18n="riviere.cross.hideaway.title">The Hollywood Hideaway</h2>
            <div class="split__meta">
              <span data-i18n="riviere.cross.hideaway.beds">3 Bedrooms + Suite</span>
              <span data-i18n="riviere.cross.hideaway.sleeps">Sleeps 6</span>
            </div>
            <p>The secluded retreat once enjoyed by French and American stars.</p>
            <span class="link-arrow">Discover the Hideaway</span>
          </div>
        </a>
      </div>
    <div class="container">
      <div class="text-center" style="margin-top: 32px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="riviere.cross.cta">Rent the Compound</a>
      </div>
    </div>
  </section>

</BaseLayout>
