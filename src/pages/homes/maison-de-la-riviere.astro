---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/maison-de-la-riviere.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = cms.gallery ?? [];

const bedrooms = [
  {
    id: 'artistes',
    title: 'La Chambre des Artistes',
    summary: 'The Artists\' Room — upstairs. King bed plus a twin.',
    details: [
      { label: 'Bed', value: 'King + Twin' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall, tub + shower (shared)' },
    ],
    photos: [
      { src: '/images/homes/maison-artistes.webp', alt: 'La Chambre des Artistes — attic bedroom with cathedral ceiling and antique drawings' },
      { src: '/images/homes/maison-artistes-couch.webp', alt: 'La Chambre des Artistes facing the couch, alternate angle' },
      { src: '/images/homes/maison-bath.webp', alt: 'Shared upstairs bathroom at Maison sur la Rivière' },
    ],
  },
  {
    id: 'ecrivains',
    title: 'La Chambre des Écrivains',
    summary: 'The Writers\' Room — upstairs. Double bed, in-room sink.',
    details: [
      { label: 'Bed', value: 'Double' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'Bathroom', value: 'Hall, tub + shower (shared)' },
    ],
    photos: [
      { src: '/images/homes/maison-ecrivains.webp', alt: 'La Chambre des Écrivains with toile-print wallpaper and corner sink' },
      { src: '/images/homes/maison-ecrivains-2.webp', alt: 'La Chambre des Écrivains with the door to the balcony, alternate view' },
      { src: '/images/homes/maison-bath.webp', alt: 'Shared upstairs bathroom at Maison sur la Rivière' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'living',
    title: 'Living Room',
    summary: 'Sun-drenched with two couches, French doors to the stream and apple trees.',
    photos: [
      { src: '/images/homes/maison-living-fire.webp', alt: 'Living room with stone fireplace, exposed beams, and floral couches' },
      { src: '/images/homes/maison-living.webp', alt: 'Sun-drenched living room with French doors' },
      { src: '/images/homes/maison-living-into-dining.webp', alt: 'View from the living room into the dining room' },
    ],
  },
  {
    id: 'dining',
    title: 'Dining Room',
    summary: 'Elegant dining room — table seats up to eighteen.',
    photos: [
      { src: '/images/homes/maison-dinner-light.webp', alt: 'Long dining table set with plates, glasses, and bread under warm chandelier light' },
      { src: '/images/homes/maison-dining.webp', alt: 'Dining room board table under the large landscape painting' },
      { src: '/images/homes/maison-dining-into-living.webp', alt: 'View from the dining room through to the living room with bookshelves and floral couch' },
      { src: '/images/homes/maison-board-room.webp', alt: 'Long wooden board-room dining table for retreat-style gatherings' },
    ],
  },
  {
    id: 'kitchen',
    title: 'Kitchen',
    summary: 'Eat-in kitchen with stone walls and exposed beams.',
    photos: [
      { src: '/images/homes/maison-kitchen.webp', alt: 'Kitchen with wood cabinetry and bread on the stovetop' },
      { src: '/images/homes/maison-eat-in-kitchen.webp', alt: 'Eat-in kitchen with wooden staircase and dining nook' },
    ],
  },
];

const amenityFeatures = [
  {
    title: 'The Stream & Apple Trees',
    summary: 'French doors open from the living room directly onto the stream and the orchard — the main view from every window on this side.',
    image: '/images/homes/le-jardin-hero.webp',
    alt: 'The stream and apple trees behind La Maison de la Rivière',
  },
  {
    title: 'The Compound Gardens',
    summary: 'Shared with the rest of the compound — flower beds, lawns, and a Giverny-style bridge over the millstream.',
    image: '/images/bridge-garden.webp',
    alt: 'Compound gardens and bridge',
  },
  {
    title: 'Al Fresco Dining',
    summary: 'Patio and gazebo space across the compound, with tables for dinner parties under the stars.',
    image: '/images/gazebo-dining.webp',
    alt: 'Compound al fresco dining',
  },
];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: 'Oven + microwave', icon: 'oven' },
  { label: 'Nespresso & kettle', icon: 'coffee' },
  { label: 'Full fridge + freezer', icon: 'fridge' },
  { label: 'Dining for up to 18', icon: 'patio' },
  { label: 'Compound gardens', icon: 'garden' },
  { label: 'Stream & orchard view', icon: 'river' },
  { label: 'Sleeps 5 across 3 beds', icon: 'guests' },
];
---

<BaseLayout title="La Maison de la Rivière — Sunny Cottage Rental Near Paris" description="Sunny two-bedroom cottage rental in Méréville, France — sleeps 5. Overlooks the Juine River and apple trees. Dining for 18, one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/maison-de-la-riviere/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "La Maison de la Rivière", "item": "https://www.moulinareves.com/homes/maison-de-la-riviere/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — sunny cottage overlooking the stream`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="riviere.hero.title">{cms.title}</h1>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 32px; padding-bottom: 24px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.bathrooms">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.beds">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Narrative Description -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="riviere.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 24px;">
        <p class="prose-lead" data-i18n="riviere.narrative.summary">
          {cms.summary}
        </p>
      </div>
    </div>
  </section>

  <!-- Rooms (bedrooms) -->
  <RoomShowcase
    eyebrow=""
    heading="Where you'll sleep"
    intro="2 bedrooms upstairs, sharing a hall bath."
    rooms={bedrooms}
    background="stone"
    i18nKey="riviere.bedrooms"
    hideTileSummary={true}
  />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow=""
    heading="Where you'll gather"
    intro=""
    rooms={livingSpaces}
    i18nKey="riviere.living"
    hideTileSummary={true}
  />

  <!-- Amenities -->
  <AmenitiesSection
    eyebrow=""
    heading="What's here"
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="riviere.amenities"
  />

  <!-- Availability -->
  <AvailabilityCalendar
    monthsToShow={12}
    eyebrow=""
    heading="Join us"
    intro="Live calendar synced from Airbnb and VRBO. Greyed dates are booked."
    i18nKey="riviere.availability"
  />

  <!-- CTA -->
  <section class="hero hero--cta" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="riviere.cta.heading">Interested in {cms.title}?</h2>
      <a href="/contact/" class="btn btn--white" data-i18n="riviere.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 24px;">
        <h2 data-i18n="riviere.cross.heading">Les Autres Maisons</h2>
      </div>
      <div class="maisons-stack">
        <a href="/homes/le-moulin/" class="split split--maison fade-in">
          <div class="split__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin" loading="lazy" />
          </div>
          <div class="split__body">
            <span class="split__eyebrow">The Mill House</span>
            <h2 data-i18n="riviere.cross.moulin.title">Le Moulin</h2>
            <div class="split__meta">
              <span data-i18n="riviere.cross.moulin.beds">5 Bedrooms</span>
              <span data-i18n="riviere.cross.moulin.sleeps">Sleeps 10</span>
            </div>
            <p>An historic mill on the Juine River. The river runs through the house. Five bedrooms across three floors.</p>
            <span class="link-arrow">Discover Le Moulin →</span>
          </div>
        </a>
        <a href="/homes/hollywood-hideaway/" class="split split--maison split--reverse fade-in">
          <div class="split__image">
            <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway" loading="lazy" />
          </div>
          <div class="split__body">
            <span class="split__eyebrow">The Refuge</span>
            <h2 data-i18n="riviere.cross.hideaway.title">The Hollywood Hideaway</h2>
            <div class="split__meta">
              <span data-i18n="riviere.cross.hideaway.beds">3 Bedrooms + Suite</span>
              <span data-i18n="riviere.cross.hideaway.sleeps">Sleeps 7</span>
            </div>
            <p>Three bedrooms plus a suite. The 60-year sanctuary of Hollywood's #1 power lawyer — French antiques, a covered gazebo, the compound's gardens.</p>
            <span class="link-arrow">Discover the Hideaway →</span>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 32px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="riviere.cross.cta">Rent the Compound</a>
      </div>
    </div>
  </section>

</BaseLayout>
