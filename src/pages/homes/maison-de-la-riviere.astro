---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../../components/AvailabilityCalendar.astro';
import PhotoCarousel from '../../components/PhotoCarousel.astro';
import RoomShowcase from '../../components/RoomShowcase.astro';
import AmenitiesSection from '../../components/AmenitiesSection.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/maison-de-la-riviere.md', 'utf-8');
const { data: cms } = matter(raw);

const carouselImages = [
  { src: '/images/homes/le-jardin-hero.webp', alt: 'La Maison de la Rivière — sunny cottage overlooking the stream' },
  { src: '/images/homes/maison-living.webp', alt: 'Sun-drenched living room with French doors' },
  { src: '/images/homes/maison-dining.webp', alt: 'Dining room — table for up to eighteen' },
  { src: '/images/homes/maison-kitchen.webp', alt: 'Eat-in kitchen with stone walls and beams' },
  { src: '/images/homes/maison-artistes.webp', alt: 'La Chambre des Artistes — the Artists\' Room' },
  { src: '/images/homes/maison-ecrivains.webp', alt: 'La Chambre des Écrivains — the Writers\' Room' },
];

const bedrooms = [
  {
    id: 'artistes',
    eyebrow: 'Bedroom · Upstairs',
    title: 'La Chambre des Artistes',
    summary: 'The Artists\' Room. Upstairs. King bed in a large bedroom, plus a twin bed and an in-room sink.',
    longDescription: 'The bigger of the two bedrooms — a king bed with room to spare for a third guest on the twin. The in-room sink keeps morning routines uncomplicated.',
    details: [
      { label: 'Beds', value: 'King + twin' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'In-room', value: 'Sink' },
      { label: 'Bathroom', value: 'Hall · tub + shower (shared)' },
    ],
    photos: [
      { src: '/images/homes/maison-artistes.webp', alt: 'La Chambre des Artistes — the Artists\' Room' },
    ],
  },
  {
    id: 'ecrivains',
    eyebrow: 'Bedroom · Upstairs',
    title: 'La Chambre des Écrivains',
    summary: 'The Writers\' Room. Upstairs. Double bed with an in-room sink. Shares the hall bathroom with Les Artistes.',
    details: [
      { label: 'Bed', value: 'Double' },
      { label: 'Floor', value: 'Upstairs' },
      { label: 'In-room', value: 'Sink' },
      { label: 'Bathroom', value: 'Hall · tub + shower (shared)' },
    ],
    photos: [
      { src: '/images/homes/maison-ecrivains.webp', alt: 'La Chambre des Écrivains — the Writers\' Room' },
    ],
  },
];

const livingSpaces = [
  {
    id: 'living',
    eyebrow: 'Living',
    title: 'The Living Room',
    summary: 'Spacious and sun-drenched, with two couches, fine antiques, and an authentic Louis Vuitton trunk as a coffee table. French doors open to the stream and apple trees.',
    longDescription: 'The light is what guests remember. Tall French doors open onto the stream and the apple orchard, and the room fills from morning until evening. Two couches, a fireplace, and the Louis Vuitton trunk that doubles as the coffee table.',
    photos: [
      { src: '/images/homes/maison-living.webp', alt: 'Sun-drenched living room with French doors' },
      { src: '/images/homes/le-jardin-hero.webp', alt: 'View from the living room toward the stream' },
    ],
  },
  {
    id: 'dining',
    eyebrow: 'Dining',
    title: 'The Dining Room',
    summary: 'Elegant dining room with a table that seats up to eighteen — built for dinner parties and long, candlelit evenings.',
    photos: [
      { src: '/images/homes/maison-dining.webp', alt: 'Dining room — table for up to eighteen' },
    ],
  },
  {
    id: 'kitchen',
    eyebrow: 'Kitchen',
    title: 'The Kitchen',
    summary: 'Eat-in kitchen with stone walls and exposed beams. Oven, full fridge + freezer, microwave, toaster, Nespresso, kettle.',
    details: [
      { label: 'Coffee', value: 'Nespresso' },
      { label: 'Fridge', value: 'Full size + freezer' },
      { label: 'Style', value: 'Stone walls, beams' },
    ],
    photos: [
      { src: '/images/homes/maison-kitchen.webp', alt: 'Eat-in kitchen with stone walls and beams' },
    ],
  },
];

const amenityFeatures = [
  {
    title: 'The Stream & Apple Trees',
    summary: 'French doors open from the living room directly onto the stream and the orchard — the main view from every window on this side.',
    image: '/images/homes/le-jardin-hero.webp',
    alt: 'The stream and apple trees behind La Maison de la Rivière',
  },
  {
    title: 'The Compound Gardens',
    summary: 'Shared with the rest of the compound — flower beds, lawns, and a Giverny-style bridge over the millstream.',
    image: '/images/bridge-garden.webp',
    alt: 'Compound gardens and bridge',
  },
  {
    title: 'Al Fresco Dining',
    summary: 'Patio and gazebo space across the compound, with tables for dinner parties under the stars.',
    image: '/images/gazebo-dining.webp',
    alt: 'Compound al fresco dining',
  },
];

const amenities = [
  { label: 'WiFi throughout', icon: 'wifi' },
  { label: 'Full kitchen', icon: 'kitchen' },
  { label: 'Oven + microwave', icon: 'oven' },
  { label: 'Nespresso & kettle', icon: 'coffee' },
  { label: 'Full fridge + freezer', icon: 'fridge' },
  { label: 'Dining for up to 18', icon: 'patio' },
  { label: 'Compound gardens', icon: 'garden' },
  { label: 'Stream & orchard view', icon: 'river' },
  { label: 'Sleeps 5 across 3 beds', icon: 'guests' },
];
---

<BaseLayout title="La Maison de la Rivière — Sunny Cottage Rental Near Paris" description="Sunny two-bedroom cottage rental in Mereville, France — sleeps 5. Overlooks the Juine River and apple trees. Dining for 18, one hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": `${cms.title} — Moulin à Rêves`,
      "description": cms.summary,
      "url": "https://www.moulinareves.com/homes/maison-de-la-riviere/",
      "image": cms.heroImage,
      "numberOfBedrooms": cms.bedrooms,
      "numberOfBathroomsTotal": cms.bathrooms,
      "occupancy": { "@type": "QuantitativeValue", "value": cms.sleeps },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mereville",
        "addressRegion": "Essonne",
        "addressCountry": "FR"
      }
    })} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.moulinareves.com/"},
        {"@type": "ListItem", "position": 2, "name": "The Maisons", "item": "https://www.moulinareves.com/homes/"},
        {"@type": "ListItem", "position": 3, "name": "La Maison de la Rivière", "item": "https://www.moulinareves.com/homes/maison-de-la-riviere/"}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src={cms.heroImage} alt={`${cms.title} — sunny cottage overlooking the stream`} />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow" data-i18n="riviere.hero.eyebrow">{cms.eyebrow}</span>
      <h1 class="hero__title" data-i18n="riviere.hero.title">{cms.title}</h1>
      <p class="hero__tagline" data-i18n="riviere.hero.tagline">{cms.tagline}</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 32px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bedrooms}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.bathrooms}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.bathrooms">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.sleeps}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">{cms.beds}</div>
          <div class="stats-bar__label" data-i18n="riviere.stats.beds">Beds</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Carousel -->
  <PhotoCarousel images={carouselImages} />

  <!-- Narrative Description -->
  <section class="section section--tight">
    <div class="container--narrow fade-in">
      <span class="eyebrow" data-i18n="riviere.narrative.eyebrow">The Maison</span>
      <h2 data-i18n="riviere.narrative.heading">{cms.title}</h2>
      <div style="margin-top: 32px;">
        <p class="prose-lead" data-i18n="riviere.narrative.summary">
          {cms.summary}
        </p>
      </div>
    </div>
  </section>

  <!-- Rooms (bedrooms) -->
  <RoomShowcase
    eyebrow="Rooms"
    heading={`Where you'll <span class="serif-italic">sleep</span>`}
    intro="Two upstairs bedrooms sharing a hall bath. Tap any room for details and photos."
    rooms={bedrooms}
    background="stone"
    i18nKey="riviere.bedrooms"
  />

  <!-- Living Spaces -->
  <RoomShowcase
    eyebrow="Living Spaces"
    heading={`Where you'll <span class="serif-italic">gather</span>`}
    intro="A sun-drenched living room, a dining room for eighteen, and a stone-and-beam kitchen."
    rooms={livingSpaces}
    i18nKey="riviere.living"
  />

  <!-- Amenities -->
  <AmenitiesSection
    eyebrow="Amenities & Grounds"
    heading={`What's <span class="serif-italic">here</span>`}
    features={amenityFeatures}
    amenities={amenities}
    background="stone"
    i18nKey="riviere.amenities"
  />

  <!-- Availability -->
  <AvailabilityCalendar
    eyebrow="Availability"
    heading={`When You Can <span class="serif-italic">Stay</span>`}
    intro="Live calendar synced from our Airbnb and VRBO listings — covers the whole compound. Greyed dates are already booked. Found a window? Tell us your dates and we'll confirm."
    i18nKey="riviere.availability"
  />

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);" data-i18n="riviere.cta.heading">Interested in {cms.title}?</h2>
      <p class="hero__tagline" data-i18n="riviere.cta.text">Tell us your dates and we'll put together everything you need. Pricing is available on inquiry.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="riviere.cta.button">Inquire About Dates</a>
    </div>
  </section>

  <!-- Cross Links -->
  <section class="section section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n-html="riviere.cross.heading">Les <span class="serif-italic">Autres Maisons</span></h2>
      </div>
      <div class="grid grid--2" style="gap: 24px;">
        <a href="/homes/le-moulin/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow" data-i18n="riviere.cross.moulin.eyebrow">Maison One</span>
            <h3 class="card__title" data-i18n="riviere.cross.moulin.title">Le Moulin à Rêves</h3>
            <div class="card__meta">
              <span data-i18n="riviere.cross.moulin.beds">5 Bedrooms</span>
              <span data-i18n="riviere.cross.moulin.sleeps">Sleeps 12</span>
            </div>
          </div>
        </a>
        <a href="/homes/hollywood-hideaway/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="The Hollywood Hideaway" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow" data-i18n="riviere.cross.hideaway.eyebrow">Maison Two</span>
            <h3 class="card__title" data-i18n="riviere.cross.hideaway.title">The Hollywood Hideaway</h3>
            <div class="card__meta">
              <span data-i18n="riviere.cross.hideaway.beds">3 Bedrooms + Suite</span>
              <span data-i18n="riviere.cross.hideaway.sleeps">Sleeps 8</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="riviere.cross.cta">Rent All Three Maisons</a>
      </div>
    </div>
  </section>

</BaseLayout>
