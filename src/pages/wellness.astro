---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Wellness Recommendations — Moulin à Rêves" description="Trusted local yoga teachers, massage therapists, and beauty practitioners near Moulin à Rêves. We share contacts; you book directly.">

  <!-- Hero -->
  <section class="hero" style="height: 60vh;">
    <div class="hero__image">
      <img src="/images/wellness-riverside-massage.webp" alt="Massage table set on the lawn beside the stream and mill house at Moulin à Rêves" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="wellness.hero.title">Wellness</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section--tight">
    <div class="container--narrow text-center fade-in">
      <h2 data-i18n="wellness.intro.heading">Let Someone Take Care of You</h2>
      <p data-i18n="wellness.intro.text" style="margin-top: 20px;">The countryside does most of the work. The air, the silence, the rhythm of days that have nowhere urgent to go. But sometimes your shoulders need more than fresh air, and your mind needs more than a good view. That's where our wellness partners come in — local practitioners who come to the compound so you don't have to go anywhere at all.</p>
      <p data-i18n="wellness.intro.text2" style="margin-top: 16px;">
        Book a private instructor to lead classes on the lawn or in the grange. 8 yoga mats are available at the property for your use.
      </p>
    </div>
  </section>

  <!-- Yoga -->
  <section class="section--tight fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/wellness-yoga-tree.webp" alt="Tree pose during a yoga session on the lawn at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="wellness.yoga.heading">Yoga on the Lawn</h2>
        <p data-i18n="wellness.yoga.p1">The lawn between the houses catches the morning sun from the east, and by eight o'clock, it's warm enough for bare feet on grass. Your instructor arrives with mats and props, and for the next hour, the only sounds are breath, birdsong, and the millstream.</p>
      </div>
    </div>
  </section>

  <!-- Massage -->
  <section id="massage" class="section--tight fade-in" style="scroll-margin-top: 96px;">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="wellness.massage.heading">Massage</h2>
        <p data-i18n="wellness.massage.p1">Your massage therapist sets up in one of the houses or, on warm days, on the shaded terrace — wherever you're most comfortable. Treatments range from deep tissue to relaxation massage, using plant-based oils from a producer in Provence.</p>
      </div>
      <div class="split__image">
        <img src="/images/wellness-massage-willow.webp" alt="Massage table on the lawn beneath the willow, with the painted bridge beyond, at Moulin à Rêves" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Beauty -->
  <section class="section--tight fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/wellness-beauty.webp" alt="Bright tile bathroom at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="wellness.beauty.heading">Beauty Treatments</h2>
        <p data-i18n="wellness.beauty.p1">Facials, manicures, pedicures — small indulgences that fit naturally into an afternoon when you have no plans and no intention of making any. Our beauty therapist comes to the compound with everything needed, using French skincare products that smell the way the countryside looks.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 40vh; min-height: 320px;">
    <div class="hero__image">
      <img src="/images/evening-compound.webp" alt="Lawn at dusk at Moulin à Rêves" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="wellness.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">Ready to Unwind?</h2>
      <p class="hero__tagline" data-i18n="wellness.cta.text">Tell us what you'd like and we'll arrange it. All wellness services are priced on inquiry.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="wellness.cta.button">Inquire About Wellness</a>
    </div>
  </section>

  <style>
    .section--tight { padding-top: 56px; padding-bottom: 56px; }
  </style>

</BaseLayout>
