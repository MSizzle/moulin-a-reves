---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Wellness Recommendations — Moulin à Rêves" description="Trusted local yoga teachers, massage therapists, and beauty practitioners near Moulin à Rêves. We share contacts; you book directly.">

  <!-- Hero -->
  <section class="hero" style="height: 56vh;">
    <div class="hero__image">
      <img src="/images/wellness-hero.webp" alt="Garden chaises on the lawn at Moulin à Rêves" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="wellness.hero.title">Wellness</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section--tight">
    <div class="container--narrow text-center fade-in">
      <h2 data-i18n="wellness.intro.heading">How wellness works at Moulin à Rêves</h2>
      <p data-i18n="wellness.intro.text" style="margin-top: 20px;">
        We do not provide wellness services ourselves. We share trusted local contacts — yoga teachers, massage therapists, beauty professionals — and you arrange directly with them.
      </p>
    </div>
  </section>

  <!-- Yoga -->
  <section class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/wellness-yoga-mill-facade.webp" alt="Yoga mats laid out before the mill facade at Le Moulin" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="wellness.yoga.heading">Yoga</h2>
        <p data-i18n="wellness.yoga.p1">
          Local instructors are available for one-off sessions or full retreat programmes on the lawn or in La Grange. Pricing and scheduling go directly through the teacher.
        </p>
      </div>
    </div>
  </section>

  <!-- Yoga gallery -->
  <section class="section--tight fade-in">
    <div class="container">
      <div class="wellness-gallery" data-gallery={JSON.stringify([
        { src: '/images/wellness-yoga-bridge.webp', alt: 'Yoga session on the painted bridge over the millstream in the gardens' },
        { src: '/images/wellness-yoga-sun-salutations.webp', alt: 'Seated sun salutations on the lawn beside the Hollywood Hideaway' },
        { src: '/images/wellness-yoga-tree.webp', alt: 'Tree pose during a yoga session on the lawn at Moulin à Rêves' },
        { src: '/images/wellness-yoga-stretch.webp', alt: 'Standing stretch on the lawn during a yoga retreat at Moulin à Rêves' },
        { src: '/images/wellness-yoga-adjustments.webp', alt: 'Yoga instructor offering hands-on adjustments at Moulin à Rêves' },
        { src: '/images/wellness-yoga-hideaway.webp', alt: 'Yoga practice on the lawn beside the Hollywood Hideaway' },
        { src: '/images/wellness-yoga-well.webp', alt: 'Yoga beside the stone well and painted bridge in the gardens' },
        { src: '/images/wellness-yoga-mill-facade.webp', alt: 'Yoga mats laid out before the mill facade at Le Moulin' },
      ])}>
        <div class="wellness-gallery__tile"><img src="/images/wellness-yoga-bridge.webp" alt="Yoga session on the painted bridge" loading="lazy" /></div>
        <div class="wellness-gallery__tile"><img src="/images/wellness-yoga-sun-salutations.webp" alt="Seated sun salutations on the lawn" loading="lazy" /></div>
        <div class="wellness-gallery__tile"><img src="/images/wellness-yoga-tree.webp" alt="Tree pose during a yoga session" loading="lazy" /></div>
        <div class="wellness-gallery__tile"><img src="/images/wellness-yoga-stretch.webp" alt="Standing stretch on the lawn" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- Massage -->
  <section id="massage" class="fade-in" style="scroll-margin-top: 96px;">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="wellness.massage.heading">Massage</h2>
        <p data-i18n="wellness.massage.p1">
          Local massage therapists travel to the compound. Treatments range from relaxation to deep tissue. Book directly once we share the contact.
        </p>
      </div>
      <div class="split__image">
        <img src="/images/wellness-massage-bridge.webp" alt="Massage table set up by the millstream beneath the painted Giverny-style bridge" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Massage gallery -->
  <section class="section--tight fade-in">
    <div class="container">
      <div class="wellness-gallery" data-gallery={JSON.stringify([
        { src: '/images/wellness-massage-bridge.webp', alt: 'Massage table set up beneath the painted Giverny-style bridge' },
        { src: '/images/wellness-massage-bridge-2.webp', alt: 'Massage table set up facing the painted bridge in the gardens' },
        { src: '/images/wellness-massage-river.webp', alt: 'Massage table set up beside the river at Moulin à Rêves' },
        { src: '/images/wellness-massage-streamside.webp', alt: 'Streamside massage at Moulin à Rêves' },
        { src: '/images/wellness-massage-willow.webp', alt: 'Massage beneath the willow trees in the gardens' },
        { src: '/images/wellness-massage-mill-lawn.webp', alt: 'Massage on the mill lawn at Moulin à Rêves' },
        { src: '/images/wellness-massage-garden.webp', alt: 'Massage in the gardens at Moulin à Rêves' },
      ])}>
        <div class="wellness-gallery__tile"><img src="/images/wellness-massage-bridge-2.webp" alt="Massage facing the painted bridge" loading="lazy" /></div>
        <div class="wellness-gallery__tile"><img src="/images/wellness-massage-river.webp" alt="Massage beside the river" loading="lazy" /></div>
        <div class="wellness-gallery__tile"><img src="/images/wellness-massage-streamside.webp" alt="Streamside massage" loading="lazy" /></div>
        <div class="wellness-gallery__tile"><img src="/images/wellness-massage-willow.webp" alt="Massage beneath the willow" loading="lazy" /></div>
      </div>
    </div>
  </section>

  <!-- Beauty -->
  <section class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/wellness-beauty.webp" alt="Bright tile bathroom at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="wellness.beauty.heading">Beauty</h2>
        <p data-i18n="wellness.beauty.p1">
          Facials, manicures, pedicures — local beauty practitioners come to the compound on request.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 40vh; min-height: 320px;">
    <div class="hero__image">
      <img src="/images/evening-compound.webp" alt="Lawn at dusk at Moulin à Rêves" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="wellness.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">Need contacts?</h2>
      <p class="hero__tagline" data-i18n="wellness.cta.text">Tell us what you would like and we will share trusted local practitioners.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="wellness.cta.button">Request Recommendations</a>
    </div>
  </section>

  <style>
    .section--tight { padding-top: 56px; padding-bottom: 56px; }
    .wellness-gallery {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      cursor: zoom-in;
    }
    .wellness-gallery__tile {
      aspect-ratio: 1 / 1;
      overflow: hidden;
      border-radius: 2px;
    }
    .wellness-gallery__tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .wellness-gallery:hover .wellness-gallery__tile img { transform: scale(1.02); }
    @media (max-width: 720px) {
      .wellness-gallery { grid-template-columns: repeat(2, 1fr); }
    }
  </style>

</BaseLayout>
