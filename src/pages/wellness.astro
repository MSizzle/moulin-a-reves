---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Wellness Recommendations — Moulin à Rêves" description="Trusted local yoga teachers, massage therapists, and beauty practitioners near Moulin à Rêves. We share contacts; you book directly.">

  <!-- Hero -->
  <section class="hero" style="height: 56vh;">
    <div class="hero__image">
      <img src="/images/wellness-hero.webp" alt="Garden chaises on the lawn at Moulin à Rêves" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="wellness.hero.title">Wellness</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section--tight">
    <div class="container--narrow text-center fade-in">
      <h2 data-i18n="wellness.intro.heading">How wellness works at Moulin à Rêves</h2>
      <p data-i18n="wellness.intro.text" style="margin-top: 20px;">
        We do not provide wellness services ourselves. We share trusted local contacts — yoga teachers, massage therapists, beauty professionals — and you arrange directly with them.
      </p>
      <p data-i18n="wellness.intro.text2" style="margin-top: 16px;">
        Book a private instructor to lead classes on the lawn or in the grange. 8 yoga mats are available at the property for your use.
      </p>
    </div>
  </section>

  <!-- Yoga -->
  <section class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/wellness-yoga-tree.webp" alt="Tree pose during a yoga session on the lawn at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="wellness.yoga.heading">Yoga</h2>
        <p data-i18n="wellness.yoga.p1">
          Local instructors are available for one-off sessions or full retreat programmes on the lawn or in La Grange. Pricing and scheduling go directly through the teacher.
        </p>
      </div>
    </div>
  </section>

  <!-- Massage -->
  <section id="massage" class="fade-in" style="scroll-margin-top: 96px;">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="wellness.massage.heading">Massage</h2>
        <p data-i18n="wellness.massage.p1">
          Local massage therapists travel to the compound. Treatments range from relaxation to deep tissue. Book directly once we share the contact.
        </p>
      </div>
      <div class="split__image">
        <img src="/images/wellness-massage-streamside.webp" alt="Streamside massage at Moulin à Rêves" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Beauty -->
  <section class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/wellness-beauty.webp" alt="Bright tile bathroom at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="wellness.beauty.heading">Beauty</h2>
        <p data-i18n="wellness.beauty.p1">
          Facials, manicures, pedicures — local beauty practitioners come to the compound on request.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 40vh; min-height: 320px;">
    <div class="hero__image">
      <img src="/images/evening-compound.webp" alt="Lawn at dusk at Moulin à Rêves" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="wellness.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">Need contacts?</h2>
      <p class="hero__tagline" data-i18n="wellness.cta.text">Tell us what you would like and we will share trusted local practitioners.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="wellness.cta.button">Request Recommendations</a>
    </div>
  </section>

  <style>
    .section--tight { padding-top: 56px; padding-bottom: 56px; }
  </style>

</BaseLayout>
