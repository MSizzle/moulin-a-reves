            // ---- Per-page review mode (v1.3 Phase 8) -------------------------------
            // Block A — Element references
            var modeTabClick = document.getElementById('modeTabClick');
            var modeTabMatch = document.getElementById('modeTabMatch');
            var modePaneClick = document.getElementById('mode-pane-per-element');
            var modePaneMatch = document.getElementById('mode-pane-per-page');
            var matchPicker = document.getElementById('matchPagePick');
            var matchPickerHint = document.getElementById('matchPickerHint');
            var matchTextarea = document.getElementById('matchEditList');
            var matchSubmitBtn = document.getElementById('matchSubmitBtn');
            var matchCharCount = document.getElementById('matchCharCount');
            var matchSiteFrame = document.getElementById('matchSite');
            var MATCH_SET_KEY = 'mar_feedback_match_set_v1';
            var MAX_EDIT_LIST_CHARS = 10000;

            // Block B — Mode-tab hash router (D-07, D-08)
            function activateMode(mode) {
