---
export const prerender = false;

import { checkAuth } from '../lib/auth';
import { FEEDBACK_INJECT_VER as VER, MATCH_INJECT_VER as MVER } from '../lib/feedback-version';

// Auth gate in the frontmatter (SSR — prerender=false). On failure we render a
// self-contained login card styled like the dashboard login; it POSTs to the
// existing /api/auth/login and reloads back here. (We deliberately do NOT
// touch src/pages/api/auth/login.ts — REUSE as-is.)
const authed = await checkAuth(Astro.request);

// Public routes the client can leave feedback on, in nav-ish order.
const PAGES: { label: string; route: string }[] = [
  { label: 'Home', route: '/' },
  { label: 'The Compound', route: '/the-compound/' },
  { label: 'Homes — overview', route: '/homes/' },
  { label: 'Le Moulin', route: '/homes/le-moulin/' },
  { label: 'Hollywood Hideaway', route: '/homes/hollywood-hideaway/' },
  { label: 'Maison de la Rivière', route: '/homes/maison-de-la-riviere/' },
  { label: 'Groups', route: '/groups/' },
  { label: 'Catering', route: '/catering/' },
  { label: 'Wellness', route: '/wellness/' },
  { label: 'Gallery', route: '/gallery/' },
  { label: 'Explore', route: '/explore/' },
  { label: 'About', route: '/about/' },
  { label: 'Contact', route: '/contact/' },
];
const firstSrc = `/?feedback=1&v=${VER}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Moulin à Rêves — Leave Feedback</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      :root { --bg:#0f172a; --panel:#1e293b; --line:#334155; --ink:#e2e8f0; --muted:#94a3b8; --accent:#FF6B2B; --accent-2:#6366f1; }
      html, body { height: 100%; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--bg); color: var(--ink); display: flex; flex-direction: column;
      }
      /* ---- login fallback ---- */
      .login-wrap { flex: 1; display: flex; align-items: center; justify-content: center; }
      .login-card { background: var(--panel); border: 1px solid var(--line); border-radius: 12px; padding: 2.5rem; width: 100%; max-width: 400px; box-shadow: 0 25px 50px rgba(0,0,0,0.25); }
      .login-card h1 { font-size: 1.4rem; margin-bottom: .4rem; }
      .login-card p { color: var(--muted); font-size: .85rem; margin-bottom: 1.4rem; }
      .login-card label { display:block; font-size:.85rem; color:var(--muted); margin-bottom:.5rem; }
      .login-card input { width:100%; padding:.75rem 1rem; background:var(--bg); border:1px solid var(--line); border-radius:8px; color:#f8fafc; font-size:1rem; margin-bottom:1.2rem; outline:none; }
      .login-card input:focus { border-color: var(--accent-2); }
      .login-card button { width:100%; padding:.75rem; background:var(--accent-2); color:#fff; border:none; border-radius:8px; font-size:1rem; cursor:pointer; }
      .login-card .err { background:#7f1d1d; border:1px solid #dc2626; color:#fca5a5; padding:.6rem .75rem; border-radius:8px; font-size:.8rem; margin-bottom:1rem; display:none; }
      /* ---- app chrome ---- */
      .bar { display:flex; align-items:center; gap:1rem; padding:.6rem 1rem; background:var(--panel); border-bottom:1px solid var(--line); flex-wrap:wrap; }
      .bar .brand { font-weight:600; font-size:.95rem; }
      .bar .brand small { color:var(--muted); font-weight:400; }
      .bar select { background:var(--bg); color:var(--ink); border:1px solid var(--line); border-radius:8px; padding:.45rem .6rem; font-size:.85rem; }
      .bar .spacer { flex:1; }
      .bar a.inbox { color:var(--accent); text-decoration:none; font-size:.85rem; border:1px solid var(--line); padding:.45rem .7rem; border-radius:8px; }
      .bar a.inbox:hover { border-color: var(--accent); }
      .hint { color:var(--muted); font-size:.78rem; }
      .frame-wrap { flex:1; position:relative; background:#000; }
      iframe { width:100%; height:100%; border:0; display:block; }
      /* ---- toast / status ---- */
      .toast { position:fixed; left:50%; bottom:24px; transform:translateX(-50%); max-width:560px; width:calc(100% - 32px); background:var(--panel); border:1px solid var(--line); border-radius:12px; padding:1rem 1.2rem; box-shadow:0 20px 50px rgba(0,0,0,.4); display:none; z-index:50; }
      .toast.show { display:block; }
      .toast.ok { border-color:#15803d; }
      .toast.err { border-color:#dc2626; }
      .toast h3 { font-size:.95rem; margin-bottom:.3rem; }
      .toast p { font-size:.85rem; color:var(--muted); }
      .toast a { color:var(--accent); }
      .toast .row { margin-top:.7rem; display:flex; gap:.6rem; }
      .toast button { background:var(--accent-2); color:#fff; border:none; border-radius:8px; padding:.5rem .9rem; font-size:.85rem; cursor:pointer; }
      .toast button.ghost { background:transparent; border:1px solid var(--line); color:var(--ink); }
      .working { position:fixed; inset:0; background:rgba(15,23,42,.55); display:none; align-items:center; justify-content:center; z-index:60; font-size:.95rem; }
      .working.show { display:flex; }
      /* ---- recent submissions rail (v1.2) ---- */
      .rail { background:var(--panel); border-top:1px solid var(--line); padding:.9rem 1.1rem; max-height:40vh; overflow-y:auto; }
      .rail__title { font-size:.85rem; color:var(--muted); margin-bottom:.55rem; }
      .rail__list { list-style:none; display:flex; flex-direction:column; gap:.55rem; padding:0; }
      .rail__row { background:var(--bg); border:1px solid var(--line); border-radius:10px; padding:.65rem .8rem; font-size:.82rem; }
      .rail__row__head { display:flex; align-items:baseline; justify-content:space-between; gap:.8rem; margin-bottom:.45rem; }
      .rail__row__head a { color:var(--accent); text-decoration:none; font-weight:600; }
      .rail__row__head .when { color:var(--muted); font-size:.75rem; }
      .rail__row__summary { color:var(--ink); margin-bottom:.45rem; }
      .rail__bar { display:grid; grid-template-columns:repeat(5,1fr); gap:3px; }
      .rail__bar__seg { height:6px; border-radius:3px; background:var(--line); transition:background .2s ease; }
      .rail__bar__seg.is-done { background:var(--accent); }
      .rail__bar__seg.is-current { background:var(--accent-2); }
      .rail__row__sub { margin-top:.4rem; color:var(--muted); font-size:.76rem; }
      .rail__row__sub a { color:var(--accent); }
      .rail__row.is-live .rail__row__summary { color:var(--muted); }
      .rail__row.is-live .rail__row__sub { color:#86efac; }
      /* ---- mode tabs (Phase 8 per-page review) ---- */
      .mode-tabs { display:flex; background:var(--panel); border-bottom:1px solid var(--line); padding:0 16px; height:44px; }
      .mode-tabs__tab { background:transparent; border:0; padding:12px 24px; color:var(--muted); font:500 13px/1.3 inherit; cursor:pointer; border-bottom:2px solid transparent; transition:color .15s ease-out, border-bottom-color .15s ease-out; min-height:44px; }
      .mode-tabs__tab:hover { color:var(--ink); }
      .mode-tabs__tab.is-active { color:var(--ink); border-bottom-color:var(--accent-2); }
      .mode-tabs__tab:focus-visible { outline:2px solid var(--accent-2); outline-offset:-2px; }
      /* ---- mode panes ---- */
      .mode-pane { display:flex; flex-direction:column; flex:1; min-height:0; }
      .mode-pane[hidden] { display:none; }
      /* ---- match input zone (per-page review mode) ---- */
      .match-input { padding:16px; background:var(--panel); border-bottom:1px solid var(--line); display:flex; flex-direction:column; gap:12px; }
      .match-input__header { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
      .match-input__label { color:var(--muted); font:500 13px/1.3 inherit; }
      .match-input__picker { background:var(--bg); color:var(--ink); border:1px solid var(--line); border-radius:8px; padding:.45rem .6rem; font-size:.85rem; }
      .match-input__hint { color:var(--muted); font:500 12px/1.2 inherit; }
      .match-input__textarea { width:100%; min-height:120px; max-height:320px; resize:vertical; padding:12px; background:var(--bg); border:1px solid var(--line); border-radius:8px; color:var(--ink); font-family:ui-monospace, SFMono-Regular, Menlo, monospace; font-size:13px; line-height:1.5; }
      .match-input__textarea:focus-visible { outline:0; border-color:var(--accent-2); }
      .match-input__footer { display:flex; align-items:center; gap:12px; }
      .match-input__submit { padding:12px 24px; background:var(--accent-2); color:#fff; border:0; border-radius:8px; font-size:14px; font-weight:600; cursor:pointer; min-height:44px; }
      .match-input__submit:hover:not(:disabled) { background:#4f46e5; }
      .match-input__submit:disabled { opacity:.5; cursor:not-allowed; }
      .match-input__submit:focus-visible { outline:2px solid var(--accent-2); outline-offset:2px; }
      .match-input__char-count { font-size:12px; color:var(--muted); margin-left:auto; }
      .match-input__char-count.is-warn { color:var(--accent); }
      .match-input__char-count.is-over { color:#fca5a5; }
      @media (prefers-reduced-motion: reduce) {
        .mode-tabs__tab { transition:none; }
      }
    </style>
  </head>
  <body>
    {!authed && (
      <div class="login-wrap">
        <form class="login-card" id="loginForm">
          <h1>Leave Feedback</h1>
          <p>Please sign in to continue.</p>
          <div class="err" id="loginErr">That password didn’t work. Try again.</div>
          <label for="pw">Password</label>
          <input type="password" id="pw" autocomplete="current-password" autofocus required />
          <button type="submit">Sign In</button>
        </form>
      </div>
      <script is:inline>
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
          e.preventDefault();
          const password = document.getElementById('pw').value;
          const res = await fetch('/api/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'include',
            body: JSON.stringify({ password }),
          });
          if (res.ok) location.href = '/feedback';
          else document.getElementById('loginErr').style.display = 'block';
        });
      </script>
    )}

    {authed && (
      <>
        <div class="bar">
          <div class="brand">Moulin à Rêves <small>· Feedback mode</small></div>
          <label class="hint" for="pagePick">Page:</label>
          <select id="pagePick">
            {PAGES.map((pg) => <option value={pg.route}>{pg.label}</option>)}
          </select>
          <span class="hint">Hover anything, click it, tell us what to change.</span>
          <span class="spacer"></span>
          <a class="inbox" href="/feedback/inbox">Open questions ↗</a>
        </div>
        <div class="mode-tabs" role="tablist" aria-label="Feedback mode">
          <button class="mode-tabs__tab is-active" id="modeTabClick" role="tab" aria-selected="true" aria-controls="mode-pane-per-element" tabindex="0">Per-element click</button>
          <button class="mode-tabs__tab" id="modeTabMatch" role="tab" aria-selected="false" aria-controls="mode-pane-per-page" tabindex="-1">Per-page review</button>
        </div>
        <div class="mode-pane" id="mode-pane-per-element" role="tabpanel" aria-labelledby="modeTabClick">
          <div class="frame-wrap">
            <iframe id="site" src={firstSrc} title="Moulin à Rêves preview"></iframe>
          </div>
        </div>
        <div class="mode-pane" id="mode-pane-per-page" role="tabpanel" aria-labelledby="modeTabMatch" hidden>
          <section class="match-input" aria-label="Per-page edit input">
            <div class="match-input__header">
              <label class="match-input__label" for="matchPagePick">Page:</label>
              <select id="matchPagePick" class="match-input__picker">
                {PAGES.map((pg) => <option value={pg.route}>{pg.label}</option>)}
              </select>
              <span class="match-input__hint" id="matchPickerHint" hidden>This page isn't catalogued yet.</span>
            </div>
            <textarea class="match-input__textarea" id="matchEditList" rows="6" maxlength="10000"
                      aria-label="Edit list for selected page"
                      placeholder="Paste a freeform list of changes for this page — one edit per line. Bullets, numbers, paragraphs are all fine."></textarea>
            <div class="match-input__footer">
              <button class="match-input__submit" id="matchSubmitBtn" disabled>Match edits</button>
              <span class="match-input__char-count" id="matchCharCount" aria-live="polite">0 / 10000</span>
            </div>
          </section>
          <div class="match-pane__split">
            <div class="match-pane__iframe-col">
              <div class="frame-wrap frame-wrap--match">
                <iframe id="matchSite" title="Moulin à Rêves preview — per-page matches"></iframe>
              </div>
            </div>
            <aside class="match-panel" id="matchPanel" aria-label="Per-page matches" tabindex="0">
              <header class="match-panel__header">
                <h3 class="match-panel__title">Per-page matches</h3>
                <p class="match-panel__subtitle" id="matchPanelSubtitle" hidden></p>
              </header>
              <div class="match-panel__banner-slot" id="matchDriftBanner" hidden>
                <div class="match-drift-banner" role="alert">
                  <div class="match-drift-banner__icon" aria-hidden="true">⚠</div>
                  <div class="match-drift-banner__body">
                    <p class="match-drift-banner__title">Matches are out of date</p>
                    <p class="match-drift-banner__msg">The site has been redeployed since these matches were generated. Click "Re-run match" to refresh.</p>
                  </div>
                  <button class="match-drift-banner__action" id="matchDriftRerun" type="button">Re-run match</button>
                </div>
              </div>
              <div class="match-panel__empty" id="matchPanelEmpty">
                <p class="match-panel__empty-title">Tell us what to change on this page</p>
                <p class="match-panel__empty-body">Type or paste your edits above, then click "Match edits". You'll review each match before anything is sent.</p>
              </div>
              <ol class="match-panel__rows" id="matchPanelRows" role="list" hidden></ol>
              <details class="match-panel__rejected" id="matchPanelRejected" hidden>
                <summary class="match-panel__rejected-summary">Rejected (<span id="matchRejectedCount">0</span>)</summary>
                <ol class="match-panel__rejected-list" id="matchPanelRejectedList" role="list"></ol>
              </details>
              <p class="match-panel__helper" id="matchPanelHelper" hidden>Approved edits show in the orange chip inside the preview. Submit the full batch from there when you're done.</p>
            </aside>
          </div>
        </div>

        <aside class="rail" id="rail" hidden>
          <h3 class="rail__title">Recent submissions</h3>
          <ul class="rail__list" id="railList"></ul>
        </aside>

        <div class="working" id="working">Sending your feedback…</div>
        <div class="toast" id="toast">
          <h3 id="toastTitle"></h3>
          <p id="toastBody"></p>
          <div class="row" id="toastRow"></div>
        </div>

        <script is:inline define:vars={{ VER, MVER, PAGES }}>
          (function () {
            var iframe = document.getElementById('site');
            var picker = document.getElementById('pagePick');
            var working = document.getElementById('working');
            var toast = document.getElementById('toast');
            var tTitle = document.getElementById('toastTitle');
            var tBody = document.getElementById('toastBody');
            var tRow = document.getElementById('toastRow');

            // ---- Recent submissions rail (v1.2 STATUS-06..09) ------------------
            var RAIL_KEY = 'mar_feedback_recent_v1';
            var rail = document.getElementById('rail');
            var railList = document.getElementById('railList');
            var pollers = {};        // issueNumber → setInterval handle
            var POLL_MS = 8000;

            function loadRecent() {
              try {
                var v = JSON.parse(localStorage.getItem(RAIL_KEY) || '[]');
                return Array.isArray(v) ? v : [];
              } catch (_) { return []; }
            }
            function saveRecent(list) {
              try { localStorage.setItem(RAIL_KEY, JSON.stringify(list.slice(0, 20))); } catch (_) {}
            }
            function relTime(iso) {
              var ms = Date.now() - new Date(iso).getTime();
              if (ms < 60000) return 'just now';
              if (ms < 3600000) return Math.floor(ms / 60000) + 'm ago';
              if (ms < 86400000) return Math.floor(ms / 3600000) + 'h ago';
              return Math.floor(ms / 86400000) + 'd ago';
            }
            function stageLabel(stage) {
              return ['', 'Submitted', 'Reviewing', 'PR opened', 'Merged', 'Live'][stage] || '';
            }
            function subBlock(item) {
              if (item.lastStage === 5) {
                var liveExtra = item.deployUrl
                  ? ' · <a target="_blank" rel="noopener" href="' + item.deployUrl + '">view deploy</a>'
                  : '';
                return '✓ Live on the site' + liveExtra;
              }
              if (item.lastSub === 'needs-client-reply') {
                return 'Question for you → <a target="_blank" rel="noopener" href="' + item.issueUrl + '">open issue</a>';
              }
              if (item.lastSub === 'needs-review') return 'Needs Monty’s review';
              if (item.lastSub === 'auto-merged' || item.lastSub === 'merged') return 'Merged · waiting for deploy…';
              return stageLabel(item.lastStage) + '…';
            }
            function escapeHtml(s) {
              return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
              });
            }
            function renderRail() {
              var list = loadRecent();
              if (!list.length) { rail.hidden = true; return; }
              rail.hidden = false;
              railList.innerHTML = '';
              list.forEach(function (item) {
                var li = document.createElement('li');
                li.className = 'rail__row' + (item.lastStage === 5 ? ' is-live' : '');
                var bar = '';
                for (var i = 1; i <= 5; i++) {
                  var cls = 'rail__bar__seg';
                  if (i < item.lastStage) cls += ' is-done';
                  else if (i === item.lastStage) cls += ' is-current';
                  bar += '<div class="' + cls + '" title="' + stageLabel(i) + '"></div>';
                }
                li.innerHTML =
                  '<div class="rail__row__head">' +
                    '<a target="_blank" rel="noopener" href="' + escapeHtml(item.issueUrl) + '">#' + escapeHtml(item.issueNumber) + '</a>' +
                    '<span class="when">' + relTime(item.submittedAt) + '</span>' +
                  '</div>' +
                  '<div class="rail__row__summary">' + escapeHtml(item.summary) + '</div>' +
                  '<div class="rail__bar">' + bar + '</div>' +
                  '<div class="rail__row__sub">' + subBlock(item) + '</div>';
                railList.appendChild(li);
              });
            }
            function isTerminal(item) {
              if (item.lastStage === 5) return true;
              if (item.lastStage === 4 && (item.lastSub === 'needs-review' || item.lastSub === 'needs-client-reply')) return true;
              return false;
            }
            function pollOne(num) {
              if (pollers[num]) return;
              var loop = function () {
                fetch('/api/feedback/status/' + encodeURIComponent(num), { credentials: 'include' })
                  .then(function (r) { return r.ok ? r.json() : null; })
                  .then(function (data) {
                    if (!data) return;
                    var list = loadRecent();
                    var idx = -1;
                    for (var i = 0; i < list.length; i++) { if (String(list[i].issueNumber) === String(num)) { idx = i; break; } }
                    if (idx === -1) { clearInterval(pollers[num]); delete pollers[num]; return; }
                    list[idx].lastStage = data.stage;
                    list[idx].lastSub = data.sub;
                    list[idx].deployUrl = data.deployUrl || null;
                    saveRecent(list);
                    renderRail();
                    if (isTerminal(list[idx])) { clearInterval(pollers[num]); delete pollers[num]; }
                  })
                  .catch(function () { /* network blip: next tick will retry */ });
              };
              loop();
              pollers[num] = setInterval(loop, POLL_MS);
            }
            function persistSubmission(data, payload) {
              try {
                var list = loadRecent();
                var routes = [];
                var editCount = 0;
                if (payload && Array.isArray(payload.edits)) {
                  editCount = payload.edits.length;
                  payload.edits.forEach(function (e) {
                    var r = e && e.pageRoute;
                    if (r && routes.indexOf(r) === -1) routes.push(r);
                  });
                } else if (payload && payload.pageRoute) {
                  editCount = 1;
                  routes.push(payload.pageRoute);
                }
                list.unshift({
                  issueNumber: data.issueNumber,
                  issueUrl: data.issueUrl,
                  summary: editCount + ' edit' + (editCount === 1 ? '' : 's') + (routes.length ? ' · ' + routes.join(', ') : ''),
                  submittedAt: new Date().toISOString(),
                  lastStage: 1,
                  lastSub: null,
                  deployUrl: null,
                });
                saveRecent(list);
              } catch (_) { /* localStorage unavailable: skip silently */ }
            }
            function startAllPollers() {
              loadRecent().forEach(function (item) { if (!isTerminal(item)) pollOne(item.issueNumber); });
            }
            renderRail();
            startAllPollers();

            picker.addEventListener('change', function () {
              iframe.src = picker.value + '?feedback=1&v=' + VER;
              hideToast();
            });

            function hideToast() { toast.className = 'toast'; tRow.innerHTML = ''; }
            function showToast(kind, title, bodyHtml, buttons) {
              toast.className = 'toast show ' + kind;
              tTitle.textContent = title;
              tBody.innerHTML = bodyHtml;
              tRow.innerHTML = '';
              (buttons || []).forEach(function (b) {
                var el = document.createElement('button');
                el.textContent = b.label;
                if (b.ghost) el.className = 'ghost';
                el.addEventListener('click', b.onClick);
                tRow.appendChild(el);
              });
            }

            window.addEventListener('message', async function (ev) {
              if (ev.origin !== location.origin) return;
              var msg = ev.data;
              if (!msg || msg.type !== 'mar-feedback-submit') return;

              working.classList.add('show');
              try {
                var res = await fetch('/api/feedback/submit', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  credentials: 'include',
                  body: JSON.stringify(msg.payload),
                });
                working.classList.remove('show');

                if (res.status === 401) {
                  // Draft is safe in the iframe's localStorage (the inject keeps
                  // it). Tell the client to sign in again without losing it.
                  iframe.contentWindow &&
                    iframe.contentWindow.postMessage({ type: 'mar-feedback-result', ok: false, auth: true }, location.origin);
                  showToast('err', 'Please sign in again', 'Your session expired. Your note is saved — sign in and resend.', [
                    { label: 'Sign in', onClick: function () { location.href = '/feedback'; } },
                  ]);
                  return;
                }

                var data = await res.json().catch(function () { return {}; });
                if (res.ok && data.ok) {
                  // CR-01 (success path): spread warning + commitErrors so inject can
                  // surface partial photo-commit failures without clearing staged state.
                  iframe.contentWindow &&
                    iframe.contentWindow.postMessage({
                      type: 'mar-feedback-result',
                      ok: true,
                      ...(data.warning ? { warning: data.warning } : {}),
                      ...(Array.isArray(data.commitErrors) ? { commitErrors: data.commitErrors } : {}),
                    }, location.origin);
                  persistSubmission(data, msg.payload);
                  renderRail();
                  if (data.issueNumber) pollOne(data.issueNumber);
                  showToast(
                    'ok',
                    'Thank you — it’s on its way',
                    (data.warning ? data.warning + ' Re-attach the affected photos and resubmit.' :
                      'We’ve logged your request' +
                      (data.issueUrl ? ' (<a target="_blank" rel="noopener" href="' + data.issueUrl + '">#' + data.issueNumber + '</a>)' : '') +
                      '. Watch the Recent submissions panel below to follow it from review to live.'),
                    [{ label: 'Done', onClick: hideToast }]
                  );
                } else {
                  // CR-01 (failure path): spread structured cap/error fields so the inject's
                  // m.cap and m.errors branches become reachable.
                  iframe.contentWindow &&
                    iframe.contentWindow.postMessage({
                      type: 'mar-feedback-result',
                      ok: false,
                      ...(Array.isArray(data && data.errors) ? { errors: data.errors } : {}),
                      ...(data && data.cap ? { cap: data.cap } : {}),
                      ...(data && typeof data.limit === 'number' ? { limit: data.limit } : {}),
                      ...(data && typeof data.actual === 'number' ? { actual: data.actual } : {}),
                      ...(data && data.error ? { error: data.error } : {}),
                    }, location.origin);
                  showToast('err', 'That didn’t go through', (data && data.error) || 'Something went wrong. Please try again.', [
                    { label: 'OK', ghost: true, onClick: hideToast },
                  ]);
                }
              } catch (e) {
                working.classList.remove('show');
                iframe.contentWindow &&
                  iframe.contentWindow.postMessage({ type: 'mar-feedback-result', ok: false }, location.origin);
                showToast('err', 'Network problem', 'We couldn’t reach the server. Your note is saved — try again in a moment.', [
                  { label: 'OK', ghost: true, onClick: hideToast },
                ]);
              }
            });

            // ---- Per-page review mode (v1.3 Phase 8) -------------------------------
            // Block A — Element references
            var modeTabClick = document.getElementById('modeTabClick');
            var modeTabMatch = document.getElementById('modeTabMatch');
            var modePaneClick = document.getElementById('mode-pane-per-element');
            var modePaneMatch = document.getElementById('mode-pane-per-page');
            var matchPicker = document.getElementById('matchPagePick');
            var matchPickerHint = document.getElementById('matchPickerHint');
            var matchTextarea = document.getElementById('matchEditList');
            var matchSubmitBtn = document.getElementById('matchSubmitBtn');
            var matchCharCount = document.getElementById('matchCharCount');
            var matchSiteFrame = document.getElementById('matchSite');
            var MATCH_SET_KEY = 'mar_feedback_match_set_v1';
            var MAX_EDIT_LIST_CHARS = 10000;

            // Block B — Mode-tab hash router (D-07, D-08)
            function activateMode(mode) {
              var isMatch = mode === 'per-page';
              modeTabClick.classList.toggle('is-active', !isMatch);
              modeTabMatch.classList.toggle('is-active', isMatch);
              modeTabClick.setAttribute('aria-selected', !isMatch);
              modeTabMatch.setAttribute('aria-selected', isMatch);
              modeTabClick.setAttribute('tabindex', isMatch ? '-1' : '0');
              modeTabMatch.setAttribute('tabindex', isMatch ? '0' : '-1');
              modePaneClick.hidden = isMatch;
              modePaneMatch.hidden = !isMatch;
              // Update URL hash without scrolling (D-08): replace, not push
              var newHash = '#mode=' + (isMatch ? 'per-page' : 'per-element');
              if (location.hash !== newHash) history.replaceState(null, '', location.pathname + location.search + newHash);
            }
            function readModeFromHash() {
              var m = (location.hash || '').match(/mode=(per-element|per-page)/);
              return m ? m[1] : 'per-element'; // default per D-07
            }
            modeTabClick.addEventListener('click', function () { activateMode('per-element'); });
            modeTabMatch.addEventListener('click', function () { activateMode('per-page'); });
            // Arrow-key tab navigation (ARIA tabs pattern, UI-SPEC §1)
            [modeTabClick, modeTabMatch].forEach(function (tab) {
              tab.addEventListener('keydown', function (ev) {
                if (ev.key === 'ArrowLeft' || ev.key === 'ArrowRight') {
                  ev.preventDefault();
                  activateMode(tab === modeTabClick ? 'per-page' : 'per-element');
                  (tab === modeTabClick ? modeTabMatch : modeTabClick).focus();
                }
              });
            });
            // Initial activation from hash
            activateMode(readModeFromHash());

            // Block C — Char counter + picker HEAD-probe + textarea wire-up (D-21)
            var lastCatalogProbeOk = false;
            function refreshSubmitBtn() {
              var len = matchTextarea.value.length;
              var trimmed = matchTextarea.value.trim();
              matchSubmitBtn.disabled = !(lastCatalogProbeOk && trimmed.length > 0 && len <= MAX_EDIT_LIST_CHARS);
              matchCharCount.textContent = len + ' / ' + MAX_EDIT_LIST_CHARS;
              matchCharCount.classList.toggle('is-warn', len > 9500 && len <= MAX_EDIT_LIST_CHARS);
              matchCharCount.classList.toggle('is-over', len > MAX_EDIT_LIST_CHARS);
            }
            // Single source of truth for the catalog URL — matches the matcher endpoint's
            // routeToSlug() in Plan 02 (loadCatalog) byte-for-byte. Inject (Plan 03)
            // duplicates this same helper inline since it can't import from src/lib at runtime.
            function routeToCatalogUrl(route) {
              var slug = route.replace(/^\/+|\/+$/g, '');
              if (!slug) slug = 'index';
              return '/edit-catalogs/' + slug + '.json';
            }
            async function probeCatalog(route) {
              try {
                var res = await fetch(routeToCatalogUrl(route), { method: 'HEAD', credentials: 'same-origin' });
                if (res.ok) { lastCatalogProbeOk = true; matchPickerHint.hidden = true; }
                else { lastCatalogProbeOk = false; matchPickerHint.hidden = false; }
              } catch (_) {
                lastCatalogProbeOk = false; matchPickerHint.hidden = false;
              }
              refreshSubmitBtn();
            }
            matchPicker.addEventListener('change', function () { probeCatalog(matchPicker.value); });
            matchTextarea.addEventListener('input', refreshSubmitBtn);
            // Initial probe for the default-selected route
            probeCatalog(matchPicker.value);
            // Cmd/Ctrl+Enter submits the form
            matchTextarea.addEventListener('keydown', function (ev) {
              if ((ev.metaKey || ev.ctrlKey) && ev.key === 'Enter' && !matchSubmitBtn.disabled) {
                ev.preventDefault();
                matchSubmitBtn.click();
              }
            });

            // Block D — Match edits click handler (MODE-02 — the core matcher call)
            matchSubmitBtn.addEventListener('click', async function () {
              if (matchSubmitBtn.disabled) return;
              var route = matchPicker.value;
              var editList = matchTextarea.value;
              // Loading state — UI-SPEC §10
              matchSubmitBtn.disabled = true;
              var originalLabel = matchSubmitBtn.textContent;
              matchSubmitBtn.textContent = 'Matching…';
              working.classList.add('show');
              working.innerHTML = '<div><strong>Matching your edits…</strong><br><span style="color:var(--muted);font-size:.85rem;">Asking Claude to find each line on the page. This usually takes 3–6 seconds.</span></div>';
              var controller = new AbortController();
              var done = function () {
                working.classList.remove('show');
                working.innerHTML = 'Sending your feedback…'; // restore default copy used by the v1.1 submit handler
                matchSubmitBtn.textContent = originalLabel;
                refreshSubmitBtn();
              };
              try {
                var res = await fetch('/api/feedback/match', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json' },
                  credentials: 'include',
                  body: JSON.stringify({ route: route, editList: editList }),
                  signal: controller.signal,
                });
                var data = await res.json().catch(function () { return {}; });
                if (res.status === 401) {
                  done();
                  showToast('err', 'Please sign in again to continue.', 'Your session expired.', [{ label: 'Sign in', onClick: function () { location.href = '/feedback'; } }]);
                  return;
                }
                if (!res.ok || !data.ok) {
                  done();
                  var copy = 'Couldn’t match those edits. Try again, or use per-element click mode.';
                  if (res.status === 404 && data.error === 'no_catalog') copy = "This page isn't catalogued yet. Try a different page.";
                  else if (res.status === 422 && data.cap === 'edit-list-chars') copy = 'That edit list is too long. Try splitting it into smaller batches.';
                  else if (res.status === 422 && data.cap === 'catalog-elements') copy = 'This page has too many editable elements for one match. Contact Monty.';
                  else if (res.status === 422 && data.error === 'empty_edit_list') copy = 'Add at least one edit before matching.';
                  else if (res.status === 500 && data.error === 'matcher_unavailable') copy = 'The matcher is offline. Use per-element click mode instead.';
                  showToast('err', 'Match failed', copy, [{ label: 'OK', ghost: true, onClick: hideToast }]);
                  return;
                }
                // Success — stash matchSet (D-03..D-05) and reload the per-page iframe
                var matchSet = {
                  id: data.matchSetId,
                  route: route,
                  buildSha: data.buildSha,
                  createdAt: new Date().toISOString(),
                  editList: editList,
                  matches: Array.isArray(data.matches) ? data.matches : [],
                  rowStates: (Array.isArray(data.matches) ? data.matches : []).map(function (_, i) { return { lineIndex: i, status: 'pending', manualLocator: null }; }),
                };
                try { sessionStorage.setItem(MATCH_SET_KEY, JSON.stringify(matchSet)); } catch (_) { /* private mode — skip silently */ }
                // Build per-page iframe src with v, matchSet, AND matchVer query params (D-22 / OVERLAY-01 / ROADMAP SC#5).
                // matchVer is the MATCH_INJECT_VER cache-bust consumed by BaseLayout.astro's NEW sibling conditional loader
                // (Plan 03) to cache-bust /feedback-match-inject.js. Including it in the iframe src is what ROADMAP
                // Success Criterion 5 requires: "MATCH_INJECT_VER is consumed by ... feedback.astro (the iframe src builder)".
                var sep = route.indexOf('?') >= 0 ? '&' : '?';
                matchSiteFrame.src = route + sep + 'feedback=1&v=' + VER + '&matchSet=' + encodeURIComponent(data.matchSetId) + '&matchVer=' + encodeURIComponent(MVER);
                done();
                // Plan 05 takes over rendering the panel rows from the same sessionStorage entry.
                // Dispatch a custom event so Plan 05's panel renderer (also inside this IIFE) can re-render.
                window.dispatchEvent(new CustomEvent('mar:match-set-updated', { detail: { matchSetId: data.matchSetId } }));
              } catch (e) {
                done();
                showToast('err', 'Network problem', 'We couldn’t reach the matcher. Try again in a moment.', [{ label: 'OK', ghost: true, onClick: hideToast }]);
              }
            });
          })();
        </script>
      </>
    )}
  </body>
</html>
