                    iframe.contentWindow.postMessage({ type: 'mar-feedback-result', ok: false, auth: true }, location.origin);
                  showToast('err', 'Please sign in again', 'Your session expired. Your note is saved — sign in and resend.', [
                    { label: 'Sign in', onClick: function () { location.href = '/feedback'; } },
                  ]);
                  return;
