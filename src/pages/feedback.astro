                      ok: true,
                      ...(data.warning ? { warning: data.warning } : {}),
                      ...(Array.isArray(data.commitErrors) ? { commitErrors: data.commitErrors } : {}),
                    }, location.origin);
                  persistSubmission(data, msg.payload);
                  renderRail();
                  if (data.issueNumber) pollOne(data.issueNumber);
                  showToast(
                    'ok',
                    'Thank you — it’s on its way',
                    (data.warning ? data.warning + ' Re-attach the affected photos and resubmit.' :
                      'We’ve logged your request' +
                      (data.issueUrl ? ' (<a target="_blank" rel="noopener" href="' + data.issueUrl + '">#' + data.issueNumber + '</a>)' : '') +
                      '. Watch the Recent submissions panel below to follow it from review to live.'),
                    [{ label: 'Done', onClick: hideToast }]
