            // ---- Per-page review side panel (v1.3 Phase 8 Plan 05) ----------------
            // Block A — Catalog lookup (lazy-loaded, shared across renders)
            var matchCatalog = null; // { route, buildSha, entries: [{ id, kind, i18nKey, ... }] }
            var matchCatalogRoute = null;
            async function ensureCatalog(route) {
