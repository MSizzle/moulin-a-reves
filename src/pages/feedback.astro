                      ...(data && data.cap ? { cap: data.cap } : {}),
                      ...(data && typeof data.limit === 'number' ? { limit: data.limit } : {}),
                      ...(data && typeof data.actual === 'number' ? { actual: data.actual } : {}),
                      ...(data && data.error ? { error: data.error } : {}),
                    }, location.origin);
