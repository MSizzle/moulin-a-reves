---
import BaseLayout from '../layouts/BaseLayout.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/homepage.md', 'utf-8');
const { data: cms } = matter(raw);

const writings = [
  {
    slug: 'spring-in-barbizon',
    title: 'Spring in Barbizon: What to See When the Light Returns',
    excerpt: 'The painters came for the light. In spring, you will understand why.',
    image: '/images/explore/barbizon.webp',
    date: '2026-03-15',
    alt: 'Spring blossoms along a stone street in Barbizon village near Moulin à Rêves'
  },
  {
    slug: 'fontainebleau-forest-guide',
    title: "A Walker's Guide to Fontainebleau Forest",
    excerpt: 'Twenty-five thousand hectares of ancient oak, sandstone boulders, and trails that lead somewhere quieter.',
    image: '/images/explore/forest.webp',
    date: '2026-02-20',
    alt: 'Dappled sunlight on a forest path through Fontainebleau near Moulin à Rêves'
  },
  {
    slug: 'planning-family-reunion-france',
    title: 'How to Plan a Family Reunion in the French Countryside',
    excerpt: 'Three generations, three houses, one unforgettable week — everything we have learned about bringing families together.',
    image: '/images/outdoor-dining.webp',
    date: '2026-01-10',
    alt: 'Multi-generational family dining outdoors at Moulin à Rêves compound, Barbizon'
  }
];
---

<BaseLayout title="Moulin à Rêves — Luxury French Countryside Rental Near Paris">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": "Moulin à Rêves",
      "description": "A compound of three stone houses on the Juine River in Mereville, Essonne, one hour from Paris. Sleeps 25 across 10 bedrooms.",
      "url": "https://moulin-a-reves.com",
      "telephone": "+19176806739",
      "email": "lemoulinfrance@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Mereville",
        "addressRegion": "Essonne",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "image": cms.heroImage,
      "numberOfRooms": 10,
      "petsAllowed": true,
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Hot Tub / Jacuzzi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Gym", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Screening Room", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Electric Bikes", "value": true}
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Where is Moulin à Rêves located?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Moulin à Rêves is located in Mereville, Essonne, France, on the banks of the Juine River — one hour south of Paris by car or train."
          }
        },
        {
          "@type": "Question",
          "name": "How many guests can Moulin à Rêves accommodate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The full compound sleeps up to 25 guests across three houses: Le Moulin à Rêves (sleeps 12), The Hollywood Hideaway (sleeps 8), and La Maison de la Rivière (sleeps 5)."
          }
        },
        {
          "@type": "Question",
          "name": "Can I rent just one house at Moulin à Rêves?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, each of the three houses can be rented individually. Le Moulin (sleeps 12), The Hollywood Hideaway (sleeps 8), and La Maison de la Rivière (sleeps 5). The full compound can also be rented exclusively for groups up to 25."
          }
        },
        {
          "@type": "Question",
          "name": "Are dogs allowed at Moulin à Rêves?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, dogs are welcome at Moulin à Rêves."
          }
        },
        {
          "@type": "Question",
          "name": "Is catering available at Moulin à Rêves?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. Catering services include breakfast delivery, dinner service, and a private chef for your entire stay. Yoga, massage, and beauty treatments can also be arranged."
          }
        },
        {
          "@type": "Question",
          "name": "How far is Moulin à Rêves from Paris?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Moulin à Rêves is approximately one hour from Paris by car, and easily reachable by train via the RER C to Étréchy."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero hero--lc">
    <div class="hero__image">
      <img src={cms.heroImage} alt="Moulin à Rêves compound — stone houses with blue shutters along the millstream" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow">Mereville · Essonne · France</span>
      <h1 class="hero__title" data-i18n="home.title">Live the countryside,<br/>unhurried.</h1>
      <p class="hero__tagline" data-i18n="home.tagline">{cms.heroTagline}</p>
      <div class="hero__actions">
        <a href="/homes/" class="btn btn--white" data-i18n="home.cta">Discover the Maisons</a>
        <a href="/contact/" class="btn btn--ghost">Speak with the Concierge</a>
      </div>
    </div>
  </section>

  <style>
    .hero--lc { height: 94vh; min-height: 620px; align-items: center; padding-bottom: 0; }
    .hero--lc .hero__content { display: flex; flex-direction: column; align-items: center; }
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 28px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      /* Compensate for trailing letter-spacing so centered text sits optically centered */
      padding-left: 0.28em;
    }
    .hero__actions {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
    }
    .btn--ghost {
      background: transparent;
      color: white;
      border: none;
      text-decoration: underline;
      text-underline-offset: 6px;
      text-decoration-thickness: 1px;
      text-decoration-color: rgba(255, 255, 255, 0.5);
      padding: 16px 8px;
    }
    .btn--ghost:hover {
      color: white;
      text-decoration-color: white;
    }
    @media (max-width: 768px) {
      .hero--lc { height: 80vh; min-height: 520px; }
    }
  </style>

  <!-- Introduction -->
  <section class="section--tight text-center">
    <div class="container--narrow fade-in">
      <span class="eyebrow">An Invitation</span>
      <h2 data-i18n="home.intro.heading">{cms.introHeading}</h2>
      <p data-i18n="home.intro.text" style="margin-top: 24px;">
        {cms.introText}
      </p>
    </div>
  </section>

  <!-- The Homes -->
  <section class="section">
    <div class="container text-center fade-in" style="margin-bottom: 56px;">
      <span class="eyebrow">The Compound</span>
      <h2 data-i18n="home.homes.heading">Three stone maisons. One story.</h2>
      <p data-i18n="home.homes.subheading" style="margin-top: 16px;">Each with its own character, its own view, its own reason to linger.</p>
    </div>
    <div class="container">
      <div class="grid grid--3" style="gap: 24px;">
        <a href="/homes/le-moulin/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves — historic mill house on the Juine River" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Maison One</span>
            <h3 class="card__title">Le Moulin à Rêves</h3>
            <div class="card__meta">
              <span>5 Bedrooms</span>
              <span>Sleeps 12</span>
            </div>
          </div>
        </a>
        <a href="/homes/hollywood-hideaway/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="The Hollywood Hideaway — a treasured sanctuary in the French countryside" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Maison Two</span>
            <h3 class="card__title">The Hollywood Hideaway</h3>
            <div class="card__meta">
              <span>3 Bedrooms + Suite</span>
              <span>Sleeps 8</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière — sunny cottage overlooking the stream" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Maison Three</span>
            <h3 class="card__title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span>2 Bedrooms</span>
              <span>Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 56px;">
        <a href="/the-compound/" class="link-arrow" data-i18n="home.rentall">Rent the Entire Compound</a>
      </div>
    </div>
  </section>

  <!-- Sense of Place — Editorial Split -->
  <section class="fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <span class="eyebrow">A Sense of Place</span>
        <h2>Where the light <em style="font-family: var(--font-display); font-weight: 300;">still falls</em> the way it did two centuries ago.</h2>
        <p data-i18n="home.senseof.quote">
          {cms.senseOfPlaceQuote}
        </p>
        <div>
          <a href="/explore/" class="link-arrow">Discover the Region</a>
        </div>
      </div>
      <div class="split__image">
        <img src="/images/forest-path.webp" alt="Dappled sunlight through Fontainebleau Forest near Moulin à Rêves" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Groups — Featured -->
  <section class="section">
    <div class="container">
      <a href="/the-compound/" class="card card--featured fade-in" style="text-decoration:none;color:inherit;">
        <div class="card__image">
          <img src={cms.groupsImage} alt="Group of friends dining outdoors at Moulin à Rêves compound in the French countryside" loading="lazy" />
        </div>
        <div class="card__body">
          <h2 class="card__title" data-i18n="home.groups.heading">{cms.groupsHeading}</h2>
          <p class="card__description" data-i18n="home.groups.desc">
            {cms.groupsDescription}
          </p>
          <div style="margin-top: 24px;">
            <span class="link-arrow" data-i18n="home.groups.cta">{cms.groupsCta}</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Experiences -->
  <section class="section section--soft">
    <div class="container text-center fade-in" style="margin-bottom: 56px;">
      <span class="eyebrow">The Art of Staying</span>
      <h2 data-i18n="home.experiences.heading">Your stay, composed.</h2>
      <p data-i18n="home.experiences.subheading" style="margin-top: 16px;">More than a place to sleep — a place to live well.</p>
    </div>
    <div class="container">
      <div class="grid grid--3" style="gap: 24px;">
        <a href="/catering/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/catering-table.webp" alt="Dinner table set under garden lights at Moulin à Rêves near Barbizon, France" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Experience 01</span>
            <h3 class="card__title" data-i18n="home.exp.catering.title">Catering</h3>
            <p class="card__description" style="color: rgba(255,255,255,0.85); margin-bottom: 0; font-size: 0.875rem;" data-i18n="home.exp.catering.desc">From breakfast at your door to a private chef for the weekend.</p>
          </div>
        </a>
        <a href="/wellness/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/yoga-lawn.webp" alt="Morning yoga on the lawn at Moulin à Rêves countryside retreat near Fontainebleau" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Experience 02</span>
            <h3 class="card__title" data-i18n="home.exp.wellness.title">Wellness</h3>
            <p class="card__description" style="color: rgba(255,255,255,0.85); margin-bottom: 0; font-size: 0.875rem;" data-i18n="home.exp.wellness.desc">Yoga, massage, and beauty — let someone else take care of you.</p>
          </div>
        </a>
        <a href="/explore/" class="card card--tall fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/barbizon-village.webp" alt="Barbizon village street with stone houses near Moulin à Rêves, Seine-et-Marne" loading="lazy" />
          </div>
          <div class="card__overlay">
            <span class="card__eyebrow">Experience 03</span>
            <h3 class="card__title" data-i18n="home.exp.explore.title">Explore</h3>
            <p class="card__description" style="color: rgba(255,255,255,0.85); margin-bottom: 0; font-size: 0.875rem;" data-i18n="home.exp.explore.desc">Forests, châteaux, painters' villages, and Paris — all within reach.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <style>
    .section--soft { background: var(--bg-warm-white); }
  </style>

  <!-- History Beat -->
  <section class="hero" style="height: 50vh; min-height: 400px;">
    <div class="hero__image">
      <img src="/images/forest-path.webp" alt="Ancient millstream running through stone buildings at Moulin à Rêves" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="home.history.heading" style="font-size: clamp(1.75rem, 4vw, 3rem);">{cms.historyHeading}</h2>
      <p class="hero__tagline" data-i18n="home.history.text">
        {cms.historyText}
      </p>
      <a href="/about/" class="btn btn--white" data-i18n="home.history.cta">{cms.historyCta}</a>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section section--stone">
    <div class="container text-center fade-in">
      <blockquote class="testimonial" data-i18n="home.testimonial">
        "{cms.testimonialQuote}"
      </blockquote>
      <p class="testimonial__attribution" data-i18n="home.testimonial.attribution">— {cms.testimonialAttribution}</p>
    </div>
  </section>

  <!-- Writings Carousel -->
  <section class="section writings">
    <div class="container text-center fade-in" style="margin-bottom: 48px;">
      <span class="eyebrow">From the Journal</span>
      <h2>Writings from the Compound</h2>
      <p style="margin-top: 12px;">Stories, guides, and seasonal notes from the French countryside.</p>
    </div>
    <div class="writings__carousel-wrap">
      <button class="writings__arrow writings__arrow--prev" id="writings-prev" aria-label="Previous writing">&#8249;</button>
      <div class="writings__carousel" id="writings-carousel">
        {writings.map((post) => (
          <a href={`/journal/${post.slug}/`} class="writings__card" style="text-decoration:none;color:inherit;">
            <div class="writings__image">
              <img src={post.image} alt={post.alt} loading="lazy" />
            </div>
            <div class="writings__body">
              <p class="writings__date">{new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
              <h3 class="writings__title">{post.title}</h3>
              <p class="writings__excerpt">{post.excerpt}</p>
              <span class="link-arrow">Read More</span>
            </div>
          </a>
        ))}
      </div>
      <button class="writings__arrow writings__arrow--next" id="writings-next" aria-label="Next writing">&#8250;</button>
    </div>
  </section>

  <style>
    .writings__carousel-wrap {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .writings__carousel {
      display: flex;
      gap: 24px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      padding-bottom: 8px;
    }
    .writings__carousel::-webkit-scrollbar { display: none; }
    .writings__card {
      flex: 0 0 calc((100% - 48px) / 3);
      min-width: 280px;
      scroll-snap-align: start;
      background: var(--bg-warm-white);
      display: flex;
      flex-direction: column;
      transition: transform var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
    }
    .writings__card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }
    .writings__image {
      aspect-ratio: 3 / 2;
      overflow: hidden;
    }
    .writings__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--duration) var(--ease-out);
    }
    .writings__card:hover .writings__image img { transform: scale(1.03); }
    .writings__body {
      padding: 24px;
      border-bottom: 3px solid var(--blue-primary);
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .writings__date {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-light);
      margin-bottom: 8px;
    }
    .writings__title {
      font-family: var(--font-display);
      font-size: 1.375rem;
      font-weight: 500;
      color: var(--blue-dark);
      margin-bottom: 10px;
    }
    .writings__excerpt {
      font-size: 0.9375rem;
      color: var(--text-secondary);
      margin-bottom: 14px;
      flex: 1;
    }
    .writings__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 1px solid var(--blue-primary);
      background: var(--bg-warm-white);
      color: var(--blue-dark);
      font-size: 1.5rem;
      line-height: 1;
      cursor: pointer;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background var(--duration) var(--ease-out), color var(--duration) var(--ease-out);
    }
    .writings__arrow:hover {
      background: var(--blue-primary);
      color: var(--bg-warm-white);
    }
    .writings__arrow--prev { left: -8px; }
    .writings__arrow--next { right: -8px; }
    @media (max-width: 768px) {
      .writings__card { flex: 0 0 85%; }
      .writings__arrow { display: none; }
    }
  </style>

  <script is:inline>
    (function () {
      const carousel = document.getElementById('writings-carousel');
      const prev = document.getElementById('writings-prev');
      const next = document.getElementById('writings-next');
      if (!carousel || !prev || !next) return;
      const scrollBy = () => {
        const card = carousel.querySelector('.writings__card');
        if (!card) return carousel.clientWidth;
        const style = window.getComputedStyle(carousel);
        const gap = parseFloat(style.columnGap || style.gap || '24');
        return card.getBoundingClientRect().width + gap;
      };
      prev.addEventListener('click', () => carousel.scrollBy({ left: -scrollBy(), behavior: 'smooth' }));
      next.addEventListener('click', () => carousel.scrollBy({ left: scrollBy(), behavior: 'smooth' }));
    })();
  </script>

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/evening-compound.webp" alt="Moulin à Rêves stone compound at golden hour, near Fontainebleau Forest, France" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="home.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">Plan Your Stay</h2>
      <p class="hero__tagline" data-i18n="home.cta.text">Tell us your dates, your group, your dreams. We'll take it from there.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="home.cta.button">Start Your Conversation</a>
    </div>
  </section>

</BaseLayout>
