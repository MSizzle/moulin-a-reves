---
import BaseLayout from '../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../components/AvailabilityCalendar.astro';
import matter from 'gray-matter';
import fs from 'node:fs';

const raw = fs.readFileSync('src/content/pages/homepage.md', 'utf-8');
const { data: cms } = matter(raw);

const writings = [
  {
    slug: 'spring-in-barbizon',
    title: 'Spring in Barbizon: What to See When the Light Returns',
    excerpt: 'The painters came for the light. In spring, you will understand why.',
    image: '/images/explore/barbizon.webp',
    date: '2026-03-15',
    alt: 'Spring blossoms along a stone street in Barbizon village near Moulin à Rêves'
  },
  {
    slug: 'fontainebleau-forest-guide',
    title: "A Walker's Guide to Fontainebleau Forest",
    excerpt: 'Twenty-five thousand hectares of ancient oak, sandstone boulders, and trails that lead somewhere quieter.',
    image: '/images/explore/forest.webp',
    date: '2026-02-20',
    alt: 'Dappled sunlight on a forest path through Fontainebleau near Moulin à Rêves'
  },
  {
    slug: 'planning-family-reunion-france',
    title: 'How to Plan a Family Reunion in the French Countryside',
    excerpt: 'Three generations, three houses, one unforgettable week — everything we have learned about bringing families together.',
    image: '/images/outdoor-dining.webp',
    date: '2026-01-10',
    alt: 'Multi-generational family dining outdoors at Moulin à Rêves compound'
  }
];

const compoundFeatures = [
  {
    title: 'La Grange',
    summary: 'The covered pavilion for long dinners, fireside evenings, ping pong, and gathering under the beams.',
    image: '/images/homes/la-grange-pavilion-wide.webp',
    alt: 'La Grange covered entertaining barn at Moulin à Rêves',
    gallery: [
      { src: '/images/homes/la-grange-pavilion-wide.webp', alt: 'La Grange — wide view of the open pavilion' },
      { src: '/images/homes/la-grange-pavilion.webp', alt: 'La Grange pavilion with stone fireplace and ping-pong table' },
      { src: '/images/homes/la-grange-fire.webp', alt: 'Fire crackling in the stone hearth of La Grange' },
      { src: '/images/group-dinner.webp', alt: 'Dinner laid on the long table under La Grange\'s pavilion' },
      { src: '/images/homes/la-grange-carriage.webp', alt: 'Antique horse-drawn carriage on display in La Grange' },
    ],
  },
  {
    title: 'Gardens',
    summary: 'The millstream, lawns, old stone, quiet corners, and the blue bridge over the water.',
    image: '/images/bridge-garden.webp',
    alt: 'Walled gardens and the millstream at Moulin à Rêves',
    gallery: [
      { src: '/images/bridge-garden.webp', alt: 'Giverny-style painted bridge over the stream beneath willow trees' },
      { src: '/images/garden-chaises.webp', alt: 'Garden chaise lounges facing the painted bridge' },
      { src: '/images/garden-chaises-wide.webp', alt: 'Wide garden view with chaise lounges' },
      { src: '/images/garden-chaise-jetson.webp', alt: 'Garden chaise lounges with Jetson the Cavalier' },
      { src: '/images/garden-private-spot.webp', alt: 'Private wicker bistro table in a wooded corner' },
      { src: '/images/garden-stone-well.webp', alt: 'Vine-covered antique stone well in the garden' },
      { src: '/images/garden-breakfast.webp', alt: 'Breakfast set on the patio outside the stone cottage' },
      { src: '/images/compound-river-courtyard.webp', alt: 'Stone footbridge with planter boxes over the small stream' },
      { src: '/images/evening-compound.webp', alt: 'Garden at dusk' },
      { src: '/images/personality.webp', alt: 'Marie Antoinette in the garden by the gate with a rooster' },
      { src: '/images/yoga-lawn.webp', alt: 'Morning yoga on the lawn between the houses' },
    ],
  },
  {
    title: 'Solarium & Jacuzzi',
    summary: 'A glassed-in solarium with jacuzzi — warm-weather mornings, winter evenings, year-round.',
    image: '/images/wellness-pool.webp',
    alt: 'Solarium with jacuzzi at Moulin à Rêves',
    comingSoon: true,
    gallery: [
      { src: '/images/wellness-pool.webp', alt: 'Solarium with jacuzzi at Moulin à Rêves' },
      { src: '/images/wellness-jacuzzi-2.webp', alt: 'The jacuzzi in the solarium at Moulin à Rêves' },
    ],
  },
  {
    title: 'Gym & Bikes',
    summary: 'Treadmill, elliptical, weights, boxing bag, yoga mats, and electric bikes for the village and forest.',
    image: '/images/gym.webp',
    alt: 'Private gym at Moulin à Rêves with elliptical, treadmill, and mirrored wall',
    gallery: [
      { src: '/images/gym.webp', alt: 'Gym at La Grange with elliptical, treadmill, and mirrored wall' },
      { src: '/images/homes/la-grange-gym-boxing.webp', alt: 'Gym with treadmill and Everlast boxing setup' },
      { src: '/images/homes/la-grange-bikes.webp', alt: 'Bicycles parked in La Grange under exposed wood beams' },
      { src: '/images/homes/la-grange-bikes-door.webp', alt: 'Bicycles lined up inside La Grange facing the door' },
    ],
  },
  {
    title: 'Screening Room',
    summary: 'An upstairs cinema room with leather club chairs for films, talks, and rainy afternoons.',
    image: '/images/screening-room.webp',
    alt: 'Screening room at Moulin à Rêves',
    gallery: [
      { src: '/images/screening-room.webp', alt: 'Screening room with leather club chairs facing the screen' },
      { src: '/images/homes/la-grange-screening-2.webp', alt: 'Screening room facing the leather chairs from the rear' },
    ],
  },
  // TODO(Melissa): drop chicken-coop photos in /public/images/ and append them to the gallery below.
  {
    title: 'Chicken Coop',
    summary: 'A working chicken coop. Wake up to the roosters; collect the eggs.',
    image: '/images/personality.webp',
    alt: 'Marie Antoinette near the rooster in the garden at Moulin à Rêves',
    comingSoon: true,
    gallery: [
      { src: '/images/personality.webp', alt: 'Marie Antoinette near the rooster in the garden' },
    ],
  },
];

const groupTypes = [
  { title: 'Family reunions', summary: 'Three houses, one garden — together by day, separate when needed.', image: '/images/outdoor-dining.webp', alt: 'Family dinner outdoors at Moulin à Rêves' },
  { title: 'Yoga retreats', summary: 'Lawn, La Grange, and the spa — set up for retreat hosts.', image: '/images/yoga-lawn.webp', alt: 'Morning yoga on the lawn at Moulin à Rêves' },
  { title: 'Friends trips', summary: 'Twenty beds, long dinners, the millstream, and Paris an hour away.', image: '/images/gazebo-dining.webp', alt: 'Friends gathered for evening dining at Moulin à Rêves' },
];
---

<BaseLayout title="Moulin à Rêves" description="A private historic compound of three stone maisons in Méréville, France. Sleeps 20 across 10 bedrooms. One hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": "Moulin à Rêves",
      "description": "A private historic compound of three stone houses in Méréville, France. Sleeps 20 across 10 bedrooms.",
      "url": "https://www.moulinareves.com",
      "telephone": "+19176806739",
      "email": "lemoulinfrance@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "image": cms.heroImage,
      "numberOfRooms": 10,
      "petsAllowed": true,
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Hot Tub / Jacuzzi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Gym", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Screening Room", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Electric Bikes", "value": true}
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Where is Moulin à Rêves located?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Moulin à Rêves is located in Méréville, France, on the banks of the Juine River — one hour south of Paris by car or train."
          }
        },
        {
          "@type": "Question",
          "name": "How many guests can Moulin à Rêves accommodate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The full compound sleeps up to 20 guests across three houses: Le Moulin à Rêves (sleeps 10), The Hollywood Hideaway (sleeps 7), and La Maison de la Rivière (sleeps 5)."
          }
        },
        {
          "@type": "Question",
          "name": "Can I rent just one house at Moulin à Rêves?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, each of the three houses can be rented individually, or rent the full compound for groups up to 20."
          }
        },
        {
          "@type": "Question",
          "name": "Are dogs allowed at Moulin à Rêves?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, dogs are welcome at Moulin à Rêves."
          }
        },
        {
          "@type": "Question",
          "name": "How far is Moulin à Rêves from Paris?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Approximately one hour from Paris by car, or by train from Gare d'Austerlitz to Étampes (then 15–20 minutes by taxi)."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero hero--lc">
    <div class="hero__image">
      <img src={cms.heroImage} alt="Moulin à Rêves compound — stone houses with blue shutters along the millstream" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n-html="home.title">Your Dream French Vacation Come True</h1>
      <p class="hero__tagline" data-i18n="home.tagline">Méréville · France</p>
      <div class="hero__actions">
        <a href="/the-compound/" class="btn btn--white" data-i18n="home.cta">Discover the Compound</a>
        <a href="/contact/" class="btn btn--ghost">Speak with the Concierge</a>
      </div>
    </div>
    <span class="hero__scroll" aria-hidden="true">découvrir</span>
  </section>

  <style>
    .hero--lc { height: 88vh; min-height: 580px; align-items: center; padding-bottom: 0; }
    .hero--lc .hero__content { display: flex; flex-direction: column; align-items: center; }
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
    .hero__actions {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
    }
    .btn--ghost {
      background: transparent;
      color: white;
      border: none;
      text-decoration: underline;
      text-underline-offset: 6px;
      text-decoration-thickness: 1px;
      text-decoration-color: rgba(255, 255, 255, 0.5);
      padding: 16px 8px;
    }
    .btn--ghost:hover {
      color: white;
      text-decoration-color: white;
    }
    @media (max-width: 768px) {
      .hero--lc { height: 76vh; min-height: 480px; }
    }
    .section--tighter { padding-top: 36px; padding-bottom: 36px; }

    /* Tile pill: low-key "more photos coming" indicator */
    .compound-tile__media { position: relative; }
    .compound-tile__pill {
      position: absolute;
      bottom: 10px;
      left: 10px;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 5px 10px;
      background: rgba(255, 255, 255, 0.86);
      color: var(--ink);
      border-radius: 999px;
      backdrop-filter: blur(2px);
      -webkit-backdrop-filter: blur(2px);
      pointer-events: none;
    }

    /* Maisons hero spread — tightened so the trio sits closer to the intro */
    .maisons-section {
      padding-top: clamp(28px, 4vw, 48px);
      padding-bottom: clamp(48px, 6vw, 72px);
    }
    .maisons-eyebrow {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--ink-mute);
    }
    .maisons-intro {
      max-width: 540px;
      margin-left: auto;
      margin-right: auto;
      font-size: 1.0625rem;
      color: var(--ink-soft);
      line-height: 1.55;
    }
    .maisons-grid {
      gap: 44px !important;
    }
    .maisons-section .card__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--ink-mute);
      margin-bottom: 8px;
    }
    @media (max-width: 900px) {
      .maisons-grid { gap: 28px !important; }
    }
  </style>

  <!-- Introduction -->
  <section class="text-center" style="padding-top: 32px; padding-bottom: 8px;">
    <div class="container--narrow fade-in">
      <h2 data-i18n="home.intro.heading">{cms.introHeading}</h2>
      <p data-i18n="home.intro.text" style="margin-top: 18px;">
        {cms.introText}
      </p>
    </div>
  </section>

  <!-- Les Maisons -->
  <section class="section maisons-section" style="padding-top: 24px;">
    <div class="container text-center fade-in" style="margin-bottom: 28px;">
      <h2 data-i18n-html="home.homes.heading">Les <span class="serif-italic">Maisons</span></h2>
    </div>
    <div class="maisons-stack">
      <a href="/homes/le-moulin/" class="split split--maison fade-in">
        <div class="split__image">
          <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves — historic mill house on the Juine River" loading="lazy" />
        </div>
        <div class="split__body">
          <span class="split__eyebrow">The Mill House</span>
          <h2>Le Moulin à Rêves</h2>
          <div class="split__meta">
            <span>5 Bedrooms</span><span>4 Baths</span><span>Sleeps 10</span>
          </div>
          <p>An historic mill on the Juine River. The river runs through the house. Five bedrooms across three floors.</p>
          <span class="link-arrow">Discover Le Moulin →</span>
        </div>
      </a>
      <a href="/homes/hollywood-hideaway/" class="split split--maison split--reverse fade-in">
        <div class="split__image">
          <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway" loading="lazy" />
        </div>
        <div class="split__body">
          <span class="split__eyebrow">The Refuge</span>
          <h2>The Hollywood Hideaway</h2>
          <div class="split__meta">
            <span>3 Bedrooms + Suite</span><span>2 Baths</span><span>Sleeps 7</span>
          </div>
          <p>Three bedrooms plus a suite. The 60-year sanctuary of Hollywood's #1 power lawyer — French antiques, a covered gazebo, the compound's gardens.</p>
          <span class="link-arrow">Discover the Hideaway →</span>
        </div>
      </a>
      <a href="/homes/maison-de-la-riviere/" class="split split--maison fade-in">
        <div class="split__image">
          <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière — sunny cottage overlooking the stream" loading="lazy" />
        </div>
        <div class="split__body">
          <span class="split__eyebrow">The Garden Cottage</span>
          <h2>La Maison de la Rivière</h2>
          <div class="split__meta">
            <span>2 Bedrooms</span><span>1 Bath</span><span>Sleeps 5</span>
          </div>
          <p>Sun-drenched cottage with French doors onto the stream and apple trees. Two bedrooms, dining for 18, an authentic Louis Vuitton trunk as a coffee table.</p>
          <span class="link-arrow">Discover La Maison →</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Discover the Compound -->
  <section class="section--tighter section--soft">
    <div class="container text-center fade-in" style="margin-bottom: 24px;">
      <h2 data-i18n-html="home.compound.heading">Discover the <span class="serif-italic">Compound</span></h2>
    </div>
    <div class="container">
      <div class="compound-grid compound-grid--3">
        {compoundFeatures.map((feat, i) => (
          feat.href ? (
            <a href={feat.href} class="compound-tile fade-in">
              <div class="compound-tile__media">
                <img src={feat.image} alt={feat.alt} loading="lazy" />
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title" data-i18n={`home.compound.feat.${i}.title`}>{feat.title}</h3>
                <p class="compound-tile__summary" data-i18n={`home.compound.feat.${i}.summary`}>{feat.summary}</p>
              </div>
            </a>
          ) : feat.gallery ? (
            <div class="compound-tile compound-tile--clickable fade-in" data-gallery={JSON.stringify(feat.gallery)} role="button" tabindex="0">
              <div class="compound-tile__media">
                <img src={feat.image} alt={feat.alt} loading="lazy" />
                {feat.comingSoon && (
                  <span class="compound-tile__pill">More photos coming</span>
                )}
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title" data-i18n={`home.compound.feat.${i}.title`}>{feat.title}</h3>
                <p class="compound-tile__summary" data-i18n={`home.compound.feat.${i}.summary`}>{feat.summary}</p>
              </div>
            </div>
          ) : (
            <div class="compound-tile fade-in">
              <div class="compound-tile__media">
                <img src={feat.image} alt={feat.alt} loading="lazy" />
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title" data-i18n={`home.compound.feat.${i}.title`}>{feat.title}</h3>
                <p class="compound-tile__summary" data-i18n={`home.compound.feat.${i}.summary`}>{feat.summary}</p>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- We Make It Easy -->
  <section class="section--tighter">
    <div class="container text-center fade-in" style="margin-bottom: 24px;">
      <h2>We Make It <span class="serif-italic">Easy</span></h2>
    </div>
    <div class="container">
      <div class="showcase showcase--triple">
        <a href="/catering/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/garden-breakfast.webp" alt="Breakfast set on the patio at Moulin à Rêves — local catering and traiteurs" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Catering</h3>
            <p class="card__description">Breakfast delivery, dinner traiteurs, and private chefs — we share the contacts, you book directly.</p>
          </div>
        </a>
        <a href="/wellness/#massage" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/wellness-massage-bridge.webp" alt="Massage table by the millstream beneath the Giverny-style bridge" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Wellness</h3>
            <p class="card__description">Yoga, massages, and beauty — trusted local practitioners who travel to the compound.</p>
          </div>
        </a>
        <a href="/explore/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/explore/forest.webp" alt="Dappled sunlight on a forest path through Fontainebleau near Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Nearby Adventures</h3>
            <p class="card__description">Fontainebleau forest, Barbizon village, châteaux, day trips — everything within reach.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Groups -->
  <section class="section--tighter">
    <div class="container text-center fade-in" style="margin-bottom: 24px;">
      <h2 data-i18n="home.groups.heading">{cms.groupsHeading}</h2>
    </div>
    <div class="container">
      <div class="showcase showcase--triple">
        {groupTypes.map((g, i) => (
          <div class="card fade-in">
            <div class="card__image">
              <img src={g.image} alt={g.alt} loading="lazy" />
            </div>
            <div class="card__body">
              <h3 class="card__title" data-i18n={`home.groups.type.${i}.title`}>{g.title}</h3>
              <p class="card__description" data-i18n={`home.groups.type.${i}.summary`}>{g.summary}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center" style="margin-top: 24px;">
        <a href="/contact/" class="link-arrow" data-i18n="home.groups.cta">{cms.groupsCta}</a>
      </div>
    </div>
  </section>

  {/* History Beat — hidden for now per Melissa */}
  {false && (
    <section class="hero" style="height: auto; min-height: 380px; padding-top: 72px; padding-bottom: 72px; align-items: center;">
      <div class="hero__image">
        <img src="/images/forest-path.webp" alt="Ancient millstream running through stone buildings at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="hero__overlay"></div>
      <div class="hero__content">
        <h2 class="hero__title" data-i18n="home.history.heading" style="font-size: clamp(1.75rem, 4vw, 3rem); margin-bottom: 18px;">{cms.historyHeading}</h2>
        <p class="hero__tagline" data-i18n="home.history.text">
          {cms.historyText}
        </p>
        <a href="/about/" class="btn btn--white" data-i18n="home.history.cta">{cms.historyCta}</a>
      </div>
    </section>
  )}

  <!-- Testimonial -->
  <section class="section--tighter section--stone">
    <div class="container text-center fade-in">
      <blockquote class="testimonial" data-i18n="home.testimonial">
        "{cms.testimonialQuote}"
      </blockquote>
      <p class="testimonial__attribution" data-i18n="home.testimonial.attribution">— {cms.testimonialAttribution}</p>
    </div>
  </section>

  {/* Writings Carousel — hidden for now per Melissa */}
  {false && (
    <section class="section--tighter writings">
      <div class="container text-center fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="home.journal.heading">From the Journal</h2>
      </div>
      <div class="writings__carousel-wrap">
        <button class="writings__arrow writings__arrow--prev" id="writings-prev" aria-label="Previous writing">&#8249;</button>
        <div class="writings__carousel" id="writings-carousel">
          {writings.map((post) => (
            <a href={`/journal/${post.slug}/`} class="writings__card" style="text-decoration:none;color:inherit;">
              <div class="writings__image">
                <img src={post.image} alt={post.alt} loading="lazy" />
              </div>
              <div class="writings__body">
                <p class="writings__date">{new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
                <h3 class="writings__title">{post.title}</h3>
                <p class="writings__excerpt">{post.excerpt}</p>
                <span class="link-arrow">Read More</span>
              </div>
            </a>
          ))}
        </div>
        <button class="writings__arrow writings__arrow--next" id="writings-next" aria-label="Next writing">&#8250;</button>
      </div>
    </section>
  )}

  <style>
    .writings__carousel-wrap {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .writings__carousel {
      display: flex;
      gap: 24px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      padding-bottom: 8px;
    }
    .writings__carousel::-webkit-scrollbar { display: none; }
    .writings__card {
      flex: 0 0 calc((100% - 48px) / 3);
      min-width: 280px;
      scroll-snap-align: start;
      background: var(--bg-warm-white);
      display: flex;
      flex-direction: column;
      transition: transform var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
    }
    .writings__card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }
    .writings__image {
      aspect-ratio: 3 / 2;
      overflow: hidden;
    }
    .writings__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--duration) var(--ease-out);
    }
    .writings__card:hover .writings__image img { transform: scale(1.03); }
    .writings__body {
      padding: 24px;
      border-bottom: 3px solid var(--blue-primary);
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .writings__date {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-light);
      margin-bottom: 8px;
    }
    .writings__title {
      font-family: var(--font-display);
      font-size: 1.375rem;
      font-weight: 500;
      color: var(--blue-dark);
      margin-bottom: 10px;
    }
    .writings__excerpt {
      font-size: 0.9375rem;
      color: var(--text-secondary);
      margin-bottom: 14px;
      flex: 1;
    }
    .writings__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 1px solid var(--blue-primary);
      background: var(--bg-warm-white);
      color: var(--blue-dark);
      font-size: 1.5rem;
      line-height: 1;
      cursor: pointer;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background var(--duration) var(--ease-out), color var(--duration) var(--ease-out);
    }
    .writings__arrow:hover {
      background: var(--blue-primary);
      color: var(--bg-warm-white);
    }
    .writings__arrow--prev { left: -8px; }
    .writings__arrow--next { right: -8px; }
    @media (max-width: 768px) {
      .writings__card { flex: 0 0 85%; }
      .writings__arrow { display: none; }
    }
  </style>

  <script is:inline>
    (function () {
      const carousel = document.getElementById('writings-carousel');
      const prev = document.getElementById('writings-prev');
      const next = document.getElementById('writings-next');
      if (!carousel || !prev || !next) return;
      const scrollBy = () => {
        const card = carousel.querySelector('.writings__card');
        if (!card) return carousel.clientWidth;
        const style = window.getComputedStyle(carousel);
        const gap = parseFloat(style.columnGap || style.gap || '24');
        return card.getBoundingClientRect().width + gap;
      };
      prev.addEventListener('click', () => carousel.scrollBy({ left: -scrollBy(), behavior: 'smooth' }));
      next.addEventListener('click', () => carousel.scrollBy({ left: scrollBy(), behavior: 'smooth' }));
    })();
  </script>

  <!-- Discover the Area (moved to bottom) -->
  <section class="section--tighter section--soft">
    <div class="container text-center fade-in" style="margin-bottom: 32px;">
      <h2 data-i18n-html="home.area.heading">Discover the <span class="serif-italic">Area</span></h2>
      <p data-i18n="home.area.intro" style="margin-top: 12px;">Forests, châteaux, painters' villages, and Paris — all within reach.</p>
    </div>
    <div class="container">
      <div class="showcase showcase--triple">
        <a href="/explore/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/barbizon-village.webp" alt="Barbizon village street near Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="home.area.barbizon">Barbizon</h3>
          </div>
        </a>
        <a href="/explore/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/explore/forest.webp" alt="Fontainebleau Forest near Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="home.area.forest">Fontainebleau Forest</h3>
          </div>
        </a>
        <a href="/explore/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/explore/paris.webp" alt="Paris an hour from Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="home.area.paris">Paris (1 hr)</h3>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 42vh; min-height: 320px;">
    <div class="hero__image">
      <img src="/images/evening-compound.webp" alt="Moulin à Rêves stone compound at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="home.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">Plan Your Stay</h2>
      <p class="hero__tagline" data-i18n="home.cta.text">Tell us your dates, your group, your dreams.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="home.cta.button">Start Your Conversation</a>
    </div>
  </section>

  <!-- Availability Calendar (moved to the bottom, under Plan Your Stay) -->
  <AvailabilityCalendar
    monthsToShow={6}
    eyebrow=""
    heading={`When You Can <span class="serif-italic">Stay</span>`}
    intro="Live calendar synced from Airbnb and VRBO. Greyed dates are booked."
    compact
    i18nKey="home.availability"
  />

</BaseLayout>
