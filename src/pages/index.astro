---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Moulin à Rêves — Luxury French Countryside Rental Near Paris">

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Moulin à Rêves compound — stone houses with blue shutters along the millstream" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title">Moulin à Rêves</h1>
      <p class="hero__tagline">Three homes. One unforgettable stay. One hour from Paris.</p>
      <div class="hero__cta">
        <a href="/homes/" class="btn btn--white">Explore the Homes</a>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section text-center">
    <div class="container--narrow fade-in">
      <h2>Where the millstream meets your morning coffee</h2>
      <p style="margin-top: 24px;">
        Moulin à Rêves is a compound of three stone houses gathered around a millstream
        in the French countryside, one hour south of Paris. Each home has its own character —
        blue shutters, garden views, and the quiet hum of water over stone — but together,
        they become something greater: a place where families reconnect, friends gather,
        and mornings stretch long.
      </p>
    </div>
  </section>

  <!-- The Homes -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <h2>The Homes</h2>
        <p style="margin-top: 12px;">Three houses, each with a story of its own.</p>
      </div>
      <div class="grid grid--3">
        <a href="/homes/le-moulin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin — stone mill house with blue shutters" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Moulin</h3>
            <p class="card__description">The heart of the compound. A stone mill house where thick walls keep summer cool and the millstream runs just outside.</p>
            <div class="card__meta">
              <span>3 Bedrooms</span>
              <span>Sleeps 6</span>
              <span>150 m&sup2;</span>
            </div>
          </div>
        </a>
        <a href="/homes/la-grange/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="La Grange — converted stone barn with garden views" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Grange</h3>
            <p class="card__description">A converted stone barn with soaring ceilings, an open kitchen, and doors that open straight onto the garden.</p>
            <div class="card__meta">
              <span>3 Bedrooms</span>
              <span>Sleeps 6</span>
              <span>140 m&sup2;</span>
            </div>
          </div>
        </a>
        <a href="/homes/le-jardin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="Le Jardin — garden cottage surrounded by flowers" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Jardin</h3>
            <p class="card__description">The quietest of the three. A garden cottage wrapped in wisteria, with a terrace made for long afternoons.</p>
            <div class="card__meta">
              <span>3 Bedrooms</span>
              <span>Sleeps 6</span>
              <span>130 m&sup2;</span>
            </div>
          </div>
        </a>
      </div>
      <div class="text-center" style="margin-top: 48px;">
        <a href="/the-compound/" class="link-arrow">Rent the Entire Compound</a>
      </div>
    </div>
  </section>

  <!-- Sense of Place -->
  <section class="hero" style="height: 50vh; min-height: 400px;">
    <div class="hero__image">
      <img src="/images/forest-path.webp" alt="Forest path near Fontainebleau — dappled sunlight through ancient trees" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__tagline" style="font-family: var(--font-display); font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-style: italic;">
        "At the edge of Fontainebleau Forest, in the land that inspired the Barbizon painters,<br />where the light still falls the way it did two centuries ago."
      </p>
    </div>
  </section>

  <!-- Experiences -->
  <section class="section">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <h2>Your Stay, Your Way</h2>
        <p style="margin-top: 12px;">More than a place to sleep — a place to live well.</p>
      </div>
      <div class="grid grid--4">
        <a href="/catering/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/catering-table.webp" alt="Dinner table set under garden lights" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Catering</h3>
            <p class="card__description">From breakfast at your door to a private chef for the weekend.</p>
          </div>
        </a>
        <a href="/wellness/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/yoga-lawn.webp" alt="Morning yoga on the lawn" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Wellness</h3>
            <p class="card__description">Yoga, massage, and beauty — let someone else take care of you.</p>
          </div>
        </a>
        <a href="/explore/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/barbizon-village.webp" alt="Barbizon village street" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Explore</h3>
            <p class="card__description">Forests, châteaux, painters' villages, and Paris — all within reach.</p>
          </div>
        </a>
        <a href="/the-compound/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/group-dinner.webp" alt="Group of friends dining outdoors" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Events</h3>
            <p class="card__description">Reunions, retreats, celebrations — space for up to 20 guests.</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section section--stone">
    <div class="container text-center fade-in">
      <blockquote class="testimonial">
        "We came for a family reunion and left as a closer family. The houses, the stream,
        the long dinners in the garden — it was everything we'd hoped for and more.
        The children still talk about the forest."
      </blockquote>
      <p class="testimonial__attribution">— Sophie & Laurent, August 2025</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 45vh; min-height: 350px;">
    <div class="hero__image">
      <img src="/images/evening-compound.webp" alt="Moulin à Rêves at golden hour" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" style="font-size: clamp(2rem, 4vw, 3rem);">Plan Your Stay</h2>
      <p class="hero__tagline">Tell us your dates, your group, your dreams. We'll take it from there.</p>
      <a href="/contact/" class="btn btn--white">Start Your Conversation</a>
    </div>
  </section>

</BaseLayout>
