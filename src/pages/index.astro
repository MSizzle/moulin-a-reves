---
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from '../components/Img.astro';
import matter from 'gray-matter';
import fs from 'node:fs';
import { exploreEstateFeatures } from '../data/explore-estate';

const raw = fs.readFileSync('src/content/pages/homepage.md', 'utf-8');
const { data: cms } = matter(raw);

const writings = [
  {
    slug: 'planning-family-reunion-france',
    title: 'How to Plan a Family Reunion in the French Countryside',
    excerpt: 'Three generations, three houses, one unforgettable week — everything we have learned about bringing families together.',
    image: '/images/outdoor-dining.webp',
    date: '2026-01-10',
    alt: 'Multi-generational family dining outdoors at Moulin à Rêves compound'
  }
];

// Explore the Estate — six estate-wide tiles shared with the house pages
// (single source of truth in src/data/explore-estate.ts so they can't drift).
const compoundFeatures = exploreEstateFeatures;

const groupTypes = [
  { title: 'Family reunions', image: '/images/family-reunions.webp', alt: 'Family gathered for a celebration under La Grange at Moulin à Rêves' },
  { title: 'Yoga Retreats', image: '/images/wellness-yoga-hideaway.webp', alt: 'Yoga practice on the lawn beside the Hollywood Hideaway at Moulin à Rêves' },
  { title: 'Celebrations with Friends', image: '/images/group-bbq.webp', alt: 'Friends raising a toast outside Hollywood Hideaway at Moulin à Rêves' },
];
---

<BaseLayout title="Moulin à Rêves" description="A private historic compound of three stone maisons in Méréville, France. Welcomes up to 20 guests across 10 bedrooms. One hour from Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LodgingBusiness",
      "name": "Moulin à Rêves",
      "description": "A private historic compound of three stone houses in Méréville, France. Welcomes up to 20 guests across 10 bedrooms.",
      "url": "https://www.moulinareves.com",
      "telephone": "+13474503786",
      "email": "lemoulinfrance@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "14, 16, 18 Rue des Crocs au Renard",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "image": cms.heroImage,
      "numberOfRooms": 10,
      "petsAllowed": true,
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Hot Tub / Jacuzzi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Gym", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Screening Room", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Electric Bikes", "value": true}
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Where is Moulin à Rêves located?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Moulin à Rêves is located in Méréville, France, on the banks of the Juine River — one hour south of Paris by car or train."
          }
        },
        {
          "@type": "Question",
          "name": "How many guests can Moulin à Rêves accommodate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Le Moulin sleeps 10, The Hollywood Hideaway sleeps 6, and La Maison de la Rivière sleeps 4. To preserve an exceptional sense of privacy and space, the estate welcomes a maximum of 20 lodging guests."
          }
        },
        {
          "@type": "Question",
          "name": "Can I rent just one house at Moulin à Rêves?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, each of the three houses can be rented individually, or rent the full compound, which welcomes a maximum of 20 lodging guests."
          }
        },
        {
          "@type": "Question",
          "name": "Are dogs allowed at Moulin à Rêves?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, dogs are welcome at Moulin à Rêves."
          }
        },
        {
          "@type": "Question",
          "name": "How far is Moulin à Rêves from Paris?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Approximately one hour from Paris by car, or by train from Gare d'Austerlitz to Étampes (then 15–20 minutes by taxi)."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Hero — unfiltered image with the wordmark set below it (client 6pm note) -->
  <section class="hero-lc">
    <div class="hero-lc__image">
      <Img src={cms.heroImage} alt="Moulin à Rêves compound — stone houses with blue shutters along the millstream" sizes="100vw" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero-lc__content text-center">
      <h1 class="hero-lc__title" data-i18n-html="home.title">Moulin à Rêves</h1>
      <p class="hero-lc__tagline" data-i18n="home.subtitle">The Mill of Dreams</p>
      <p class="hero-lc__location" data-i18n="home.hero.location">Méréville, France</p>
    </div>
  </section>

  <style>
    /* Home hero — full-bleed unfiltered image, wordmark set below on cream */
    .hero-lc { background: var(--bg-cream); }
    .hero-lc__image {
      width: 100%;
      height: clamp(520px, 76vh, 940px);
      overflow: hidden;
    }
    .hero-lc__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .hero-lc__content {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      max-width: min(1280px, 94vw);
      margin: 0 auto;
      padding: clamp(28px, 4vw, 48px) 24px clamp(8px, 2vw, 20px);
    }
    /* Each line centers as a shrink-wrapped flex item — independent of the
       global `p { max-width: 65ch }` rule and per-element margin shorthands. */
    .hero-lc__content > * { max-width: 100%; }
    .hero-lc__title {
      font-family: var(--font-serif);
      font-size: clamp(2.25rem, 5vw, 5.5rem);
      font-weight: 400;
      color: var(--ink);
      letter-spacing: -0.015em;
      line-height: 1.04;
      margin: 0;
    }
    @media (min-width: 900px) {
      .hero-lc__title { white-space: nowrap; }
    }
    .hero-lc__tagline {
      font-family: var(--font-serif);
      font-size: clamp(1.3125rem, 2.4vw, 2.0625rem);
      font-weight: 400;
      line-height: 1.3;
      color: var(--ink-soft);
      margin: 10px 0 0;
    }
    .hero-lc__location {
      font-family: var(--font-body);
      font-size: 0.8125rem;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--ink-mute);
      margin: 16px 0 0;
      /* compensate the trailing letter-spacing so the uppercase line sits truly centered */
      padding-left: 0.24em;
    }
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
    .hero__actions {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
    }
    .btn--ghost {
      background: transparent;
      color: white;
      border: none;
      text-decoration: underline;
      text-underline-offset: 6px;
      text-decoration-thickness: 1px;
      text-decoration-color: rgba(255, 255, 255, 0.5);
      padding: 16px 8px;
    }
    .btn--ghost:hover {
      color: white;
      text-decoration-color: white;
    }
    @media (max-width: 768px) {
      .hero--lc { height: 76vh; min-height: 480px; }
    }
    .section--tighter { padding-top: 36px; padding-bottom: 36px; }

    /* Tile pill: low-key "more photos coming" indicator */
    .compound-tile__media { position: relative; }
    .compound-tile__pill {
      position: absolute;
      bottom: 10px;
      left: 10px;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 5px 10px;
      background: rgba(255, 255, 255, 0.86);
      color: var(--ink);
      border-radius: 999px;
      backdrop-filter: blur(2px);
      -webkit-backdrop-filter: blur(2px);
      pointer-events: none;
    }

    /* Maisons hero spread — tightened so the trio sits closer to the intro */
    .maisons-section {
      padding-top: clamp(28px, 4vw, 48px);
      padding-bottom: clamp(48px, 6vw, 72px);
    }
    .maisons-eyebrow {
      display: inline-block;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--ink-mute);
    }
    .maisons-intro {
      max-width: 880px;
      margin-left: auto;
      margin-right: auto;
      font-size: 1.0625rem;
      color: var(--ink-soft);
      line-height: 1.55;
    }
    .maisons-grid {
      gap: 44px !important;
    }
    .maisons-section .card__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--ink-mute);
      margin-bottom: 8px;
    }
    @media (max-width: 900px) {
      .maisons-grid { gap: 28px !important; }
    }
  </style>

  <!-- Introduction -->
  <section class="text-center" style="padding-top: 32px; padding-bottom: 8px;">
    <div class="container--narrow fade-in">
      <p data-i18n="home.intro.text">
        {cms.introText}
      </p>
    </div>
  </section>

  <!-- Full-width Giverny bridge band -->
  <section style="margin: 8px 0 0;">
    <Img src="/images/homepage-giverny-bridge.webp" alt="The Giverny-style bridge over the millstream at Moulin à Rêves" sizes="100vw" style="width: 100%; height: 70vh; object-fit: cover; object-position: center 70%; display: block;" loading="lazy" />
  </section>

  <!-- The Luxury of Space -->
  <section class="text-center" style="padding-top: 36px; padding-bottom: 24px;">
    <div class="container--narrow fade-in">
      <h2 data-i18n="home.luxuryspace.heading">The Luxury of Space</h2>
      <p data-i18n="home.luxuryspace.text" style="margin-top: 20px;">Encircled by stone walls and surrounded by gardens, Moulin à Rêves offers guests beauty and privacy to relax and reconnect. Whether you come alone, as a couple, or with friends for a celebration or retreat, here you can slow down and be inspired.</p>
    </div>
  </section>

  <!-- Les Maisons -->
  <section class="section maisons-section" style="padding-top: 24px; padding-bottom: 12px;">
    <div class="container text-center fade-in" style="margin-bottom: 28px;">
      <h2 data-i18n="home.homes.heading">Discover the Homes</h2>
      <p data-i18n="home.homes.intro" class="maisons-intro" style="margin-top: 16px;">Three distinctive homes offer different ways to experience the estate. Moulin à Rêves features ten bedrooms across three homes, welcoming up to twenty lodging guests while preserving a rare sense of privacy and space.</p>
    </div>
    <div class="maisons-stack">
      <a href="/homes/le-moulin/" class="split split--maison fade-in">
        <div class="split__image">
          <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin — historic mill house on the Juine River" loading="lazy" />
        </div>
        <div class="split__body">
          <h2>Le Moulin</h2>
          <div class="split__meta">
            <span>5 Bedrooms</span><span>4 Baths</span><span>Sleeps 10</span>
          </div>
          <p>The original mill and principal residence of the estate.</p>
          <span class="link-arrow">Discover Le Moulin</span>
        </div>
      </a>
      <a href="/homes/hollywood-hideaway/" class="split split--maison split--reverse fade-in">
        <div class="split__image">
          <img src="/images/homes/hh-patio.webp" alt="The Hollywood Hideaway — breakfast table on the patio facing the blue-shuttered facade" loading="lazy" />
        </div>
        <div class="split__body">
          <h2>The Hollywood Hideaway</h2>
          <div class="split__meta">
            <span>4 Bedrooms</span><span>2 Baths</span><span>Sleeps 6</span>
          </div>
          <p>The secluded retreat once enjoyed by French and American stars.</p>
          <span class="link-arrow">Discover the Hideaway</span>
        </div>
      </a>
      <a href="/homes/maison-de-la-riviere/" class="split split--maison fade-in">
        <div class="split__image">
          <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière — sunny cottage overlooking the stream" loading="lazy" />
        </div>
        <div class="split__body">
          <h2>La Maison de la Rivière</h2>
          <div class="split__meta">
            <span>2 Bedrooms</span><span>1 Bath</span><span>Sleeps 4</span>
          </div>
          <p>The sun-drenched cottage where your cares float away.</p>
          <span class="link-arrow">Discover La Maison</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Refined Country Living — heading cleared by client (2026-06-13), section removed -->

  <!-- Discover the Compound -->
  <section class="section--tighter section--soft" style="padding-top: 8px;">
    <div class="container text-center fade-in" style="margin-bottom: 24px;">
      <h2 data-i18n="home.compound.heading">Explore the Estate</h2>
    </div>
    <div class="container">
      <div class="compound-grid compound-grid--3">
        {compoundFeatures.map((feat, i) => (
          feat.href ? (
            <a href={feat.href} class="compound-tile fade-in">
              <div class="compound-tile__media">
                <img src={feat.image} alt={feat.alt} loading="lazy" />
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title" data-i18n={`home.compound.feat.${i}.title`}>{feat.title}</h3>
                <p class="compound-tile__summary" data-i18n={`home.compound.feat.${i}.summary`}>{feat.summary}</p>
              </div>
            </a>
          ) : feat.gallery ? (
            <div class="compound-tile compound-tile--clickable fade-in" data-gallery={JSON.stringify(feat.gallery)} role="button" tabindex="0">
              <div class="compound-tile__media">
                <img src={feat.image} alt={feat.alt} loading="lazy" />
                {feat.comingSoon && (
                  <span class="compound-tile__pill">More photos coming</span>
                )}
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title" data-i18n={`home.compound.feat.${i}.title`}>{feat.title}</h3>
                <p class="compound-tile__summary" data-i18n={`home.compound.feat.${i}.summary`}>{feat.summary}</p>
              </div>
            </div>
          ) : (
            <div class="compound-tile fade-in">
              <div class="compound-tile__media">
                <img src={feat.image} alt={feat.alt} loading="lazy" />
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title" data-i18n={`home.compound.feat.${i}.title`}>{feat.title}</h3>
                <p class="compound-tile__summary" data-i18n={`home.compound.feat.${i}.summary`}>{feat.summary}</p>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- We Make It Easy -->
  <section class="section--tighter">
    <div class="container text-center fade-in" style="margin-bottom: 24px;">
      <h2>We Make It Easy</h2>
    </div>
    <div class="container">
      <div class="showcase showcase--triple">
        <a href="/catering/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-marie-antoinette.webp" alt="A Marie-Antoinette-styled feast laid on the garden patio at Moulin à Rêves — local catering and traiteurs" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Catering</h3>
            <p class="card__description">Breakfast delivery, dinner traiteurs, and private chefs — we share the contacts, you book directly.</p>
          </div>
        </a>
        <a href="/wellness/#massage" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/wellness-riverside-massage.webp" alt="Massage table on the sunlit lawn beside the millstream and blue-shuttered mill house" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Wellness</h3>
            <p class="card__description">Yoga, massages, and beauty — trusted local practitioners who travel to the compound.</p>
          </div>
        </a>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/garden-chaise-jetson.webp" alt="Jetson the Cavalier sunning on a garden chaise at Moulin à Rêves" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="home.dogs.heading">Dogs Welcome</h3>
            <p class="card__description" data-i18n="home.dogs.fee">€100 fee per dog for the length of your stay.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Groups -->
  <section class="section--tighter" style="padding-bottom: 12px;">
    <div class="container text-center fade-in" style="margin-bottom: 24px;">
      <h2 data-i18n="home.groups.heading">{cms.groupsHeading}</h2>
      <p data-i18n="home.groups.sub" style="margin-top: 12px;">A private estate designed for meaningful time together.</p>
      <p data-i18n="home.groups.events" style="margin-top: 8px; font-size: 0.95rem; opacity: 0.75;">Events welcome for up to 50 guests, including all lodging guests, for a €5,000 facility fee.</p>
    </div>
    <div class="container">
      <div class="showcase showcase--triple">
        {groupTypes.map((g, i) => (
          <a class="card fade-in" href="/groups/" style="text-decoration:none;color:inherit;">
            <div class="card__image">
              <img src={g.image} alt={g.alt} loading="lazy" />
            </div>
            <div class="card__body">
              <h3 class="card__title" data-i18n={`home.groups.type.${i}.title`}>{g.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* History Beat — hidden for now per Melissa */}
  {false && (
    <section class="hero" style="height: auto; min-height: 380px; padding-top: 72px; padding-bottom: 72px; align-items: center;">
      <div class="hero__image">
        <img src="/images/forest-path.webp" alt="Ancient millstream running through stone buildings at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="hero__overlay"></div>
      <div class="hero__content">
        <h2 class="hero__title" data-i18n="home.history.heading" style="font-size: clamp(1.75rem, 4vw, 3rem); margin-bottom: 18px;">{cms.historyHeading}</h2>
        <p class="hero__tagline" data-i18n="home.history.text">
          {cms.historyText}
        </p>
        <a href="/about/" class="btn btn--white" data-i18n="home.history.cta">{cms.historyCta}</a>
      </div>
    </section>
  )}

  {/* Writings Carousel — hidden for now per Melissa */}
  {false && (
    <section class="section--tighter writings">
      <div class="container text-center fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="home.journal.heading">From the Journal</h2>
      </div>
      <div class="writings__carousel-wrap">
        <button class="writings__arrow writings__arrow--prev" id="writings-prev" aria-label="Previous writing">&#8249;</button>
        <div class="writings__carousel" id="writings-carousel">
          {writings.map((post) => (
            <a href={`/journal/${post.slug}/`} class="writings__card" style="text-decoration:none;color:inherit;">
              <div class="writings__image">
                <img src={post.image} alt={post.alt} loading="lazy" />
              </div>
              <div class="writings__body">
                <p class="writings__date">{new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
                <h3 class="writings__title">{post.title}</h3>
                <p class="writings__excerpt">{post.excerpt}</p>
                <span class="link-arrow">Read More</span>
              </div>
            </a>
          ))}
        </div>
        <button class="writings__arrow writings__arrow--next" id="writings-next" aria-label="Next writing">&#8250;</button>
      </div>
    </section>
  )}

  <style>
    .writings__carousel-wrap {
      position: relative;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 16px;
    }
    .writings__carousel {
      display: flex;
      gap: 24px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      padding-bottom: 8px;
    }
    .writings__carousel::-webkit-scrollbar { display: none; }
    .writings__card {
      flex: 0 0 calc((100% - 48px) / 3);
      min-width: 280px;
      scroll-snap-align: start;
      background: var(--bg-warm-white);
      display: flex;
      flex-direction: column;
      transition: transform var(--duration) var(--ease-out), box-shadow var(--duration) var(--ease-out);
    }
    .writings__card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }
    .writings__image {
      aspect-ratio: 3 / 2;
      overflow: hidden;
    }
    .writings__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--duration) var(--ease-out);
    }
    .writings__card:hover .writings__image img { transform: scale(1.03); }
    .writings__body {
      padding: 24px;
      border-bottom: 3px solid var(--blue-primary);
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .writings__date {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-light);
      margin-bottom: 8px;
    }
    .writings__title {
      font-family: var(--font-display);
      font-size: 1.375rem;
      font-weight: 500;
      color: var(--blue-dark);
      margin-bottom: 10px;
    }
    .writings__excerpt {
      font-size: 0.9375rem;
      color: var(--text-secondary);
      margin-bottom: 14px;
      flex: 1;
    }
    .writings__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      width: 44px;
      height: 44px;
      border-radius: 50%;
      border: 1px solid var(--blue-primary);
      background: var(--bg-warm-white);
      color: var(--blue-dark);
      font-size: 1.5rem;
      line-height: 1;
      cursor: pointer;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background var(--duration) var(--ease-out), color var(--duration) var(--ease-out);
    }
    .writings__arrow:hover {
      background: var(--blue-primary);
      color: var(--bg-warm-white);
    }
    .writings__arrow--prev { left: -8px; }
    .writings__arrow--next { right: -8px; }
    @media (max-width: 768px) {
      .writings__card { flex: 0 0 85%; }
      .writings__arrow { display: none; }
    }
  </style>

  <script is:inline>
    (function () {
      const carousel = document.getElementById('writings-carousel');
      const prev = document.getElementById('writings-prev');
      const next = document.getElementById('writings-next');
      if (!carousel || !prev || !next) return;
      const scrollBy = () => {
        const card = carousel.querySelector('.writings__card');
        if (!card) return carousel.clientWidth;
        const style = window.getComputedStyle(carousel);
        const gap = parseFloat(style.columnGap || style.gap || '24');
        return card.getBoundingClientRect().width + gap;
      };
      prev.addEventListener('click', () => carousel.scrollBy({ left: -scrollBy(), behavior: 'smooth' }));
      next.addEventListener('click', () => carousel.scrollBy({ left: scrollBy(), behavior: 'smooth' }));
    })();
  </script>

  <!-- Discover the Area — removed per client 6pm note (flows straight to Plan Your Stay).
       Translation keys home.area.* are intentionally left in translations.json for later restore. -->

  <!-- CTA -->
  <section class="section text-center">
    <div class="container fade-in">
      <a href="/contact/" class="btn btn--green" data-i18n="home.cta.button">Join us!</a>
    </div>
  </section>


</BaseLayout>
