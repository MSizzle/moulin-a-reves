---
// DRAFT: All copy on this page is draft text seeded from /about/ and
// existing content. Owner should review ALL text before publishing.
// Art photos and final text are pending from the owner — see TODO arrays.
import BaseLayout from '../layouts/BaseLayout.astro';

// ---- Art gallery — seeded with existing repo photos showing art / antiques ----
// Prioritised: Louis Vuitton trunk living room, salon, dining rooms, interior details.
// TODO: replace / augment with owner's dedicated art photography when received.
// Drop directory convention:
//   public/images/art/   → for dedicated art/antiques photos (kebab-case.webp, max 2000px q85)
const artGallery = [
  {
    src: '/images/homes/maison-living-trunk.webp',
    alt: 'The Louis Vuitton trunk coffee table in the living room of La Maison de la Rivière',
    caption: 'The coffee table fashioned from a Louis Vuitton trunk — one of Barbara Guggenheim\'s signature pieces.',
  },
  {
    src: '/images/homes/le-moulin-living.webp',
    alt: 'The salon of Le Moulin — antiques, fabric-upholstered walls, period furnishings',
    caption: 'Le Salon at Le Moulin — 18th-century country antiques throughout.',
  },
  {
    src: '/images/homes/le-moulin-living-detail.webp',
    alt: 'Living room detail at Le Moulin showing antique furnishings and art',
    caption: 'A detail from Le Salon — each object chosen by Barbara Guggenheim.',
  },
  // TODO: add owner's dedicated art photography:
  //   - Folies Bergère poster(s) in situ
  //   - Fabric-upholstered wall detail
  //   - Louis Vuitton trunk close-up
  //   - Any antique pieces the owner wants to highlight
  //   (Drop into public/images/art/, kebab-case.webp)
];

// Lead / hero image for the art page
const heroImage = '/images/homes/maison-living-trunk.webp';
---

<BaseLayout
  title="The Art & Antiques — Moulin à Rêves"
  description="The interiors of Moulin à Rêves, curated by world-renowned art advisor Barbara Guggenheim: 18th-century country antiques, original Folies Bergère posters, and the Louis Vuitton trunk coffee table."
>

  <!-- Hero -->
  <section class="hero" style="height: 60vh;">
    <div class="hero__image">
      <img src={heroImage} alt="The Louis Vuitton trunk coffee table — La Maison de la Rivière" />
      <!-- TODO: replace hero image with owner's preferred art/antiques hero shot
           when dedicated photography arrives (drop into public/images/art/) -->
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <p class="hero__eyebrow" data-i18n="art.hero.subtitle" style="font-size: 0.875rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.8); margin-bottom: 12px;">A living collection</p>
      <h1 class="hero__title" data-i18n="art.hero.title">The Art &amp; Antiques</h1>
    </div>
  </section>

  <!-- Intro narrative -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="art.intro.heading">A Home Curated by a World-Renowned Art Advisor</h2>
      <div style="margin-top: 24px;">
        <p data-i18n="art.intro.p1" style="line-height: 1.75;">
          Together with her husband, renowned attorney Bert Fields, art advisor Barbara Guggenheim has been the loving steward of Moulin à Rêves for more than thirty years.
        </p>
        <p data-i18n="art.intro.p2" style="margin-top: 16px; line-height: 1.75;">
          Her impeccable taste and passion for collecting have infused every room of the estate with beauty, character, and a touch of whimsy. From fine oil paintings and 19th-century antiques to her beloved collections of poodle figurines and vintage scarves, Moulin à Rêves reflects decades of thoughtful collecting and loving restoration.
        </p>
        <p data-i18n="art.intro.p3" style="margin-top: 16px; line-height: 1.75;">
          Richly upholstered walls, luxurious down duvets, fine French linens, and antique furnishings create interiors that feel both elegant and inviting, enveloping guests in a sense of comfort, authenticity, and old-world French charm.
        </p>
        <p data-i18n="art.intro.p4" style="margin-top: 16px; line-height: 1.75;">
          The collection extends throughout the estate. The antique water wheel from the original mill rests in the living room. A historic farm cart stands before Le Moulin, and an antique carriage awaits in La Grange.
        </p>
        <p data-i18n="art.intro.p5" style="margin-top: 16px; line-height: 1.75;">
          These antiques and authentic touches create a special atmosphere that feels both elegant and enchanting. Moulin à Rêves is not a museum, but a cherished home where guests are invited to make themselves at home among these treasures and enjoy the timeless beauty of the estate.
        </p>
        <!-- TODO: owner to review and expand/edit narrative above; add provenance stories,
             specific pieces she wishes to highlight, notes on the Folies Bergère posters, etc. -->
      </div>
      <p style="margin-top: 32px;">
        <a href="/about/" class="link-arrow" data-i18n="art.about.link">Read the full history of Moulin à Rêves</a>
      </p>
    </div>
  </section>

  <!-- Gallery grid — hero-style lightbox -->
  <section class="section--tight section--soft">
    <div class="container--narrow fade-in text-center">
      <h2 data-i18n="art.gallery.heading">A Glimpse of the Collection</h2>
    </div>
    <!-- Art gallery grid — each tile opens the lightbox -->
    <div class="container fade-in" style="margin-top: 36px;">
      <div class="art-gallery-grid">
        {artGallery.map((item, i) => (
          <div
            class="art-gallery-tile"
            data-gallery={JSON.stringify(artGallery)}
            data-gallery-index={i}
            role="button"
            tabindex="0"
            aria-label={`View ${item.alt}`}
          >
            <div class="card__image art-gallery-tile__image">
              <img src={item.src} alt={item.alt} loading="lazy" />
            </div>
            {item.caption && (
              <p class="art-gallery-tile__caption">{item.caption}</p>
            )}
          </div>
        ))}
      </div>
    </div>
    <!-- TODO: owner to add dedicated art/antiques photos to public/images/art/
         and update artGallery array above with new entries. -->
  </section>

  <!-- Cross-link back to /about/ -->
  <section class="section--tight">
    <div class="container--narrow fade-in text-center">
      <p style="font-family: var(--font-serif); font-style: italic; font-size: 1.125rem; line-height: 1.6; max-width: 56ch; margin: 0 auto;">
        The story of Moulin à Rêves begins with Vaudeville legend Borrah Minevitch, runs through Hollywood, and arrives in the hands of Barbara Guggenheim — who made these rooms what they are today.
        <!-- TODO: owner to review / replace this bridge sentence -->
      </p>
      <p style="margin-top: 24px;">
        <a href="/about/" class="link-arrow" data-i18n="art.about.link">Read the full history of Moulin à Rêves</a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section--tight fade-in text-center">
    <div class="container">
      <a href="/contact/" class="btn btn--green" data-i18n="art.cta.button">Join us</a>
    </div>
  </section>

  <style>
    .art-gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(16px, 2.5vw, 28px);
    }
    @media (max-width: 768px) {
      .art-gallery-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
      .art-gallery-grid { grid-template-columns: 1fr; }
    }
    .art-gallery-tile {
      cursor: zoom-in;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .art-gallery-tile:focus-visible {
      outline: 2px solid var(--blue-primary);
      outline-offset: 2px;
    }
    .art-gallery-tile__image {
      position: relative;
      overflow: hidden;
      aspect-ratio: 4 / 3;
      background: var(--bg-stone);
    }
    .art-gallery-tile__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.35s ease;
    }
    .art-gallery-tile:hover .art-gallery-tile__image img {
      transform: scale(1.04);
    }
    /* Overlay hover effect */
    .art-gallery-tile__image::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(15,15,15,0.32) 0%, rgba(15,15,15,0) 50%);
      opacity: 0;
      transition: opacity 0.25s ease;
      z-index: 2;
      pointer-events: none;
    }
    .art-gallery-tile:hover .art-gallery-tile__image::before { opacity: 1; }
    .art-gallery-tile__caption {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--ink-soft);
      margin: 0;
    }
  </style>

  <!-- Wire gallery tiles: clicking any tile opens the lightbox at that index -->
  <script is:inline>
    (function () {
      document.querySelectorAll('.art-gallery-tile[data-gallery]').forEach(function (tile) {
        tile.addEventListener('click', function () {
          var raw = tile.dataset.gallery;
          var startIndex = parseInt(tile.dataset.galleryIndex || '0', 10);
          if (!raw) return;
          try {
            var items = JSON.parse(raw);
            items = items.map(function (it) {
              if (typeof it === 'string') return { src: it, alt: '', caption: '' };
              return it;
            });
            // Trigger via the global data-gallery handler by injecting a temporary element
            var tmp = document.createElement('div');
            tmp.setAttribute('data-gallery', JSON.stringify(items));
            tmp.setAttribute('data-gallery-start', String(startIndex));
            tmp.style.display = 'none';
            document.body.appendChild(tmp);
            // Dispatch a click so the global handler in BaseLayout picks it up
            tmp.click();
            document.body.removeChild(tmp);
          } catch (_) {}
        });
        tile.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); tile.click(); }
        });
      });
    })();
  </script>

</BaseLayout>
