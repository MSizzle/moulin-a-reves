---
import BaseLayout from '../layouts/BaseLayout.astro';
import AvailabilityCalendar from '../components/AvailabilityCalendar.astro';
---

<BaseLayout title="Contact — Moulin à Rêves" description="Get in touch with Moulin à Rêves. Inquire about availability, pricing, and services for your stay in the French countryside near Paris.">

  <!-- Hero -->
  <section class="hero" style="height: 50vh;">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Blue front door of one of the Moulin à Rêves stone houses near Barbizon, France" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="contact.hero.title">Join us!</h1>
    </div>
  </section>

  <!-- Form + Contact Info -->
  <section class="section">
    <div class="container">
      <div class="grid grid--2" style="gap: 64px;">

        <!-- Form -->
        <div class="fade-in">
          <h2 data-i18n="contact.form.heading">Bienvenue!</h2>
          <p data-i18n="contact.form.intro" style="margin-top: 12px; margin-bottom: 32px;">
            Fill out the form below and we'll respond within 24 hours with availability and a personalised proposal.
          </p>

          <form id="contact-form">
            <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="form__group">
              <label class="form__label" data-i18n="contact.form.name" for="name">Your Name</label>
              <input type="text" id="name" name="name" class="form__input" required />
            </div>

            <div class="form__group">
              <label class="form__label" data-i18n="contact.form.email" for="email">Email</label>
              <input type="email" id="email" name="email" class="form__input" required />
            </div>

            <div class="grid grid--2" style="gap: 16px;">
              <div class="form__group">
                <label class="form__label" data-i18n="contact.form.checkin" for="checkin">Check-in</label>
                <input type="date" id="checkin" name="checkin" class="form__input" />
              </div>
              <div class="form__group">
                <label class="form__label" data-i18n="contact.form.checkout" for="checkout">Check-out</label>
                <input type="date" id="checkout" name="checkout" class="form__input" />
              </div>
            </div>

            <div class="form__group">
              <label class="form__label" data-i18n="contact.form.group">Your Group</label>
              <div class="guest-counters">
                <div class="guest-counter">
                  <span class="guest-counter__label" data-i18n="contact.form.adults">Adults</span>
                  <div class="guest-counter__controls">
                    <button type="button" class="guest-counter__btn" data-target="adults" data-action="decrease" aria-label="Decrease adults">−</button>
                    <input type="number" id="adults" name="adults" class="guest-counter__value" value="2" min="1" max="20" readonly />
                    <button type="button" class="guest-counter__btn" data-target="adults" data-action="increase" aria-label="Increase adults">+</button>
                  </div>
                </div>
                <div class="guest-counter">
                  <span class="guest-counter__label" data-i18n="contact.form.children">Children</span>
                  <div class="guest-counter__controls">
                    <button type="button" class="guest-counter__btn" data-target="children" data-action="decrease" aria-label="Decrease children">−</button>
                    <input type="number" id="children" name="children" class="guest-counter__value" value="0" min="0" max="20" readonly />
                    <button type="button" class="guest-counter__btn" data-target="children" data-action="increase" aria-label="Increase children">+</button>
                  </div>
                </div>
                <div class="guest-counter">
                  <span class="guest-counter__label" data-i18n="contact.form.dogs">Dogs</span>
                  <div class="guest-counter__controls">
                    <button type="button" class="guest-counter__btn" data-target="dogs" data-action="decrease" aria-label="Decrease dogs">−</button>
                    <input type="number" id="dogs" name="dogs" class="guest-counter__value" value="0" min="0" max="5" readonly />
                    <button type="button" class="guest-counter__btn" data-target="dogs" data-action="increase" aria-label="Increase dogs">+</button>
                  </div>
                </div>
              </div>
            </div>

            <div class="form__group">
              <label class="form__label" data-i18n="contact.form.houses" for="houses">Which House(s)?</label>
              <select id="houses" name="houses" class="form__select">
                <option value="all-three" selected data-i18n="contact.form.houses.all">Rent the Compound (all three houses)</option>
                <option value="le-moulin">Le Moulin</option>
                <option value="hollywood-hideaway">The Hollywood Hideaway</option>
                <option value="maison-de-la-riviere">La Maison de la Rivière</option>
                <option value="two-houses" data-i18n="contact.form.houses.two">Two Houses</option>
                <option value="not-sure" data-i18n="contact.form.houses.notsure">Not Sure Yet</option>
              </select>
            </div>

            <div class="form__group">
              <label class="form__label" data-i18n="contact.form.message" for="message">Your Message</label>
              <textarea id="message" name="message" class="form__textarea" placeholder="Tell us about your trip — occasion, interests, any services you'd like (catering, wellness, etc.)..."></textarea>
            </div>

            <button type="submit" class="btn btn--primary" data-i18n="contact.form.submit">Send Your Inquiry</button>
          </form>
        </div>

        <!-- Contact Info + Directions -->
        <div>
          <div class="fade-in">
            <h2 data-i18n="contact.details.heading">Contact Details</h2>
            <div style="margin-top: 24px;">
              <h4 data-i18n="contact.details.email">Email</h4>
              <p><a href="mailto:lemoulinfrance@gmail.com">lemoulinfrance@gmail.com</a></p>
            </div>
            <div style="margin-top: 20px;">
              <h4 data-i18n="contact.details.phone">Phone</h4>
              <p><a href="tel:+13474503786">+1 (347) 450-3786</a></p>
            </div>
            <div style="margin-top: 20px;">
              <h4 data-i18n="contact.details.address">Address</h4>
              <p data-i18n-html="contact.details.addressLines">14, 16, 18 Rue des Crocs au Renard<br />91660 Le Mérévillois</p>
            </div>
          </div>

          <div class="fade-in" style="margin-top: 40px;">
            <h2 data-i18n="contact.getting.heading">Getting Here</h2>
            <p data-i18n="contact.getting.summary" style="margin-top: 16px;">
              About 1 hour from Paris by car or train. <a href="/about/#getting-here">See the full directions FAQ →</a> for airport transfers, train options, taxis, ride apps, and car rental.
            </p>
          </div>

          <!-- Map -->
          <div class="fade-in" style="margin-top: 40px;">
            <div style="overflow: hidden; height: 350px; border-radius: 4px;">
              <iframe
                src="https://www.google.com/maps?q=14+Rue+des+Crocs+au+Renard,+91660+Le+M%C3%A9r%C3%A9villois,+France&z=14&output=embed"
                style="border: 0; width: 100%; height: 100%;"
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                allowfullscreen
                title="Map showing Moulin à Rêves in Le Mérévillois, France"
              ></iframe>
            </div>
            <p data-i18n="contact.map.caption" style="margin-top: 8px; font-size: 0.8125rem; color: var(--text-light);">
              Méréville, France &middot; One hour south of Paris
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Live Availability — heading omitted; the hero already greets with "Join us!" -->
  <AvailabilityCalendar
    monthsToShow={12}
    eyebrow=""
    heading=""
    intro=""
  />

<style>
  .guest-counters {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .guest-counter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex: 1;
    min-width: 200px;
    background: var(--bg-warm-white);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 4px;
    padding: 10px 14px;
  }

  .guest-counter__label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .guest-counter__controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .guest-counter__btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--blue-primary);
    background: transparent;
    color: var(--blue-primary);
    font-size: 1.125rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    line-height: 1;
  }

  .guest-counter__btn:hover {
    background: var(--blue-primary);
    color: white;
  }

  .guest-counter__value {
    width: 32px;
    text-align: center;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    border: none;
    background: transparent;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .guest-counter__value::-webkit-outer-spin-button,
  .guest-counter__value::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  input[type="date"] {
    color-scheme: light;
  }

  @media (max-width: 768px) {
    .guest-counters {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>

<script>
  document.querySelectorAll('.guest-counter__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      const action = btn.dataset.action;
      const input = document.getElementById(target) as HTMLInputElement;
      if (!input) return;

      let value = parseInt(input.value) || 0;
      const min = parseInt(input.min) || 0;
      const max = parseInt(input.max) || 20;

      if (action === 'increase' && value < max) {
        input.value = String(value + 1);
      } else if (action === 'decrease' && value > min) {
        input.value = String(value - 1);
      }
    });
  });

  // Set min date to today
  const today = new Date().toISOString().split('T')[0];
  const checkin = document.getElementById('checkin') as HTMLInputElement;
  const checkout = document.getElementById('checkout') as HTMLInputElement;
  if (checkin) checkin.min = today;
  if (checkout) checkout.min = today;

  // Sync checkout min to checkin value
  checkin?.addEventListener('change', () => {
    if (checkout && checkin.value) {
      checkout.min = checkin.value;
      if (checkout.value && checkout.value < checkin.value) {
        checkout.value = checkin.value;
      }
    }
  });

  // Submit to Airtable via API route
  const contactForm = document.getElementById('contact-form') as HTMLFormElement;
  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const bot = (contactForm.querySelector('[name="bot-field"]') as HTMLInputElement)?.value;
    if (bot) return;

    const btn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: (document.getElementById('name') as HTMLInputElement).value,
          email: (document.getElementById('email') as HTMLInputElement).value,
          checkin: (document.getElementById('checkin') as HTMLInputElement).value,
          checkout: (document.getElementById('checkout') as HTMLInputElement).value,
          adults: (document.getElementById('adults') as HTMLInputElement).value,
          children: (document.getElementById('children') as HTMLInputElement).value,
          dogs: (document.getElementById('dogs') as HTMLInputElement).value,
          houses: (document.getElementById('houses') as HTMLSelectElement).value,
          message: (document.getElementById('message') as HTMLTextAreaElement).value,
        }),
      });
      if (res.ok) {
        window.location.href = '/success/';
      } else {
        btn.disabled = false;
        btn.textContent = 'Send Your Inquiry';
        alert('Something went wrong. Please try again or email us directly.');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Send Your Inquiry';
      alert('Something went wrong. Please try again or email us directly.');
    }
  });
</script>

</BaseLayout>
