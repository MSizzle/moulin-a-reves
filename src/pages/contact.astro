---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact — Moulin à Rêves" description="Get in touch with Moulin à Rêves. Inquire about availability, pricing, and services for your stay in the French countryside near Paris.">

  <!-- Hero -->
  <section class="hero" style="height: 50vh;">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Blue front door of one of the Moulin à Rêves houses" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title">Get in Touch</h1>
      <p class="hero__tagline">Tell us your dates, your group, your dreams. We'll take it from there.</p>
    </div>
  </section>

  <!-- Form + Contact Info -->
  <section class="section">
    <div class="container">
      <div class="grid grid--2" style="gap: 64px;">

        <!-- Form -->
        <div class="fade-in">
          <h2>Start Your Conversation</h2>
          <p style="margin-top: 12px; margin-bottom: 32px;">
            Fill out the form below and we'll respond within 24 hours with availability and a personalised proposal.
          </p>

          <form name="contact" method="POST" action="/success/" data-netlify="true" netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="contact" />
            <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="form__group">
              <label class="form__label" for="name">Your Name</label>
              <input type="text" id="name" name="name" class="form__input" required />
            </div>

            <div class="form__group">
              <label class="form__label" for="email">Email</label>
              <input type="email" id="email" name="email" class="form__input" required />
            </div>

            <div class="grid grid--2" style="gap: 16px;">
              <div class="form__group">
                <label class="form__label" for="checkin">Check-in</label>
                <input type="date" id="checkin" name="checkin" class="form__input" />
              </div>
              <div class="form__group">
                <label class="form__label" for="checkout">Check-out</label>
                <input type="date" id="checkout" name="checkout" class="form__input" />
              </div>
            </div>

            <div class="form__group">
              <label class="form__label">Your Group</label>
              <div class="guest-counters">
                <div class="guest-counter">
                  <span class="guest-counter__label">Adults</span>
                  <div class="guest-counter__controls">
                    <button type="button" class="guest-counter__btn" data-target="adults" data-action="decrease" aria-label="Decrease adults">−</button>
                    <input type="number" id="adults" name="adults" class="guest-counter__value" value="2" min="1" max="20" readonly />
                    <button type="button" class="guest-counter__btn" data-target="adults" data-action="increase" aria-label="Increase adults">+</button>
                  </div>
                </div>
                <div class="guest-counter">
                  <span class="guest-counter__label">Children</span>
                  <div class="guest-counter__controls">
                    <button type="button" class="guest-counter__btn" data-target="children" data-action="decrease" aria-label="Decrease children">−</button>
                    <input type="number" id="children" name="children" class="guest-counter__value" value="0" min="0" max="20" readonly />
                    <button type="button" class="guest-counter__btn" data-target="children" data-action="increase" aria-label="Increase children">+</button>
                  </div>
                </div>
                <div class="guest-counter">
                  <span class="guest-counter__label">Dogs</span>
                  <div class="guest-counter__controls">
                    <button type="button" class="guest-counter__btn" data-target="dogs" data-action="decrease" aria-label="Decrease dogs">−</button>
                    <input type="number" id="dogs" name="dogs" class="guest-counter__value" value="0" min="0" max="5" readonly />
                    <button type="button" class="guest-counter__btn" data-target="dogs" data-action="increase" aria-label="Increase dogs">+</button>
                  </div>
                </div>
              </div>
            </div>

            <div class="form__group">
              <label class="form__label" for="houses">Which House(s)?</label>
              <select id="houses" name="houses" class="form__select">
                <option value="">Select a preference</option>
                <option value="le-moulin">Le Moulin</option>
                <option value="la-grange">La Grange</option>
                <option value="le-jardin">Le Jardin</option>
                <option value="two-houses">Two Houses</option>
                <option value="all-three">All Three (The Compound)</option>
                <option value="not-sure">Not Sure Yet</option>
              </select>
            </div>

            <div class="form__group">
              <label class="form__label" for="message">Your Message</label>
              <textarea id="message" name="message" class="form__textarea" placeholder="Tell us about your trip — occasion, interests, any services you'd like (catering, wellness, etc.)..."></textarea>
            </div>

            <button type="submit" class="btn btn--primary">Send Your Inquiry</button>
          </form>
        </div>

        <!-- Contact Info + Directions -->
        <div>
          <div class="fade-in">
            <h2>Contact Details</h2>
            <div style="margin-top: 24px;">
              <h4>Email</h4>
              <p><a href="mailto:hello@moulin-a-reves.com">hello@moulin-a-reves.com</a></p>
            </div>
            <div style="margin-top: 20px;">
              <h4>Phone</h4>
              <p><a href="tel:+19172085853">+1 (917) 208-5853</a></p>
            </div>
            <div style="margin-top: 20px;">
              <h4>Address</h4>
              <p>Moulin a Reves<br />Seine-et-Marne (77)<br />Ile-de-France, France</p>
            </div>
          </div>

          <div class="fade-in" style="margin-top: 48px;">
            <h2>Getting Here</h2>

            <div style="margin-top: 24px;">
              <h4>From Paris by Car</h4>
              <p style="margin-top: 8px;">
                Take the A6 south from Paris towards Lyon. Exit at Fontainebleau and follow signs towards Barbizon / Milly-la-Foret. The compound is approximately one hour from central Paris, depending on traffic. Detailed directions and GPS coordinates will be sent with your booking confirmation.
              </p>
            </div>

            <div style="margin-top: 24px;">
              <h4>From Paris by Train</h4>
              <p style="margin-top: 8px;">
                Take the Transilien Line R from Gare de Lyon to Fontainebleau-Avon station (approximately 40 minutes). From the station, the compound is a 20-minute drive. We can arrange a taxi to meet you, or you can rent a car at the station.
              </p>
            </div>

            <div style="margin-top: 24px;">
              <h4>From the Airports</h4>
              <p style="margin-top: 8px;">
                Charles de Gaulle (CDG): approximately 1 hour 30 minutes by car. Orly (ORY): approximately 1 hour. We can arrange private transfers from either airport on request.
              </p>
            </div>
          </div>

          <!-- Map -->
          <div class="fade-in" style="margin-top: 48px;">
            <div style="border-radius: 8px; overflow: hidden; height: 350px;">
              <iframe
                src="https://www.openstreetmap.org/export/embed.html?bbox=2.55%2C48.40%2C2.70%2C48.47&layer=mapnik&marker=48.4433%2C2.6033"
                style="border: 0; width: 100%; height: 100%;"
                loading="lazy"
                title="Map showing Moulin à Rêves location near Barbizon, France"
              ></iframe>
            </div>
            <p style="margin-top: 8px; font-size: 0.8125rem; color: var(--text-light);">
              Near Barbizon, Seine-et-Marne &middot; One hour south of Paris
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

<style>
  .guest-counters {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }

  .guest-counter {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex: 1;
    min-width: 140px;
    background: var(--bg-warm-white);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-radius: 4px;
    padding: 10px 14px;
  }

  .guest-counter__label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .guest-counter__controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .guest-counter__btn {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1.5px solid var(--blue-primary);
    background: transparent;
    color: var(--blue-primary);
    font-size: 1.125rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    line-height: 1;
  }

  .guest-counter__btn:hover {
    background: var(--blue-primary);
    color: white;
  }

  .guest-counter__value {
    width: 32px;
    text-align: center;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    border: none;
    background: transparent;
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .guest-counter__value::-webkit-outer-spin-button,
  .guest-counter__value::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  input[type="date"] {
    color-scheme: light;
  }

  @media (max-width: 768px) {
    .guest-counters {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>

<script>
  document.querySelectorAll('.guest-counter__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.target;
      const action = btn.dataset.action;
      const input = document.getElementById(target) as HTMLInputElement;
      if (!input) return;

      let value = parseInt(input.value) || 0;
      const min = parseInt(input.min) || 0;
      const max = parseInt(input.max) || 20;

      if (action === 'increase' && value < max) {
        input.value = String(value + 1);
      } else if (action === 'decrease' && value > min) {
        input.value = String(value - 1);
      }
    });
  });

  // Set min date to today
  const today = new Date().toISOString().split('T')[0];
  const checkin = document.getElementById('checkin') as HTMLInputElement;
  const checkout = document.getElementById('checkout') as HTMLInputElement;
  if (checkin) checkin.min = today;
  if (checkout) checkout.min = today;

  // Sync checkout min to checkin value
  checkin?.addEventListener('change', () => {
    if (checkout && checkin.value) {
      checkout.min = checkin.value;
      if (checkout.value && checkout.value < checkin.value) {
        checkout.value = checkin.value;
      }
    }
  });
</script>

</BaseLayout>
