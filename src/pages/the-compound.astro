---
import BaseLayout from '../layouts/BaseLayout.astro';
import RoomShowcase from '../components/RoomShowcase.astro';

const sharedSpaces = [
  {
    id: 'pavilion',
    title: 'La Grange — Covered Pavilion',
    summary: 'Open-air entertaining barn with stone fireplace, ping-pong table, and the long communal table for twenty.',
    longDescription: 'The heart of the compound when the houses come together. Stone fireplace, ping-pong, dinner for twenty under cover.',
    photos: [
      { src: '/images/homes/la-grange-pavilion-wide.webp', alt: 'Wide view of La Grange\'s open pavilion with ping-pong and dining table' },
      { src: '/images/homes/la-grange-pavilion.webp', alt: 'La Grange\'s open pavilion with stone fireplace' },
      { src: '/images/homes/la-grange-fire.webp', alt: 'Fire crackling in the stone hearth of La Grange' },
      { src: '/images/group-dinner.webp', alt: 'Dinner laid on the long table under La Grange\'s pavilion' },
      { src: '/images/homes/la-grange-bath.webp', alt: 'Ground floor bathroom at La Grange' },
      { src: '/images/homes/la-grange-laundry.webp', alt: 'Laundry room with washer and dryer at La Grange' },
    ],
  },
  {
    id: 'gym',
    title: 'The Gym',
    summary: 'Treadmill, elliptical, weights, boxing bag, eight yoga mats.',
    photos: [
      { src: '/images/gym.webp', alt: 'Gym at La Grange with elliptical, treadmill, and mirrored wall' },
      { src: '/images/homes/la-grange-gym-boxing.webp', alt: 'Gym with treadmill and Everlast boxing setup' },
    ],
  },
  {
    id: 'screening',
    title: 'Screening Room',
    summary: 'Cinema room with leather club chairs and a large screen.',
    photos: [
      { src: '/images/screening-room.webp', alt: 'Screening room with leather club chairs facing the screen' },
      { src: '/images/homes/la-grange-screening-2.webp', alt: 'Screening room facing the leather chairs from the rear' },
    ],
  },
  {
    id: 'spa',
    title: 'Solarium & Jacuzzi',
    summary: 'A glassed-in solarium with jacuzzi — warm-weather mornings, winter evenings, year-round.',
    // TODO(Melissa): drop additional jacuzzi/solarium photos in /public/images/ and add them below.
    photos: [
      { src: '/images/wellness-pool.webp', alt: 'Solarium with jacuzzi at Moulin à Rêves' },
    ],
  },
  {
    id: 'bikes',
    title: 'Bikes & The Carriage',
    summary: 'Electric bikes for exploring the village and forest, plus the antique horse-drawn carriage.',
    photos: [
      { src: '/images/homes/la-grange-bikes.webp', alt: 'Bicycles parked in La Grange under exposed wood beams' },
      { src: '/images/homes/la-grange-bikes-door.webp', alt: 'Bicycles lined up inside La Grange facing the door' },
      { src: '/images/homes/la-grange-carriage.webp', alt: 'Antique red horse-drawn carriage on display in La Grange' },
    ],
  },
  {
    id: 'gardens',
    title: 'Gardens, Bridge & Stream',
    summary: 'The Giverny-style bridge over the millstream, walled gardens, the lawn, and quiet corners.',
    longDescription: 'Between the houses: a millstream that has been running for centuries, crossed by a stone footbridge worn smooth by generations. The gardens are informal — old roses, lavender, a kitchen garden where the herbs grow faster than anyone can use them.',
    photos: [
      { src: '/images/bridge-garden.webp', alt: 'Giverny-style painted bridge over the stream beneath willow trees' },
      { src: '/images/garden-chaises.webp', alt: 'Garden chaise lounges facing the painted bridge' },
      { src: '/images/garden-chaises-wide.webp', alt: 'Wide garden view with chaise lounges and the painted bridge' },
      { src: '/images/garden-chaise-jetson.webp', alt: 'Garden chaise lounges with Jetson the Cavalier in the sun' },
      { src: '/images/garden-private-spot.webp', alt: 'Private wicker bistro table in a wooded corner of the garden' },
      { src: '/images/garden-stone-well.webp', alt: 'Vine-covered antique stone well sheltered in the garden' },
      { src: '/images/garden-breakfast.webp', alt: 'Breakfast set on the patio outside the stone cottage' },
      { src: '/images/compound-river-courtyard.webp', alt: 'Stone footbridge with planter boxes over the small stream' },
      { src: '/images/evening-compound.webp', alt: 'Garden at dusk with feet propped up looking toward the stone cottage' },
      { src: '/images/personality.webp', alt: 'Marie Antoinette in the garden by the gate with a rooster' },
      { src: '/images/yoga-lawn.webp', alt: 'Morning yoga on the lawn between the houses' },
    ],
  },
];
---

<BaseLayout title="Rent the Full Compound — Moulin à Rêves | 20 Guests Near Paris" description="Rent all three houses at Moulin à Rêves — 10 bedrooms, 7 baths, sleeps 20. Family reunions, retreats, weddings & celebrations near Paris, France.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": "The Compound — Moulin à Rêves",
      "description": "Rent all three stone houses at Moulin à Rêves. 10 bedrooms, 7 bathrooms, sleeps 20. Perfect for family reunions, retreats, weddings, and celebrations near Paris.",
      "url": "https://www.moulinareves.com/the-compound/",
      "image": "/images/hero-compound.webp",
      "numberOfBedrooms": 10,
      "numberOfBathroomsTotal": 7,
      "occupancy": { "@type": "QuantitativeValue", "value": 20 },
      "petsAllowed": true,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "16 Rue des Crocs aux Renards",
        "postalCode": "91660",
        "addressLocality": "Le Mérévillois",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.3167,
        "longitude": 2.0833
      },
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Hot Tub / Jacuzzi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Gym", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Screening Room", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Electric Bikes", "value": true}
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How many guests can the full compound accommodate?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The full compound at Moulin à Rêves sleeps 20 guests across 10 bedrooms and 7 bathrooms in three separate houses."
          }
        },
        {
          "@type": "Question",
          "name": "What is included when you rent the compound?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The compound rental includes exclusive use of three houses (Le Moulin, The Hollywood Hideaway, La Maison de la Rivière), shared gardens, millstream, La Grange event barn, pétanque court, and communal dining terrace. Optional add-ons: gym, jacuzzi/solarium, screening room (€50/day each), electric bikes (€25/day)."
          }
        },
        {
          "@type": "Question",
          "name": "Is Moulin à Rêves suitable for weddings?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The compound is well-suited for intimate weddings and celebrations with its walled gardens, millstream, La Grange covered barn (seats 20+), and gazebo dining area."
          }
        },
        {
          "@type": "Question",
          "name": "How far is the compound from Paris?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Moulin à Rêves is approximately one hour from Paris by car, located in Méréville, France near the Juine River."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Aerial view of the three houses of Moulin à Rêves gathered around the millstream" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <span class="hero__eyebrow">Moulin à Rêves</span>
      <h1 class="hero__title" data-i18n="compound.hero.title">The Compound</h1>
      <p class="hero__tagline" data-i18n="compound.hero.tagline">Three houses. Shared grounds. The whole place, exclusively yours.</p>
    </div>
  </section>

  <style>
    .hero__eyebrow {
      display: block;
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 500;
      letter-spacing: 0.28em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.96);
      margin-bottom: 24px;
      text-shadow: 0 1px 10px rgba(0, 0, 0, 0.55);
      padding-left: 0.28em;
    }
  </style>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 32px; padding-bottom: 32px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">3</div>
          <div class="stats-bar__label" data-i18n="compound.stats.houses">Houses</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">10</div>
          <div class="stats-bar__label" data-i18n="compound.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">7</div>
          <div class="stats-bar__label" data-i18n="compound.stats.bathrooms">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">20</div>
          <div class="stats-bar__label" data-i18n="compound.stats.guests">Guests</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 class="text-center" data-i18n="compound.intro.heading">Rent the Compound</h2>
      <p data-i18n="compound.intro.p1" style="margin-top: 24px;">
        Three houses around shared gardens, a millstream, and the buildings between them — La Grange, the spa with jacuzzi, the gym, the screening room. 10 bedrooms, 7 bathrooms, sleeps 20.
      </p>
      <p data-i18n="compound.intro.p2" style="margin-top: 16px;">
        Each house has its own kitchen, living room, and front door. The grounds between them are where the real life of the stay happens.
      </p>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="section--tight section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="compound.madefor.heading">Made For</h2>
      </div>
      <div class="compound-grid compound-grid--4">
        <div class="compound-tile fade-in">
          <div class="compound-tile__media">
            <img src="/images/outdoor-dining.webp" alt="Multi-generational family gathered for outdoor dinner at Moulin à Rêves, Barbizon" loading="lazy" />
          </div>
          <div class="compound-tile__body">
            <h3 class="compound-tile__title" data-i18n="compound.madefor.reunion.title">Family Reunions</h3>
            <p class="compound-tile__summary" data-i18n="compound.madefor.reunion.desc">Three generations under three roofs, with a shared garden where everyone meets. Close enough to be together, separate enough to stay sane.</p>
          </div>
        </div>
        <div class="compound-tile fade-in">
          <div class="compound-tile__media">
            <img src="/images/screening-room.webp" alt="Corporate retreat screening room at Moulin à Rêves near Fontainebleau, France" loading="lazy" />
          </div>
          <div class="compound-tile__body">
            <h3 class="compound-tile__title" data-i18n="compound.madefor.corporate.title">Corporate Retreats</h3>
            <p class="compound-tile__summary" data-i18n="compound.madefor.corporate.desc">Strategy sessions in the morning, forest walks in the afternoon, long dinners in the evening. The kind of offsite that actually works.</p>
          </div>
        </div>
        <div class="compound-tile fade-in">
          <div class="compound-tile__media">
            <img src="/images/wellness-pool.webp" alt="Yoga retreat by the indoor pool at Moulin à Rêves countryside compound" loading="lazy" />
          </div>
          <div class="compound-tile__body">
            <h3 class="compound-tile__title" data-i18n="compound.madefor.yoga.title">Yoga Retreats</h3>
            <p class="compound-tile__summary" data-i18n="compound.madefor.yoga.desc">Morning practice on the lawn, healthy meals prepared by a private chef, massage in the afternoon. We can help you arrange every detail.</p>
          </div>
        </div>
        <div class="compound-tile fade-in">
          <div class="compound-tile__media">
            <img src="/images/gazebo-dining.webp" alt="Evening celebration dining under the gazebo at Moulin à Rêves, Seine-et-Marne" loading="lazy" />
          </div>
          <div class="compound-tile__body">
            <h3 class="compound-tile__title" data-i18n="compound.madefor.celebrations.title">Celebrations</h3>
            <p class="compound-tile__summary" data-i18n="compound.madefor.celebrations.desc">Birthdays, anniversaries, intimate weddings. The garden, the millstream, the long evening light — some settings don't need much decoration.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Grounds -->
  <section class="fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="compound.grounds.heading">The Shared Grounds</h2>
        <p data-i18n="compound.grounds.p1">
          Between the three houses lies the heart of Moulin a Reves: a millstream that has been running for centuries, crossed by a stone footbridge worn smooth by generations of feet. The gardens are informal — old roses along the walls, lavender borders, a kitchen garden where the herbs grow faster than anyone can use them.
        </p>
        <p data-i18n="compound.grounds.p2">
          There's a petanque court on the gravel near the linden trees, a long communal table that seats twenty for outdoor dinners, and a lawn large enough for yoga, croquet, or simply lying in the grass watching the clouds move over the forest canopy. In the evening, the grounds are lit by low lanterns, and the only sounds are conversation, the stream, and the occasional owl.
        </p>
      </div>
      <div class="split__image">
        <img src="/images/bridge-garden.webp" alt="The shared gardens and millstream at Moulin à Rêves" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Shared Spaces -->
  <RoomShowcase
    eyebrow=""
    heading={`Shared <span class="serif-italic">Spaces</span>`}
    intro="La Grange, the spa, the gym, the screening room, the gardens — open to all guests staying at the compound."
    rooms={sharedSpaces}
    background="stone"
    i18nKey="compound.sharedspaces"
  />

  <!-- The Three Houses -->
  <section class="section--tight section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 24px;">
        <h2 data-i18n-html="compound.threehomes.heading">Les <span class="serif-italic">Trois Maisons</span></h2>
      </div>
      <div class="showcase showcase--triple">
        <a href="/homes/le-moulin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves — historic mill house on the Juine River" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Moulin à Rêves</h3>
            <div class="card__meta">
              <span>5 Bed</span>
              <span>4 Bath</span>
              <span>Sleeps 10</span>
            </div>
          </div>
        </a>
        <a href="/homes/hollywood-hideaway/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/hh-exterior.webp" alt="The Hollywood Hideaway — French countryside sanctuary" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">The Hollywood Hideaway</h3>
            <div class="card__meta">
              <span>3 Bed + Suite</span>
              <span>2 Bath</span>
              <span>Sleeps 7</span>
            </div>
          </div>
        </a>
        <a href="/homes/maison-de-la-riviere/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière — sunny cottage overlooking the stream" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Maison de la Rivière</h3>
            <div class="card__meta">
              <span>2 Bed</span>
              <span>1 Bath</span>
              <span>Sleeps 5</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section--tight">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 28px;">
        <h2 data-i18n="compound.services.heading">We'll Handle the Details</h2>
        <p data-i18n="compound.services.subheading" style="margin-top: 12px;">Everything can be arranged in advance. Just ask.</p>
      </div>
      <div class="grid grid--3">
        <div class="fade-in" style="text-align: center;">
          <h3 data-i18n="compound.services.catering.title">Catering</h3>
          <p data-i18n="compound.services.catering.desc" style="margin-top: 12px;">Breakfast delivery, dinner service, or a private chef for the entire stay. From croissants at your door to a five-course meal beneath the trees.</p>
          <a href="/catering/" class="link-arrow" data-i18n="compound.services.learnmore" style="margin-top: 16px;">Learn More</a>
        </div>
        <div class="fade-in" style="text-align: center;">
          <h3 data-i18n="compound.services.wellness.title">Wellness</h3>
          <p data-i18n="compound.services.wellness.desc" style="margin-top: 12px;">Yoga on the lawn, in-house massage, beauty treatments. We work with local practitioners who know how to make you forget your calendar.</p>
          <a href="/wellness/" class="link-arrow" data-i18n="compound.services.learnmore" style="margin-top: 16px;">Learn More</a>
        </div>
        <div class="fade-in" style="text-align: center;">
          <h3 data-i18n="compound.services.experiences.title">Experiences</h3>
          <p data-i18n="compound.services.experiences.desc" style="margin-top: 12px;">Forest walks, wine tastings, chateau visits, cooking classes. We know the area well and can arrange whatever your group needs.</p>
          <a href="/explore/" class="link-arrow" data-i18n="compound.services.learnmore" style="margin-top: 16px;">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section section--stone">
    <div class="container text-center fade-in">
      <blockquote class="testimonial" data-i18n="compound.testimonial">
        «&nbsp;We booked all three houses for my parents' 50th anniversary. Twenty of us, three generations, a week in the French countryside. The children made friends with the frogs in the millstream. The adults made friends with the local wine. It was the best week we've had as a family.&nbsp;»
      </blockquote>
      <p class="testimonial__attribution" data-i18n="compound.testimonial.attribution">— James & Catherine, September 2025</p>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section class="section--tight" id="inquire">
    <div class="container--narrow fade-in">
      <div class="text-center" style="margin-bottom: 28px;">
        <h2 data-i18n="compound.form.heading">Plan Your Group Stay</h2>
        <p data-i18n="compound.form.subheading" style="margin-top: 12px;">Tell us about your group and your occasion. We'll put together a proposal.</p>
      </div>
      <form id="compound-form">
        <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div class="grid grid--2">
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.name" for="name">Your Name</label>
            <input type="text" id="name" name="name" class="form__input" required />
          </div>
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.email" for="email">Email</label>
            <input type="email" id="email" name="email" class="form__input" required />
          </div>
        </div>

        <div class="grid grid--2">
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.dates" for="dates">Preferred Dates</label>
            <input type="text" id="dates" name="dates" class="form__input" placeholder="e.g. 15–22 July 2026" />
          </div>
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.guests" for="guests">Number of Guests</label>
            <input type="text" id="guests" name="guests" class="form__input" placeholder="e.g. 16 adults, 4 children" />
          </div>
        </div>

        <div class="form__group">
          <label class="form__label" data-i18n="compound.form.occasion" for="occasion">Occasion</label>
          <select id="occasion" name="occasion" class="form__select">
            <option value="" data-i18n="compound.form.occasion.select">Select an occasion</option>
            <option value="family-reunion" data-i18n="compound.form.occasion.reunion">Family Reunion</option>
            <option value="corporate-retreat" data-i18n="compound.form.occasion.corporate">Corporate Retreat</option>
            <option value="yoga-retreat" data-i18n="compound.form.occasion.yoga">Yoga / Wellness Retreat</option>
            <option value="wedding" data-i18n="compound.form.occasion.wedding">Wedding / Celebration</option>
            <option value="friends-holiday" data-i18n="compound.form.occasion.friends">Friends Holiday</option>
            <option value="other" data-i18n="compound.form.occasion.other">Other</option>
          </select>
        </div>

        <div class="form__group">
          <label class="form__label" data-i18n="compound.form.message" for="message">Tell Us More</label>
          <textarea id="message" name="message" class="form__textarea" placeholder="Anything you'd like us to know — catering needs, wellness requests, special occasions..."></textarea>
        </div>

        <div class="text-center">
          <button type="submit" class="btn btn--primary" data-i18n="compound.form.submit">Start Your Conversation</button>
        </div>
      </form>
    </div>
  </section>

<script>
  const compoundForm = document.getElementById('compound-form') as HTMLFormElement;
  compoundForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const bot = (compoundForm.querySelector('[name="bot-field"]') as HTMLInputElement)?.value;
    if (bot) return;

    const btn = compoundForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/compound', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: (document.getElementById('name') as HTMLInputElement).value,
          email: (document.getElementById('email') as HTMLInputElement).value,
          dates: (document.getElementById('dates') as HTMLInputElement).value,
          guests: (document.getElementById('guests') as HTMLInputElement).value,
          occasion: (document.getElementById('occasion') as HTMLSelectElement).value,
          message: (document.getElementById('message') as HTMLTextAreaElement).value,
        }),
      });
      if (res.ok) {
        window.location.href = '/success/';
      } else {
        btn.disabled = false;
        btn.textContent = 'Start Your Conversation';
        alert('Something went wrong. Please try again or email us directly.');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Start Your Conversation';
      alert('Something went wrong. Please try again or email us directly.');
    }
  });
</script>

</BaseLayout>
