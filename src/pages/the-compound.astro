---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Compound — Moulin à Rêves" description="Rent all three houses at Moulin à Rêves. 9 bedrooms, sleeps 20. Perfect for family reunions, retreats, weddings, and celebrations near Paris.">

  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "VacationRental",
      "name": "The Compound — Moulin à Rêves",
      "description": "Rent all three stone houses at Moulin à Rêves. 9 bedrooms, 6 bathrooms, sleeps 20. Perfect for family reunions, retreats, weddings, and celebrations near Paris.",
      "url": "https://moulin-a-reves.com/the-compound/",
      "image": "/images/hero-compound.webp",
      "numberOfBedrooms": 9,
      "numberOfBathroomsTotal": 6,
      "occupancy": { "@type": "QuantitativeValue", "value": 20 },
      "floorSize": { "@type": "QuantitativeValue", "value": 420, "unitCode": "MTK" },
      "petsAllowed": true,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Barbizon",
        "addressRegion": "Seine-et-Marne",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.4433,
        "longitude": 2.6033
      },
      "amenityFeature": [
        {"@type": "LocationFeatureSpecification", "name": "WiFi", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Garden", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Hot Tub", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Gym", "value": true},
        {"@type": "LocationFeatureSpecification", "name": "Screening Room", "value": true}
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="hero">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Aerial view of the three houses of Moulin à Rêves gathered around the millstream" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="compound.hero.title">The Compound</h1>
      <p class="hero__tagline" data-i18n="compound.hero.tagline">Three houses. Shared grounds. The whole place, exclusively yours.</p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="section" style="padding-top: 48px; padding-bottom: 48px;">
    <div class="container">
      <div class="stats-bar">
        <div class="stats-bar__item">
          <div class="stats-bar__number">3</div>
          <div class="stats-bar__label" data-i18n="compound.stats.houses">Houses</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">9</div>
          <div class="stats-bar__label" data-i18n="compound.stats.bedrooms">Bedrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">6</div>
          <div class="stats-bar__label" data-i18n="compound.stats.bathrooms">Bathrooms</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">20</div>
          <div class="stats-bar__label" data-i18n="compound.stats.guests">Guests</div>
        </div>
        <div class="stats-bar__item">
          <div class="stats-bar__number">420</div>
          <div class="stats-bar__label" data-i18n="compound.stats.total">m&sup2; total</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Introduction -->
  <section class="section">
    <div class="container--narrow fade-in">
      <h2 class="text-center" data-i18n="compound.intro.heading">Rent All Three</h2>
      <p data-i18n="compound.intro.p1" style="margin-top: 32px;">
        Some occasions call for more than a single house. When you book the entire compound at Moulin a Reves, you get three separate homes arranged around shared gardens, a millstream, and the kind of space that lets a group of twenty spread out during the day and come together for the evening. Each house has its own kitchen, its own living room, its own front door — but the grounds between them are where the real life of your stay will happen.
      </p>
      <p data-i18n="compound.intro.p2" style="margin-top: 20px;">
        You'll gather at the long table beneath the linden trees for dinner. The children will move between houses as if they've always lived here. Someone will start a game of petanque on the gravel court while the apéritif is being poured. And at the end of the evening, everyone walks home — just not very far.
      </p>
    </div>
  </section>

  <!-- Use Cases -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <h2 data-i18n="compound.madefor.heading">Made For</h2>
      </div>
      <div class="grid grid--4">
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/outdoor-dining.webp" alt="Multi-generational family gathered for outdoor dinner at Moulin à Rêves, Barbizon" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="compound.madefor.reunion.title">Family Reunions</h3>
            <p class="card__description" data-i18n="compound.madefor.reunion.desc">Three generations under three roofs, with a shared garden where everyone meets. Close enough to be together, separate enough to stay sane.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/screening-room.webp" alt="Corporate retreat screening room at Moulin à Rêves near Fontainebleau, France" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="compound.madefor.corporate.title">Corporate Retreats</h3>
            <p class="card__description" data-i18n="compound.madefor.corporate.desc">Strategy sessions in the morning, forest walks in the afternoon, long dinners in the evening. The kind of offsite that actually works.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/wellness-pool.webp" alt="Yoga retreat by the indoor pool at Moulin à Rêves countryside compound" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="compound.madefor.yoga.title">Yoga Retreats</h3>
            <p class="card__description" data-i18n="compound.madefor.yoga.desc">Morning practice on the lawn, healthy meals prepared by a private chef, massage in the afternoon. We can help you arrange every detail.</p>
          </div>
        </div>
        <div class="card fade-in">
          <div class="card__image">
            <img src="/images/gazebo-dining.webp" alt="Evening celebration dining under the gazebo at Moulin à Rêves, Seine-et-Marne" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title" data-i18n="compound.madefor.celebrations.title">Celebrations</h3>
            <p class="card__description" data-i18n="compound.madefor.celebrations.desc">Birthdays, anniversaries, intimate weddings. The garden, the millstream, the long evening light — some settings don't need much decoration.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Grounds -->
  <section class="section">
    <div class="container">
      <div class="grid grid--2" style="align-items: center;">
        <div class="fade-in">
          <h2 data-i18n="compound.grounds.heading">The Shared Grounds</h2>
          <p data-i18n="compound.grounds.p1" style="margin-top: 24px;">
            Between the three houses lies the heart of Moulin a Reves: a millstream that has been running for centuries, crossed by a stone footbridge worn smooth by generations of feet. The gardens are informal — old roses along the walls, lavender borders, a kitchen garden where the herbs grow faster than anyone can use them.
          </p>
          <p data-i18n="compound.grounds.p2" style="margin-top: 20px;">
            There's a petanque court on the gravel near the linden trees, a long communal table that seats twenty for outdoor dinners, and a lawn large enough for yoga, croquet, or simply lying in the grass watching the clouds move over the forest canopy. In the evening, the grounds are lit by low lanterns, and the only sounds are conversation, the stream, and the occasional owl.
          </p>
        </div>
        <div class="fade-in">
          <img src="/images/bridge-garden.webp" alt="The shared gardens and millstream at Moulin à Rêves" style="border-radius: 8px; width: 100%;" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- The Three Houses -->
  <section class="section section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 64px;">
        <h2 data-i18n="compound.threehomes.heading">The Three Houses</h2>
      </div>
      <div class="grid grid--3">
        <a href="/homes/le-moulin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin stone mill house with blue shutters at Moulin à Rêves, Barbizon" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Moulin</h3>
            <p class="card__description" data-i18n="compound.moulin.desc">The original mill house. Thick stone walls, a working fireplace, and the millstream at your door.</p>
            <div class="card__meta">
              <span data-i18n="compound.moulin.beds">3 Bed</span>
              <span data-i18n="compound.moulin.sleeps">Sleeps 6</span>
              <span>150 m&sup2;</span>
            </div>
          </div>
        </a>
        <a href="/homes/la-grange/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/la-grange-hero.webp" alt="La Grange converted stone barn with tall windows at Moulin à Rêves, Barbizon" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">La Grange</h3>
            <p class="card__description" data-i18n="compound.grange.desc">The converted barn. Soaring ceilings, an open kitchen, and doors that fold onto the garden.</p>
            <div class="card__meta">
              <span data-i18n="compound.grange.beds">3 Bed</span>
              <span data-i18n="compound.grange.sleeps">Sleeps 6</span>
              <span>140 m&sup2;</span>
            </div>
          </div>
        </a>
        <a href="/homes/le-jardin/" class="card fade-in" style="text-decoration:none;color:inherit;">
          <div class="card__image">
            <img src="/images/homes/le-jardin-hero.webp" alt="Le Jardin garden cottage wrapped in wisteria at Moulin à Rêves, Barbizon" loading="lazy" />
          </div>
          <div class="card__body">
            <h3 class="card__title">Le Jardin</h3>
            <p class="card__description" data-i18n="compound.jardin.desc">The garden cottage. Wrapped in wisteria, with a terrace made for long afternoons.</p>
            <div class="card__meta">
              <span data-i18n="compound.jardin.beds">3 Bed</span>
              <span data-i18n="compound.jardin.sleeps">Sleeps 6</span>
              <span>130 m&sup2;</span>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 48px;">
        <h2 data-i18n="compound.services.heading">We'll Handle the Details</h2>
        <p data-i18n="compound.services.subheading" style="margin-top: 12px;">Everything can be arranged in advance. Just ask.</p>
      </div>
      <div class="grid grid--3">
        <div class="fade-in" style="text-align: center;">
          <h3 data-i18n="compound.services.catering.title">Catering</h3>
          <p data-i18n="compound.services.catering.desc" style="margin-top: 12px;">Breakfast delivery, dinner service, or a private chef for the entire stay. From croissants at your door to a five-course meal beneath the trees.</p>
          <a href="/catering/" class="link-arrow" data-i18n="compound.services.learnmore" style="margin-top: 16px;">Learn More</a>
        </div>
        <div class="fade-in" style="text-align: center;">
          <h3 data-i18n="compound.services.wellness.title">Wellness</h3>
          <p data-i18n="compound.services.wellness.desc" style="margin-top: 12px;">Yoga on the lawn, in-house massage, beauty treatments. We work with local practitioners who know how to make you forget your calendar.</p>
          <a href="/wellness/" class="link-arrow" data-i18n="compound.services.learnmore" style="margin-top: 16px;">Learn More</a>
        </div>
        <div class="fade-in" style="text-align: center;">
          <h3 data-i18n="compound.services.experiences.title">Experiences</h3>
          <p data-i18n="compound.services.experiences.desc" style="margin-top: 12px;">Forest walks, wine tastings, chateau visits, cooking classes. We know the area well and can arrange whatever your group needs.</p>
          <a href="/explore/" class="link-arrow" data-i18n="compound.services.learnmore" style="margin-top: 16px;">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="section section--stone">
    <div class="container text-center fade-in">
      <blockquote class="testimonial" data-i18n="compound.testimonial">
        "We booked all three houses for my parents' 50th anniversary. Twenty of us, three generations, a week in the French countryside. The children made friends with the frogs in the millstream. The adults made friends with the local wine. It was the best week we've had as a family."
      </blockquote>
      <p class="testimonial__attribution" data-i18n="compound.testimonial.attribution">— James & Catherine, September 2025</p>
    </div>
  </section>

  <!-- Inquiry Form -->
  <section class="section" id="inquire">
    <div class="container--narrow fade-in">
      <div class="text-center" style="margin-bottom: 48px;">
        <h2 data-i18n="compound.form.heading">Plan Your Group Stay</h2>
        <p data-i18n="compound.form.subheading" style="margin-top: 12px;">Tell us about your group and your occasion. We'll put together a proposal.</p>
      </div>
      <form id="compound-form">
        <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div class="grid grid--2">
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.name" for="name">Your Name</label>
            <input type="text" id="name" name="name" class="form__input" required />
          </div>
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.email" for="email">Email</label>
            <input type="email" id="email" name="email" class="form__input" required />
          </div>
        </div>

        <div class="grid grid--2">
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.dates" for="dates">Preferred Dates</label>
            <input type="text" id="dates" name="dates" class="form__input" placeholder="e.g. 15–22 July 2026" />
          </div>
          <div class="form__group">
            <label class="form__label" data-i18n="compound.form.guests" for="guests">Number of Guests</label>
            <input type="text" id="guests" name="guests" class="form__input" placeholder="e.g. 16 adults, 4 children" />
          </div>
        </div>

        <div class="form__group">
          <label class="form__label" data-i18n="compound.form.occasion" for="occasion">Occasion</label>
          <select id="occasion" name="occasion" class="form__select">
            <option value="" data-i18n="compound.form.occasion.select">Select an occasion</option>
            <option value="family-reunion" data-i18n="compound.form.occasion.reunion">Family Reunion</option>
            <option value="corporate-retreat" data-i18n="compound.form.occasion.corporate">Corporate Retreat</option>
            <option value="yoga-retreat" data-i18n="compound.form.occasion.yoga">Yoga / Wellness Retreat</option>
            <option value="wedding" data-i18n="compound.form.occasion.wedding">Wedding / Celebration</option>
            <option value="friends-holiday" data-i18n="compound.form.occasion.friends">Friends Holiday</option>
            <option value="other" data-i18n="compound.form.occasion.other">Other</option>
          </select>
        </div>

        <div class="form__group">
          <label class="form__label" data-i18n="compound.form.message" for="message">Tell Us More</label>
          <textarea id="message" name="message" class="form__textarea" placeholder="Anything you'd like us to know — catering needs, wellness requests, special occasions..."></textarea>
        </div>

        <div class="text-center">
          <button type="submit" class="btn btn--primary" data-i18n="compound.form.submit">Start Your Conversation</button>
        </div>
      </form>
    </div>
  </section>

<script>
  const compoundForm = document.getElementById('compound-form') as HTMLFormElement;
  compoundForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const bot = (compoundForm.querySelector('[name="bot-field"]') as HTMLInputElement)?.value;
    if (bot) return;

    const btn = compoundForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch('/api/compound', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: (document.getElementById('name') as HTMLInputElement).value,
          email: (document.getElementById('email') as HTMLInputElement).value,
          dates: (document.getElementById('dates') as HTMLInputElement).value,
          guests: (document.getElementById('guests') as HTMLInputElement).value,
          occasion: (document.getElementById('occasion') as HTMLSelectElement).value,
          message: (document.getElementById('message') as HTMLTextAreaElement).value,
        }),
      });
      if (res.ok) {
        window.location.href = '/success/';
      } else {
        btn.disabled = false;
        btn.textContent = 'Start Your Conversation';
        alert('Something went wrong. Please try again or email us directly.');
      }
    } catch {
      btn.disabled = false;
      btn.textContent = 'Start Your Conversation';
      alert('Something went wrong. Please try again or email us directly.');
    }
  });
</script>

</BaseLayout>
