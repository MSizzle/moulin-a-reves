---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'spring-in-barbizon',
    title: 'Spring in Barbizon: What to See When the Light Returns',
    excerpt: 'The painters came for the light. In spring, you will understand why. A guide to Barbizon and the surrounding countryside when the wisteria blooms and the forest floor turns green.',
    image: '/images/explore/barbizon.webp',
    date: '2026-03-15',
    alt: 'Spring blossoms along a stone street in Barbizon village near Moulin à Rêves'
  },
  {
    slug: 'fontainebleau-forest-guide',
    title: "A Walker's Guide to Fontainebleau Forest",
    excerpt: 'Twenty-five thousand hectares of ancient oak, sandstone boulders, and trails that lead somewhere quieter. Our favourite walks, from gentle morning strolls to full-day adventures.',
    image: '/images/explore/forest.webp',
    date: '2026-02-20',
    alt: 'Dappled sunlight on a forest path through Fontainebleau near Moulin à Rêves'
  },
  {
    slug: 'planning-family-reunion-france',
    title: 'How to Plan a Family Reunion in the French Countryside',
    excerpt: 'Three generations, three houses, one unforgettable week. Everything we have learned about bringing families together at Moulin à Rêves — from logistics to long dinners.',
    image: '/images/outdoor-dining.webp',
    date: '2026-01-10',
    alt: 'Multi-generational family dining outdoors at Moulin à Rêves compound, Barbizon'
  }
];
---

<BaseLayout title="Journal — Moulin à Rêves" description="Stories, guides, and seasonal notes from Moulin à Rêves. Discover Barbizon, Fontainebleau Forest, and the French countryside one hour from Paris.">

  <!-- Hero -->
  <section class="hero" style="height: 50vh;">
    <div class="hero__image">
      <img src="/images/forest-path.webp" alt="Sunlit forest path through Fontainebleau near Moulin à Rêves, Barbizon" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title">Journal</h1>
      <p class="hero__tagline">Stories, guides, and seasonal notes from the French countryside.</p>
    </div>
  </section>

  <!-- Blog Grid -->
  <section class="section">
    <div class="container">
      <div class="grid grid--3">
        {posts.map((post) => (
          <a href={`/journal/${post.slug}/`} class="card fade-in" style="text-decoration:none;color:inherit;">
            <div class="card__image">
              <img src={post.image} alt={post.alt} />
            </div>
            <div class="card__body">
              <p class="card__date">{new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
              <h3 class="card__title">{post.title}</h3>
              <p class="card__description">{post.excerpt}</p>
              <span class="link-arrow" style="margin-top: 12px;">Read More</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="section section--stone text-center">
    <div class="container fade-in">
      <h2>Stay in the Loop</h2>
      <p style="margin-top: 16px; margin-bottom: 32px;">
        Seasonal updates, travel tips, and stories from the compound. No spam — just France.
      </p>
      <form class="journal-newsletter" name="journal-newsletter" method="POST" action="/success/" data-netlify="true" netlify-honeypot="bot-field" style="max-width: 480px; margin: 0 auto; display: flex; gap: 8px;">
        <input type="hidden" name="form-name" value="journal-newsletter" />
        <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>
        <input type="email" name="email" placeholder="Your email" class="form__input" required style="flex: 1;" />
        <button type="submit" class="btn btn--primary">Subscribe</button>
      </form>
    </div>
  </section>

  <style>
    .card__date {
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-light);
      margin-bottom: 8px;
    }
  </style>

</BaseLayout>
