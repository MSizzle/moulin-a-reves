---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Groups — Yoga, Family Reunions & Creative Retreats | Moulin à Rêves" description="Host your group at Moulin à Rêves: yoga retreats, family reunions, and creative retreats on a private compound one hour from Paris. Sleeps 20.">

  <!-- Hero -->
  <section class="hero" style="height: 56vh;">
    <div class="hero__image">
      <img src="/images/wellness-yoga-bridge.webp" alt="Morning yoga beside the millstream at Moulin à Rêves" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="groups.hero.title">Groups</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section--tight">
    <div class="container--narrow text-center fade-in">
      <h2 data-i18n="groups.intro.heading">Built for gathering</h2>
      <p data-i18n="groups.intro.text" style="margin-top: 20px;">
        Three stone houses, a walled garden, the millstream, La Grange for long dinners, a gym, a screening room, a jacuzzi, and the lawn for sun salutations. Booked together, the compound becomes whatever your group needs it to be — a retreat, a reunion, a workshop, a celebration.
      </p>
    </div>
  </section>

  <!-- Yoga -->
  <section id="yoga" class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/wellness-yoga-mill-facade.webp" alt="Yoga practice on the lawn outside Le Moulin's blue-shuttered facade" loading="lazy" />
      </div>
      <div class="split__body">
        <span class="split__eyebrow" data-i18n="groups.yoga.eyebrow">Yoga & Wellness Retreats</span>
        <h2 data-i18n="groups.yoga.heading">Yoga retreats</h2>
        <p data-i18n="groups.yoga.p1">
          The lawn at sunrise, the millstream in earshot, La Grange when the rain comes. Practice on the grass, by the bridge, or in the pavilion — and bring your own teacher or ours. Massages and beauty treatments by trusted local practitioners are easy to arrange on site.
        </p>
        <p data-i18n="groups.yoga.p2">
          Up to twenty practitioners across three houses — single rooms when guests want quiet, shared meals when they don't.
        </p>
        <a href="/contact/" class="link-arrow" data-i18n="groups.yoga.cta">Plan a yoga retreat →</a>
      </div>
    </div>
  </section>

  <!-- Family Reunions -->
  <section id="family-reunions" class="fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <span class="split__eyebrow" data-i18n="groups.family.eyebrow">Family Reunions</span>
        <h2 data-i18n="groups.family.heading">Family reunions</h2>
        <p data-i18n="groups.family.p1">
          Three generations, three houses, one garden — together by day, separate when needed. Grandparents settle into Le Moulin, the cousins claim the Hideaway, the new parents take the cottage. The kids run the bridge between them.
        </p>
        <p data-i18n="groups.family.p2">
          A long table under La Grange for the whole-family dinner, a screening room for the rainy afternoon, electric bikes for the village run. Catering, breakfast delivery, and private chefs are easy to arrange.
        </p>
        <a href="/contact/" class="link-arrow" data-i18n="groups.family.cta">Plan a family reunion →</a>
      </div>
      <div class="split__image">
        <img src="/images/group-kids-bridge.webp" alt="Children running across the painted bridge over the millstream at Moulin à Rêves" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Creative Retreats -->
  <section id="creative-retreats" class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/retreat-writers.webp" alt="Writers gathered at a long table for a creative retreat at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <span class="split__eyebrow" data-i18n="groups.creative.eyebrow">Creative Retreats</span>
        <h2 data-i18n="groups.creative.heading">Creative retreats</h2>
        <p data-i18n="groups.creative.p1">
          Writing weeks, painting workshops, photography intensives, songwriting sessions — the compound has room for the practice and the quiet. La Grange holds workshops of twenty under the beams. The library, the gardens, and the rooms hold the long, slow work in between.
        </p>
        <p data-i18n="groups.creative.p2">
          Same setting that drew the painters of Barbizon, fifteen minutes away. Bring your group, your facilitator, and your medium — we'll make the rooms ready.
        </p>
        <a href="/contact/" class="link-arrow" data-i18n="groups.creative.cta">Plan a creative retreat →</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section--tighter section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 36px;">
        <h2 data-i18n="groups.testimonials.heading">From past groups</h2>
      </div>
      <div class="testimonials-grid">
        <figure class="testimonial-card fade-in">
          <blockquote class="testimonial" data-i18n="groups.testimonials.q1">
            "We came for a family reunion and left as a closer family. The kids still talk about the river."
          </blockquote>
          <figcaption class="testimonial__attribution" data-i18n="groups.testimonials.a1">— Sophie &amp; Laurent · Family Reunion, August 2025</figcaption>
        </figure>
        <figure class="testimonial-card fade-in">
          <blockquote class="testimonial" data-i18n="groups.testimonials.q2">
            "Twelve students, seven days, three meals on the lawn. The setting did half the teaching for me."
          </blockquote>
          <figcaption class="testimonial__attribution" data-i18n="groups.testimonials.a2">— Anika · Yoga Retreat Host, June 2025</figcaption>
        </figure>
        <figure class="testimonial-card fade-in">
          <blockquote class="testimonial" data-i18n="groups.testimonials.q3">
            "Our writers' week. Quiet rooms, long dinners, the millstream outside the window. Nobody wanted to leave."
          </blockquote>
          <figcaption class="testimonial__attribution" data-i18n="groups.testimonials.a3">— David · Writing Retreat, May 2025</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="groups-cta fade-in">
    <div class="groups-cta__image">
      <img src="/images/barn-events.webp" alt="Long dinner table set under La Grange's covered pavilion at Moulin à Rêves" loading="lazy" />
    </div>
    <div class="groups-cta__body container--narrow text-center">
      <h2 data-i18n="groups.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">Plan your group stay</h2>
      <p data-i18n="groups.cta.tagline" style="margin-top: 14px; max-width: 56ch; margin-left: auto; margin-right: auto;">Tell us your dates and your group — we'll take it from there.</p>
      <a href="/contact/" class="btn btn--primary" data-i18n="groups.cta.button" style="margin-top: 24px;">Inquire</a>
    </div>
  </section>

  <style>
    /* Testimonials section needs real breathing room — without this rule the class
       had no padding and the cards collided with neighbours. */
    .section--tighter { padding-top: clamp(72px, 8vw, 120px); padding-bottom: clamp(72px, 8vw, 120px); }

    /* Plan-your-group-stay CTA: shows the photo at its full natural aspect (no
       crop) followed by the call-to-action — fits horizontal images cleanly. */
    .groups-cta {
      padding-top: clamp(56px, 7vw, 96px);
      padding-bottom: clamp(56px, 7vw, 96px);
    }
    .groups-cta__image {
      max-width: 1200px;
      margin: 0 auto 36px;
      padding: 0 clamp(16px, 4vw, 32px);
    }
    .groups-cta__image img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 4px;
    }

    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(20px, 3vw, 36px);
    }
    .testimonial-card {
      margin: 0;
      padding: clamp(28px, 3vw, 40px);
      background: var(--bg-warm-white);
      border-bottom: 3px solid var(--blue-primary);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .testimonial-card .testimonial {
      font-family: var(--font-serif);
      font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
      line-height: 1.55;
      font-style: italic;
      color: var(--ink);
      margin: 0 0 18px;
    }
    .testimonial-card .testimonial__attribution {
      font-family: var(--font-body);
      font-size: 0.8125rem;
      letter-spacing: 0.06em;
      color: var(--ink-mute);
    }
    @media (max-width: 900px) {
      .testimonials-grid { grid-template-columns: 1fr; }
    }
  </style>

</BaseLayout>
