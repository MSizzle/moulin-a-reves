---
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from '../components/Img.astro';

// ---- Item 8: Gallery data for the three group-type sections ----
// Each array is seeded with existing repo images.
// TODO: drop owner's dedicated gallery photos here when received.
// Drop directory convention:
//   public/images/groups/yoga/      → for Yoga retreat gallery images (kebab-case.webp, max 2000px, q85)
//   public/images/groups/family/    → for Family reunion gallery images
//   public/images/groups/creative/  → for Creative retreat gallery images
// Run scripts/process-photos.mjs (or sharp inline) to resize stills to max 2000px webp q85
// before adding to the arrays below.

const yogaGallery = [
  // June 15 revision: lead is now the former #6 (Hideaway aerial); the "women with wings"
  // bridge photo moved to the Creative Retreats gallery. Remaining order preserved.
  { src: '/images/wellness-yoga-hideaway.webp', alt: 'Aerial view of a yoga class on the lawn beside the millstream at Moulin à Rêves' },
  { src: '/images/wellness-yoga-sun-salutations.webp', alt: 'Sun salutations beside the millstream at Moulin à Rêves' },
  { src: '/images/wellness-yoga-adjustments.webp', alt: 'A yoga instructor assisting a student during a retreat at Moulin à Rêves' },
  { src: '/images/wellness-yoga-stretch.webp', alt: 'Stretching on the grass at Moulin à Rêves' },
  { src: '/images/wellness-yoga-well.webp', alt: 'Yoga meditation by the stone well at Moulin à Rêves' },
  { src: '/images/groups-yoga-lawn-dog.webp', alt: 'Yoga mats laid out on the lawn with the dog and the blue-shuttered mill behind at Moulin à Rêves' },
];

const familyGallery = [
  // Lead image (shown in split layout; clicking opens the full lightbox)
  // Phase 3 §5: removed the beer-toast photo and the four no-people shots
  // (two duplicate empty dinner-table photos + two empty garden photos).
  { src: '/images/groups-family-gathering-grange.webp', alt: 'Three generations of a family gathered around the table under La Grange\'s pavilion at Moulin à Rêves' },
  { src: '/images/group-kids-bridge.webp', alt: 'Children running across the painted bridge over the millstream at Moulin à Rêves' },
  { src: '/images/group-father-friends.webp', alt: 'Fathers and friends gathered at Moulin à Rêves' },
  { src: '/images/group-mother-daughter-steps.webp', alt: 'Mother and daughter on the steps at Moulin à Rêves' },
  { src: '/images/group-ping-pong.webp', alt: 'Ping pong game at Moulin à Rêves' },
  { src: '/images/group-tuscan-sun.webp', alt: 'Friends relaxing in the sun at Moulin à Rêves' },
  { src: '/images/groups/family-ping-pong.webp', alt: 'Two guests playing ping pong on the lawn in front of the blue-shuttered mill house at Moulin à Rêves' },
];

const creativeGallery = [
  // June 15 revision: cover image kept; all other photos replaced with the owner's
  // dedicated creative-retreat shots. The "women with wings" bridge photo moved here
  // from the Yoga gallery.
  { src: '/images/retreat-writers.webp', alt: 'A writer working on a laptop on a garden chaise during a creative retreat at Moulin à Rêves' },
  { src: '/images/groups/creative-board-table.webp', alt: 'The long board-room table beneath a large landscape painting — a writing and workshop space at Moulin à Rêves' },
  { src: '/images/groups/creative-wishing-well.webp', alt: 'The historic stone wishing well in the gardens at Moulin à Rêves' },
  { src: '/images/wellness-yoga-bridge.webp', alt: 'Guests on the Giverny-style green bridge holding yoga mats aloft like wings at Moulin à Rêves' },
  { src: '/images/groups/creative-writer-paradise.webp', alt: 'A writer at work on a laptop, reclining on a garden chaise beside the bridge at Moulin à Rêves' },
  { src: '/images/groups/creative-jetson-napping.webp', alt: 'The Cavalier napping on the couch beside the Louis Vuitton trunk in the river house living room at Moulin à Rêves' },
  { src: '/images/groups/creative-board-table-angle.webp', alt: 'The long board-room table beneath the landscape painting, viewed from the far end — a writing and workshop space at Moulin à Rêves' },
];

// ---- Celebrations block gallery (June 15 revision) ----
const celebrationsGallery = [
  // Lead image (shown in split layout; clicking opens the full lightbox)
  { src: '/images/groups/grange-party-gathering.webp', alt: "Guests gathered for a celebration beneath La Grange's covered pavilion at Moulin à Rêves" },
  { src: '/images/melissa-toast-bridge.webp', alt: 'A guest in a pink dress raising a celebratory toast by the painted bridge at Moulin à Rêves' },
  { src: '/images/champagne.webp', alt: 'Champagne set out on a quiet garden table at Moulin à Rêves' },
  { src: '/images/groups-family-gathering-grange.webp', alt: 'Three generations gathered around the table under La Grange\'s pavilion at Moulin à Rêves' },
  { src: '/images/groups/guys-getaway.webp', alt: "A group of friends gathered around the table under La Grange for a celebration at Moulin à Rêves" },
];

// ---- Item 9: Video testimonial row ----
// Data-driven: add/remove videos from this array to update the row.
// Processed videos live in public/videos/; posters in public/images/testimonials/.
// Phase 3 §3: removed the "friends-birthday" and "husband-english-tag" videos;
// three remain (rave-review, guests-luxembourg, family-french en français).
const testimonialVideos = [
  {
    src: '/videos/testimonial-rave-review.mp4',
    poster: '/images/testimonials/testimonial-rave-review-poster.webp',
    label: null, // EN label; null = no extra label
  },
  {
    src: '/videos/testimonial-guests-luxembourg.mp4',
    poster: '/images/testimonials/testimonial-guests-luxembourg-poster.webp',
    label: null,
  },
  {
    src: '/videos/testimonial-family-french.mp4',
    poster: '/images/testimonials/testimonial-family-french-poster.webp',
    label: '(en français)', // French-language video label
  },
];
---

<BaseLayout title="Groups — Yoga, Family Reunions & Creative Retreats | Moulin à Rêves" description="Host your group at Moulin à Rêves: yoga retreats, family reunions, and creative retreats on a private compound one hour from Paris. Welcomes up to 10 lodging guests.">

  <!-- Hero -->
  <section class="hero" style="height: 60vh;">
    <div class="hero__image">
      <Img src="/images/family-reunions.webp" alt="A family gathered for a celebration under La Grange at Moulin à Rêves." sizes="100vw" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="groups.hero.title">The Art of Gathering</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section--tight">
    <div class="container--narrow text-center fade-in">
      <h2 data-i18n="groups.intro.heading">A Sanctuary for Meaningful Time Together</h2>
      <p data-i18n="groups.intro.text" style="margin-top: 20px;">
        From intimate retreats to milestone celebrations, Moulin à Rêves offers a rare setting where family, friends, and colleagues can gather, create, celebrate, and reconnect.
      </p>
      <p data-i18n="groups.intro.estate" style="margin-top: 16px;">
        Enclosed within its own gardens and gathering spaces, the estate combines the beauty of the French countryside with the rare luxury of having an entire estate to yourselves.
      </p>
      <p data-i18n="groups.intro.events" style="margin-top: 16px;">
        Private events of up to 35 guests may be hosted on the estate for an additional event fee of $5,000.
      </p>
    </div>
  </section>

  <!-- Yoga — Item 8: clickable gallery, lead image shown, lightbox opens full set -->
  <section id="yoga" class="section--tight fade-in">
    <div class="split">
      <div class="split__image">
        <!-- data-gallery triggers the fullscreen lightbox with all yoga gallery images -->
        <div
          class="groups-gallery-trigger"
          data-gallery={JSON.stringify(yogaGallery)}
          role="button"
          tabindex="0"
          aria-label="View yoga retreat gallery"
        >
          <img src="/images/wellness-yoga-hideaway.webp" alt="Aerial view of a yoga class on the lawn beside the millstream at Moulin à Rêves" loading="lazy" />
          <span class="groups-gallery-pill" aria-hidden="true">View gallery</span>
        </div>
      </div>
      <div class="split__body">
        <span class="split__eyebrow" data-i18n="groups.yoga.eyebrow">Yoga & Wellness Retreats</span>
        <h2 data-i18n="groups.yoga.heading">Yoga retreats</h2>
        <p data-i18n="groups.yoga.p1">
          The perfect setting for rest, reflection, and renewal. Practice in the garden beside the river, near the Giverny-style bridge, surrounded by the quiet beauty of the French countryside. On rainy days, bring your mats inside La Grange.
        </p>
        <p data-i18n="groups.yoga.p2">
          Nourish your students with abundant meals prepared by local chefs. Moulin à Rêves offers not only an inspiring setting for practice, but also a place for connection, conversation, and restoration.
        </p>
        <a href="/contact/" class="link-arrow" data-i18n="groups.yoga.cta">Plan a yoga retreat</a>
      </div>
    </div>
  </section>

  <!-- Family Reunions — Item 8: clickable gallery -->
  <section id="family-reunions" class="section--tight fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="groups.family.heading">Family reunions</h2>
        <p data-i18n="groups.family.p1">
          Three generations, three homes, one garden — together when you wish, with space to retreat when you prefer quiet time alone. Grandparents settle into Le Moulin, cousins claim the Hideaway, and young families enjoy the cottage. The children run freely between them.
        </p>
        <p data-i18n="groups.family.p2">
          Long dinners beneath La Grange, ping pong tournaments on the lawn, evenings around the fire pit, films in the screening room, bicycle rides through the village. Time together at Moulin à Rêves creates magical memories of a lifetime.
        </p>
        <a href="/contact/" class="link-arrow" data-i18n="groups.family.cta">Plan a family reunion</a>
      </div>
      <div class="split__image">
        <!-- data-gallery triggers the fullscreen lightbox with all family gallery images -->
        <div
          class="groups-gallery-trigger"
          data-gallery={JSON.stringify(familyGallery)}
          role="button"
          tabindex="0"
          aria-label="View family reunion gallery"
        >
          <img src="/images/group-kids-bridge.webp" alt="Children running across the painted bridge over the millstream at Moulin à Rêves" loading="lazy" />
          <span class="groups-gallery-pill" aria-hidden="true">View gallery</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Celebrations — June 15 revision: now precedes Creative Retreats -->
  <section id="celebrations" class="section--tight fade-in">
    <div class="split">
      <div class="split__image">
        <!-- data-gallery triggers the fullscreen lightbox with all celebrations gallery images -->
        <div
          class="groups-gallery-trigger"
          data-gallery={JSON.stringify(celebrationsGallery)}
          role="button"
          tabindex="0"
          aria-label="View celebrations gallery"
        >
          <img src="/images/groups/grange-party-gathering.webp" alt="Guests gathered for a celebration beneath La Grange's covered pavilion at Moulin à Rêves" loading="lazy" />
          <span class="groups-gallery-pill" aria-hidden="true">View gallery</span>
        </div>
      </div>
      <div class="split__body">
        <span class="split__eyebrow" data-i18n="groups.celebrations.eyebrow">Celebrations</span>
        <h2 data-i18n="groups.celebrations.heading">Celebrations at Moulin à Rêves</h2>
        <p data-i18n="groups.celebrations.p1">
          Some places host events. Moulin à Rêves becomes part of the memory.
        </p>
        <p data-i18n="groups.celebrations.p2">
          Whether celebrating a wedding, birthday, anniversary, holiday, or special gathering, Moulin à Rêves offers a beautiful setting for life's most meaningful occasions.
        </p>
        <p data-i18n="groups.celebrations.p3">
          Gather beneath La Grange, dine under the stars, and enjoy the rare luxury of quality time with those you love most.
        </p>
        <a href="/contact/" class="link-arrow" data-i18n="groups.celebrations.cta">Plan a celebration</a>
      </div>
    </div>
  </section>

  <!-- Creative Retreats — June 15 revision: now follows Celebrations -->
  <section id="creative-retreats" class="section--tight fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <span class="split__eyebrow" data-i18n="groups.creative.eyebrow">Creative Retreats</span>
        <h2 data-i18n="groups.creative.heading">Creative Retreats</h2>
        <p data-i18n="groups.creative.p1">
          Moulin à Rêves is a place of inspiration. Whether you're starting a memoir, collaborating on a screenplay, or leading an artistic retreat, Moulin à Rêves offers the space and beauty for meaningful creative work.
        </p>
        <p data-i18n="groups.creative.p2">
          The rhythm of the river creates an atmosphere that encourages creative flow. There's even a historic wishing well, so that you can fill your creative well.
        </p>
        <p data-i18n="groups.creative.p3">
          Gather in La Grange for workshops and conversation. Retreat to a private nook in the gardens or living rooms for focus and deep work. Many books and songs have been created here.
        </p>
        <a href="/contact/" class="link-arrow" data-i18n="groups.creative.cta">Plan a creative retreat</a>
      </div>
      <div class="split__image">
        <!-- data-gallery triggers the fullscreen lightbox with all creative gallery images -->
        <div
          class="groups-gallery-trigger"
          data-gallery={JSON.stringify(creativeGallery)}
          role="button"
          tabindex="0"
          aria-label="View creative retreats gallery"
        >
          <img src="/images/retreat-writers.webp" alt="A writer working on a laptop on a garden chaise during a creative retreat at Moulin à Rêves" loading="lazy" />
          <span class="groups-gallery-pill" aria-hidden="true">View gallery</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials — Item 9: video row above written quotes -->
  <section class="section--tighter section--stone">
    <div class="container">
      <div class="text-center fade-in" style="margin-bottom: 20px;">
        <h2 data-i18n="groups.testimonials.heading">From Our Guests</h2>
      </div>

      <!-- Item 9: Data-driven video testimonial row (above written quotes) -->
      <!-- NOTE: subtitle question surfaced in report — not decided here. -->
      <!-- NOTE: "(en français)" label on the French-language video. -->
      <div class="testimonial-videos fade-in">
        {testimonialVideos.map((v) => (
          <button
            class="testimonial-video-card"
            data-video-src={v.src}
            data-video-poster={v.poster}
            aria-label={`Play video testimonial${v.label ? ' ' + v.label : ''}`}
            type="button"
          >
            <div class="testimonial-video-card__thumb">
              <img src={v.poster} alt={`Video testimonial poster${v.label ? ' ' + v.label : ''}`} loading="lazy" />
              <span class="testimonial-video-card__play" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="36" height="36" fill="white"><circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.55)"/><polygon points="10,8 18,12 10,16" fill="white"/></svg>
              </span>
            </div>
            {v.label && <span class="testimonial-video-card__label">{v.label}</span>}
          </button>
        ))}
      </div>

      <!-- Phase 3 §3: four written quotes replaced by one anonymous full-width line -->
      <figure class="testimonial-line fade-in">
        <blockquote class="testimonial-line__quote" data-i18n="groups.testimonials.quote">
          "Magnificent grounds, extraordinary taste, and a rare sense of peace and refinement. The estate exceeded our expectations in every way."
        </blockquote>
      </figure>
    </div>
  </section>

  <!-- CTA — June 15: heading + tagline removed; just the green Join Us button with consistent spacing -->
  <section class="section text-center">
    <div class="container fade-in">
      <a href="/contact/" class="btn btn--green" data-i18n="groups.cta.button">Join us</a>
    </div>
  </section>

  <style>
    /* Testimonials section — tightened per client (June 14): less space before heading and around the quote */
    .section--tighter { padding-top: clamp(40px, 5vw, 72px); padding-bottom: clamp(40px, 5vw, 72px); }

    /* Plan-your-group-stay CTA */
    .groups-cta {
      padding-top: clamp(56px, 7vw, 96px);
      padding-bottom: clamp(56px, 7vw, 96px);
    }
    /* ---- Item 8: Gallery trigger (wraps the lead image in each split section) ---- */
    .groups-gallery-trigger {
      position: relative;
      cursor: zoom-in;
      display: block;
    }
    .groups-gallery-trigger img {
      display: block;
      width: 100%;
      height: auto;
    }
    .groups-gallery-pill {
      position: absolute;
      right: 14px;
      bottom: 14px;
      padding: 8px 14px;
      background: rgba(255, 255, 255, 0.92);
      color: var(--ink);
      font-family: var(--font-body);
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      opacity: 0;
      transform: translateY(6px);
      transition: opacity 0.2s ease, transform 0.2s ease;
      pointer-events: none;
    }
    .groups-gallery-trigger:hover .groups-gallery-pill,
    .groups-gallery-trigger:focus-visible .groups-gallery-pill {
      opacity: 1;
      transform: translateY(0);
    }
    @media (max-width: 768px) {
      .groups-gallery-pill { opacity: 1; transform: translateY(0); }
    }
    .groups-gallery-trigger:focus-visible {
      outline: 2px solid var(--blue-primary);
      outline-offset: 2px;
    }

    /* ---- Item 9: Video testimonial row ---- */
    /* Three videos in a 3-up row spanning the full content width, with a small
       gap between (client June 14: larger thumbnails, full width). */
    .testimonial-videos {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(14px, 1.8vw, 28px);
      margin: 0 auto clamp(20px, 3vw, 32px);
    }
    @media (max-width: 640px) {
      .testimonial-videos { grid-template-columns: 1fr; max-width: 420px; }
    }
    .testimonial-video-card {
      position: relative;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }
    .testimonial-video-card__thumb {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: 4px;
      background: #111;
    }
    .testimonial-video-card__thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }
    .testimonial-video-card:hover .testimonial-video-card__thumb img {
      transform: scale(1.03);
    }
    .testimonial-video-card__play {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: opacity 0.2s ease;
    }
    .testimonial-video-card:hover .testimonial-video-card__play { opacity: 0.85; }
    .testimonial-video-card__label {
      font-family: var(--font-body);
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      color: var(--ink-mute);
      font-style: italic;
    }

    /* ---- Phase 3 §3: single anonymous testimonial line across the bottom ---- */
    .testimonial-line {
      margin: 0 auto;
      max-width: 60ch;
      text-align: center;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      padding-top: clamp(28px, 3.5vw, 44px);
    }
    .testimonial-line__quote {
      margin: 0;
      font-family: var(--font-serif);
      font-size: clamp(1.25rem, 2vw, 1.6rem);
      line-height: 1.5;
      font-style: italic;
      color: var(--ink);
    }
  </style>

  <!-- Item 9: Video card click handler — opens video in the fullscreen lightbox -->
  <script is:inline>
    (function () {
      document.querySelectorAll('.testimonial-video-card').forEach(function (card) {
        card.addEventListener('click', function () {
          var src = card.dataset.videoSrc;
          var poster = card.dataset.videoPoster;
          if (!src) return;
          // Build a single-item "gallery" with type:video so the lightbox video path activates
          var items = [{ type: 'video', src: src, poster: poster || '', alt: '', caption: '' }];
          // The lightbox open() function is scoped inside its IIFE but we can trigger it
          // via a synthetic data-gallery click on a hidden trigger element.
          // Instead we dispatch a custom event that the lightbox script listens for.
          var lb = document.getElementById('lightbox');
          if (!lb) return;
          // Re-use the global click delegation: create a temporary element
          // with data-gallery and click it so the existing handler fires.
          var tmp = document.createElement('div');
          tmp.setAttribute('data-gallery', JSON.stringify(items));
          tmp.style.display = 'none';
          document.body.appendChild(tmp);
          tmp.click();
          document.body.removeChild(tmp);
        });
      });
    })();
  </script>

</BaseLayout>
