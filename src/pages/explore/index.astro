---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Méréville gallery — order per client June 13 notes:
// 1 arrival · 2 watercress · 3 market hall · 4 fields · 5 bicycle · 6 gardens
const merevilleGallery = [
  // TODO: replace with the client's "Welcome to Méréville" sign photo when it arrives.
  { src: '/images/explore/mereville-market-square.webp', alt: 'Arriving in the village of Méréville', caption: 'Arriving in Méréville' },
  { src: '/images/explore/mereville-watercress-beds.webp', alt: 'Watercress beds in the valley near Méréville', caption: 'Watercress beds across from Moulin à Rêves' },
  { src: '/images/explore/boulangerie-mereville.webp', alt: 'Le Fournil boulangerie storefront in the village of Méréville', caption: 'Le Fournil, the village boulangerie' },
  { src: '/images/explore/mereville-rapeseed-fields.webp', alt: 'Golden fields lining a country road near Méréville', caption: 'Golden fields in spring' },
  { src: '/images/explore/cycling-gate.webp', alt: 'Guest cycling out from the blue gate of Moulin à Rêves with a baguette and dog', caption: 'Cycling out from the gates' },
  { src: '/images/explore/parc-mereville.webp', alt: 'Grotto, rock-arch bridge, and stream in the gardens of the Domaine de Méréville', caption: 'The gardens of the Domaine de Méréville' },
];

// "Day Trips & Things To Do" — further afield (~1 h+). Copy per client June 13 notes.
const dayTrips = [
  {
    href: null,
    image: '/images/explore/paris.webp',
    alt: 'Paris skyline with the Eiffel Tower, one hour from Moulin à Rêves',
    title: 'Paris',
    desc: 'Spend a day in the City of Light, then return to the peace of the countryside in time for dinner. Trains depart every half hour from Étampes, just 15 minutes away.',
  },
  {
    href: null,
    image: '/images/explore/vaux.webp',
    alt: 'Château de Vaux-le-Vicomte baroque facade and Le Nôtre formal gardens',
    title: 'Vaux-le-Vicomte',
    desc: 'Discover the magnificent château that inspired Versailles. Explore the formal gardens and experience the famous candlelit evenings held on summer Saturdays.',
  },
  {
    href: null,
    image: '/images/explore/versailles-hall-of-mirrors.webp',
    alt: 'The Hall of Mirrors at the Palace of Versailles — gilded statues, crystal chandeliers, and the painted ceiling by Le Brun',
    title: 'Versailles',
    desc: "Experience the palace of Louis XIV, one of France's most spectacular destinations. Discover the Hall of Mirrors, Marie-Antoinette's Hamlet, and the gilded grandeur of the Sun King's court.",
  },
  {
    href: null,
    image: '/images/explore/chartres.webp',
    alt: 'Notre-Dame de Chartres UNESCO Gothic cathedral, a day trip from Moulin à Rêves',
    title: 'Chartres',
    desc: 'Step inside one of the finest Gothic cathedrals in the world. Admire its legendary stained-glass windows and explore the charming old town surrounding this UNESCO World Heritage site.',
  },
  {
    href: null,
    image: '/images/explore/orleans.webp',
    alt: 'The Loire river quays at Orléans with the medieval city skyline and Sainte-Croix Cathedral',
    title: 'Orléans',
    desc: 'The historic city of Joan of Arc sits on the banks of the Loire River. Stroll its medieval streets, visit the soaring Sainte-Croix Cathedral, and enjoy lunch along the riverfront.',
  },
  {
    href: null,
    image: '/images/explore/chambord.webp',
    alt: 'Château de Chambord Renaissance facade reflected in the canal, in the Loire Valley',
    title: 'Loire Valley Châteaux · 1 hr 30 minutes',
    desc: "Spend a day exploring some of France's most celebrated Renaissance châteaux, including Blois, Amboise, and Chenonceau. Visit Leonardo da Vinci's final home at Le Clos Lucé and discover the splendor of the Loire Valley.",
  },
];
---

<BaseLayout title="Things to Do Near Fontainebleau Forest — Moulin à Rêves Guide" description="Explore Méréville, Fontainebleau Forest, Barbizon village, châteaux, local markets, and Paris — all within easy reach of Moulin à Rêves in Méréville, France.">

  <!-- Hero -->
  <section class="hero" style="height: 60vh;">
    <div class="hero__image">
      <img src="/images/explore/moret-bridge.webp" alt="Stone bridge over the Loing river in Moret-sur-Loing, twenty-five minutes from Moulin à Rêves" />
    </div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="explore.hero.title">Things to Do</h1>
    </div>
  </section>

  <!-- A. Discover Méréville -->
  <section class="section">
    <div class="container--narrow fade-in text-center">
      <h2>Discover <span class="serif-italic">Méréville</span></h2>
      <p class="prose-lead" style="margin-top: 16px;">
        Known as the watercress capital of France, Méréville offers a glimpse of authentic French country life. Browse the weekly market, enjoy hot baguettes from the village boulangerie, cycle past endless fields and windmills and stroll beside the emerald watercress beds just beyond the gates of Moulin à Rêves.
      </p>
      <p style="margin-top: 16px;">
        Life moves at a gentler pace here, inviting you to slow down and savor the simple pleasures of the French countryside.
      </p>
    </div>

    <div class="container fade-in" style="margin-top: 40px;">
      <div class="mereville-gallery">
        {merevilleGallery.map((item) => (
          <figure class="mereville-gallery__item">
            <div class="mereville-gallery__photo">
              <img src={item.src} alt={item.alt} loading="lazy" />
            </div>
            <figcaption>{item.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Day Trips & Things To Do -->
  <section class="section section--stone">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 36px; text-align: center;">
        <h2>Day Trips &amp; Things To Do</h2>
        <p style="margin-top: 12px; max-width: 60ch; margin-left: auto; margin-right: auto;">Some of France's most beautiful châteaux, cathedrals, and historic cities are just an hour away from Moulin à Rêves.</p>
      </div>
      <div class="compound-grid compound-grid--3">
        {dayTrips.map((item) => (
          item.href ? (
            <a class="compound-tile fade-in" href={item.href} target="_blank" rel="noopener noreferrer">
              <div class="compound-tile__media">
                <img src={item.image} alt={item.alt} loading="lazy" />
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title">{item.title}</h3>
                <p class="compound-tile__summary">{item.desc}</p>
              </div>
            </a>
          ) : (
            <div class="compound-tile fade-in">
              <div class="compound-tile__media">
                <img src={item.image} alt={item.alt} loading="lazy" />
              </div>
              <div class="compound-tile__body">
                <h3 class="compound-tile__title">{item.title}</h3>
                <p class="compound-tile__summary">{item.desc}</p>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container--narrow fade-in">
      <a href="/contact/" class="btn btn--green" data-i18n="explore.cta.button">Join us.</a>
    </div>
  </section>

  <style>
    .mereville-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    @media (max-width: 768px) {
      .mereville-gallery { grid-template-columns: 1fr; }
    }
    .mereville-gallery__item { margin: 0; }
    .mereville-gallery__photo {
      aspect-ratio: 4 / 3;
      overflow: hidden;
      border-radius: 2px;
    }
    .mereville-gallery__photo img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .mereville-gallery__photo:hover img { transform: scale(1.04); }
    .mereville-gallery__item figcaption {
      margin-top: 10px;
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.95rem;
      color: var(--ink-soft);
      text-align: center;
    }
    .drive-time {
      font-family: var(--font-body);
      font-style: normal;
      font-weight: 400;
      font-size: 0.8125rem;
      letter-spacing: 0.04em;
      color: var(--ink-soft);
      white-space: nowrap;
    }
  </style>

</BaseLayout>
