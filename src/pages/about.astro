---
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from '../components/Img.astro';

// History gallery — June 15 revision: a featured full-width image, then a row of
// three, then a portrait beneath. (borrah-archive-1 retired.)
const featuredImage = {
  src: '/images/history/borrah-albums.webp',
  alt: "Borrah Minevitch's record albums and books, alongside Bert and Barbara memorabilia",
  caption: 'Albums, books, and family pieces — Borrah, Bert, and Barbara across the decades.',
};
const secondRow = [
  {
    src: '/images/history/borrah-chaplin.webp',
    alt: 'Charlie Chaplin photographed with Borrah Minevitch',
    caption: 'Borrah and Charlie Chaplin — close friends across the Hollywood and vaudeville circuits.',
  },
  {
    src: '/images/history/borrah-why-i-love-the-harmonica.webp',
    alt: "Cover of Borrah Minevitch's book Why I Love the Harmonica",
    caption: 'Why I Love the Harmonica — Borrah\'s own book on the instrument that made his name.',
  },
  {
    src: '/images/history/borrah-harmonica-secrets.webp',
    alt: "Vintage harmonica memorabilia from Borrah Minevitch's career",
    caption: 'Pages from the Harmonica Rascals years — sheet music, programmes, and stage memorabilia.',
  },
];
const belowFeatured = {
  src: '/images/history/borrah-minevitch-portrait.webp',
  alt: 'Vaudeville harmonica virtuoso Borrah Minevitch — Library of Congress portrait',
  caption: 'Borrah Minevitch, c. 1920s — vaudeville harmonica virtuoso who bought the Moulin in 1948.',
};
---

<BaseLayout title="About Moulin à Rêves — Historic French Mill Compound Near Paris" description="The history of Moulin à Rêves — a 19th-century mill on the Juine River in Méréville, France.">

  <!-- Hero -->
  <section class="hero" style="height: 60vh;">
    <div class="hero__image">
      <Img src="/images/history/borrah-metal-sculpture.webp" alt="Bronze relief sculpture of Borrah Minevitch and the Harmonica Rascals" sizes="100vw" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="about.hero.title">About</h1>
    </div>
  </section>

  <!-- History -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="about.history.heading">The History of Moulin à Rêves</h2>
      <p class="serif-italic" data-i18n="about.history.subtitle" style="margin-top: 6px; font-size: clamp(1.1rem, 2vw, 1.4rem);">From Vaudeville to Hollywood to You</p>
      <div style="margin-top: 24px;">
        <p data-i18n="about.history.p1">
          The story of Moulin à Rêves is every bit as magical as the estate itself.
        </p>
        <p data-i18n="about.history.p2" style="margin-top: 16px;">
          For more than seventy-five years, it has remained in the hands of one family. The story begins in 1948, when vaudeville legend Borrah Minevitch fell in love with Moulin à Rêves.
        </p>
        <p data-i18n="about.history.p3" style="margin-top: 16px;">
          Born in Minsk, Borrah arrived in America at the age of five. He dreamed of playing the violin, but his mother could only afford a toy harmonica. Borrah was a "newsy" and played his harmonica while selling papers on the street. He discovered that the more he played, the more papers he sold. He never stopped playing—or tinkering.
        </p>
        <p data-i18n="about.history.p4" style="margin-top: 16px;">
          By the time he was in college, Borrah perfected the chromatic harmonica and sold the rights to Hohner for $1,000,000. He became the world's first harmonica virtuoso and one of vaudeville's biggest stars. Leading his band, The Harmonica Rascals, he performed on Broadway with Florenz Ziegfeld and toured symphony halls from Hollywood to London, Berlin, and Vienna.
        </p>
        <p data-i18n="about.history.p5" style="margin-top: 16px;">
          Success brought Borrah to Paris, where he purchased a celebrated jazz club on Île Saint-Louis. He bought Moulin à Rêves with the vision of turning it into an inn for artists and writers.
        </p>
        <p data-i18n="about.history.p6" style="margin-top: 16px;">
          Charlie Chaplin, Jean Cocteau, Jacques Tati, Billy Rose, Maxime of Maxim's, and even the Duchess of Windsor were among his friends and guests. Moulin à Rêves became a place where conversation, music, art, and friendship flourished.
        </p>
        <p data-i18n="about.history.p7" style="margin-top: 16px;">
          The next chapter belongs to renowned attorney Bert Fields, who married Borrah's daughter, model Lydia Stevens. Bert became one of Hollywood's most influential lawyers. His clients included Michael Jackson, Tom Cruise, Dustin Hoffman, Warren Beatty, and major studios including Disney and DreamWorks. For nearly fifty years, Moulin à Rêves remained Bert's beloved sanctuary. Here he cooked, wrote, entertained friends, and enjoyed the pleasures of French country life. The Hollywood Hideaway, one of the estate's three homes, still reflects his warmth, hospitality, and love of gathering people together.
        </p>
        <p data-i18n="about.history.p8" style="margin-top: 16px;">
          Today, the estate reflects the eye and stewardship of Bert's second wife, art advisor Barbara Guggenheim. For more than thirty years, she has lovingly restored the property and infused it with her impeccable taste. From fine antiques and oil paintings to whimsical collections of poodle ceramics and scarves, her influence brings elegance, warmth, and charm to every corner of the estate.
        </p>
        <p data-i18n="about.history.p9" style="margin-top: 16px;">
          And now the story continues with you.
        </p>
        <p data-i18n="about.history.p10" style="margin-top: 16px; font-size: 1.25rem;">
          Bienvenue chez vous.
        </p>
        <div class="watch-listen" style="margin-top: 28px;">
          <p class="watch-listen__label" data-i18n="about.media.label">Watch &amp; Listen</p>
          <div class="watch-listen__cards">
            <a class="watch-listen__card" href="https://youtu.be/mESI_bER0v8" target="_blank" rel="noopener">
              <span class="watch-listen__icon" aria-hidden="true">▶</span>
              <span class="watch-listen__text"><span class="watch-listen__title" data-i18n="about.media.youtube">Borrah on YouTube</span><span class="watch-listen__src">YouTube</span></span>
            </a>
            <a class="watch-listen__card" href="https://youtu.be/r3tYKO1ByDw" target="_blank" rel="noopener">
              <span class="watch-listen__icon" aria-hidden="true">▶</span>
              <span class="watch-listen__text"><span class="watch-listen__title" data-i18n="about.media.film">The Harmonica Rascals on Film</span><span class="watch-listen__src">YouTube</span></span>
            </a>
            <a class="watch-listen__card" href="https://open.spotify.com/artist/3MsD3zR8zUIHAzNdQhgGbm" target="_blank" rel="noopener">
              <span class="watch-listen__icon" aria-hidden="true">♪</span>
              <span class="watch-listen__text"><span class="watch-listen__title" data-i18n="about.media.spotify">Borrah on Spotify</span><span class="watch-listen__src">Spotify</span></span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- History Gallery -->
  <section class="section--tight">
    <div class="container--narrow fade-in text-center">
      <h2 data-i18n="about.gallery.heading">From the Archives</h2>
    </div>
    <div class="container fade-in" style="margin-top: 36px;">
      <figure class="history-featured">
        <img src={featuredImage.src} alt={featuredImage.alt} loading="lazy" />
        <figcaption>{featuredImage.caption}</figcaption>
      </figure>
      <div class="history-gallery history-gallery--3" style="margin-top: 32px;">
        {secondRow.map((img) => (
          <figure class="history-gallery__item">
            <img src={img.src} alt={img.alt} loading="lazy" />
            <figcaption>{img.caption}</figcaption>
          </figure>
        ))}
      </div>
      <figure class="history-featured" style="margin-top: 32px;">
        <img src={belowFeatured.src} alt={belowFeatured.alt} loading="lazy" />
        <figcaption>{belowFeatured.caption}</figcaption>
      </figure>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section--tight section--soft" id="faq">
    <div class="container--narrow fade-in text-center">
      <h2 data-i18n-html="about.faq.heading">Frequently Asked <span class="serif-italic">Questions</span></h2>
    </div>
    <div class="container--narrow fade-in" style="margin-top: 36px;">
      <div class="faq" id="getting-here">
        <details class="faq__item" open>
          <summary class="faq__q" data-i18n="about.faq.address.q">What's the address?</summary>
          <div class="faq__a">
            <p data-i18n="about.faq.address.a">14, 16, 18 Rue des Crocs au Renard, 91660 Le Mérévillois.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.opt1.q">How do I get there from the airport by Uber or taxi?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.opt1.orly.h">From Paris Orly (ORY):</strong> <span data-i18n="about.faq.opt1.orly.p">45–55 min · €65–€105 (car) · €90–€160 (van, up to 6).</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.opt1.cdg.h">From Charles de Gaulle (CDG):</strong> <span data-i18n="about.faq.opt1.cdg.p">1h15–1h30 · €130–€250 (car or van).</span></p>
            <p style="margin-top: 10px;" data-i18n="about.faq.opt1.note">Simplest door-to-door option — no transfers. Live prices vary by time of day.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.opt2.q">Can I take the train via Étampes?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.opt2.s1.h">Step 1 — Uber to Gare d'Austerlitz:</strong> <span data-i18n="about.faq.opt2.s1.p">From Orly: €30–€50 (30–40 min) · From CDG: €50–€70 (45–60 min).</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.opt2.s2.h">Step 2 — Train to Étampes:</strong> <span data-i18n="about.faq.opt2.s2.p">RER C: ~50 min, ~€2.50, every ~30 min. TER / Intercités: 30–35 min, €10–€20, fewer departures.</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.opt2.s3.h">Step 3 — Taxi from Étampes:</strong> <span data-i18n="about.faq.opt2.s3.p">~20 min, ~€25.</span> Book ahead with <a href="https://www.allotaxisetampes.fr" target="_blank" rel="noopener">Allo Taxis Étampes</a>, <a href="https://taxietampes.fr" target="_blank" rel="noopener">Taxi Étampes</a>, or <a href="https://www.taxi-91.fr/Taxi-etampes" target="_blank" rel="noopener">Taxi 91</a>.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.opt3.q">Can I get there entirely by public transport?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.opt3.s1.h">Airport to Paris:</strong> <span data-i18n="about.faq.opt3.s1.p">RER B from the airport → Denfert-Rochereau → Métro 6 → Gare d'Austerlitz. ~50–70 min, ~€12–€15.</span></p>
            <p style="margin-top: 10px;" data-i18n="about.faq.opt3.s2.p">Then RER C or TER to Étampes (see above), and a taxi (~20 min, ~€25) to the Moulin.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.rideapps.q">Which ride apps work in France?</summary>
          <div class="faq__a">
            <ul>
              <li><strong>Uber</strong> — <a href="https://www.uber.com" target="_blank" rel="noopener">uber.com</a></li>
              <li><strong>Heetch</strong> (often cheaper) — <a href="https://www.heetch.com" target="_blank" rel="noopener">heetch.com</a></li>
              <li><strong>FREE NOW</strong> (connects to taxis) — <a href="https://www.free-now.com" target="_blank" rel="noopener">free-now.com</a></li>
            </ul>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.rental.q">Where can I rent a car?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.rental.airports.h">At the airports:</strong> <span data-i18n="about.faq.rental.airports.p">Europcar, Sixt, Hertz · typically €40–€120/day.</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.rental.etampes.h">In Étampes:</strong> <a href="https://www.avis.fr/services-avis/location-voiture/europe/france/%C3%A9tampes/etampes-location-de-voiture" target="_blank" rel="noopener">Avis Étampes</a>.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.dogs.q">Is the property dog-friendly?</summary>
          <div class="faq__a">
            <p data-i18n="about.faq.dogs.a">Yes — Moulin à Rêves is dog-friendly. We have walked our own dogs through the gardens for years and welcome well-behaved pups. Let us know in advance so we can prepare the houses, and please keep dogs off the beds and out of the spa.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.trips.q">What's nearby for a day trip?</summary>
          <div class="faq__a">
            <ul>
              <li><strong>Chartres</strong> — <span data-i18n="about.faq.trips.chartres">home of the iconic Gothic cathedral.</span></li>
              <li><strong>Orléans</strong> — <span data-i18n="about.faq.trips.orleans">city of Joan of Arc on the Loire.</span></li>
              <li><strong>Vaux-le-Vicomte</strong> — <span data-i18n="about.faq.trips.vaux">the château that inspired Versailles.</span></li>
              <li><strong data-i18n="about.faq.trips.loire.h">Loire Valley</strong> — <span data-i18n="about.faq.trips.loire">90 minutes away — Chambord, Chenonceau, Amboise, Blois.</span></li>
            </ul>
          </div>
        </details>
      </div>
    </div>
  </section>

  <style>
    .section--tight { padding-top: 64px; padding-bottom: 64px; }
    .faq__item {
      border-top: 1px solid rgba(0, 0, 0, 0.1);
      padding: 18px 0;
    }
    .faq__item:last-child { border-bottom: 1px solid rgba(0, 0, 0, 0.1); }
    .faq__q {
      cursor: pointer;
      list-style: none;
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 500;
      font-size: 1.25rem;
      color: var(--ink);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }
    .faq__q::-webkit-details-marker { display: none; }
    .faq__q::after {
      content: '+';
      font-family: var(--font-body);
      font-style: normal;
      font-size: 1.5rem;
      color: var(--blue-primary, #3a5a8a);
      transition: transform 0.2s ease;
      flex-shrink: 0;
    }
    details[open] .faq__q::after { content: '–'; }
    .faq__a {
      padding-top: 14px;
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--ink-soft);
    }
    .faq__a p { margin: 0; }
    .faq__a ul { margin: 0; padding-left: 18px; }
    .faq__a li { margin: 4px 0; }
    .faq__a a { color: var(--blue-primary, #3a5a8a); text-decoration: underline; }

    .history-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
      align-items: start;
    }
    .history-gallery__item { margin: 0; }
    .history-gallery__item img {
      width: 100%;
      height: auto;
      display: block;
      background: #f5f3ee;
    }
    .history-gallery__item figcaption {
      margin-top: 12px;
      font-family: var(--font-body);
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--ink-soft);
      font-style: italic;
    }

    /* June 15: featured full-width image + a forced row of three */
    .history-featured {
      margin: 0 auto;
      max-width: 900px;
    }
    .history-featured img {
      width: 100%;
      height: auto;
      display: block;
      background: #f5f3ee;
    }
    .history-featured figcaption {
      margin-top: 12px;
      font-family: var(--font-body);
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--ink-soft);
      font-style: italic;
      text-align: center;
    }
    .history-gallery--3 { grid-template-columns: repeat(3, 1fr); }
    @media (max-width: 768px) {
      .history-gallery--3 { grid-template-columns: 1fr; }
    }

    /* June 15: Watch & Listen link cards */
    .watch-listen__label {
      font-family: var(--font-body);
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-soft);
      margin: 0 0 12px;
    }
    .watch-listen__cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    @media (max-width: 640px) {
      .watch-listen__cards { grid-template-columns: 1fr; }
    }
    .watch-listen__card {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 14px 16px;
      border: 1px solid rgba(0, 0, 0, 0.12);
      border-radius: 6px;
      text-decoration: none;
      color: var(--ink);
      background: #fff;
      transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    }
    .watch-listen__card:hover {
      border-color: var(--blue-primary, #3a5a8a);
      background: var(--bg-stone, #f5f3ee);
      transform: translateY(-2px);
    }
    .watch-listen__icon {
      flex-shrink: 0;
      width: 34px;
      height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: var(--blue-primary, #3a5a8a);
      color: #fff;
      font-size: 0.9rem;
    }
    .watch-listen__text {
      display: flex;
      flex-direction: column;
      line-height: 1.3;
      text-align: left;
    }
    .watch-listen__title { font-family: var(--font-serif); font-size: 0.95rem; }
    .watch-listen__src {
      font-family: var(--font-body);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink-soft);
    }
  </style>

</BaseLayout>
