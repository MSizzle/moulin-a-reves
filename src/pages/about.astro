---
import BaseLayout from '../layouts/BaseLayout.astro';

const historyGallery = [
  {
    src: '/images/history/borrah-minevitch-portrait.webp',
    alt: 'Vaudeville harmonica virtuoso Borrah Minevitch — Library of Congress portrait',
    caption: 'Borrah Minevitch, c. 1920s — vaudeville harmonica virtuoso who bought the Moulin in 1948.',
  },
  {
    src: '/images/history/borrah-harmonica-contest-poster.webp',
    alt: 'WPA-era poster — Harmonica Contest on the Mall, Central Park — Borrah Minevitch, Director',
    caption: 'WPA-era Central Park "Harmonica Contest" poster — Borrah Minevitch named as Director of the Harmonica Institute of America.',
  },
  {
    src: '/images/history/borrah-chaplin.webp',
    alt: 'Charlie Chaplin photographed with Borrah Minevitch',
    caption: 'Borrah and Charlie Chaplin — close friends across the Hollywood and vaudeville circuits.',
  },
  {
    src: '/images/history/borrah-metal-sculpture.webp',
    alt: 'Metal sculpture of Borrah Minevitch leading the harmonica band',
    caption: 'Metal sculpture of Borrah leading the Harmonica Rascals on stage.',
  },
  {
    src: '/images/history/borrah-why-i-love-the-harmonica.webp',
    alt: "Cover of Borrah Minevitch's book Why I Love the Harmonica",
    caption: '"Why I Love the Harmonica" — Borrah\'s own book on the instrument that made his name.',
  },
  {
    src: '/images/history/borrah-harmonica-secrets.webp',
    alt: "Vintage harmonica memorabilia from Borrah Minevitch's career",
    caption: 'Pages from the Harmonica Rascals years — sheet music, programmes, and stage memorabilia.',
  },
  {
    src: '/images/history/borrah-albums.webp',
    alt: "Borrah Minevitch's record albums and books, alongside Bert and Barbara memorabilia",
    caption: 'Albums, books, and family pieces — Borrah, Bert, and Barbara across the decades.',
  },
  {
    src: '/images/history/borrah-archive-1.webp',
    alt: 'Archival photograph from the Minevitch family collection',
    caption: 'From the family archive.',
  },
];
---

<BaseLayout title="About Moulin à Rêves — Historic French Mill Compound Near Paris" description="The history of Moulin à Rêves — a 19th-century mill on the Juine River in Méréville, France.">

  <!-- Hero -->
  <section class="hero" style="height: 56vh;">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Stone wall with blue shutters at Moulin à Rêves" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="about.hero.title">About</h1>
      <p class="hero__tagline" data-i18n="about.hero.tagline">The story of the Mill of Dreams.</p>
    </div>
  </section>

  <!-- History -->
  <section class="section--tight">
    <div class="container--narrow fade-in">
      <h2 data-i18n="about.history.heading">The History of Moulin à Rêves — From Vaudeville to Hollywood to You</h2>
      <div style="margin-top: 24px;">
        <p data-i18n-html="about.history.p1">
          The history of Moulin à Rêves is as magical as the setting. It has been owned by one family for over 75 years. It was purchased in 1948 by Vaudeville legend Borrah Minevitch. Borrah began playing the harmonica as a 5-year-old boy to pass the time while he sold newspapers. He earned $1,000,000 from the Hohner harmonica company for his chromatic harmonica invention. He was friends with Charlie Chaplin and producer Billy Rose, and toured the world with his band, the Harmonica Rascals — from Florenz Ziegfeld's Broadway theatres to Berlin, London, and Vienna. He fell in love with France. Watch the Rascals: <a href="https://www.youtube.com/watch?v=mESI_bER0v8" target="_blank" rel="noopener">vintage performance</a> · <a href="https://www.youtube.com/watch?v=-C4Qj8nyvaw" target="_blank" rel="noopener">on film</a>.
        </p>
        <p data-i18n-html="about.history.p2" style="margin-top: 16px;">
          He used his harmonica fortune to acquire this Mill and a famous jazz club on Paris's Île Saint-Louis. Alongside his friend, the owner of the legendary Maxim's, they planned to turn the Moulin into an inn for Paris artists. Their guests and friends included icons like Jacques Tati and Jean Cocteau. Borrah's daughter married Hollywood star lawyer Bert Fields, whose clients included Michael Jackson, Dustin Hoffman, Tom Cruise, and so many others. For 50 years, this was Bert's "Hollywood Hideaway" where he cooked, wrote, and entertained. His Hollywood friends would visit him here, far from the paparazzi.
        </p>
        <p data-i18n="about.history.p3" style="margin-top: 16px;">
          Today, the interiors reflect the impeccable eye of Bert's second wife, world-renowned art advisor Barbara Guggenheim. She has lovingly restored the Moulin and decorated it with 18th-century country antiques, including original Folies Bergère posters, fabric-upholstered walls, and a coffee table made from a Louis Vuitton trunk.
        </p>
        <p data-i18n="about.history.p4" style="margin-top: 16px;">
          The wifi is excellent. The Viking professional ovens and Ritz Paris terry robes — every detail has been chosen with care.
        </p>
      </div>
    </div>
  </section>

  <!-- Photo Break -->
  <section class="hero" style="height: 44vh; min-height: 340px;">
    <div class="hero__image">
      <img src="/images/bridge-garden.webp" alt="The millstream at Moulin à Rêves" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
  </section>

  <!-- History Gallery -->
  <section class="section--tight">
    <div class="container--narrow fade-in text-center">
      <h2 data-i18n-html="about.gallery.heading">From the <span class="serif-italic">archives</span></h2>
      <p data-i18n="about.gallery.lede" style="margin-top: 12px; max-width: 56ch; margin-left: auto; margin-right: auto;">Glimpses of Borrah Minevitch, his Harmonica Rascals years, and the family he passed the Mill on to.</p>
    </div>
    <div class="container fade-in" style="margin-top: 36px;">
      <div class="history-gallery">
        {historyGallery.map((img) => (
          <figure class="history-gallery__item">
            <img src={img.src} alt={img.alt} loading="lazy" />
            <figcaption>{img.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section--tight section--soft" id="faq">
    <div class="container--narrow fade-in text-center">
      <h2 data-i18n-html="about.faq.heading">Frequently Asked <span class="serif-italic">Questions</span></h2>
      <p data-i18n="about.faq.lede" style="margin-top: 12px; max-width: 56ch; margin-left: auto; margin-right: auto;">Address, directions from Paris and the airports, taxis, ride apps, car rental, and nearby day trips.</p>
    </div>
    <div class="container--narrow fade-in" style="margin-top: 36px;">
      <div class="faq" id="getting-here">
        <details class="faq__item" open>
          <summary class="faq__q" data-i18n="about.faq.address.q">What's the address?</summary>
          <div class="faq__a">
            <p data-i18n="about.faq.address.a">14, 16, 18 Rue des Crocs au Renard, 91660 Le Mérévillois.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.opt1.q">How do I get there from the airport by Uber or taxi?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.opt1.orly.h">From Paris Orly (ORY):</strong> <span data-i18n="about.faq.opt1.orly.p">45–55 min · €65–€105 (car) · €90–€160 (van, up to 6).</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.opt1.cdg.h">From Charles de Gaulle (CDG):</strong> <span data-i18n="about.faq.opt1.cdg.p">1h15–1h30 · €130–€250 (car or van).</span></p>
            <p style="margin-top: 10px;" data-i18n="about.faq.opt1.note">Simplest door-to-door option — no transfers. Live prices vary by time of day.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.opt2.q">Can I take the train via Étampes?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.opt2.s1.h">Step 1 — Uber to Gare d'Austerlitz:</strong> <span data-i18n="about.faq.opt2.s1.p">From Orly: €30–€50 (30–40 min) · From CDG: €50–€70 (45–60 min).</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.opt2.s2.h">Step 2 — Train to Étampes:</strong> <span data-i18n="about.faq.opt2.s2.p">RER C: ~50 min, ~€2.50, every ~30 min. TER / Intercités: 30–35 min, €10–€20, fewer departures.</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.opt2.s3.h">Step 3 — Taxi from Étampes:</strong> <span data-i18n="about.faq.opt2.s3.p">~20 min, ~€25.</span> Book ahead with <a href="https://www.allotaxisetampes.fr" target="_blank" rel="noopener">Allo Taxis Étampes</a>, <a href="https://taxietampes.fr" target="_blank" rel="noopener">Taxi Étampes</a>, or <a href="https://www.taxi-91.fr/Taxi-etampes" target="_blank" rel="noopener">Taxi 91</a>.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.opt3.q">Can I get there entirely by public transport?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.opt3.s1.h">Airport to Paris:</strong> <span data-i18n="about.faq.opt3.s1.p">RER B from the airport → Denfert-Rochereau → Métro 6 → Gare d'Austerlitz. ~50–70 min, ~€12–€15.</span></p>
            <p style="margin-top: 10px;" data-i18n="about.faq.opt3.s2.p">Then RER C or TER to Étampes (see above), and a taxi (~20 min, ~€25) to the Moulin.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.rideapps.q">Which ride apps work in France?</summary>
          <div class="faq__a">
            <ul>
              <li><strong>Uber</strong> — <a href="https://www.uber.com" target="_blank" rel="noopener">uber.com</a></li>
              <li><strong>Heetch</strong> (often cheaper) — <a href="https://www.heetch.com" target="_blank" rel="noopener">heetch.com</a></li>
              <li><strong>FREE NOW</strong> (connects to taxis) — <a href="https://www.free-now.com" target="_blank" rel="noopener">free-now.com</a></li>
            </ul>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.rental.q">Where can I rent a car?</summary>
          <div class="faq__a">
            <p><strong data-i18n="about.faq.rental.airports.h">At the airports:</strong> <span data-i18n="about.faq.rental.airports.p">Europcar, Sixt, Hertz · typically €40–€120/day.</span></p>
            <p style="margin-top: 10px;"><strong data-i18n="about.faq.rental.etampes.h">In Étampes:</strong> <a href="https://www.avis.fr/services-avis/location-voiture/europe/france/%C3%A9tampes/etampes-location-de-voiture" target="_blank" rel="noopener">Avis Étampes</a>.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.dogs.q">Is the property dog-friendly?</summary>
          <div class="faq__a">
            <p data-i18n="about.faq.dogs.a">Yes — Moulin à Rêves is dog-friendly. We have walked our own dogs through the gardens for years and welcome well-behaved pups. Let us know in advance so we can prepare the houses, and please keep dogs off the beds and out of the spa.</p>
          </div>
        </details>

        <details class="faq__item">
          <summary class="faq__q" data-i18n="about.faq.trips.q">What's nearby for a day trip?</summary>
          <div class="faq__a">
            <ul>
              <li><strong>Chartres</strong> — <span data-i18n="about.faq.trips.chartres">home of the iconic Gothic cathedral.</span></li>
              <li><strong>Orléans</strong> — <span data-i18n="about.faq.trips.orleans">city of Joan of Arc on the Loire.</span></li>
              <li><strong>Barbizon</strong> — <span data-i18n="about.faq.trips.barbizon">painters' village at the edge of Fontainebleau forest.</span> <a href="/journal/spring-in-barbizon/">Read more →</a></li>
              <li><strong>Vaux-le-Vicomte</strong> — <span data-i18n="about.faq.trips.vaux">the château that inspired Versailles.</span></li>
              <li><strong data-i18n="about.faq.trips.loire.h">Loire Valley</strong> — <span data-i18n="about.faq.trips.loire">90 minutes away — Chambord, Chenonceau, Amboise, Blois.</span></li>
              <li><strong>Fontainebleau</strong> — <span data-i18n="about.faq.trips.fontainebleau">royal château and 25,000 hectares of ancient forest, twenty minutes away.</span></li>
            </ul>
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 40vh; min-height: 320px;">
    <div class="hero__image">
      <img src="/images/evening-compound.webp" alt="Moulin à Rêves at golden hour" loading="lazy" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="about.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">come and visit!</h2>
      <a href="/contact/" class="btn btn--white" data-i18n="about.cta.button">Plan Your Stay</a>
    </div>
  </section>

  <style>
    .section--tight { padding-top: 64px; padding-bottom: 64px; }
    .faq__item {
      border-top: 1px solid rgba(0, 0, 0, 0.1);
      padding: 18px 0;
    }
    .faq__item:last-child { border-bottom: 1px solid rgba(0, 0, 0, 0.1); }
    .faq__q {
      cursor: pointer;
      list-style: none;
      font-family: var(--font-serif);
      font-style: italic;
      font-weight: 500;
      font-size: 1.25rem;
      color: var(--ink);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }
    .faq__q::-webkit-details-marker { display: none; }
    .faq__q::after {
      content: '+';
      font-family: var(--font-body);
      font-style: normal;
      font-size: 1.5rem;
      color: var(--blue-primary, #3a5a8a);
      transition: transform 0.2s ease;
      flex-shrink: 0;
    }
    details[open] .faq__q::after { content: '–'; }
    .faq__a {
      padding-top: 14px;
      font-size: 0.9375rem;
      line-height: 1.6;
      color: var(--ink-soft);
    }
    .faq__a p { margin: 0; }
    .faq__a ul { margin: 0; padding-left: 18px; }
    .faq__a li { margin: 4px 0; }
    .faq__a a { color: var(--blue-primary, #3a5a8a); text-decoration: underline; }

    .history-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
      align-items: start;
    }
    .history-gallery__item { margin: 0; }
    .history-gallery__item img {
      width: 100%;
      height: auto;
      display: block;
      background: #f5f3ee;
    }
    .history-gallery__item figcaption {
      margin-top: 12px;
      font-family: var(--font-body);
      font-size: 0.875rem;
      line-height: 1.5;
      color: var(--ink-soft);
      font-style: italic;
    }
  </style>

</BaseLayout>
