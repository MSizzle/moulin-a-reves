---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gallery — Moulin à Rêves" description="Photos of Moulin à Rêves — three stone houses, gardens, the millstream, and the French countryside near Fontainebleau Forest.">

  <!-- Hero -->
  <section class="hero" style="height: 50vh;">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Golden hour light across the Moulin à Rêves stone compound near Barbizon, France" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="gallery.hero.title">Gallery</h1>
      <p class="hero__tagline" data-i18n="gallery.hero.tagline">See the place. Then come and feel it.</p>
    </div>
  </section>

  <!-- Le Moulin -->
  <section class="section">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.moulin.heading">Le Moulin</h2>
        <p data-i18n="gallery.moulin.sub" style="margin-top: 8px;">The original mill house.</p>
      </div>
      <div class="photo-grid fade-in">
        <figure>
          <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin à Rêves stone mill house exterior with blue shutters and antique flower cart" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/le-moulin-suite-romantique.webp" alt="La Suite Romantique master bedroom with exposed beams and stone fireplace at Le Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/le-moulin-kitchen.webp" alt="Eat-in kitchen with French armoire and Viking-style ovens at Le Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/bridge-garden.webp" alt="The Giverny-style green bridge over the Juine millstream at Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/le-moulin-living.webp" alt="Living room with leather club chairs and original millwheel at Le Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/le-moulin-dining.webp" alt="Formal dining room set for 12 with chandelier and antiques at Le Moulin à Rêves" loading="lazy" />
        </figure>
      </div>
    </div>
  </section>

  <!-- Hollywood Hideaway -->
  <section class="section section--stone">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.grange.heading">The Hollywood Hideaway</h2>
        <p data-i18n="gallery.grange.sub" style="margin-top: 8px;">A 60-year sanctuary, sleeps 7.</p>
      </div>
      <div class="photo-grid fade-in">
        <figure>
          <img src="/images/homes/hh-exterior.webp" alt="Exterior of the Hollywood Hideaway among the gardens" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/hh-looking-glass.webp" alt="Through the Looking Glass king bedroom with antique mirror at The Hollywood Hideaway" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/hh-kitchen.webp" alt="Bright white kitchen with red accents at The Hollywood Hideaway" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/hh-american-in-paris.webp" alt="An American in Paris queen bedroom with French wallpaper at The Hollywood Hideaway" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/hh-dining-living.webp" alt="Open dining and living room at The Hollywood Hideaway" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/hh-gazebo.webp" alt="Covered gazebo with dining table at The Hollywood Hideaway" loading="lazy" />
        </figure>
      </div>
    </div>
  </section>

  <!-- Maison de la Rivière -->
  <section class="section">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.jardin.heading">La Maison de la Rivière</h2>
        <p data-i18n="gallery.jardin.sub" style="margin-top: 8px;">The garden cottage along the stream.</p>
      </div>
      <div class="photo-grid fade-in">
        <figure>
          <img src="/images/homes/le-jardin-hero.webp" alt="La Maison de la Rivière exterior with the millstream and ivy-covered stone at Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/maison-dining.webp" alt="Dining room with grand landscape painting and stone walls at La Maison de la Rivière" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/maison-artistes.webp" alt="La Chambre des Artistes — sun-drenched bedroom with vaulted timber beams" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/maison-living.webp" alt="Living room with floral couches, fireplace, and the Louis Vuitton trunk coffee table" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/maison-kitchen.webp" alt="Eat-in kitchen with stone walls, beams, and a baguette on the counter at La Maison de la Rivière" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/homes/maison-ecrivains.webp" alt="La Chambre des Écrivains — the Writers' Room with a double bed at La Maison de la Rivière" loading="lazy" />
        </figure>
      </div>
    </div>
  </section>

  <!-- The Grounds -->
  <section class="section section--stone">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.grounds.heading">The Grounds</h2>
        <p data-i18n="gallery.grounds.sub" style="margin-top: 8px;">Gardens, millstream, and the spaces between.</p>
      </div>
      <div class="photo-grid fade-in">
        <figure>
          <img src="/images/hero-compound.webp" alt="Wide view of the Moulin à Rêves compound with the millstream running between the stone buildings" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/bridge-garden.webp" alt="The Giverny-style green bridge under willows at Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/yoga-lawn.webp" alt="Garden chaises on the lawn with the bridge in view at Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/barn-events.webp" alt="La Grange dinner table set under the timber roof at Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/outdoor-dining.webp" alt="Patio breakfast with croissants on the lawn at Moulin à Rêves" loading="lazy" />
        </figure>
        <figure>
          <img src="/images/evening-compound.webp" alt="Moulin à Rêves at dusk under a pink sky" loading="lazy" />
        </figure>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container fade-in">
      <h2 data-i18n="gallery.cta.heading">Seen Enough?</h2>
      <p data-i18n="gallery.cta.text" style="margin-top: 16px; margin-bottom: 32px;">
        Photos only tell part of the story. The sound of the stream, the smell of lavender, the warmth of the stone — you'll have to come for those.
      </p>
      <a href="/contact/" class="btn btn--primary" data-i18n="gallery.cta.button">Plan Your Stay</a>
    </div>
  </section>

</BaseLayout>
