---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gallery — Moulin à Rêves" description="Photos of Moulin à Rêves — three stone houses, gardens, the millstream, and the French countryside near Fontainebleau Forest.">

  <!-- Hero -->
  <section class="hero" style="height: 50vh;">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Golden hour light across the Moulin à Rêves compound" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title">Gallery</h1>
      <p class="hero__tagline">See the place. Then come and feel it.</p>
    </div>
  </section>

  <!-- Le Moulin -->
  <section class="section">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2>Le Moulin</h2>
        <p style="margin-top: 8px;">The original mill house.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item masonry__item--tall">
          <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin exterior with blue shutters" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin master bedroom" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin farmhouse kitchen" />
        </div>
        <div class="masonry__item masonry__item--wide">
          <img src="/images/bridge-garden.webp" alt="Le Moulin millstream terrace" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin living room with fireplace" />
        </div>
        <div class="masonry__item">
          <img src="/images/screening-room.webp" alt="Le Moulin stone wall detail" />
        </div>
      </div>
    </div>
  </section>

  <!-- La Grange -->
  <section class="section section--stone">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2>La Grange</h2>
        <p style="margin-top: 8px;">The converted barn.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item">
          <img src="/images/homes/la-grange-hero.webp" alt="La Grange exterior with tall windows" />
        </div>
        <div class="masonry__item masonry__item--tall">
          <img src="/images/homes/la-grange-living.webp" alt="La Grange soaring ceiling and beams" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/la-grange-living.webp" alt="La Grange open kitchen" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/la-grange-living.webp" alt="La Grange master bedroom under the eaves" />
        </div>
        <div class="masonry__item masonry__item--wide">
          <img src="/images/gazebo-dining.webp" alt="La Grange garden with folding doors open" />
        </div>
        <div class="masonry__item">
          <img src="/images/barn-events.webp" alt="La Grange iron tie-rod detail" />
        </div>
      </div>
    </div>
  </section>

  <!-- Le Jardin -->
  <section class="section">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2>Le Jardin</h2>
        <p style="margin-top: 8px;">The garden cottage.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item">
          <img src="/images/homes/le-jardin-hero.webp" alt="Le Jardin covered in wisteria" />
        </div>
        <div class="masonry__item">
          <img src="/images/gazebo-dining.webp" alt="Le Jardin terrace with table set for dinner" />
        </div>
        <div class="masonry__item masonry__item--tall">
          <img src="/images/bridge-garden.webp" alt="Le Jardin master bedroom" />
        </div>
        <div class="masonry__item">
          <img src="/images/screening-room.webp" alt="Le Jardin living room with wood stove" />
        </div>
        <div class="masonry__item">
          <img src="/images/outdoor-dining.webp" alt="Le Jardin galley kitchen" />
        </div>
        <div class="masonry__item masonry__item--wide">
          <img src="/images/forest-path.webp" alt="Wisteria in bloom on the south wall" />
        </div>
      </div>
    </div>
  </section>

  <!-- The Grounds -->
  <section class="section section--stone">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2>The Grounds</h2>
        <p style="margin-top: 8px;">Gardens, millstream, and the spaces between.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item masonry__item--wide">
          <img src="/images/hero-compound.webp" alt="Aerial view of the compound and gardens" />
        </div>
        <div class="masonry__item masonry__item--tall">
          <img src="/images/bridge-garden.webp" alt="The millstream with stone bridge" />
        </div>
        <div class="masonry__item">
          <img src="/images/wellness-pool.webp" alt="The walled garden with roses" />
        </div>
        <div class="masonry__item">
          <img src="/images/gym.webp" alt="The pétanque court under the linden trees" />
        </div>
        <div class="masonry__item">
          <img src="/images/outdoor-dining.webp" alt="Long dinner table set outdoors" />
        </div>
        <div class="masonry__item">
          <img src="/images/personality.webp" alt="The compound at golden hour" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container fade-in">
      <h2>Seen Enough?</h2>
      <p style="margin-top: 16px; margin-bottom: 32px;">
        Photos only tell part of the story. The sound of the stream, the smell of lavender, the warmth of the stone — you'll have to come for those.
      </p>
      <a href="/contact/" class="btn btn--primary">Plan Your Stay</a>
    </div>
  </section>

  <style>
    .masonry {
      columns: 3;
      column-gap: 16px;
    }

    .masonry__item {
      break-inside: avoid;
      margin-bottom: 16px;
      border-radius: 8px;
      overflow: hidden;
      background: var(--bg-warm-white);
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
    }

    .masonry__item img {
      width: 100%;
      height: auto;
      display: block;
      transition: transform var(--duration) var(--ease-out);
    }

    .masonry__item:hover img {
      transform: scale(1.03);
    }

    .masonry__item--tall img {
      min-height: 350px;
      object-fit: cover;
    }

    .masonry__item--wide {
      break-inside: avoid;
    }

    .masonry__item--wide img {
      min-height: 220px;
      object-fit: cover;
    }

    @media (max-width: 1024px) {
      .masonry {
        columns: 2;
      }
    }

    @media (max-width: 768px) {
      .masonry {
        columns: 1;
      }

      .masonry__item--tall img,
      .masonry__item--wide img {
        min-height: 200px;
      }
    }
  </style>

</BaseLayout>
