---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Gallery — Moulin à Rêves" description="Photos of Moulin à Rêves — three stone houses, gardens, the millstream, and the French countryside near Fontainebleau Forest.">

  <!-- Hero -->
  <section class="hero" style="height: 50vh;">
    <div class="hero__image">
      <img src="/images/hero-compound.webp" alt="Golden hour light across the Moulin à Rêves stone compound near Barbizon, France" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="gallery.hero.title">Gallery</h1>
      <p class="hero__tagline" data-i18n="gallery.hero.tagline">See the place. Then come and feel it.</p>
    </div>
  </section>

  <!-- Le Moulin -->
  <section class="section">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.moulin.heading">Le Moulin</h2>
        <p data-i18n="gallery.moulin.sub" style="margin-top: 8px;">The original mill house.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item masonry__item--tall">
          <img src="/images/homes/le-moulin-hero.webp" alt="Le Moulin stone mill house exterior with blue shutters at Moulin à Rêves, Barbizon" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin master bedroom with exposed beams at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin farmhouse kitchen with copper pans at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item masonry__item--wide">
          <img src="/images/bridge-garden.webp" alt="Le Moulin stone terrace overlooking the millstream at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/le-moulin-living.webp" alt="Le Moulin living room with stone fireplace at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/screening-room.webp" alt="Le Moulin original limestone wall detail at Moulin à Rêves, Barbizon" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- La Grange -->
  <section class="section section--stone">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.grange.heading">La Grange</h2>
        <p data-i18n="gallery.grange.sub" style="margin-top: 8px;">The converted barn.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item">
          <img src="/images/homes/la-grange-hero.webp" alt="La Grange converted barn exterior with tall windows at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item masonry__item--tall">
          <img src="/images/homes/la-grange-living.webp" alt="La Grange soaring five-metre ceiling with original beams at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/la-grange-living.webp" alt="La Grange open kitchen with reclaimed oak worktops at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/homes/la-grange-living.webp" alt="La Grange master bedroom with skylight bath under the eaves at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item masonry__item--wide">
          <img src="/images/gazebo-dining.webp" alt="La Grange garden terrace with folding barn doors open at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/barn-events.webp" alt="La Grange original iron tie-rod architectural detail at Moulin à Rêves" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Le Jardin -->
  <section class="section">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.jardin.heading">Le Jardin</h2>
        <p data-i18n="gallery.jardin.sub" style="margin-top: 8px;">The garden cottage.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item">
          <img src="/images/homes/le-jardin-hero.webp" alt="Le Jardin garden cottage covered in wisteria blooms at Moulin à Rêves, Barbizon" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/gazebo-dining.webp" alt="Le Jardin terrace with table set for dinner under the wisteria at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item masonry__item--tall">
          <img src="/images/bridge-garden.webp" alt="Le Jardin master bedroom with south-facing garden views at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/screening-room.webp" alt="Le Jardin living room with wood-burning stove and bookshelves at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/outdoor-dining.webp" alt="Le Jardin galley kitchen with garden window at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item masonry__item--wide">
          <img src="/images/forest-path.webp" alt="Wisteria in full bloom on Le Jardin south wall at Moulin à Rêves, Barbizon" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- The Grounds -->
  <section class="section section--stone">
    <div class="container">
      <div class="fade-in" style="margin-bottom: 32px;">
        <h2 data-i18n="gallery.grounds.heading">The Grounds</h2>
        <p data-i18n="gallery.grounds.sub" style="margin-top: 8px;">Gardens, millstream, and the spaces between.</p>
      </div>
      <div class="masonry fade-in">
        <div class="masonry__item masonry__item--wide">
          <img src="/images/hero-compound.webp" alt="Aerial view of Moulin à Rêves compound and shared gardens near Barbizon, France" loading="lazy" />
        </div>
        <div class="masonry__item masonry__item--tall">
          <img src="/images/bridge-garden.webp" alt="The millstream with centuries-old stone bridge at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/wellness-pool.webp" alt="The walled garden with climbing roses at Moulin à Rêves, Barbizon" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/gym.webp" alt="The petanque court under linden trees at Moulin à Rêves compound" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/outdoor-dining.webp" alt="Long communal dinner table set outdoors in the garden at Moulin à Rêves" loading="lazy" />
        </div>
        <div class="masonry__item">
          <img src="/images/personality.webp" alt="Moulin à Rêves compound bathed in golden evening light, Seine-et-Marne" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section text-center">
    <div class="container fade-in">
      <h2 data-i18n="gallery.cta.heading">Seen Enough?</h2>
      <p data-i18n="gallery.cta.text" style="margin-top: 16px; margin-bottom: 32px;">
        Photos only tell part of the story. The sound of the stream, the smell of lavender, the warmth of the stone — you'll have to come for those.
      </p>
      <a href="/contact/" class="btn btn--primary" data-i18n="gallery.cta.button">Plan Your Stay</a>
    </div>
  </section>

  <style>
    .masonry {
      columns: 3;
      column-gap: 16px;
    }

    .masonry__item {
      break-inside: avoid;
      margin-bottom: 16px;
      border-radius: 8px;
      overflow: hidden;
      background: var(--bg-warm-white);
      box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06);
    }

    .masonry__item img {
      width: 100%;
      height: auto;
      display: block;
      transition: transform var(--duration) var(--ease-out);
    }

    .masonry__item:hover img {
      transform: scale(1.03);
    }

    .masonry__item--tall img {
      min-height: 350px;
      object-fit: cover;
    }

    .masonry__item--wide {
      break-inside: avoid;
    }

    .masonry__item--wide img {
      min-height: 220px;
      object-fit: cover;
    }

    @media (max-width: 1024px) {
      .masonry {
        columns: 2;
      }
    }

    @media (max-width: 768px) {
      .masonry {
        columns: 1;
      }

      .masonry__item--tall img,
      .masonry__item--wide img {
        min-height: 200px;
      }
    }
  </style>

</BaseLayout>
