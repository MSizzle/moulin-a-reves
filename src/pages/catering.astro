---
import BaseLayout from '../layouts/BaseLayout.astro';
import Img from '../components/Img.astro';
---

<BaseLayout title="Catering Recommendations — Moulin à Rêves" description="Trusted local catering and chef contacts near Moulin à Rêves. Guests book directly with providers; we share recommendations.">

  <!-- Hero — guests gathered behind a table laid with food at La Grange -->
  <section class="hero catering-hero" style="height: 60vh;">
    <div class="hero__image">
      <Img src="/images/catering-group-table.webp" alt="Guests gathered behind a long table laid with food at Moulin à Rêves" sizes="100vw" loading="eager" fetchpriority="high" />
    </div>
    <div class="hero__overlay"></div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="catering.hero.title">Catering</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="section--tight">
    <div class="container--narrow text-center fade-in">
      <h2 data-i18n="catering.intro.heading">Bon Appétit!</h2>
      <p data-i18n="catering.intro.text" style="margin-top: 20px;">Food is one of the great pleasures of French life, and at Moulin à Rêves, we make it easy to enjoy. Visit the weekly market, browse the local boulangerie, shop at the nearby supermarket, or let us help arrange the details before you arrive.</p>
    </div>
  </section>

  <!-- À Table -->
  <section class="section--tight fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/homes/maison-dinner-light.webp" alt="The dining room table set for a fully staffed meal at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="catering.table.heading">À Table</h2>
        <p data-i18n="catering.table.p1">Some of the most memorable moments at Moulin à Rêves happen around the table. Gather in one of three elegant dining rooms, beneath La Grange, or on one of the estate's garden patios dressed with Pierre Deux linens. Whether you're cooking with market-fresh ingredients, sharing a catered feast, or lingering over a bottle of wine with friends, here meals are meant to be savored as long as the conversation lasts.</p>
      </div>
    </div>
  </section>

  <!-- Before Your Arrival -->
  <section class="section--tight fade-in">
    <div class="container--narrow text-center">
      <h2 data-i18n="catering.arrival.heading">Before Your Arrival</h2>
      <p data-i18n="catering.arrival.p1" style="margin-top: 20px;">Arrive to a kitchen stocked with groceries, wine, and essentials. Whether you'd like breakfast staples, picnic supplies, aperitif ingredients, or provisions for a special dinner, we can arrange advance shopping for an additional fee.</p>
    </div>
  </section>

  <!-- Fresh from the Boulangerie -->
  <section class="section--tight fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="catering.boulangerie.heading">Fresh from the Boulangerie</h2>
        <p data-i18n="catering.boulangerie.p1">Start your day with warm baguettes and croissants delivered to the estate each morning, or bike into the village and enjoy one of France's most cherished daily rituals.</p>
      </div>
      <div class="split__image">
        <img src="/images/catering-patisserie.webp" alt="Fresh baguettes, croissants, and pastries from the village boulangerie" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Local Chefs & Catering -->
  <section class="section--tight fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/group-dinner.webp" alt="A long table set for dinner beneath La Grange at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="catering.chef.heading">Local Chefs &amp; Catering</h2>
        <p data-i18n="catering.chef.p1">From nourishing retreat meals to elegant dinners beneath La Grange, we're happy to connect you with trusted local chefs, caterers, and food producers.</p>
        <p data-i18n="catering.chef.p2" style="margin-top: 16px;">Options range from simple drop-off meals prepared by local artisans to fully catered celebrations with service staff. We can recommend everything from traditional French country fare featuring local specialties to refined multi-course dinners for special occasions.</p>
      </div>
    </div>
  </section>

  <!-- Be Our Guest -->
  <section class="section--tight fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="catering.guest.heading">Be Our Guest</h2>
        <p data-i18n="catering.guest.p1">From setup and serving to cleanup, we can connect you with trusted local staff so you can focus on enjoying time with family and friends.</p>
      </div>
      <div class="split__image">
        <img src="/images/catering-friends.webp" alt="Friends gathered around a meal or celebration at Moulin à Rêves" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- À Votre Santé -->
  <section class="section--tight fade-in">
    <div class="container--narrow text-center">
      <h2 data-i18n="catering.sante.heading">À Votre Santé</h2>
      <p data-i18n="catering.sante.p1" style="margin-top: 20px;">Whether it's a simple breakfast on the terrace or a celebration beneath La Grange, we believe the best memories are made around the table.</p>
      <p data-i18n="catering.sante.p2" style="margin-top: 16px;">We'll help you enjoy the pleasures of French country life.</p>
      <a href="/contact/" class="btn btn--green" data-i18n="catering.cta.button" style="margin-top: 28px;">Join us</a>
    </div>
  </section>

  <style>
    .section--tight { padding-top: 56px; padding-bottom: 56px; }
    .catering-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .catering-grid__tile {
      position: relative;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      cursor: zoom-in;
      border-radius: 4px;
    }
    .catering-grid__tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .catering-grid__tile:hover img { transform: scale(1.04); }
    .catering-grid__label {
      position: absolute;
      bottom: 16px;
      left: 16px;
      color: white;
      font-family: var(--font-display, serif);
      font-size: 1.5rem;
      letter-spacing: 0.04em;
      text-shadow: 0 1px 8px rgba(0,0,0,0.6);
    }
    @media (max-width: 720px) {
      .catering-grid { grid-template-columns: 1fr; }
      .catering-grid__tile { aspect-ratio: 3 / 2; }
    }
  </style>

</BaseLayout>
