---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Catering Recommendations — Moulin à Rêves" description="Trusted local catering and chef contacts near Moulin à Rêves. Guests book directly with providers; we share recommendations.">

  <!-- Hero -->
  <section class="hero" style="height: 56vh;">
    <div class="hero__image">
      <img src="/images/group-dinner.webp" alt="Plated seasonal dinner with friends at Moulin à Rêves" />
    </div>
    <div class="hero__content">
      <h1 class="hero__title" data-i18n="catering.hero.title">Catering</h1>
      <p class="hero__tagline" data-i18n="catering.hero.tagline">Trusted local providers. We share contacts; you book directly.</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="section--tight">
    <div class="container--narrow text-center fade-in">
      <h2 data-i18n="catering.intro.heading">How catering works at Moulin à Rêves</h2>
      <p data-i18n="catering.intro.text" style="margin-top: 20px;">
        We do not provide catering ourselves. We share trusted local contacts — boulangeries, chefs, traiteurs — and you arrange directly with them. Tell us what you have in mind and we will pass along the right names.
      </p>
    </div>
  </section>

  <!-- Breakfast -->
  <section class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/garden-breakfast.webp" alt="Breakfast set on the patio outside the stone cottage at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="catering.breakfast.heading">Breakfast Delivery</h2>
        <p data-i18n="catering.breakfast.p1">
          The local boulangerie delivers fresh croissants, baguette, butter, confiture, and seasonal fruit to your door. Arrange directly with them once you book.
        </p>
      </div>
    </div>
  </section>

  <!-- Dinner -->
  <section class="fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="catering.dinner.heading">Dinner & Traiteurs</h2>
        <p data-i18n="catering.dinner.p1">
          Several local chefs and traiteurs prepare seasonal multi-course dinners delivered ready to plate. Menus and pricing are arranged directly with each provider.
        </p>
      </div>
      <div class="split__image">
        <img src="/images/homes/maison-dinner-light.webp" alt="Warm dining room set for a multi-course dinner at La Maison de la Rivière" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Pâtisseries -->
  <section class="fade-in">
    <div class="split">
      <div class="split__image">
        <img src="/images/catering-patisserie.webp" alt="French patisserie pastry display at Moulin à Rêves" loading="lazy" />
      </div>
      <div class="split__body">
        <h2 data-i18n="catering.patisserie.heading">Pâtisseries & Sweets</h2>
        <p data-i18n="catering.patisserie.p1">
          Macarons, tarts, layered cakes, and seasonal fruit from the village pâtissiers — a tray waiting on the table when guests arrive, or a celebration cake delivered to mark the occasion.
        </p>
      </div>
    </div>
  </section>

  <!-- Private Chef -->
  <section class="fade-in">
    <div class="split split--reverse">
      <div class="split__body">
        <h2 data-i18n="catering.chef.heading">Private Chef</h2>
        <p data-i18n="catering.chef.p1">
          For groups who want a chef on site for the whole stay, we can share contacts for chefs in the region. They handle shopping, cooking, and dietary needs directly with you.
        </p>
      </div>
      <div class="split__image">
        <img src="/images/catering-group-table.webp" alt="Long catering table set for a group dinner at Moulin à Rêves" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Food gallery -->
  <section class="section--tight fade-in">
    <div class="container">
      <div class="text-center" style="margin-bottom: 32px;">
        <h2 data-i18n="catering.gallery.heading">On the <span class="serif-italic">table</span></h2>
      </div>
      <div class="catering-grid">
        <div class="catering-grid__tile" data-gallery={JSON.stringify([
          { src: '/images/catering-cake.webp', alt: 'Layered celebration cake on the catering table at Moulin à Rêves' },
          { src: '/images/catering-macaroons.webp', alt: 'Pastel French macarons arranged on a serving plate' },
          { src: '/images/catering-strawberries.webp', alt: 'Bowl of fresh strawberries served at Moulin à Rêves' },
          { src: '/images/catering-patisserie.webp', alt: 'French patisserie pastry display at Moulin à Rêves' },
        ])}>
          <img src="/images/catering-cake.webp" alt="Layered celebration cake on the catering table at Moulin à Rêves" loading="lazy" />
          <span class="catering-grid__label">Sweet</span>
        </div>
        <div class="catering-grid__tile" data-gallery={JSON.stringify([
          { src: '/images/catering-meat.webp', alt: 'Carved meat platter from the catering kitchen at Moulin à Rêves' },
          { src: '/images/catering-salad.webp', alt: 'Fresh garden salad on the catering table at Moulin à Rêves' },
          { src: '/images/catering-group-table.webp', alt: 'Long catering table set for a group dinner at Moulin à Rêves' },
        ])}>
          <img src="/images/catering-meat.webp" alt="Carved meat platter from the catering kitchen at Moulin à Rêves" loading="lazy" />
          <span class="catering-grid__label">Savory</span>
        </div>
        <div class="catering-grid__tile" data-gallery={JSON.stringify([
          { src: '/images/catering-friends.webp', alt: 'Friends gathered around a catered meal at Moulin à Rêves' },
          { src: '/images/catering-group-gathering.webp', alt: 'Group gathered for a catered dinner at Moulin à Rêves' },
          { src: '/images/group-tuscan-sun.webp', alt: 'Open-air family dinner under string lights at Moulin à Rêves' },
        ])}>
          <img src="/images/catering-friends.webp" alt="Friends gathered around a catered meal at Moulin à Rêves" loading="lazy" />
          <span class="catering-grid__label">Together</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="hero" style="height: 40vh; min-height: 320px;">
    <div class="hero__image">
      <img src="/images/barn-events.webp" alt="Long dinner table at La Grange, Moulin à Rêves" loading="lazy" />
    </div>
    <div class="hero__content">
      <h2 class="hero__title" data-i18n="catering.cta.heading" style="font-size: clamp(2rem, 4vw, 3rem);">Need contacts?</h2>
      <p class="hero__tagline" data-i18n="catering.cta.text">Tell us what you have in mind and we will share trusted local providers.</p>
      <a href="/contact/" class="btn btn--white" data-i18n="catering.cta.button">Request Recommendations</a>
    </div>
  </section>

  <style>
    .section--tight { padding-top: 56px; padding-bottom: 56px; }
    .catering-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .catering-grid__tile {
      position: relative;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      cursor: zoom-in;
      border-radius: 4px;
    }
    .catering-grid__tile img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }
    .catering-grid__tile:hover img { transform: scale(1.04); }
    .catering-grid__label {
      position: absolute;
      bottom: 16px;
      left: 16px;
      color: white;
      font-family: var(--font-display, serif);
      font-size: 1.5rem;
      letter-spacing: 0.04em;
      text-shadow: 0 1px 8px rgba(0,0,0,0.6);
    }
    @media (max-width: 720px) {
      .catering-grid { grid-template-columns: 1fr; }
      .catering-grid__tile { aspect-ratio: 3 / 2; }
    }
  </style>

</BaseLayout>
