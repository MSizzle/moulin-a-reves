---
import Img from './Img.astro';

interface Photo {
  src: string;
  alt?: string;
  caption?: string;
}

interface Detail {
  label: string;
  value: string;
}

export interface Room {
  id?: string;
  eyebrow?: string;
  title: string;
  summary: string;
  longDescription?: string;
  details?: Detail[];
  photos: Photo[];
  /** Optional: 3 emoji-prefixed quality tags for sleep cards, e.g. "🛌 King bedroom · 🛁 En-suite bath · ✨ Upstairs" */
  qualities?: string;
}

interface Props {
  eyebrow: string;
  heading: string;
  intro?: string;
  rooms: Room[];
  background?: 'cream' | 'stone';
  i18nKey?: string;
  hideTileSummary?: boolean;
  /** Gather mode: show only italic title, hide photo-count badge, hide summary */
  gatherMode?: boolean;
  /** Render the intro as a strong, near-black summary line (e.g. "5 Bedrooms • 4 Baths • …") */
  introStrong?: boolean;
}

const { eyebrow, heading, intro, rooms, background = 'cream', i18nKey, hideTileSummary = false, gatherMode = false, introStrong = false } = Astro.props;
const sectionClass = background === 'stone' ? 'section section--tight section--soft' : 'section section--tight';
const eyebrowKey = i18nKey ? `${i18nKey}.eyebrow` : undefined;
const headingKey = i18nKey ? `${i18nKey}.heading` : undefined;
const introKey = i18nKey ? `${i18nKey}.intro` : undefined;
// gatherMode forces hideTileSummary behaviour too
const effectiveHideTileSummary = hideTileSummary || gatherMode;
const tileSummaryClass = effectiveHideTileSummary ? 'compound-tile__summary compound-tile__summary--hidden' : 'compound-tile__summary';
---

<section class={sectionClass}>
  <div class="container">
    <div class="text-center fade-in" style="margin-bottom: 28px;">
      {eyebrow && <span class="eyebrow" {...(eyebrowKey ? { 'data-i18n': eyebrowKey } : {})}>{eyebrow}</span>}
      <h2 set:html={heading} {...(headingKey ? { 'data-i18n-html': headingKey } : {})} />
      {intro && (introStrong
        ? <p class="roomshowcase__summary" {...(introKey ? { 'data-i18n': introKey } : {})}>{intro}</p>
        : <p style="margin-top: 10px; font-size: 0.875rem; color: var(--ink-mute);" {...(introKey ? { 'data-i18n': introKey } : {})}>{intro}</p>)}
    </div>
    <div class="compound-grid compound-grid--3 compound-grid--rooms">
      {rooms.map((room, i) => {
        const slug = room.id || `${i}`;
        const base = i18nKey ? `${i18nKey}.room.${slug}` : undefined;
        const titleKey = base ? `${base}.title` : undefined;
        const summaryKey = base ? `${base}.summary` : undefined;
        const eyebrowKey = base ? `${base}.eyebrow` : undefined;
        const longKey = base ? `${base}.longDescription` : undefined;
        const detailKeys = base && room.details
          ? room.details.map((_, j) => ({ label: `${base}.detail.${j}.label`, value: `${base}.detail.${j}.value` }))
          : undefined;
        const roomPayload = {
          ...room,
          ...(base
            ? {
                i18nKeys: {
                  eyebrow: eyebrowKey,
                  title: titleKey,
                  summary: summaryKey,
                  longDescription: longKey,
                  details: detailKeys,
                },
              }
            : {}),
        };
        // Build the photos-only payload for the hero lightbox
        const galleryPhotos = room.photos.map(p => ({ src: p.src, alt: p.alt || room.title, caption: p.caption || '' }));
        return (
          <div class="compound-tile compound-tile--clickable fade-in" data-gallery={JSON.stringify(galleryPhotos)} role="button" tabindex="0">
            <div class="compound-tile__media">
              <Img src={room.photos[0].src} alt={room.photos[0].alt || room.title} sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw" loading="lazy" />
              {!gatherMode && room.photos.length > 1 && (
                <span class="card__photo-count">{room.photos.length} photos</span>
              )}
            </div>
            <div class="compound-tile__body">
              <h3 class={gatherMode ? 'compound-tile__title compound-tile__title--gather' : 'compound-tile__title'} {...(titleKey ? { 'data-i18n': titleKey } : {})}>{room.title}</h3>
              {!effectiveHideTileSummary && (
                <p class={tileSummaryClass} {...(summaryKey ? { 'data-i18n': summaryKey } : {})}>{room.summary}</p>
              )}
              {!gatherMode && room.qualities && (
                <p class="compound-tile__qualities">{room.qualities}</p>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  [data-gallery] {
    cursor: zoom-in;
  }
  [data-gallery] .compound-tile__media {
    position: relative;
  }
  [data-gallery] .compound-tile__media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 15, 15, 0.35) 0%, rgba(15, 15, 15, 0) 50%);
    opacity: 0;
    transition: opacity var(--duration) var(--ease-out);
    z-index: 2;
    pointer-events: none;
  }
  [data-gallery]:hover .compound-tile__media::before {
    opacity: 1;
  }
  [data-gallery]:focus-visible {
    outline: 2px solid var(--blue-primary);
    outline-offset: 4px;
  }

  /* Strong intro: bedroom summary line (Bedrooms • Baths • Beds • Sleeps) */
  .roomshowcase__summary {
    margin-top: 12px;
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0.01em;
  }

  /* Sleep-mode: emoji quality tags second line */
  .compound-tile__qualities {
    font-size: 0.8125rem;
    color: var(--ink-mute);
    margin-top: 6px;
    line-height: 1.4;
    letter-spacing: 0.01em;
  }

  /* Gather-mode: italic room name only, no badge */
  .compound-tile__title--gather {
    font-style: italic;
    font-family: var(--font-serif);
    font-weight: 400;
  }

  .card__photo-count {
    position: absolute;
    right: 14px;
    bottom: 14px;
    z-index: 3;
    background: rgba(15, 15, 15, 0.65);
    color: white;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 6px 12px;
    backdrop-filter: blur(4px);
  }
</style>
