---
interface Feature {
  title: string;
  summary: string;
  image: string;
  alt?: string;
}

interface AmenityItem {
  label: string;
  icon?: string;
}

interface Props {
  eyebrow?: string;
  heading?: string;
  intro?: string;
  features: Feature[];
  amenities: AmenityItem[];
  background?: 'cream' | 'stone';
  i18nKey?: string;
}

const { eyebrow = 'Amenities & Grounds', heading = "What's Here", intro, features, amenities, background = 'cream', i18nKey } = Astro.props;
const sectionClass = background === 'stone' ? 'section section--tight section--soft' : 'section section--tight';
const eyebrowKey = i18nKey ? `${i18nKey}.eyebrow` : undefined;
const headingKey = i18nKey ? `${i18nKey}.heading` : undefined;
const introKey = i18nKey ? `${i18nKey}.intro` : undefined;
const includedKey = i18nKey ? `${i18nKey}.includedHeading` : undefined;

const ICONS: Record<string, string> = {
  wifi: '<path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/>',
  kitchen: '<path d="M6 2v20"/><path d="M18 2v20"/><path d="M6 8h12"/><path d="M6 14h12"/>',
  oven: '<rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><circle cx="7" cy="6" r="0.5" fill="currentColor"/><circle cx="11" cy="6" r="0.5" fill="currentColor"/><circle cx="15" cy="6" r="0.5" fill="currentColor"/>',
  coffee: '<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>',
  fireplace: '<path d="M12 2c1 3 4 5 4 9a4 4 0 0 1-8 0c0-2 1-3 1-5 1 1 2 2 3 1z"/>',
  garden: '<path d="M12 2v20"/><path d="M12 7c-3 0-5 2-5 5"/><path d="M12 12c3 0 5-2 5-5"/><path d="M12 17c-4 0-7-3-7-7"/>',
  river: '<path d="M2 8c3-2 5 2 8 0s5-2 8 0 4 0 4 0"/><path d="M2 14c3-2 5 2 8 0s5-2 8 0 4 0 4 0"/>',
  parking: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>',
  washer: '<rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="5"/><circle cx="8" cy="6" r="0.5" fill="currentColor"/><circle cx="11" cy="6" r="0.5" fill="currentColor"/>',
  bed: '<path d="M2 17V7a2 2 0 0 1 2-2h6v8H2"/><path d="M2 17h20v-4a4 4 0 0 0-4-4h-8"/><path d="M2 21v-4"/><path d="M22 21v-4"/>',
  bath: '<path d="M9 6 7.5 4.5a2 2 0 0 0-2.83 2.83L6 8.5"/><line x1="10" y1="5" x2="8" y2="7"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M3 12v3a4 4 0 0 0 4 4h10a4 4 0 0 0 4-4v-3"/><line x1="6" y1="21" x2="6" y2="19"/><line x1="18" y1="21" x2="18" y2="19"/>',
  patio: '<path d="M3 21h18"/><path d="M6 21V11"/><path d="M18 21V11"/><path d="M2 11h20"/><path d="M12 2L4 11h16L12 2z"/>',
  office: '<rect x="3" y="3" width="18" height="14" rx="1"/><line x1="3" y1="21" x2="21" y2="21"/><line x1="8" y1="17" x2="8" y2="21"/><line x1="16" y1="17" x2="16" y2="21"/>',
  guests: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  fridge: '<rect x="5" y="2" width="14" height="20" rx="2"/><line x1="5" y1="10" x2="19" y2="10"/><line x1="9" y1="6" x2="9" y2="7"/><line x1="9" y1="14" x2="9" y2="16"/>',
  tv: '<rect x="2" y="4" width="20" height="14" rx="2"/><polyline points="8 22 12 18 16 22"/>',
  check: '<polyline points="20 6 9 17 4 12"/>',
};

function svgFor(key: string | undefined): string {
  const k = (key || 'check').toLowerCase();
  return ICONS[k] || ICONS['check'];
}
---

<section class={sectionClass}>
  <div class="container">
    <div class="text-center fade-in" style="margin-bottom: 36px;">
      <span class="eyebrow" {...(eyebrowKey ? { 'data-i18n': eyebrowKey } : {})}>{eyebrow}</span>
      <h2 set:html={heading} {...(headingKey ? { 'data-i18n-html': headingKey } : {})} />
      {intro && <p style="margin-top: 12px; font-size: 0.875rem; color: var(--ink-mute);" {...(introKey ? { 'data-i18n': introKey } : {})}>{intro}</p>}
    </div>

    {features.length > 0 && (
      <div class="amenity-features">
        {features.map((f, i) => {
          const featTitleKey = i18nKey ? `${i18nKey}.feature.${i}.title` : undefined;
          const featSummaryKey = i18nKey ? `${i18nKey}.feature.${i}.summary` : undefined;
          return (
            <article class="amenity-feature fade-in">
              <div class="amenity-feature__image">
                <img src={f.image} alt={f.alt || f.title} loading="lazy" />
              </div>
              <div class="amenity-feature__body">
                <h3 class="amenity-feature__title" {...(featTitleKey ? { 'data-i18n': featTitleKey } : {})}>{f.title}</h3>
                <p class="amenity-feature__summary" {...(featSummaryKey ? { 'data-i18n': featSummaryKey } : {})}>{f.summary}</p>
              </div>
            </article>
          );
        })}
      </div>
    )}

    {amenities.length > 0 && (
      <div class="amenity-list fade-in">
        <h4 class="amenity-list__heading" {...(includedKey ? { 'data-i18n': includedKey } : {})}>Also included</h4>
        <ul class="amenity-list__grid">
          {amenities.map((a, i) => {
            const labelKey = i18nKey ? `${i18nKey}.amenity.${i}` : undefined;
            return (
              <li class="amenity-list__item">
                <svg class="amenity-list__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={svgFor(a.icon)}></svg>
                <span {...(labelKey ? { 'data-i18n': labelKey } : {})}>{a.label}</span>
              </li>
            );
          })}
        </ul>
      </div>
    )}
  </div>
</section>

<style>
  .amenity-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
    margin-bottom: 56px;
  }

  .amenity-feature {
    display: flex;
    flex-direction: column;
  }

  .amenity-feature__image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-stone);
  }

  .amenity-feature__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .amenity-feature:hover .amenity-feature__image img {
    transform: scale(1.04);
  }

  .amenity-feature__body {
    padding: 18px 4px 0;
  }

  .amenity-feature__title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.375rem;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .amenity-feature__summary {
    font-size: 0.9375rem;
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: none;
  }

  .amenity-list {
    border-top: 1px solid rgba(32, 32, 32, 0.1);
    padding-top: 32px;
  }

  .amenity-list__heading {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--ink-mute);
    margin-bottom: 20px;
  }

  .amenity-list__grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 14px 28px;
    padding: 0;
    margin: 0;
  }

  .amenity-list__item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.9375rem;
    color: var(--ink-soft);
  }

  .amenity-list__icon {
    color: var(--ink);
    flex-shrink: 0;
    opacity: 0.75;
  }

  @media (max-width: 768px) {
    .amenity-features {
      gap: 24px;
      margin-bottom: 40px;
    }
    .amenity-list__grid {
      grid-template-columns: 1fr 1fr;
      gap: 12px 16px;
    }
  }
</style>
