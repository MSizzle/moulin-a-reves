---
/**
 * <Img> ‚Äî responsive <img> for the committed photos under /public/images/.
 *
 * It keeps the original 2000px WebP as the `src` (so the markup degrades to a
 * plain working image if anything goes wrong) and adds a `srcset` of smaller
 * width variants. Those variants are GENERATED AT BUILD TIME by the
 * `responsive-images` integration (src/integrations/responsive-images), which
 * scans the emitted HTML for `<base>-<w>.webp` references and writes each one
 * into dist/client/ with Sharp. Nothing extra is committed to the repo.
 *
 * Usage:
 *   <Img src="/images/hero-compound.webp" alt="‚Ä¶" sizes="100vw"
 *        loading="eager" fetchpriority="high" />
 *
 * Only local `/images/‚Ä¶.webp` sources get a srcset; anything else (remote URLs,
 * non-webp) falls back to a plain <img src> so callers can't accidentally point
 * srcset at files the integration won't generate.
 */
interface Props {
  src: string;
  alt: string;
  sizes?: string;
  /** Variant widths to offer. The original is added at 2000w. */
  widths?: number[];
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  decoding?: 'async' | 'sync' | 'auto';
  class?: string;
  style?: string;
  [key: string]: any;
}

const {
  src,
  alt,
  sizes = '100vw',
  widths = [480, 768, 1280],
  loading = 'lazy',
  fetchpriority,
  decoding = 'async',
  class: className,
  style,
  ...rest
} = Astro.props;

// Only build a srcset for local committed WebP photos. The variant files are
// `<base>-<w>.webp` next to the original (e.g. /images/hero-compound-768.webp).
const isResponsive = typeof src === 'string' && src.startsWith('/images/') && src.endsWith('.webp');
const base = isResponsive ? src.slice(0, -'.webp'.length) : '';
const srcset = isResponsive
  ? [...widths.map((w) => `${base}-${w}.webp ${w}w`), `${src} 2000w`].join(', ')
  : undefined;

// Reserve the layout box at build time. Without intrinsic width/height a
// `loading="lazy"` image is zero-height until its bitmap downloads, then snaps
// to full size ‚Äî so a grid of lazy photos reflows and "pops in" unevenly as
// each one arrives. The originals live at `public/<src>`; Sharp reads just the
// header, so this is cheap. CSS keeps `width:100%; height:auto`, so the browser
// uses these numbers only for the aspect-ratio box, not the rendered size.
let dims: { width: number; height: number } | null = null;
if (isResponsive) {
  try {
    const sharp = (await import('sharp')).default;
    const meta = await sharp(`public${src}`).metadata();
    if (meta.width && meta.height) dims = { width: meta.width, height: meta.height };
  } catch {
    // Missing/unreadable original ‚Äî degrade to no dims rather than break the build.
  }
}
---

<img
  src={src}
  srcset={srcset}
  sizes={srcset ? sizes : undefined}
  alt={alt}
  width={dims?.width}
  height={dims?.height}
  loading={loading}
  decoding={decoding}
  fetchpriority={fetchpriority}
  class={className}
  style={style}
  {...rest}
/>
