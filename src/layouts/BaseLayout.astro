      .footer__newsletter-form .form__input {
        flex: 1;
        padding: 10px 14px;
        font-size: 0.875rem;
        background: rgba(255, 255, 255, 0.6);
        border: 1px solid rgba(27, 79, 114, 0.25);
        color: var(--ink);
      }

      .footer__newsletter-form .form__input::placeholder {
        color: var(--ink-mute);
      }

      .footer__newsletter-form .btn {
        padding: 10px 20px;
        font-size: 0.75rem;
        white-space: nowrap;
      }

      .footer__bottom {
        border-top: 1px solid rgba(27, 79, 114, 0.18);
        padding-top: 24px;
        text-align: center;
      }

      .footer__bottom p {
        font-size: 0.8125rem;
        color: var(--ink);
        font-weight: 600;
        max-width: none;
      }

      @media (max-width: 1200px) {
        .nav__links {
          display: none;
        }

        .nav__hamburger {
          display: flex;
        }
      }

      @media (max-width: 1024px) {
        .nav__inner {
          padding-left: var(--side-padding-tablet);
          padding-right: var(--side-padding-tablet);
        }

        .footer__grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 768px) {
        .nav__inner {
          padding: 16px var(--side-padding-mobile);
        }

        .footer__grid {
          grid-template-columns: 1fr;
          gap: 32px;
        }

        .footer__newsletter-form {
          flex-direction: column;
        }
      }
    </style>

    <script>
      // Nav scroll behavior
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          nav?.classList.add('nav--scrolled');
        } else {
          nav?.classList.remove('nav--scrolled');
        }
      });

      // Mobile nav toggle
      const toggle = document.getElementById('nav-toggle');
      const mobile = document.getElementById('nav-mobile');
      const close = document.getElementById('nav-close');

      toggle?.addEventListener('click', () => mobile?.classList.add('active'));
      close?.addEventListener('click', () => mobile?.classList.remove('active'));

      // Scroll animations — with sibling stagger for grid children
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12 }
      );

      // Assign sequential delays to fade-in siblings inside grids (80ms per step, capped)
      document.querySelectorAll('.grid').forEach((grid) => {
        const fades = grid.querySelectorAll(':scope > .fade-in');
        fades.forEach((el, i) => {
          if (el instanceof HTMLElement) {
            el.style.setProperty('--fade-delay', Math.min(i * 80, 480) + 'ms');
          }
        });
      });

      document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));

      // ---- Language Toggle (EN/FR) ----
      // Translations loaded from /i18n/translations.json (generated at build time)
      let translations: Record<string, Record<string, string>> = {};

      // Fetch translations asynchronously and always apply — including for EN —
      // so dashboard edits to English text replace the static markup at runtime.
      // /api/translations proxies the latest translations.json straight from
      // GitHub so Publish appears on the live site without a Vercel rebuild.
      fetch('/api/translations', { cache: 'no-store' })
        .then(res => res.json())
        .then(data => {
          translations = data;
          setLanguage(currentLang);
        })
        .catch(() => {
          // Fallback: nav-only translations if fetch fails
          translations = {
            'nav.homes': { en: 'Maisons', fr: 'Les Maisons' },
            'nav.compound': { en: 'The Compound', fr: 'Le Domaine' },
            'nav.explore': { en: 'Explore', fr: 'Explorer' },
            'nav.catering': { en: 'Catering', fr: 'Restauration' },
            'nav.wellness': { en: 'Wellness', fr: 'Bien-être' },
            'nav.about': { en: 'About', fr: 'À Propos' },
            'nav.contact': { en: 'Contact', fr: 'Contact' },
            'nav.inquire': { en: 'Inquire', fr: 'Réserver' },
          };
          if (currentLang !== 'en') {
            setLanguage(currentLang);
          }
        });

      let currentLang = localStorage.getItem('lang') || 'en';

      function setLanguage(lang: string) {
        currentLang = lang;
        localStorage.setItem('lang', lang);
        document.documentElement.lang = lang;

        // Update all elements with data-i18n (textContent)
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const key = el.getAttribute('data-i18n');
          if (key && translations[key] && translations[key][lang]) {
            el.textContent = translations[key][lang];
          }
        });

        // Update all elements with data-i18n-placeholder
        document.querySelectorAll('[data-i18n-placeholder]').forEach((el) => {
          const key = el.getAttribute('data-i18n-placeholder');
          if (key && translations[key] && translations[key][lang]) {
            (el as HTMLInputElement).placeholder = translations[key][lang];
          }
        });

        // Update toggle labels
        document.querySelectorAll('.lang-toggle__label').forEach((label) => {
          const labelLang = label.getAttribute('data-lang');
          if (labelLang === lang) {
            label.classList.add('lang-toggle__label--active');
          } else {
            label.classList.remove('lang-toggle__label--active');
          }
        });

        // Update toggle title
        const langBtn = document.getElementById('lang-toggle');
        if (langBtn) {
          langBtn.title = lang === 'en' ? 'Passer en français' : 'Switch to English';
        }
      }

      // Toggle click handler
      const langToggle = document.getElementById('lang-toggle');
      langToggle?.addEventListener('click', () => {
        setLanguage(currentLang === 'en' ? 'fr' : 'en');
      });

      // Apply saved language on load
      if (currentLang !== 'en') {
        setLanguage(currentLang);
      }
    </script>

    <!-- Newsletter form handlers (footer + popup) -->
    <script>
      async function submitNewsletter(form: HTMLFormElement, source: string) {
        const bot = (form.querySelector('[name="bot-field"]') as HTMLInputElement)?.value;
        if (bot) return;

        const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement;
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Sending...';

        try {
          const res = await fetch('/api/newsletter', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: emailInput.value, source }),
          });
          if (res.ok) {
            btn.textContent = 'Subscribed!';
            emailInput.value = '';
            setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 3000);
          } else {
            btn.disabled = false;
            btn.textContent = originalText;
            alert('Something went wrong. Please try again.');
          }
        } catch {
          btn.disabled = false;
          btn.textContent = originalText;
          alert('Something went wrong. Please try again.');
        }
      }

      document.getElementById('footer-newsletter-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        submitNewsletter(e.target as HTMLFormElement, 'Footer');
      });

      document.getElementById('popup-newsletter-form')?.addEventListener('submit', (e) => {
        e.preventDefault();
        submitNewsletter(e.target as HTMLFormElement, 'Popup');
      });
    </script>
  </body>
</html>
